        }
      ];
    %>
    <div class="specialists-content">
      <span class="section-badge">
        <i data-lucide="users"></i>
        Spécialistes
      </span>
      <h2 class="section-title">Trouvez vos<br><span class="gradient-text">spécialistes</span></h2>
      <p class="section-subtitle">Sélectionnez un métier pour découvrir le bon expert et lancer votre recherche d’entrepreneur.</p>

      <div class="specialists-pills" id="specialists-pills">
        <% specialistTrades.forEach((trade, index) => { %>
          <button
            type="button"
            class="specialist-pill <%= index === 0 ? 'active' : '' %>"
            data-name="<%= trade.name %>"
            data-desc="<%= trade.desc %>"
            data-details="<%= trade.details %>"
            data-image="<%= trade.image %>"
            data-url="/contractors?specialty=<%= encodeURIComponent(trade.specialty) %>&service=<%= encodeURIComponent(trade.service) %>&q=<%= encodeURIComponent(trade.name) %>">
            <span class="specialist-pill-image">
              <img src="<%= trade.image %>" alt="<%= trade.name %>" loading="lazy" onerror="this.src='/assets/afterhouse.jpeg'">
            </span>
            <span><%= trade.name %></span>
          </button>
        <% }) %>
      </div>
    </div>

    <div class="specialists-detail" id="specialists-detail">
      <div class="specialists-detail-media">
        <img id="specialists-detail-image" src="<%= specialistTrades[0].image %>" alt="<%= specialistTrades[0].name %>" onerror="this.src='/assets/afterhouse.jpeg'">
        <span>Réseau d'experts vérifiés</span>
      </div>
      <div class="specialists-detail-body">
        <span class="specialists-detail-kicker">Métier sélectionné</span>
        <h3 id="specialists-detail-title"><%= specialistTrades[0].name %></h3>
        <p id="specialists-detail-desc"><%= specialistTrades[0].desc %></p>
        <button type="button" id="specialists-detail-cta" class="specialists-cta">
          En savoir plus sur le métier
          <i data-lucide="info"></i>
        </button>
      </div>
    </div>
  </div>
</section>

<div class="specialists-modal" id="specialists-modal" hidden>
  <div class="specialists-modal-backdrop" data-close-specialists-modal></div>
  <div class="specialists-modal-card" role="dialog" aria-modal="true" aria-labelledby="specialists-modal-title">
    <button type="button" class="specialists-modal-close" data-close-specialists-modal aria-label="Fermer">
      <i data-lucide="x"></i>
    </button>
    <img id="specialists-modal-image" src="<%= specialistTrades[0].image %>" alt="<%= specialistTrades[0].name %>" onerror="this.src='/assets/afterhouse.jpeg'">
    <div class="specialists-modal-body">
      <span class="specialists-detail-kicker">Guide métier</span>
      <h3 id="specialists-modal-title"><%= specialistTrades[0].name %></h3>
      <p id="specialists-modal-desc"><%= specialistTrades[0].details %></p>
    </div>
  </div>
</div>

