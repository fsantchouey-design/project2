<!-- Hero Section -->
<section class="hero">
  <!-- Animated Background -->
  <div class="hero-bg">
    <div class="hero-gradient"></div>
    <div class="hero-grid"></div>
    <div class="floating-shapes">
      <div class="shape shape-1"></div>
      <div class="shape shape-2"></div>
      <div class="shape shape-3"></div>
      <div class="shape shape-4"></div>
      <div class="shape shape-5"></div>
    </div>
  </div>

  <div class="hero-container">
    <div class="hero-content" data-animate="fade-up">
      <div class="hero-badge animate-pulse-glow">
        <i data-lucide="sparkles"></i>
        <span>Criby, l'IA de design de CraftyCrib</span>
        <span class="badge-new">NOUVEAU</span>
      </div>
      
      <h1 class="hero-title">
        <span class="title-line" data-animate="fade-up" data-delay="100">Réinventez votre</span>
        <span class="title-line title-gradient" data-animate="fade-up" data-delay="200">intérieur en un instant</span>
      </h1>
      
      <p class="hero-subtitle" data-animate="fade-up" data-delay="300">
        Téléchargez une photo, décrivez votre vision et laissez Criby, notre IA révolutionnaire, 
        générer instantanément des designs photoréalistes. De la vision à la réalisation 
        avec nos experts qualifiés.
      </p>
      
      <div class="hero-actions" data-animate="fade-up" data-delay="400">
        <a href="/auth/register" class="btn btn-primary btn-lg btn-glow">
          <i data-lucide="wand-2"></i>
          Commencer gratuitement
          <span class="btn-shine"></span>
        </a>
        <a href="#how-it-works" class="btn btn-glass btn-lg">
          <i data-lucide="play-circle"></i>
          Voir la démo
        </a>
      </div>
      
      <div class="hero-stats" data-animate="fade-up" data-delay="500">
        <div class="stat">
          <span class="stat-value" data-counter="50000">0</span>
          <span class="stat-suffix">+</span>
          <span class="stat-label">Designs créés</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-value" data-counter="80">0</span>
          <span class="stat-suffix">+</span>
          <span class="stat-label">Styles uniques</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-value">4.9</span>
          <span class="stat-suffix"></span>
          <span class="stat-label">Note moyenne</span>
        </div>
      </div>
    </div>
    
    <div class="hero-visual" data-animate="fade-left" data-delay="200">
      <div class="hero-showcase">
        <!-- Interactive Before/After Slider -->
        <div class="comparison-slider" id="heroComparison">
          <div class="comparison-before">
            <img src="<%= landingImages.heroBefore.url %>" alt="<%= landingImages.heroBefore.alt %>">
            <span class="comparison-label comparison-label-before">AVANT</span>
          </div>
          <div class="comparison-after">
            <img src="<%= landingImages.heroAfter.url %>" alt="<%= landingImages.heroAfter.alt %>">
            <span class="comparison-label comparison-label-after">APRÈS</span>
          </div>
          <div class="comparison-handle">
            <div class="handle-line"></div>
            <div class="handle-circle">
              <i data-lucide="move-horizontal"></i>
            </div>
            <div class="handle-line"></div>
          </div>
        </div>
        
        <!-- Floating UI Cards -->
        <div class="floating-card floating-card-style">
          <i data-lucide="palette"></i>
          <span>Style Moderne</span>
        </div>
        <div class="floating-card floating-card-ai">
          <div class="ai-indicator">
            <span class="ai-dot"></span>
            <span>Criby AI</span>
          </div>
          <span class="ai-status">Génération en cours...</span>
        </div>
        <div class="floating-card floating-card-rating">
          <div class="rating-stars">
            <i data-lucide="star"></i>
            <i data-lucide="star"></i>
            <i data-lucide="star"></i>
            <i data-lucide="star"></i>
            <i data-lucide="star"></i>
          </div>
          <span>4.9 / 5</span>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Scroll Indicator -->
  <div class="scroll-indicator">
    <div class="scroll-mouse">
      <div class="scroll-wheel"></div>
    </div>
    <span>Défiler pour découvrir</span>
  </div>
</section>

