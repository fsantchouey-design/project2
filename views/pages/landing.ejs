<!-- Pricing Section -->
<section id="pricing" class="ai-studio-section">
  <style>
    .ai-studio-section {
      padding: 6rem 0;
      background: linear-gradient(135deg, #0a0a0a 0%, #0f1a12 50%, #0a0a0a 100%);
      position: relative;
      overflow: hidden;
    }
    .ai-studio-section::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0; bottom: 0;
      background: radial-gradient(ellipse 80% 50% at 50% -10%, rgba(34,197,94,0.12) 0%, transparent 70%);
      pointer-events: none;
    }
    .ai-studio-header {
      text-align: center;
      margin-bottom: 4rem;
    }
    .ai-studio-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: rgba(34,197,94,0.1);
      border: 1px solid rgba(34,197,94,0.3);
      border-radius: 999px;
      padding: 0.4rem 1.1rem;
      font-size: 0.82rem;
      color: #22c55e;
      font-weight: 600;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      margin-bottom: 1.5rem;
    }
    .ai-studio-title {
      font-size: clamp(2rem, 5vw, 3.2rem);
      font-weight: 800;
      color: #f0fdf4;
      line-height: 1.15;
      margin-bottom: 1rem;
    }
    .ai-studio-title span {
      background: linear-gradient(135deg, #22c55e, #06b6d4);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .ai-studio-subtitle {
      font-size: 1.1rem;
      color: #94a3b8;
      max-width: 580px;
      margin: 0 auto;
      line-height: 1.7;
    }
    .ai-studio-stats {
      display: flex;
      justify-content: center;
      gap: 3rem;
      flex-wrap: wrap;
      margin-bottom: 4rem;
      padding: 2rem;
      background: rgba(255,255,255,0.02);
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 1.2rem;
      max-width: 860px;
      margin-left: auto;
      margin-right: auto;
    }
    .ai-stat-item {
      text-align: center;
    }
    .ai-stat-value {
      font-size: 2rem;
      font-weight: 800;
      color: #22c55e;
      display: block;
    }
    .ai-stat-label {
      font-size: 0.82rem;
      color: #64748b;
      text-transform: uppercase;
      letter-spacing: 0.07em;
    }
    .ai-tools-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1.2rem;
    }
    @media (max-width: 1200px) { .ai-tools-grid { grid-template-columns: repeat(3, 1fr); } }
    @media (max-width: 860px) { .ai-tools-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 480px) { .ai-tools-grid { grid-template-columns: 1fr; } }
    .ai-tool-card {
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 1rem;
      padding: 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
      cursor: default;
    }
    .ai-tool-card:hover {
      border-color: rgba(34,197,94,0.35);
      transform: translateY(-3px);
      box-shadow: 0 12px 40px rgba(34,197,94,0.08);
    }
    .ai-tool-icon-wrap {
      width: 44px; height: 44px;
      border-radius: 0.7rem;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .ai-tool-icon-wrap.c-green { background: rgba(34,197,94,0.12); color: #22c55e; }
    .ai-tool-icon-wrap.c-cyan  { background: rgba(6,182,212,0.12); color: #06b6d4; }
    .ai-tool-icon-wrap.c-purple{ background: rgba(168,85,247,0.12); color: #a855f7; }
    .ai-tool-icon-wrap.c-blue  { background: rgba(59,130,246,0.12); color: #3b82f6; }
    .ai-tool-icon-wrap svg { width: 22px; height: 22px; }
    .ai-tool-name {
      font-size: 0.95rem;
      font-weight: 700;
      color: #e2e8f0;
    }
    .ai-tool-desc {
      font-size: 0.8rem;
      color: #64748b;
      line-height: 1.55;
      flex: 1;
    }
    .ai-tool-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 0.78rem;
      font-weight: 600;
      color: #22c55e;
      text-decoration: none;
      padding: 0.35rem 0;
      border: none;
      background: none;
      cursor: pointer;
      transition: opacity 0.15s;
    }
    .ai-tool-btn:hover { opacity: 0.75; }
    .ai-studio-cta {
      text-align: center;
      margin-top: 3.5rem;
