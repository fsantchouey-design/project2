<div class="settings-page">
  <section class="settings-hero">
    <div>
      <span class="settings-kicker">CraftyCrib Account</span>
      <h1>Paramètres</h1>
      <p>Gérez votre profil, vos préférences, votre sécurité et vos notifications dans un espace clair et premium.</p>
    </div>
    <div class="settings-hero-profile">
      <img src="<%= user.avatar || '/images/default-avatar.png' %>" alt="<%= user.firstName %> <%= user.lastName %>">
      <span><%= user.firstName %> <%= user.lastName %></span>
      <small><%= user.email %></small>
    </div>
  </section>

  <div class="settings-layout">
    <nav class="settings-nav" aria-label="Navigation paramètres">
      <a href="#profile" class="settings-nav-item active"><i data-lucide="user"></i>Profil</a>
      <a href="#security" class="settings-nav-item"><i data-lucide="shield-check"></i>Sécurité</a>
      <a href="#preferences" class="settings-nav-item"><i data-lucide="sliders-horizontal"></i>Préférences</a>
      <a href="#notifications" class="settings-nav-item"><i data-lucide="bell"></i>Notifications</a>
      <a href="#billing" class="settings-nav-item"><i data-lucide="credit-card"></i>Facturation</a>
      <a href="#data" class="settings-nav-item"><i data-lucide="lock-keyhole"></i>Données</a>
    </nav>

    <main class="settings-content">
      <section class="settings-section" id="profile">
        <div class="settings-section-header">
          <div>
            <span class="settings-kicker">Compte</span>
            <h2>Profil</h2>
          </div>
          <span class="settings-status-pill">Connecté</span>
        </div>

        <!-- Avatar upload (standalone form, cannot be nested) -->
        <form action="/dashboard/settings/avatar" method="POST" enctype="multipart/form-data" id="avatar-upload-form">
          <div class="profile-card">
            <div class="profile-avatar-wrap">
              <% if (user.avatar && user.avatar !== '/images/default-avatar.png') { %>
                <img id="avatar-preview" src="<%= user.avatar %>" alt="Photo de profil">
              <% } else { %>
                <div id="avatar-initials-circle" class="avatar-initials-circle">
                  <%= user.firstName.charAt(0) %><%= user.lastName.charAt(0) %>
                </div>
                <img id="avatar-preview" src="" alt="Photo de profil" style="display:none; width:76px; height:76px; border-radius:50%; object-fit:cover; border:3px solid rgba(16,185,129,0.4);">
              <% } %>
            </div>
            <div>
              <h3>Photo de profil</h3>
              <p>Format JPG, PNG ou WebP. Taille max : 5 Mo.</p>
              <label class="settings-secondary-btn" for="avatar-file-input" style="cursor:pointer;">
                <i data-lucide="image-up"></i>
                Modifier
              </label>
              <input type="file" id="avatar-file-input" name="avatar" accept="image/jpeg,image/png,image/webp" hidden>
            </div>
          </div>
        </form>

        <form action="/dashboard/settings" method="POST" class="settings-form">
          <div class="form-row">
            <div class="form-group">
              <label class="form-label">Prénom</label>
              <input type="text" name="firstName" class="form-input" value="<%= user.firstName %>" required>
            </div>
            <div class="form-group">
              <label class="form-label">Nom</label>
              <input type="text" name="lastName" class="form-input" value="<%= user.lastName %>" required>
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label class="form-label">Email</label>
              <input type="email" class="form-input" value="<%= user.email %>" disabled>
              <p class="form-hint">L’email est lié à l’authentification du compte.</p>
            </div>
            <div class="form-group">
              <label class="form-label">Téléphone</label>
              <input type="tel" name="phone" class="form-input" value="<%= user.phone || '' %>" placeholder="+1 514 000 0000">
            </div>
          </div>

          <div class="form-actions">
            <button type="submit" class="settings-primary-btn">
              <i data-lucide="save"></i>
              Sauvegarder
            </button>
          </div>
        </form>
      </section>

      <section class="settings-section" id="security">
        <div class="settings-section-header">
          <div>
            <span class="settings-kicker">Protection</span>
            <h2>Sécurité</h2>
          </div>
        </div>

        <div class="settings-form">
          <div class="form-row">
            <div class="form-group">
              <label class="form-label" for="current-password">Ancien mot de passe</label>
              <input type="password" id="current-password" class="form-input" autocomplete="current-password" placeholder="••••••••">
            </div>
            <div class="form-group">
              <label class="form-label" for="new-password">Nouveau mot de passe</label>
              <input type="password" id="new-password" class="form-input" autocomplete="new-password" placeholder="Minimum 6 caractères">
            </div>
          </div>
          <div class="form-group">
            <label class="form-label" for="confirm-password">Confirmation</label>
            <input type="password" id="confirm-password" class="form-input" autocomplete="new-password" placeholder="Confirmer le nouveau mot de passe">
          </div>
          <div id="password-feedback" style="display:none; margin-bottom:12px; font-size:14px;"></div>
          <button type="button" id="change-password-btn" class="settings-secondary-btn">
            <i data-lucide="key-round"></i>
            Changer mot de passe
          </button>
        </div>

        <div class="settings-row-card">
          <div>
            <h4>Authentification à deux facteurs</h4>
            <p>Ajoutez une couche de protection supplémentaire à votre compte.</p>
          </div>
          <span class="settings-status-pill muted">Bientôt</span>
        </div>
      </section>

      <section class="settings-section" id="preferences">
        <div class="settings-section-header">
          <div>
            <span class="settings-kicker">Expérience</span>
            <h2>Préférences</h2>
          </div>
        </div>

        <div class="preference-grid">
          <div class="preference-card">
            <h4>Langue</h4>
            <div class="segmented-control" data-setting="language">
              <button type="button" class="segment active" data-value="fr">FR</button>
              <button type="button" class="segment" data-value="en">EN</button>
            </div>
          </div>
          <div class="preference-card">
            <h4>Thème</h4>
            <div class="segmented-control" data-setting="theme">
              <button type="button" class="segment active" data-value="dark">Dark</button>
              <button type="button" class="segment" data-value="light">Light</button>
            </div>
          </div>
          <div class="preference-card">
            <h4>Interface</h4>
            <label class="compact-toggle">
              <span>Animations légères</span>
              <input type="checkbox" class="settings-toggle-input" data-local-setting="softAnimations" checked>
            </label>
            <label class="compact-toggle">
              <span>Cartes compactes</span>
              <input type="checkbox" class="settings-toggle-input" data-local-setting="compactCards">
            </label>
          </div>
        </div>
      </section>

      <section class="settings-section" id="notifications">
        <div class="settings-section-header">
          <div>
            <span class="settings-kicker">Alertes</span>
            <h2>Notifications</h2>
          </div>
          <span class="settings-save-hint" id="notification-save-hint">Sauvegarde locale</span>
        </div>

        <div class="notification-options">
          <div class="notification-item">
            <div class="notification-info">
              <h4>Email Notifications</h4>
              <p>Receive updates about your projects via email</p>
            </div>
            <label class="toggle">
              <input type="checkbox" data-notification="emailNotifications" checked>
              <span class="toggle-slider"></span>
            </label>
          </div>

          <div class="notification-item">
            <div class="notification-info">
              <h4>Project Updates</h4>
              <p>Get notified when your designs are ready</p>
            </div>
            <label class="toggle">
              <input type="checkbox" data-notification="projectUpdates" checked>
              <span class="toggle-slider"></span>
            </label>
          </div>

          <div class="notification-item">
            <div class="notification-info">
              <h4>Contractor Messages</h4>
              <p>Receive notifications for new messages</p>
            </div>
            <label class="toggle">
              <input type="checkbox" data-notification="contractorMessages" checked>
              <span class="toggle-slider"></span>
            </label>
          </div>

          <div class="notification-item">
            <div class="notification-info">
              <h4>Marketing Emails</h4>
              <p>Tips, features, and promotional content</p>
            </div>
            <label class="toggle">
              <input type="checkbox" data-notification="marketingEmails">
              <span class="toggle-slider"></span>
            </label>
          </div>
        </div>
      </section>

      <section class="settings-section" id="billing">
        <div class="settings-section-header">
          <div>
            <span class="settings-kicker">Abonnement</span>
            <h2>Facturation &amp; Crédits IA</h2>
          </div>
          <span class="settings-status-pill" id="billing-sub-pill">
            <span id="billing-sub-pill-text">Chargement…</span>
          </span>
        </div>

        <!-- Credits card -->
        <div class="billing-credits-card" id="billing-credits-card">
          <div class="billing-credits-left">
            <div class="billing-credits-icon">
              <i data-lucide="zap"></i>
            </div>
            <div>
              <h4>Crédits IA disponibles</h4>
              <p id="billing-credits-desc">Chargement en cours…</p>
            </div>
          </div>
          <div class="billing-credits-count" id="billing-credits-count">
            <span class="credits-spinner">
              <i data-lucide="loader-circle"></i>
            </span>
          </div>
        </div>

        <!-- Subscription plans -->
        <div class="billing-plans-grid" id="billing-plans-grid">
          <!-- Filled dynamically -->
        </div>

        <!-- Actions -->
        <div class="billing-actions">
          <a href="/pricing" class="settings-primary-btn" id="billing-get-credits-btn">
            <i data-lucide="zap"></i>
            Obtenir plus de crédits
          </a>
          <a href="#" class="settings-secondary-btn" id="billing-stripe-btn" style="display:none;">
            <i data-lucide="credit-card"></i>
            Gérer via Stripe
          </a>
        </div>
      </section>

      <section class="settings-section" id="data">
        <div class="settings-section-header">
          <div>
            <span class="settings-kicker">Confidentialité</span>
            <h2>Données</h2>
          </div>
        </div>

        <div class="settings-row-card">
          <div>
            <h4>Télécharger mes données</h4>
            <p>Export complet du compte, des projets et préférences. TODO backend export.</p>
          </div>
          <button type="button" class="settings-secondary-btn" data-toast="Export de données à connecter côté backend.">
            <i data-lucide="download"></i>
            Télécharger
          </button>
        </div>

        <div class="settings-row-card danger">
          <div>
            <h4>Supprimer mon compte</h4>
            <p>Action définitive après confirmation. Ne sera branchée qu’avec une route sécurisée.</p>
          </div>
          <button type="button" class="settings-danger-btn" onclick="confirmAccountDelete()">
            <i data-lucide="trash-2"></i>
            Supprimer
          </button>
        </div>

        <a href="/privacy" class="privacy-link">Voir la politique de confidentialité</a>
      </section>
    </main>
  </div>
</div>

<style>
  .settings-page {
    max-width: 1280px;
    margin: 0 auto;
    padding: var(--spacing-xl);
  }

  .settings-hero {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 24px;
    padding: 26px;
    border: 1px solid rgba(16, 185, 129, 0.22);
    border-radius: 20px;
    background:
      radial-gradient(circle at 12% 12%, rgba(16,185,129,0.18), transparent 34%),
      var(--bg-card);
    box-shadow: 0 22px 58px rgba(2, 6, 23, 0.14);
  }

  .settings-kicker {
    display: inline-flex;
    margin-bottom: 8px;
    color: var(--accent-primary);
    font-size: 11px;
    font-weight: 900;
    letter-spacing: 0.9px;
    text-transform: uppercase;
  }

  .settings-hero h1 {
    margin: 0 0 8px;
    color: var(--text-primary);
    font-size: clamp(2rem, 4vw, 3rem);
    letter-spacing: 0;
  }

  .settings-hero p {
    max-width: 720px;
    margin: 0;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .settings-hero-profile {
    min-width: 220px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    padding: 18px;
    border: 1px solid var(--border-color);
    border-radius: 16px;
    background: rgba(16, 185, 129, 0.07);
  }

  .settings-hero-profile img,
  .profile-avatar-wrap img {
    width: 76px;
    height: 76px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid rgba(16,185,129,0.4);
  }

  .settings-hero-profile span {
    color: var(--text-primary);
    font-weight: 900;
  }

  .settings-hero-profile small {
    color: var(--text-muted);
  }

  .settings-layout {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 24px;
    align-items: start;
  }

  .settings-nav {
    position: sticky;
    top: 20px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 12px;
    border: 1px solid var(--border-color);
    border-radius: 16px;
    background: var(--bg-card);
  }

  .settings-nav-item {
    display: flex;
    align-items: center;
    gap: 10px;
    min-height: 44px;
    padding: 0 12px;
    border-radius: 10px;
    color: var(--text-secondary);
    font-weight: 850;
    text-decoration: none;
    transition: background 0.2s, color 0.2s, transform 0.2s;
  }

  .settings-nav-item:hover,
  .settings-nav-item.active {
    background: rgba(16, 185, 129, 0.13);
    color: var(--accent-primary);
    transform: translateX(2px);
  }

  .settings-nav-item i {
    width: 19px;
    height: 19px;
  }

  .settings-section {
    margin-bottom: 20px;
    padding: 22px;
    border: 1px solid var(--border-color);
    border-radius: 18px;
    background: var(--bg-card);
    box-shadow: 0 14px 34px rgba(2, 6, 23, 0.08);
  }

  .settings-section-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 20px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--border-color);
  }

  .settings-section h2 {
    margin: 0;
    color: var(--text-primary);
    font-size: 1.35rem;
  }

  .settings-form {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .profile-card,
  .settings-row-card,
  .preference-card,
  .billing-details {
    padding: 16px;
    border: 1px solid var(--border-color);
    border-radius: 14px;
    background: var(--bg-secondary);
  }

  .profile-card {
    display: flex;
    align-items: center;
    gap: 18px;
  }

  .profile-card h3,
  .settings-row-card h4,
  .preference-card h4,
  .billing-details h4,
  .plan-info h4,
  .notification-info h4 {
    margin: 0 0 6px;
    color: var(--text-primary);
    font-size: 1rem;
  }

  .profile-card p,
  .settings-row-card p,
  .plan-info p,
  .notification-info p {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.86rem;
    line-height: 1.45;
  }

  .form-row {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
  }

  .form-actions {
    display: flex;
    justify-content: flex-end;
  }

  .settings-primary-btn,
  .settings-secondary-btn,
  .settings-danger-btn {
    min-height: 42px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 0 15px;
    border-radius: 10px;
    font-weight: 900;
    cursor: pointer;
    text-decoration: none;
    border: 1px solid rgba(16, 185, 129, 0.36);
  }

  .settings-primary-btn {
    background: var(--accent-primary);
    color: #00140e;
  }

  .settings-secondary-btn {
    background: rgba(16, 185, 129, 0.11);
    color: var(--accent-primary);
  }

  .settings-danger-btn {
    background: rgba(239, 68, 68, 0.1);
    color: var(--error);
    border-color: rgba(239, 68, 68, 0.35);
  }

  .settings-primary-btn i,
  .settings-secondary-btn i,
  .settings-danger-btn i {
    width: 17px;
    height: 17px;
  }

  .settings-status-pill,
  .settings-save-hint {
    display: inline-flex;
    align-items: center;
    min-height: 28px;
    padding: 0 10px;
    border-radius: 999px;
    background: rgba(16, 185, 129, 0.13);
    color: var(--accent-primary);
    font-size: 12px;
    font-weight: 900;
  }

  .settings-status-pill.muted {
    background: var(--bg-secondary);
    color: var(--text-muted);
  }

  .settings-row-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    margin-top: 14px;
  }

  .settings-row-card.danger {
    border-color: rgba(239, 68, 68, 0.32);
  }

  .preference-grid,
  .billing-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
  }

  .preference-card:nth-child(3) {
    grid-column: 1 / -1;
  }

  .segmented-control {
    display: inline-grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 4px;
    padding: 4px;
    border-radius: 12px;
    background: var(--bg-tertiary);
  }

  .segment {
    min-height: 36px;
    padding: 0 14px;
    border: 0;
    border-radius: 9px;
    background: transparent;
    color: var(--text-secondary);
    font-weight: 900;
    cursor: pointer;
  }

  .segment.active {
    background: var(--accent-primary);
    color: #00140e;
  }

  .compact-toggle {
    min-height: 42px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    color: var(--text-secondary);
    font-weight: 800;
  }

  .settings-toggle-input {
    width: 18px;
    height: 18px;
    accent-color: var(--accent-primary);
  }

  .notification-options {
    border: 1px solid var(--border-color);
    border-radius: 14px;
    overflow: hidden;
    background: var(--bg-secondary);
  }

  .notification-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 18px;
    padding: 18px;
    border-bottom: 1px solid var(--border-color);
  }

  .notification-item:last-child {
    border-bottom: none;
  }

  .toggle {
    position: relative;
    width: 50px;
    height: 26px;
    flex: 0 0 auto;
    cursor: pointer;
  }

  .toggle input {
    opacity: 0;
    width: 0;
    height: 0;
  }

  .toggle-slider {
    position: absolute;
    inset: 0;
    background: var(--bg-tertiary);
    border-radius: var(--radius-full);
    transition: var(--transition-base);
  }

  .toggle-slider::before {
    content: '';
    position: absolute;
    width: 20px;
    height: 20px;
    left: 3px;
    bottom: 3px;
    background: var(--text-muted);
    border-radius: 50%;
    transition: var(--transition-base);
  }

  .toggle input:checked + .toggle-slider {
    background: var(--accent-primary);
  }

  .toggle input:checked + .toggle-slider::before {
    transform: translateX(24px);
    background: #00140e;
  }

  .current-plan {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 18px;
    border: 1px solid rgba(16, 185, 129, 0.24);
    border-radius: 14px;
    background: linear-gradient(135deg, rgba(16,185,129,0.12), rgba(59,130,246,0.08));
  }

  .plan-badge {
    display: inline-flex;
    min-height: 26px;
    align-items: center;
    padding: 0 10px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 900;
    text-transform: uppercase;
    margin-bottom: 8px;
  }

  .plan-badge.free {
    background: var(--bg-tertiary);
    color: var(--text-muted);
  }

  .plan-badge.premium {
    background: var(--accent-primary);
    color: #00140e;
  }

  .avatar-initials-circle {
    width: 76px;
    height: 76px;
    border-radius: 50%;
    background: linear-gradient(135deg, #10b981, #06b6d4);
    color: #ffffff;
    font-size: 22px;
    font-weight: 800;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 3px solid rgba(16,185,129,0.4);
    flex-shrink: 0;
  }

  /* Billing credits card */
  .billing-credits-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 18px;
    border: 1px solid rgba(16,185,129,0.25);
    border-radius: 14px;
    background: linear-gradient(135deg, rgba(16,185,129,0.1), rgba(6,182,212,0.06));
    margin-bottom: 16px;
  }

  .billing-credits-left {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .billing-credits-icon {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: rgba(16,185,129,0.18);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .billing-credits-icon i {
    width: 22px;
    height: 22px;
    color: var(--accent-primary);
  }

  .billing-credits-card h4 {
    margin: 0 0 4px;
    color: var(--text-primary);
    font-size: 1rem;
  }

  .billing-credits-card p {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.85rem;
  }

  .billing-credits-count {
    font-size: 2.5rem;
    font-weight: 900;
    color: var(--accent-primary);
    line-height: 1;
    flex-shrink: 0;
  }

  .billing-credits-number {
    color: var(--accent-primary);
  }

  .billing-credits-error {
    font-size: 0.85rem;
    color: var(--error);
  }

  .credits-spinner i {
    width: 28px;
    height: 28px;
    color: var(--accent-primary);
    animation: spin 1s linear infinite;
  }

  @keyframes spin { to { transform: rotate(360deg); } }

  /* Plans grid */
  .billing-plans-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 10px;
    margin-bottom: 16px;
  }

  .billing-plan-card {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 14px;
    border: 1px solid var(--border-color);
    border-radius: 12px;
    background: var(--bg-secondary);
    position: relative;
    transition: border-color 0.18s, background 0.18s;
  }

  .billing-plan-card.active {
    border-color: rgba(16,185,129,0.45);
    background: rgba(16,185,129,0.07);
  }

  .billing-plan-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .billing-plan-card strong {
    display: block;
    font-size: 0.9rem;
    color: var(--text-primary);
  }

  .billing-plan-card p {
    margin: 2px 0 0;
    font-size: 0.78rem;
    color: var(--text-muted);
    line-height: 1.35;
  }

  .billing-plan-current {
    position: absolute;
    top: 8px;
    right: 10px;
    font-size: 10px;
    font-weight: 800;
    color: var(--accent-primary);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .billing-actions {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .billing-details strong {
    display: block;
    margin: 4px 0 8px;
    color: var(--accent-primary);
    font-size: 2rem;
    line-height: 1;
  }

  .privacy-link {
    display: inline-flex;
    margin-top: 14px;
    color: var(--accent-primary);
    font-weight: 900;
    text-decoration: none;
  }

  @media (max-width: 900px) {
    .settings-hero,
    .settings-layout {
      grid-template-columns: 1fr;
    }

    .settings-hero {
      flex-direction: column;
      align-items: stretch;
    }

    .settings-nav {
      position: static;
      flex-direction: row;
      overflow-x: auto;
    }

    .settings-nav-item {
      flex: 0 0 auto;
    }
  }

  @media (max-width: 640px) {
    .settings-page {
      padding: 16px;
    }

    .form-row,
    .preference-grid,
    .billing-grid,
    .billing-plans-grid {
      grid-template-columns: 1fr;
    }

    .profile-card,
    .settings-row-card,
    .current-plan,
    .notification-item,
    .billing-credits-card {
      align-items: flex-start;
      flex-direction: column;
    }

    .billing-credits-count {
      font-size: 2rem;
    }
  }
</style>

<script>
  (() => {
    const localPrefsKey = 'craftycrib.settings.preferences';
    const notificationKey = 'craftycrib.settings.notifications';
    const avatarFileInput = document.getElementById('avatar-file-input');
    const avatarPreview = document.getElementById('avatar-preview');
    const avatarInitials = document.getElementById('avatar-initials-circle');
    const avatarUploadForm = document.getElementById('avatar-upload-form');
    const notificationHint = document.getElementById('notification-save-hint');

    function readJson(key, fallback) {
      try {
        return JSON.parse(localStorage.getItem(key) || JSON.stringify(fallback));
      } catch (error) {
        return fallback;
      }
    }

    function saveJson(key, value) {
      localStorage.setItem(key, JSON.stringify(value));
    }

    // Avatar: preview then submit
    avatarFileInput?.addEventListener('change', () => {
      const file = avatarFileInput.files && avatarFileInput.files[0];
      if (!file) return;
      const reader = new FileReader();
      reader.onload = event => {
        if (avatarPreview) {
          avatarPreview.src = event.target.result;
          avatarPreview.style.display = 'block';
        }
        if (avatarInitials) avatarInitials.style.display = 'none';
      };
      reader.readAsDataURL(file);
      // Auto-submit after preview
      setTimeout(() => avatarUploadForm?.submit(), 400);
    });

    // ===== Load real billing/credits data =====
    (async function loadBillingData() {
      const creditCountEl = document.getElementById('billing-credits-count');
      const creditDescEl = document.getElementById('billing-credits-desc');
      const subPillText = document.getElementById('billing-sub-pill-text');
      const plansGrid = document.getElementById('billing-plans-grid');
      const stripeBtn = document.getElementById('billing-stripe-btn');

      try {
        const resp = await fetch('/api/user/profile', { credentials: 'same-origin' });
        if (!resp.ok) throw new Error('HTTP ' + resp.status);
        const data = await resp.json();

        const credits = data.credits ?? 0;
        const sub = data.subscription || {};
        const subType = sub.type || 'free';
        const subLabels = { free: 'Gratuit', partner: 'Partner', advanced: 'Advanced', credits: 'Crédits' };
        const subLabel = subLabels[subType] || 'Gratuit';

        // Credits count
        if (creditCountEl) {
          creditCountEl.innerHTML = '<span class="billing-credits-number">' + credits + '</span>';
        }
        if (creditDescEl) {
          const used = data.creditsUsed ?? 0;
          creditDescEl.textContent = used > 0
            ? used + ' crédit(s) utilisé(s) · ' + credits + ' restant(s)'
            : credits + ' crédit(s) disponible(s) sur votre compte';
        }

        // Sub pill
        if (subPillText) subPillText.textContent = subLabel;

        // Stripe button
        if (stripeBtn && sub.stripeCustomerId) {
          stripeBtn.style.display = 'inline-flex';
          stripeBtn.href = '/dashboard/settings/stripe-portal';
        }

        // Plans grid
        if (plansGrid) {
          var plans = [
            { type: 'free', label: 'Gratuit', desc: '3 crédits offerts pour démarrer.', color: '#64748b' },
            { type: 'credits', label: 'Crédits', desc: 'Achetez des crédits à la carte.', color: '#3b82f6' },
            { type: 'partner', label: 'Partner', desc: 'Gratuit avec un contrat artisan.', color: '#10b981' },
            { type: 'advanced', label: 'Advanced', desc: 'Générations illimitées + priorité.', color: '#8b5cf6' },
          ];
          plansGrid.innerHTML = plans.map(function(p) {
            var isActive = subType === p.type;
            var currentBadge = isActive ? '<span class="billing-plan-current">Actuel</span>' : '';
            return '<div class="billing-plan-card ' + (isActive ? 'active' : '') + '">' +
              '<span class="billing-plan-dot" style="background:' + p.color + '"></span>' +
              '<div><strong>' + p.label + '</strong><p>' + p.desc + '</p></div>' +
              currentBadge +
              '</div>';
          }).join('');
        }

        if (typeof lucide !== 'undefined') lucide.createIcons();
      } catch (err) {
        if (creditCountEl) creditCountEl.innerHTML = '<span class="billing-credits-error">Erreur de chargement</span>';
        if (creditDescEl) creditDescEl.textContent = 'Impossible de récupérer vos crédits. Réessayez.';
        if (subPillText) subPillText.textContent = '—';
      }
    })();

    document.querySelectorAll('.segmented-control').forEach(group => {
      const setting = group.dataset.setting;
      const prefs = readJson(localPrefsKey, {});
      if (prefs[setting]) {
        group.querySelectorAll('.segment').forEach(button => {
          button.classList.toggle('active', button.dataset.value === prefs[setting]);
        });
      }
      group.addEventListener('click', event => {
        const button = event.target.closest('.segment');
        if (!button) return;
        group.querySelectorAll('.segment').forEach(item => item.classList.remove('active'));
        button.classList.add('active');
        const nextPrefs = readJson(localPrefsKey, {});
        nextPrefs[setting] = button.dataset.value;
        saveJson(localPrefsKey, nextPrefs);
      });
    });

    document.querySelectorAll('.settings-toggle-input').forEach(input => {
      const prefs = readJson(localPrefsKey, {});
      if (Object.prototype.hasOwnProperty.call(prefs, input.dataset.localSetting)) {
        input.checked = !!prefs[input.dataset.localSetting];
      }
      input.addEventListener('change', () => {
        const nextPrefs = readJson(localPrefsKey, {});
        nextPrefs[input.dataset.localSetting] = input.checked;
        saveJson(localPrefsKey, nextPrefs);
      });
    });

    document.querySelectorAll('[data-notification]').forEach(input => {
      const saved = readJson(notificationKey, {});
      if (Object.prototype.hasOwnProperty.call(saved, input.dataset.notification)) {
        input.checked = !!saved[input.dataset.notification];
      }
      input.addEventListener('change', () => {
        const next = readJson(notificationKey, {});
        next[input.dataset.notification] = input.checked;
        saveJson(notificationKey, next);
        if (notificationHint) {
          notificationHint.textContent = 'Sauvegardé';
          setTimeout(() => { notificationHint.textContent = 'Sauvegarde locale'; }, 1200);
        }
      });
    });

    document.querySelectorAll('[data-toast]').forEach(button => {
      button.addEventListener('click', () => alert(button.dataset.toast));
    });

    // Password change
    const changePasswordBtn = document.getElementById('change-password-btn');
    if (changePasswordBtn) {
      changePasswordBtn.addEventListener('click', async () => {
        const currentPassword = document.getElementById('current-password').value;
        const newPassword = document.getElementById('new-password').value;
        const confirmPassword = document.getElementById('confirm-password').value;
        const feedback = document.getElementById('password-feedback');

        const showFeedback = (msg, ok) => {
          feedback.textContent = msg;
          feedback.style.display = 'block';
          feedback.style.color = ok ? '#00ff88' : '#ff6b6b';
        };

        if (!currentPassword || !newPassword || !confirmPassword) {
          return showFeedback('Veuillez remplir tous les champs.', false);
        }

        changePasswordBtn.disabled = true;
        try {
          const res = await fetch('/dashboard/settings/password', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ currentPassword, newPassword, confirmPassword })
          });
          const data = await res.json();
          showFeedback(data.message, data.success);
          if (data.success) {
            document.getElementById('current-password').value = '';
            document.getElementById('new-password').value = '';
            document.getElementById('confirm-password').value = '';
          }
        } catch {
          showFeedback('Une erreur réseau est survenue.', false);
        } finally {
          changePasswordBtn.disabled = false;
        }
      });
    }
  })();

  function confirmAccountDelete() {
    if (confirm('Confirmer la suppression du compte ? Cette action sera définitive une fois le backend branché.')) {
      alert('TODO backend : route sécurisée de suppression de compte.');
    }
  }
</script>
