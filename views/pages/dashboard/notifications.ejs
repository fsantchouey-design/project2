<style>
  .notif-page { max-width: 680px; margin: 0 auto; padding: 32px 20px; }
  .notif-page-title { font-size: 1.4rem; font-weight: 700; margin-bottom: 4px; }
  .notif-page-sub { color: var(--text-muted); font-size: 0.875rem; margin-bottom: 28px; }
  .notif-empty { text-align: center; padding: 52px 24px; background: var(--bg-card); border: 1px solid var(--border-color); border-radius: var(--radius-lg); }
  .notif-empty svg { width: 44px; height: 44px; color: var(--text-muted); margin-bottom: 14px; }
  .notif-empty h3 { font-size: 1rem; margin-bottom: 6px; }
  .notif-empty p { color: var(--text-muted); font-size: 0.875rem; }
  .notif-list { display: flex; flex-direction: column; gap: 12px; }
  .notif-card { background: var(--bg-card); border: 1px solid var(--border-color); border-radius: var(--radius-lg); padding: 20px 22px; display: flex; align-items: flex-start; gap: 16px; }
  .notif-icon { width: 40px; height: 40px; border-radius: 50%; background: rgba(59,130,246,0.12); display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 18px; }
  .notif-body { flex: 1; min-width: 0; }
  .notif-msg { font-size: 0.9rem; font-weight: 500; margin-bottom: 2px; }
  .notif-from { font-size: 0.8rem; color: var(--text-muted); margin-bottom: 10px; }
  .notif-date { font-size: 0.75rem; color: var(--text-muted); margin-top: 8px; }
  .notif-published { display: inline-flex; align-items: center; gap: 5px; font-size: 0.8rem; font-weight: 600; color: #10b981; background: rgba(16,185,129,0.1); border-radius: 20px; padding: 4px 12px; }
  .notif-btn { display: inline-flex; align-items: center; gap: 6px; padding: 7px 16px; border-radius: 8px; background: #3b82f6; color: #fff; font-size: 0.82rem; font-weight: 600; border: none; cursor: pointer; transition: opacity 0.15s; }
  .notif-btn:hover { opacity: 0.88; }
  /* Review modal */
  #rev-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.55); z-index: 1000; align-items: center; justify-content: center; }
  #rev-overlay.open { display: flex; }
  .rev-modal { background: var(--bg-card); border: 1px solid var(--border-color); border-radius: var(--radius-lg); padding: 28px 26px; width: 100%; max-width: 420px; position: relative; }
  .rev-modal-title { font-size: 1rem; font-weight: 700; margin-bottom: 4px; }
  .rev-modal-sub { font-size: 0.82rem; color: var(--text-muted); margin-bottom: 20px; }
  .rev-close { position: absolute; top: 14px; right: 16px; background: none; border: none; font-size: 18px; cursor: pointer; color: var(--text-muted); line-height: 1; }
  .rev-close:hover { color: var(--text-primary, #111); }
  .rev-stars { display: flex; gap: 6px; margin-bottom: 18px; }
  .rev-star { font-size: 30px; cursor: pointer; color: #d1d5db; transition: color 0.1s; user-select: none; }
  .rev-star.active { color: #f59e0b; }
  .rev-label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-muted); margin-bottom: 6px; display: block; }
  .rev-textarea { width: 100%; background: var(--bg-card-hover, #f8fafc); border: 1px solid var(--border-color); border-radius: 8px; padding: 10px 12px; font-family: inherit; font-size: 0.85rem; resize: vertical; min-height: 90px; outline: none; box-sizing: border-box; color: inherit; }
  .rev-textarea:focus { border-color: #3b82f6; }
  .rev-actions { display: flex; gap: 8px; justify-content: flex-end; margin-top: 18px; }
  .rev-cancel { padding: 7px 16px; border-radius: 8px; border: 1px solid var(--border-color); background: none; font-size: 0.82rem; cursor: pointer; color: inherit; }
  .rev-submit { padding: 7px 18px; border-radius: 8px; background: #3b82f6; color: #fff; font-size: 0.82rem; font-weight: 600; border: none; cursor: pointer; }
  .rev-submit:disabled { opacity: 0.5; cursor: not-allowed; }
  .rev-error { font-size: 0.8rem; color: #ef4444; margin-top: 8px; display: none; }
</style>

<div class="notif-page">
  <div class="notif-page-title">Notifications</div>
  <div class="notif-page-sub">Vos notifications et demandes d'avis</div>

  <% var notifList = typeof notifications !== 'undefined' ? notifications : []; %>
  <% if (notifList.length === 0) { %>
    <div class="notif-empty">
      <i data-lucide="bell-off"></i>
      <h3>Aucune notification</h3>
      <p>Vous verrez ici vos demandes d'avis lorsqu'un professionnel aura terminé votre demande.</p>
    </div>
  <% } else { %>
    <div class="notif-list">
      <% notifList.forEach(function(n) { %>
        <div class="notif-card">
          <div class="notif-icon">⭐</div>
          <div class="notif-body">
            <div class="notif-msg"><%= n.message %></div>
            <div class="notif-from">Prestation réalisée par <strong><%= n.contractorName || 'un professionnel' %></strong></div>
            <% if (n.status === 'published') { %>
              <span class="notif-published">✓ Avis publié</span>
            <% } else { %>
              <button class="notif-btn"
                data-qid="<%= n.quoteRequestId %>"
                data-cname="<%= n.contractorName || '' %>"
                onclick="openRevModal(this)">
                ⭐ Laisser un avis
              </button>
            <% } %>
            <div class="notif-date"><%= new Date(n.createdAt).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' }) %></div>
          </div>
        </div>
      <% }); %>
    </div>
  <% } %>
</div>

<!-- Review modal -->
<div id="rev-overlay">
  <div class="rev-modal">
    <div class="rev-modal-title">Laisser un avis</div>
    <div class="rev-modal-sub" id="rev-modal-sub">Votre avis aide la communauté CraftyCrib.</div>
    <button class="rev-close" onclick="closeRevModal()">✕</button>
    <input type="hidden" id="rev-qid">
    <div class="rev-stars" id="rev-stars">
      <span class="rev-star" data-v="1">★</span>
      <span class="rev-star" data-v="2">★</span>
      <span class="rev-star" data-v="3">★</span>
      <span class="rev-star" data-v="4">★</span>
      <span class="rev-star" data-v="5">★</span>
    </div>
    <label class="rev-label">Commentaire (optionnel)</label>
    <textarea class="rev-textarea" id="rev-comment" placeholder="Décrivez votre expérience avec ce professionnel…" rows="4"></textarea>
    <div class="rev-error" id="rev-error"></div>
    <div class="rev-actions">
      <button class="rev-cancel" onclick="closeRevModal()">Annuler</button>
      <button class="rev-submit" id="rev-submit" onclick="submitReview()">Publier l'avis</button>
    </div>
  </div>
</div>

<script>
(function(){
  var selectedRating = 0;
  var stars = document.querySelectorAll('#rev-stars .rev-star');

  stars.forEach(function(s) {
    s.addEventListener('mouseover', function() { highlightStars(+this.getAttribute('data-v')); });
    s.addEventListener('click',     function() { selectedRating = +this.getAttribute('data-v'); highlightStars(selectedRating); });
  });
  document.getElementById('rev-stars').addEventListener('mouseleave', function() { highlightStars(selectedRating); });

  function highlightStars(n) {
    stars.forEach(function(s) { s.classList.toggle('active', +s.getAttribute('data-v') <= n); });
  }

  window.openRevModal = function(btn) {
    selectedRating = 0;
    highlightStars(0);
    document.getElementById('rev-qid').value = btn.getAttribute('data-qid');
    document.getElementById('rev-comment').value = '';
    document.getElementById('rev-error').style.display = 'none';
    document.getElementById('rev-error').textContent = '';
    var cname = btn.getAttribute('data-cname');
    document.getElementById('rev-modal-sub').textContent = cname
      ? 'Évaluez votre expérience avec ' + cname + '.'
      : 'Votre avis aide la communauté CraftyCrib.';
    document.getElementById('rev-overlay').classList.add('open');
  };

  window.closeRevModal = function() {
    document.getElementById('rev-overlay').classList.remove('open');
  };

  document.getElementById('rev-overlay').addEventListener('click', function(e) {
    if (e.target === this) closeRevModal();
  });

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeRevModal();
  });

  window.submitReview = function() {
    var qid     = document.getElementById('rev-qid').value;
    var comment = document.getElementById('rev-comment').value.trim();
    var errEl   = document.getElementById('rev-error');
    var btn     = document.getElementById('rev-submit');

    if (!selectedRating) {
      errEl.textContent = 'Veuillez sélectionner une note.';
      errEl.style.display = 'block';
      return;
    }
    errEl.style.display = 'none';
    btn.disabled = true;
    btn.textContent = 'Publication…';

    fetch('/api/reviews', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      credentials: 'same-origin',
      body: JSON.stringify({ quoteRequestId: qid, rating: selectedRating, comment: comment })
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.success) {
        closeRevModal();
        window.location.reload();
      } else {
        errEl.textContent = data.error || 'Une erreur est survenue.';
        errEl.style.display = 'block';
        btn.disabled = false;
        btn.textContent = 'Publier l\'avis';
      }
    })
    .catch(function() {
      errEl.textContent = 'Erreur réseau. Veuillez réessayer.';
      errEl.style.display = 'block';
      btn.disabled = false;
      btn.textContent = 'Publier l\'avis';
    });
  };
})();
</script>
