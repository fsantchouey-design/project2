<!-- Page Header -->
<div class="page-header">
  <div>
    <h1>Tableau de bord</h1>
    <p class="subtitle">Bienvenue, <%= user.firstName %>. Voici un aperçu de vos projets.</p>
  </div>
  <a href="/projects/new" class="btn btn-primary">
    <i data-lucide="plus"></i>
    Nouveau projet
  </a>
</div>

<!-- Stats Grid -->
<div class="stats-grid">
  <div class="stat-card">
    <div class="stat-icon green">
      <i data-lucide="folder"></i>
    </div>
    <div class="stat-info">
      <div class="stat-value"><%= stats.totalProjects %></div>
      <div class="stat-label">Projets totaux</div>
    </div>
  </div>
  
  <div class="stat-card">
    <div class="stat-icon purple">
      <i data-lucide="sparkles"></i>
    </div>
    <div class="stat-info">
      <div class="stat-value"><%= stats.totalVariants %></div>
      <div class="stat-label">Designs IA</div>
    </div>
  </div>
  
  <div class="stat-card">
    <div class="stat-icon orange">
      <i data-lucide="clock"></i>
    </div>
    <div class="stat-info">
      <div class="stat-value"><%= stats.inProgress %></div>
      <div class="stat-label">En cours</div>
    </div>
  </div>
  
  <div class="stat-card">
    <div class="stat-icon blue">
      <i data-lucide="check-circle"></i>
    </div>
    <div class="stat-info">
      <div class="stat-value"><%= stats.completedDesigns %></div>
      <div class="stat-label">Terminés</div>
    </div>
  </div>
</div>

<!-- Content Grid -->
<div class="content-grid">
  <!-- Left Column - Projects -->
  <div>
    <!-- Recent Projects -->
    <div class="content-card">
      <div class="card-header">
        <h2>Projets récents</h2>
        <a href="/projects">Voir tout</a>
      </div>
      
      <% if (projects && projects.length > 0) { %>
        <div class="project-list">
          <% projects.slice(0, 5).forEach(project => { %>
            <a href="/projects/<%= project._id %>" class="project-item">
              <div class="project-thumb">
                <% if (project.designVariants && project.designVariants.length > 0) { %>
                  <img src="<%= project.designVariants[project.designVariants.length - 1].imageUrl || project.designVariants[project.designVariants.length - 1].thumbnailUrl %>" alt="<%= project.title %>">
                <% } else if (project.originalImages && project.originalImages.length > 0) { %>
                  <img src="<%= project.originalImages[0].url %>" alt="<%= project.title %>">
                <% } else { %>
                  <i data-lucide="image"></i>
                <% } %>
              </div>
              <div class="project-info">
                <h3><%= project.title %></h3>
                <p><%= project.roomType %><% if (project.style) { %> • <%= project.style %><% } %></p>
                <span class="project-status <%= project.status %>"><%= project.status %></span>
              </div>
            </a>
          <% }) %>
        </div>
      <% } else { %>
        <div class="empty-state">
          <div class="empty-state-icon">
            <i data-lucide="folder-plus"></i>
          </div>
          <h3>Aucun projet</h3>
          <p>Créez votre premier projet et laissez l'IA transformer votre espace</p>
          <a href="/projects/new" class="btn btn-primary">
            <i data-lucide="plus"></i>
            Créer un projet
          </a>
        </div>
      <% } %>
    </div>
  </div>
  
  <!-- Right Column -->
  <div>
    <!-- AI Credits -->
    <div class="content-card ai-credits-card" style="margin-bottom: 16px;">
      <div class="card-body ai-credits-body">
        <div class="ai-credits-header">
          <span class="ai-credits-label">
            <i data-lucide="zap"></i>
            Crédits IA
          </span>
          <a href="/pricing" class="ai-credits-link">Obtenir plus</a>
        </div>
        <div class="ai-credits-value"><%= user.subscription?.credits || 3 %></div>
        <div class="ai-credits-subtext"><%= user.isPremium ? 'Plan illimité' : 'sur 10 crédits gratuits' %></div>
        <% if (!user.isPremium) { %>
          <div class="ai-credits-progress">
            <div class="ai-credits-progress-bar" style="width: <%= ((user.subscription?.credits || 3) / 10) * 100 %>%;"></div>
          </div>
        <% } %>
      </div>
    </div>
    
    <!-- Quick Actions -->
    <div class="content-card" style="margin-bottom: 16px;">
      <div class="card-header">
        <h2>Actions rapides</h2>
      </div>
      <div class="card-body">
        <div class="quick-actions">
          <a href="/projects/new" class="quick-action">
            <i data-lucide="plus-circle"></i>
            <span>Nouveau projet</span>
          </a>
          <a href="/contractors" class="quick-action">
            <i data-lucide="hard-hat"></i>
            <span>Entrepreneurs</span>
          </a>
          <a href="/dashboard/messages" class="quick-action">
            <i data-lucide="message-square"></i>
            <span>Messages</span>
          </a>
          <a href="/gallery" class="quick-action">
            <i data-lucide="images"></i>
            <span>Galerie</span>
          </a>
        </div>
      </div>
    </div>
    
    <!-- Inspiration Carousel -->
    <div class="content-card" style="margin-bottom: 16px;">
      <div class="card-header">
        <h2>🍳 Idées / Inspiration</h2>
        <div class="inspiration-dropdown">
          <select id="inspiration-select" class="inspiration-select" onchange="changeInspiration(this.value)">
            <option value="cuisine" selected>Cuisine</option>
            <option value="salon">Salon</option>
            <option value="chambre">Chambre</option>
            <option value="salle-de-bain">Salle de bain</option>
            <option value="exterieur">Extérieur</option>
          </select>
        </div>
      </div>
      <div class="card-body" style="padding: 12px;">
        <div class="insp-carousel" id="insp-carousel">
          <div class="insp-track" id="insp-track">
            <div class="insp-slide">
              <a href="/inspiration/cuisine?style=moderne" class="insp-slide-inner">
                <img src="/assets/11houses/Modern Arabic.jpeg" alt="Cuisine Moderne">
                <span class="insp-label">Moderne</span>
              </a>
            </div>
            <div class="insp-slide">
              <a href="/inspiration/cuisine?style=rustique" class="insp-slide-inner">
                <img src="/assets/11houses/Rustic.jpeg" alt="Cuisine Rustique">
                <span class="insp-label">Rustique</span>
              </a>
            </div>
            <div class="insp-slide">
              <a href="/inspiration/cuisine?style=industriel" class="insp-slide-inner">
                <img src="/assets/11houses/Industrial.jpeg" alt="Cuisine Industrielle">
                <span class="insp-label">Industriel</span>
              </a>
            </div>
            <div class="insp-slide">
              <a href="/inspiration/cuisine?style=luxe" class="insp-slide-inner">
                <img src="/assets/11houses/Luxury.jpeg" alt="Cuisine Luxe">
                <span class="insp-label">Luxe</span>
              </a>
            </div>
          </div>

          <button class="insp-btn insp-btn-prev" id="insp-prev" aria-label="Précédent">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          </button>
          <button class="insp-btn insp-btn-next" id="insp-next" aria-label="Suivant">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          </button>

          <div class="insp-dots" id="insp-dots">
            <button class="insp-dot active" aria-label="Slide 1"></button>
            <button class="insp-dot" aria-label="Slide 2"></button>
            <button class="insp-dot" aria-label="Slide 3"></button>
            <button class="insp-dot" aria-label="Slide 4"></button>
          </div>
        </div>

        <a href="/inspiration/cuisine" class="btn btn-outline btn-block" style="margin-top: 12px;">
          Voir toutes les inspirations
        </a>
      </div>
    </div>

    <script>
      function changeInspiration(type) {
        window.location.href = '/inspiration/' + type;
      }

      (function() {
        const track   = document.getElementById('insp-track');
        const carousel = document.getElementById('insp-carousel');
        const dots    = Array.from(document.querySelectorAll('#insp-dots .insp-dot'));
        const slides  = Array.from(track.querySelectorAll('.insp-slide'));
        let current = 0;
        let timer;

        function goTo(index) {
          current = (index + slides.length) % slides.length;
          track.style.transform = 'translateX(-' + (current * 100) + '%)';
          dots.forEach(function(d, i) { d.classList.toggle('active', i === current); });
        }

        function startAuto() { timer = setInterval(function() { goTo(current + 1); }, 3000); }
        function resetAuto()  { clearInterval(timer); startAuto(); }

        document.getElementById('insp-prev').addEventListener('click', function() { goTo(current - 1); resetAuto(); });
        document.getElementById('insp-next').addEventListener('click', function() { goTo(current + 1); resetAuto(); });
        dots.forEach(function(dot, i) { dot.addEventListener('click', function() { goTo(i); resetAuto(); }); });

        carousel.addEventListener('mouseenter', function() { clearInterval(timer); });
        carousel.addEventListener('mouseleave', startAuto);

        startAuto();
      })();
    </script>
    
    <!-- Upgrade CTA -->
    <% if (!user.isPremium) { %>
      <div class="content-card upgrade-card">
        <div class="card-body upgrade-card-body">
          <div class="upgrade-card-icon">⚡</div>
          <h3>Passez à Pro</h3>
          <p>Générations IA illimitées et exports HD</p>
          <a href="/pricing" class="btn btn-primary btn-block">
            Passer à Pro
          </a>
        </div>
      </div>
    <% } %>
  </div>
</div>
