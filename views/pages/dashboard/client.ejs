<!-- Dashboard Hero -->
<section class="dashboard-hero">
  <div class="dashboard-hero-content">
    <span class="dashboard-kicker">CraftyCrib AI Studio</span>
    <h1>Bienvenue, <%= user.firstName || 'créateur' %></h1>
    <p>Gérez vos projets, relancez vos outils IA et transformez chaque espace avec une expérience premium.</p>
    <div class="dashboard-hero-actions">
      <a href="/projects/new" class="dashboard-hero-btn primary">
        <i data-lucide="plus"></i>
        Nouveau projet
      </a>
      <a href="/dashboard/ai-tools" class="dashboard-hero-btn secondary">
        <i data-lucide="wand-sparkles"></i>
        Explorer les outils IA
      </a>
    </div>
  </div>
  <div class="dashboard-hero-panel">
    <div class="hero-panel-icon"><i data-lucide="sparkles"></i></div>
    <span>Prochaine action</span>
    <strong>Uploader une pièce et générer un nouveau design</strong>
    <a href="/projects/new">Démarrer</a>
  </div>
</section>

<!-- Stats Grid -->
<div class="stats-grid">
  <div class="stat-card stat-total">
    <div class="stat-icon green">
      <i data-lucide="folder"></i>
    </div>
    <div class="stat-info">
      <div class="stat-value"><%= stats.totalProjects %></div>
      <div class="stat-label">Projets totaux</div>
    </div>
    <span class="stat-accent"></span>
  </div>
  
  <div class="stat-card stat-ai">
    <div class="stat-icon purple">
      <i data-lucide="sparkles"></i>
    </div>
    <div class="stat-info">
      <div class="stat-value"><%= stats.totalVariants %></div>
      <div class="stat-label">Designs IA</div>
    </div>
    <span class="stat-accent"></span>
  </div>
  
  <div class="stat-card stat-progress">
    <div class="stat-icon orange">
      <i data-lucide="clock"></i>
    </div>
    <div class="stat-info">
      <div class="stat-value"><%= stats.inProgress %></div>
      <div class="stat-label">En cours</div>
    </div>
    <span class="stat-accent"></span>
  </div>
  
  <div class="stat-card stat-done">
    <div class="stat-icon blue">
      <i data-lucide="check-circle"></i>
    </div>
    <div class="stat-info">
      <div class="stat-value"><%= stats.completedDesigns %></div>
      <div class="stat-label">Terminés</div>
    </div>
    <span class="stat-accent"></span>
  </div>
</div>

<!-- Content Grid -->
<div class="content-grid">
  <!-- Left Column - Projects -->
  <div>
    <!-- Recent Projects -->
    <div class="content-card recent-projects-card">
      <div class="card-header">
        <div>
          <span class="section-kicker">Activité</span>
          <h2>Projets récents</h2>
        </div>
        <a href="/projects">Voir tout</a>
      </div>
      
      <% if (projects && projects.length > 0) { %>
        <div class="project-list">
          <% projects.slice(0, 5).forEach(project => { %>
            <a href="/projects/<%= project._id %>/studio" class="project-item" data-project-id="<%= project._id %>" data-title="<%= project.title %>" data-room-type="<%= project.roomType || 'Projet' %>">
              <div class="project-thumb">
                <% if (project.designVariants && project.designVariants.length > 0) { %>
                  <img src="<%= project.designVariants[project.designVariants.length - 1].imageUrl || project.designVariants[project.designVariants.length - 1].thumbnailUrl %>" alt="<%= project.title %>">
                <% } else if (project.originalImages && project.originalImages.length > 0) { %>
                  <img src="<%= project.originalImages[0].url %>" alt="<%= project.title %>">
                <% } else { %>
                  <i data-lucide="image"></i>
                <% } %>
              </div>
              <div class="project-info">
                <h3><%= project.title %></h3>
                <p><%= project.roomType %><% if (project.style) { %> • <%= project.style %><% } %></p>
                <div class="project-row-meta">
                  <span class="project-status <%= project.status %>"><%= project.status %></span>
                  <span><%= project.designVariants ? project.designVariants.length : 0 %> design<%= project.designVariants && project.designVariants.length > 1 ? 's' : '' %></span>
                </div>
              </div>
            </a>
          <% }) %>
        </div>
      <% } else { %>
        <div class="empty-state">
          <div class="empty-state-icon">
            <i data-lucide="folder-plus"></i>
          </div>
          <h3>Aucun projet</h3>
          <p>Créez votre premier projet et laissez l'IA transformer votre espace</p>
          <a href="/projects/new" class="btn btn-primary">
            <i data-lucide="plus"></i>
            Créer un projet
          </a>
        </div>
      <% } %>
    </div>
  </div>
  
  <!-- Right Column -->
  <div>
    <!-- Favorites -->
    <div class="content-card dashboard-favorites-card" id="dashboard-favorites-card" style="margin-bottom: 16px;" hidden>
      <div class="card-header">
        <div>
          <span class="section-kicker">Favoris</span>
          <h2>Projets favoris</h2>
        </div>
        <a href="/projects">Gérer</a>
      </div>
      <div class="card-body">
        <div class="dashboard-favorites-list" id="dashboard-favorites-list"></div>
      </div>
    </div>

    <!-- Recommended AI Tools -->
    <div class="content-card recommended-tools-card" style="margin-bottom: 16px;">
      <div class="card-header">
        <div>
          <span class="section-kicker">IA recommandée</span>
          <h2>Outils IA</h2>
        </div>
        <a href="/dashboard/ai-tools">Tout voir</a>
      </div>
      <div class="card-body">
        <div class="recommended-tools">
          <a href="/dashboard/new-project?tool=redesign" class="recommended-tool">
            <i data-lucide="pencil-ruler"></i>
            <span>Redesign</span>
          </a>
          <a href="/dashboard/new-project?tool=furniture_removal" class="recommended-tool">
            <i data-lucide="eraser"></i>
            <span>Furniture Removal</span>
          </a>
          <a href="/dashboard/new-project?tool=paint_visualizer" class="recommended-tool">
            <i data-lucide="paintbrush"></i>
            <span>Paint Visualizer</span>
          </a>
        </div>
      </div>
    </div>

    <!-- AI Credits -->
    <div class="content-card ai-credits-card" style="margin-bottom: 16px;">
      <div class="card-body ai-credits-body">
        <div class="ai-credits-header">
          <span class="ai-credits-label">
            <i data-lucide="zap"></i>
            Crédits IA
          </span>
          <a href="/pricing" class="ai-credits-link">Obtenir plus</a>
        </div>
        <div class="ai-credits-value"><%= user.subscription?.credits || 3 %></div>
        <div class="ai-credits-subtext"><%= user.isPremium ? 'Plan illimité' : 'sur 10 crédits gratuits' %></div>
        <% if (!user.isPremium) { %>
          <div class="ai-credits-progress">
            <div class="ai-credits-progress-bar" style="width: <%= ((user.subscription?.credits || 3) / 10) * 100 %>%;"></div>
          </div>
        <% } %>
      </div>
    </div>
    
    <!-- Quick Actions -->
    <div class="content-card" style="margin-bottom: 16px;">
      <div class="card-header">
        <h2>Actions rapides</h2>
      </div>
      <div class="card-body">
        <div class="quick-actions">
          <a href="/projects/new" class="quick-action">
            <i data-lucide="plus-circle"></i>
            <span>Nouveau projet</span>
          </a>
          <a href="/contractors" class="quick-action">
            <i data-lucide="hard-hat"></i>
            <span>Entrepreneurs</span>
          </a>
          <a href="/dashboard/messages" class="quick-action">
            <i data-lucide="message-square"></i>
            <span>Messages</span>
          </a>
          <a href="/gallery" class="quick-action">
            <i data-lucide="images"></i>
            <span>Galerie</span>
          </a>
        </div>
      </div>
    </div>
    
    <!-- Inspiration Carousel -->
    <div class="content-card" style="margin-bottom: 16px;">
      <div class="card-header">
        <h2>🍳 Idées / Inspiration</h2>
        <div class="inspiration-dropdown">
          <select id="inspiration-select" class="inspiration-select" onchange="changeInspiration(this.value)">
            <option value="cuisine" selected>Cuisine</option>
            <option value="salon">Salon</option>
            <option value="chambre">Chambre</option>
            <option value="salle-de-bain">Salle de bain</option>
            <option value="exterieur">Extérieur</option>
          </select>
        </div>
      </div>
      <div class="card-body" style="padding: 12px;">
        <div class="insp-marquee" id="insp-marquee" aria-label="Galerie d'inspiration cuisine">
          <div class="insp-marquee-track">
            <% const inspirationItems = [
              { src: '/assets/11houses/Modern Arabic.jpeg', label: 'Moderne' },
              { src: '/assets/11houses/Rustic.jpeg', label: 'Rustique' },
              { src: '/assets/11houses/Industrial.jpeg', label: 'Industriel' },
              { src: '/assets/11houses/Luxury.jpeg', label: 'Luxe' },
              { src: '/assets/11houses/Bois.jpeg', label: 'Bois naturel' },
              { src: '/assets/11houses/Nordic Black.jpeg', label: 'Nordic Black' },
              { src: '/assets/11houses/Quartz.jpeg', label: 'Quartz' },
              { src: '/assets/11houses/Marbre.jpeg', label: 'Marbre' },
              { src: '/assets/11houses/Bali.jpeg', label: 'Bali' }
            ]; %>
            <% inspirationItems.concat(inspirationItems).forEach((item, index) => {
              const imageIndex = index % inspirationItems.length;
            %>
              <button type="button" class="insp-marquee-card" onclick="openCarouselLightbox(<%= imageIndex %>)">
                <img src="<%= item.src %>" alt="Inspiration <%= item.label %>" loading="lazy">
                <span class="insp-label"><%= item.label %></span>
              </button>
            <% }) %>
          </div>
        </div>

        <a href="/inspiration/cuisine" class="btn btn-outline btn-block" style="margin-top: 12px;">
          Voir toutes les inspirations
        </a>
      </div>
    </div>

    <script>
      function changeInspiration(type) {
        window.location.href = '/inspiration/' + type;
      }

      (function renderDashboardFavorites() {
        const card = document.getElementById('dashboard-favorites-card');
        const list = document.getElementById('dashboard-favorites-list');
        if (!card || !list) return;

        let favoriteIds = [];
        try {
          favoriteIds = JSON.parse(localStorage.getItem('craftycrib.favoriteProjects') || '[]');
        } catch (error) {
          favoriteIds = [];
        }

        const dashboardProjects = Array.from(document.querySelectorAll('.project-item')).map(item => ({
          id: item.dataset.projectId,
          title: item.dataset.title || 'Projet',
          roomType: item.dataset.roomType || 'Projet',
          imageUrl: item.querySelector('.project-thumb img')?.getAttribute('src') || ''
        }));
        const favorites = dashboardProjects.filter(project => favoriteIds.includes(project.id)).slice(0, 3);
        card.hidden = favorites.length === 0;
        list.innerHTML = favorites.map(project => {
          const media = project.imageUrl
            ? `<img src="${project.imageUrl}" alt="${project.title}">`
            : '<span class="favorite-placeholder"><i data-lucide="image"></i></span>';
          return `
            <a href="/projects/${project.id}" class="dashboard-favorite-item">
              ${media}
              <span>
                <strong>${project.title}</strong>
                <small>${project.roomType || 'Projet'}</small>
              </span>
            </a>
          `;
        }).join('');
        if (typeof lucide !== 'undefined') lucide.createIcons();
      })();

      // Carousel lightbox
      const carouselLbImages = [
        '/assets/11houses/Modern Arabic.jpeg',
        '/assets/11houses/Rustic.jpeg',
        '/assets/11houses/Industrial.jpeg',
        '/assets/11houses/Luxury.jpeg',
        '/assets/11houses/Bois.jpeg',
        '/assets/11houses/Nordic Black.jpeg',
        '/assets/11houses/Quartz.jpeg',
        '/assets/11houses/Marbre.jpeg',
        '/assets/11houses/Bali.jpeg'
      ];
      let carouselLbIdx = 0;

      function openCarouselLightbox(idx) {
        carouselLbIdx = idx;
        renderCarouselLb();
        const lb = document.getElementById('carousel-lightbox');
        lb.style.display = 'flex';
        document.body.style.overflow = 'hidden';
      }
      function renderCarouselLb() {
        document.getElementById('carousel-lb-img').src = carouselLbImages[carouselLbIdx];
        document.getElementById('carousel-lb-dl').href = carouselLbImages[carouselLbIdx];
        document.getElementById('carousel-lb-counter').textContent = (carouselLbIdx + 1) + ' / ' + carouselLbImages.length;
      }
      function carouselLbNav(dir) {
        carouselLbIdx = (carouselLbIdx + dir + carouselLbImages.length) % carouselLbImages.length;
        renderCarouselLb();
      }
      function closeCarouselLightbox() {
        document.getElementById('carousel-lightbox').style.display = 'none';
        document.body.style.overflow = '';
      }
      document.addEventListener('keydown', function(e) {
        const lb = document.getElementById('carousel-lightbox');
        if (!lb || lb.style.display === 'none') return;
        if (e.key === 'Escape') closeCarouselLightbox();
        if (e.key === 'ArrowLeft')  carouselLbNav(-1);
        if (e.key === 'ArrowRight') carouselLbNav(1);
      });

    </script>
    
    <!-- Carousel Lightbox -->
    <div id="carousel-lightbox" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,0.96);flex-direction:column;align-items:center;justify-content:center;" onclick="closeCarouselLightbox()">
      <div style="position:relative;flex:1;display:flex;align-items:center;justify-content:center;width:100%;padding:12px 60px;min-height:0;" onclick="event.stopPropagation()">
        <img id="carousel-lb-img" src="" alt="" style="max-width:100%;max-height:calc(100vh - 72px);object-fit:contain;border-radius:10px;user-select:none;">
        <button onclick="carouselLbNav(-1)" style="position:absolute;left:12px;width:44px;height:44px;background:rgba(255,255,255,0.13);border:1px solid rgba(255,255,255,0.2);border-radius:50%;color:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:1.3rem;">&#8249;</button>
        <button onclick="carouselLbNav(1)"  style="position:absolute;right:12px;width:44px;height:44px;background:rgba(255,255,255,0.13);border:1px solid rgba(255,255,255,0.2);border-radius:50%;color:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:1.3rem;">&#8250;</button>
      </div>
      <div style="display:flex;align-items:center;gap:12px;padding:10px 16px;background:rgba(0,0,0,0.5);border-top:1px solid rgba(255,255,255,0.08);width:100%;flex-shrink:0;" onclick="event.stopPropagation()">
        <span id="carousel-lb-counter" style="color:rgba(255,255,255,0.6);font-size:0.82rem;flex:1;text-align:center;"></span>
        <a id="carousel-lb-dl" href="#" download target="_blank" style="display:inline-flex;align-items:center;gap:6px;color:rgba(255,255,255,0.85);background:rgba(255,255,255,0.1);border:none;border-radius:6px;padding:6px 14px;cursor:pointer;font-size:0.8rem;text-decoration:none;">⬇ Télécharger</a>
        <button onclick="closeCarouselLightbox()" style="display:inline-flex;align-items:center;gap:6px;color:rgba(255,255,255,0.85);background:rgba(255,255,255,0.1);border:none;border-radius:6px;padding:6px 14px;cursor:pointer;font-size:0.8rem;">✕ Fermer</button>
      </div>
    </div>

    <!-- Upgrade CTA -->
    <% if (!user.isPremium) { %>
      <div class="content-card upgrade-card">
        <div class="card-body upgrade-card-body">
          <div class="upgrade-card-icon">⚡</div>
          <h3>Passez à Pro</h3>
          <p>Générations IA illimitées et exports HD</p>
          <a href="/pricing" class="btn btn-primary btn-block">
            Passer à Pro
          </a>
        </div>
      </div>
    <% } %>
  </div>
</div>