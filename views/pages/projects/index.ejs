<%
  const projectList = projects || [];
  const statusLabel = {
    completed: 'Generated',
    generating: 'Generating',
    draft: 'Draft',
    pending: 'Pending',
    'in-progress': 'In progress',
    archived: 'Archived'
  };
  const toolNames = {
    beautiful_redesign: 'Beautiful Redesign',
    perfect_redesign: 'Perfect Redesign',
    creative_redesign: 'Creative Redesign',
    sketch_to_render: 'Sketch to Render',
    precision: 'Precision',
    fill_spaces: 'Fill Spaces',
    decor_staging: 'Decor Staging',
    furniture_removal: 'Furniture Removal',
    change_color_textures: 'Change Color Textures',
    paint_visualizer: 'Paint Visualizer',
    furniture_finder: 'Furniture Finder',
    full_hd: 'Full HD',
    sky_colors: 'Sky Colors',
    magic_redesign: 'Magic Redesign',
    video_generation: 'Video Generation',
    virtual_staging: 'Virtual Staging',
    text_to_design: 'Text To Design',
    furniture_creator: 'Furniture Creator',
    design_advisor: 'Design Advisor',
    design_transfer: 'Design Transfer',
    floor_editor: 'Floor Editor',
    material_swap: 'Material Swap',
    room_composer: 'Room Composer',
    design_critique: 'Design Critique',
    create_maskimage: 'Create Mask Image',
    smart_home: 'Smart Home'
  };
%>

<div class="projects-page">
  <section class="projects-hero">
    <div>
      <span class="projects-eyebrow">CraftyCrib Studio</span>
      <h1>Mes projets</h1>
      <p>Retrouvez vos espaces, relancez les outils IA et gardez vos meilleurs projets à portée de main.</p>
    </div>
    <a href="/projects/new" class="projects-primary-action">
      <i data-lucide="plus"></i>
      Nouveau projet
    </a>
  </section>

  <% if (projectList.length > 0) { %>
    <section class="projects-toolbar" aria-label="Project filters">
      <div class="projects-search">
        <i data-lucide="search"></i>
        <input type="search" id="project-search" placeholder="Rechercher un projet, une pièce, un style...">
      </div>
      <div class="projects-filter-group" id="project-filters">
        <button type="button" class="project-filter active" data-filter="all">Tous <span><%= projectList.length %></span></button>
        <button type="button" class="project-filter" data-filter="active">En cours</button>
        <button type="button" class="project-filter" data-filter="completed">Terminés</button>
        <button type="button" class="project-filter" data-filter="favorite">Favoris</button>
      </div>
    </section>

    <section class="favorites-section" id="favorites-section" hidden>
      <div class="section-heading">
        <div>
          <span class="projects-eyebrow">Favoris</span>
          <h2>Projets épinglés</h2>
        </div>
        <span class="favorites-count" id="favorites-count">0 projet</span>
      </div>
      <div class="favorites-strip" id="favorites-strip"></div>
    </section>

    <section class="projects-grid" id="projects-grid">
      <% projectList.forEach(project => {
        const variants = project.designVariants || [];
        const latestVariant = variants.length ? variants[variants.length - 1] : null;
        const originalImage = project.originalImages && project.originalImages.length ? project.originalImages[0] : null;
        const imageUrl = (latestVariant && (latestVariant.imageUrl || latestVariant.thumbnailUrl)) || (originalImage && originalImage.url) || '';
        const lastParams = latestVariant && latestVariant.aiParameters ? latestVariant.aiParameters : {};
        const rawTool = lastParams.toolName || lastParams.type || latestVariant?.name || '';
        const normalizedTool = String(rawTool).replace(/-/g, '_');
        const toolLabel = toolNames[normalizedTool] || rawTool || 'AI Studio';
        const createdAt = new Date(project.createdAt);
        const searchable = [
          project.title,
          project.description,
          project.roomType,
          project.style,
          project.status,
          toolLabel
        ].filter(Boolean).join(' ').toLowerCase();
        const isCompleted = project.status === 'completed' || variants.length > 0;
      %>
        <article class="project-card"
          data-project-id="<%= project._id %>"
          data-status="<%= project.status %>"
          data-completed="<%= isCompleted ? 'true' : 'false' %>"
          data-search="<%= searchable.replace(/"/g, '&quot;') %>">
          <div class="project-media">
            <% if (imageUrl) { %>
              <img src="<%= imageUrl %>" alt="<%= project.title %>" loading="lazy">
            <% } else { %>
              <div class="project-placeholder">
                <i data-lucide="image"></i>
              </div>
            <% } %>
            <button type="button" class="favorite-toggle" data-project-id="<%= project._id %>" aria-label="Ajouter aux favoris">
              <i data-lucide="heart"></i>
            </button>
            <div class="project-badges">
              <span class="project-badge status-badge status-<%= project.status %>"><%= statusLabel[project.status] || project.status %></span>
              <% if (variants.length > 0) { %>
                <span class="project-badge generated-badge"><%= variants.length %> génération<%= variants.length > 1 ? 's' : '' %></span>
              <% } %>
            </div>
          </div>

          <div class="project-body">
            <div class="project-title-row">
              <h3><%= project.title %></h3>
              <span class="project-date"><%= createdAt.toLocaleDateString('fr-CA') %></span>
            </div>
            <p><%= project.description ? (project.description.length > 112 ? project.description.substring(0, 112) + '...' : project.description) : 'Aucune description pour ce projet.' %></p>

            <div class="project-meta-grid">
              <span><i data-lucide="home"></i><%= project.roomType || 'Room' %></span>
              <span><i data-lucide="palette"></i><%= project.style || 'Style libre' %></span>
              <span><i data-lucide="wand-sparkles"></i><%= toolLabel %></span>
              <span><i data-lucide="images"></i><%= variants.length %> design<%= variants.length > 1 ? 's' : '' %></span>
            </div>

            <div class="project-actions">
              <a href="/projects/<%= project._id %>/view" class="project-action primary">
                <i data-lucide="eye"></i>
                View
              </a>
              <a href="/projects/<%= project._id %>/studio" class="project-action">
                <i data-lucide="edit-3"></i>
                Edit
              </a>
              <form action="/projects/<%= project._id %>?_method=DELETE" method="POST" class="project-delete-form" onsubmit="return confirm('Supprimer ce projet ?')">
                <button type="submit" class="project-action danger" aria-label="Delete <%= project.title %>">
                  <i data-lucide="trash-2"></i>
                </button>
              </form>
            </div>
          </div>
        </article>
      <% }) %>
    </section>

    <div class="projects-empty-filter" id="projects-empty-filter" hidden>
      <i data-lucide="search-x"></i>
      <h3>Aucun projet trouvé</h3>
      <p>Essayez un autre filtre ou une autre recherche.</p>
    </div>
  <% } else { %>
    <div class="empty-state">
      <div class="empty-icon">
        <i data-lucide="folder-plus"></i>
      </div>
      <h3>Aucun projet pour le moment</h3>
      <p>Créez votre premier projet et commencez à générer des designs IA.</p>
      <a href="/projects/new" class="projects-primary-action">
        <i data-lucide="plus"></i>
        Créer un projet
      </a>
    </div>
  <% } %>
</div>

<style>
  .projects-page {
    max-width: 1440px;
    margin: 0 auto;
    padding: var(--spacing-xl);
  }

  .projects-hero {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 22px;
    padding: 24px;
    border: 1px solid rgba(16, 185, 129, 0.22);
    border-radius: 16px;
    background:
      linear-gradient(135deg, rgba(16, 185, 129, 0.13), transparent 45%),
      var(--bg-card);
    box-shadow: 0 18px 44px rgba(2, 6, 23, 0.13);
  }

  .projects-eyebrow {
    display: inline-flex;
    margin-bottom: 8px;
    color: var(--accent-primary);
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .projects-hero h1 {
    margin: 0 0 6px;
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    letter-spacing: 0;
  }

  .projects-hero p {
    max-width: 680px;
    margin: 0;
    color: var(--text-muted);
    line-height: 1.55;
  }

  .projects-primary-action,
  .project-action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    min-height: 42px;
    padding: 0 16px;
    border-radius: 10px;
    border: 1px solid rgba(16, 185, 129, 0.35);
    background: var(--accent-primary);
    color: #00140e;
    font-weight: 900;
    text-decoration: none;
    cursor: pointer;
  }

  .projects-primary-action i,
  .project-action i {
    width: 17px;
    height: 17px;
  }

  .projects-toolbar {
    display: grid;
    grid-template-columns: minmax(260px, 1fr) auto;
    gap: 14px;
    align-items: center;
    margin-bottom: 20px;
  }

  .projects-search {
    position: relative;
  }

  .projects-search i {
    position: absolute;
    left: 14px;
    top: 50%;
    width: 18px;
    height: 18px;
    transform: translateY(-50%);
    color: var(--text-muted);
  }

  .projects-search input {
    width: 100%;
    min-height: 46px;
    padding: 0 14px 0 44px;
    border: 1px solid var(--border-color);
    border-radius: 12px;
    background: var(--bg-card);
    color: var(--text-primary);
    font: inherit;
    font-weight: 700;
  }

  .projects-search input:focus {
    outline: none;
    border-color: rgba(16, 185, 129, 0.55);
    box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.1);
  }

  .projects-filter-group {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .project-filter {
    min-height: 42px;
    padding: 0 14px;
    border: 1px solid var(--border-color);
    border-radius: 999px;
    background: var(--bg-card);
    color: var(--text-secondary);
    font-weight: 850;
    cursor: pointer;
  }

  .project-filter span {
    margin-left: 5px;
    opacity: 0.72;
  }

  .project-filter.active,
  .project-filter:hover {
    border-color: rgba(16, 185, 129, 0.45);
    background: rgba(16, 185, 129, 0.13);
    color: var(--accent-primary);
  }

  .favorites-section {
    margin-bottom: 24px;
    padding: 18px;
    border: 1px solid rgba(16, 185, 129, 0.18);
    border-radius: 16px;
    background: var(--bg-card);
  }

  .section-heading {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 14px;
  }

  .section-heading h2 {
    margin: 0;
    font-size: 1.15rem;
  }

  .favorites-count {
    color: var(--text-muted);
    font-size: 13px;
    font-weight: 800;
  }

  .favorites-strip {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(210px, 260px);
    gap: 12px;
    overflow-x: auto;
    padding-bottom: 4px;
  }

  .favorite-mini-card {
    position: relative;
    min-height: 118px;
    overflow: hidden;
    border-radius: 12px;
    background: var(--bg-secondary);
    text-decoration: none;
    color: #fff;
  }

  .favorite-mini-card img,
  .favorite-mini-card .project-placeholder {
    width: 100%;
    height: 118px;
    object-fit: cover;
  }

  .favorite-mini-card span {
    position: absolute;
    inset: auto 0 0;
    padding: 32px 12px 10px;
    background: linear-gradient(to top, rgba(0,0,0,0.78), transparent);
    font-weight: 900;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(310px, 1fr));
    gap: 18px;
  }

  .project-card {
    overflow: hidden;
    border: 1px solid var(--border-color);
    border-radius: 16px;
    background: var(--bg-card);
    box-shadow: 0 12px 34px rgba(2, 6, 23, 0.1);
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .project-card[hidden] {
    display: none;
  }

  .project-card:hover {
    transform: translateY(-4px);
    border-color: rgba(16, 185, 129, 0.34);
    box-shadow: 0 18px 46px rgba(2, 6, 23, 0.18);
  }

  .project-media {
    position: relative;
    height: 214px;
    background: var(--bg-secondary);
  }

  .project-media img,
  .project-placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .project-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-muted);
  }

  .project-placeholder i {
    width: 48px;
    height: 48px;
  }

  .favorite-toggle {
    position: absolute;
    top: 12px;
    right: 12px;
    width: 38px;
    height: 38px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(255,255,255,0.22);
    border-radius: 999px;
    background: rgba(2, 6, 23, 0.58);
    color: #fff;
    cursor: pointer;
    backdrop-filter: blur(8px);
  }

  .favorite-toggle i {
    width: 18px;
    height: 18px;
  }

  .favorite-toggle.is-favorite {
    border-color: rgba(16, 185, 129, 0.65);
    background: rgba(16, 185, 129, 0.92);
    color: #00140e;
  }

  .project-badges {
    position: absolute;
    left: 12px;
    right: 58px;
    bottom: 12px;
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .project-badge {
    display: inline-flex;
    align-items: center;
    min-height: 26px;
    padding: 0 10px;
    border-radius: 999px;
    background: rgba(2, 6, 23, 0.72);
    color: #fff;
    font-size: 12px;
    font-weight: 900;
    backdrop-filter: blur(8px);
    text-transform: capitalize;
  }

  .generated-badge {
    background: rgba(16, 185, 129, 0.92);
    color: #00140e;
  }

  .status-completed { color: #34d399; }
  .status-generating,
  .status-pending,
  .status-in-progress { color: #fbbf24; }
  .status-draft { color: #cbd5e1; }
  .status-archived { color: #94a3b8; }

  .project-body {
    padding: 18px;
  }

  .project-title-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 8px;
  }

  .project-title-row h3 {
    margin: 0;
    font-size: 1.1rem;
    line-height: 1.25;
  }

  .project-date {
    flex: 0 0 auto;
    color: var(--text-muted);
    font-size: 12px;
    font-weight: 800;
  }

  .project-body p {
    min-height: 42px;
    margin: 0 0 14px;
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .project-meta-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 9px;
    margin-bottom: 16px;
  }

  .project-meta-grid span {
    min-width: 0;
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 8px 9px;
    border-radius: 9px;
    background: var(--bg-secondary);
    color: var(--text-muted);
    font-size: 12px;
    font-weight: 800;
    text-transform: capitalize;
  }

  .project-meta-grid i {
    width: 15px;
    height: 15px;
    color: var(--accent-primary);
    flex: 0 0 auto;
  }

  .project-actions {
    display: grid;
    grid-template-columns: 1fr 1fr auto;
    gap: 8px;
  }

  .project-action {
    min-height: 38px;
    padding: 0 12px;
    border-color: var(--border-color);
    background: var(--bg-secondary);
    color: var(--text-primary);
    font-size: 13px;
  }

  .project-action.primary {
    border-color: rgba(16, 185, 129, 0.35);
    background: rgba(16, 185, 129, 0.16);
    color: var(--accent-primary);
  }

  .project-action:hover {
    border-color: rgba(16, 185, 129, 0.45);
  }

  .project-action.danger {
    color: var(--error);
  }

  .project-delete-form {
    margin: 0;
  }

  .projects-empty-filter,
  .empty-state {
    text-align: center;
    padding: 44px 20px;
    border: 1px dashed var(--border-color);
    border-radius: 16px;
    background: var(--bg-card);
  }

  .projects-empty-filter i,
  .empty-icon i {
    width: 48px;
    height: 48px;
    color: var(--text-muted);
  }

  .empty-icon {
    width: 96px;
    height: 96px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 18px;
    border-radius: 50%;
    background: var(--bg-secondary);
  }

  .projects-empty-filter h3,
  .empty-state h3 {
    margin: 12px 0 6px;
  }

  .projects-empty-filter p,
  .empty-state p {
    margin: 0 0 18px;
    color: var(--text-muted);
  }

  @media (max-width: 900px) {
    .projects-hero,
    .projects-toolbar {
      grid-template-columns: 1fr;
      align-items: stretch;
    }

    .projects-hero {
      flex-direction: column;
      align-items: stretch;
    }

    .projects-filter-group {
      justify-content: flex-start;
    }
  }

  @media (max-width: 560px) {
    .projects-page {
      padding: 16px;
    }

    .projects-grid {
      grid-template-columns: 1fr;
    }

    .project-meta-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  (() => {
    const favoriteKey = 'craftycrib.favoriteProjects';
    const cards = Array.from(document.querySelectorAll('.project-card'));
    const searchInput = document.getElementById('project-search');
    const filters = Array.from(document.querySelectorAll('.project-filter'));
    const emptyFilter = document.getElementById('projects-empty-filter');
    const favoritesSection = document.getElementById('favorites-section');
    const favoritesStrip = document.getElementById('favorites-strip');
    const favoritesCount = document.getElementById('favorites-count');
    let activeFilter = 'all';

    function readFavorites() {
      try {
        return new Set(JSON.parse(localStorage.getItem(favoriteKey) || '[]'));
      } catch (error) {
        return new Set();
      }
    }

    function writeFavorites(favorites) {
      localStorage.setItem(favoriteKey, JSON.stringify([...favorites]));
    }

    function isActiveStatus(card) {
      return ['draft', 'generating', 'pending', 'in-progress'].includes(card.dataset.status);
    }

    function matchesFilter(card, favorites) {
      if (activeFilter === 'favorite') return favorites.has(card.dataset.projectId);
      if (activeFilter === 'completed') return card.dataset.completed === 'true';
      if (activeFilter === 'active') return isActiveStatus(card);
      return true;
    }

    function renderFavorites(favorites) {
      const favoriteCards = cards.filter((card) => favorites.has(card.dataset.projectId));
      favoritesSection.hidden = favoriteCards.length === 0;
      favoritesCount.textContent = `${favoriteCards.length} projet${favoriteCards.length > 1 ? 's' : ''}`;
      favoritesStrip.innerHTML = favoriteCards.map((card) => {
        const link = `/projects//studio`;
        const title = card.querySelector('h3')?.textContent || 'Project';
        const image = card.querySelector('.project-media img')?.getAttribute('src');
        const media = image
          ? `<img src="${image}" alt="${title}">`
          : '<div class="project-placeholder"><i data-lucide="image"></i></div>';
        return `<a href="${link}" class="favorite-mini-card">${media}<span>${title}</span></a>`;
      }).join('');
      if (typeof lucide !== 'undefined') lucide.createIcons();
    }

    function applyState() {
      const favorites = readFavorites();
      const query = (searchInput?.value || '').trim().toLowerCase();
      let visibleCount = 0;

      cards.forEach((card) => {
        const favoriteButton = card.querySelector('.favorite-toggle');
        const isFavorite = favorites.has(card.dataset.projectId);
        favoriteButton?.classList.toggle('is-favorite', isFavorite);
        favoriteButton?.setAttribute('aria-label', isFavorite ? 'Retirer des favoris' : 'Ajouter aux favoris');

        const matchesSearch = !query || card.dataset.search.includes(query);
        const visible = matchesSearch && matchesFilter(card, favorites);
        card.hidden = !visible;
        if (visible) visibleCount += 1;
      });

      if (emptyFilter) emptyFilter.hidden = visibleCount > 0;
      renderFavorites(favorites);
    }

    document.querySelectorAll('.favorite-toggle').forEach((button) => {
      button.addEventListener('click', () => {
        const favorites = readFavorites();
        const id = button.dataset.projectId;
        if (favorites.has(id)) favorites.delete(id);
        else favorites.add(id);
        writeFavorites(favorites);
        applyState();
      });
    });

    filters.forEach((button) => {
      button.addEventListener('click', () => {
        filters.forEach((item) => item.classList.remove('active'));
        button.classList.add('active');
        activeFilter = button.dataset.filter;
        applyState();
      });
    });

    searchInput?.addEventListener('input', applyState);
    applyState();
  })();
</script>
