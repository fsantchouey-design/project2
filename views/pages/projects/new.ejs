    function hasDecorTransform() {
      const { scaleX, scaleY, rotation, scale } = decorTransform;
      return scaleX !== 1 || scaleY !== 1 || rotation !== 0 || scale !== 1;
    }

    function applyDecorTransformToFile(file) {
      return new Promise((resolve) => {
        const img = new Image();
        img.onload = () => {
          const { scaleX, scaleY, rotation, scale } = decorTransform;
          const rad = (rotation * Math.PI) / 180;
          const cos = Math.abs(Math.cos(rad));
          const sin = Math.abs(Math.sin(rad));
          const cw = Math.max(512, Math.round((img.naturalWidth * cos + img.naturalHeight * sin) * scale));
          const ch = Math.max(512, Math.round((img.naturalWidth * sin + img.naturalHeight * cos) * scale));
          const canvas = document.createElement('canvas');
          canvas.width = cw;
          canvas.height = ch;
          const ctx = canvas.getContext('2d');
          ctx.translate(cw / 2, ch / 2);
          ctx.rotate(rad);
          ctx.scale(scaleX * scale, scaleY * scale);
          ctx.drawImage(img, -img.naturalWidth / 2, -img.naturalHeight / 2);
          URL.revokeObjectURL(img.src);
          canvas.toBlob(blob => resolve(blob ? new File([blob], 'object.png', { type: 'image/png' }) : file), 'image/png');
        };
        img.onerror = () => resolve(file);
        img.src = URL.createObjectURL(file);
      });
    }

