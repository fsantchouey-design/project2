    function wireToolInterface() {
      toolInterface.querySelectorAll('[data-set-design-type]').forEach((button) => {
        button.addEventListener('click', () => {
          designType = button.dataset.setDesignType;
          document.querySelectorAll('[data-set-design-type]').forEach((item) => item.classList.toggle('active', item === button));
        });
      });
      toolInterface.querySelectorAll('[data-tool-key]').forEach((button) => {
        button.addEventListener('click', () => selectToolByKey(button.dataset.toolKey));
      });
      toolInterface.querySelectorAll('[data-redesign-mode]').forEach((button) => {
        button.addEventListener('click', () => {
          setRedesignMode(button.dataset.redesignMode);
        });
      });
      toolInterface.querySelectorAll('[data-sync-select]').forEach((select) => {
        select.addEventListener('change', () => {
          const target = document.getElementById(select.dataset.syncSelect);
          if (target) {
            target.value = select.value;
            target.dispatchEvent(new Event('change', { bubbles: true }));
          }
        });
      });
      toolInterface.querySelectorAll('[data-sync-textarea]').forEach((textarea) => {
        textarea.addEventListener('input', () => {
          const target = document.getElementById(textarea.dataset.syncTextarea);
          if (target) target.value = textarea.value;
        });
      });
      toolInterface.querySelectorAll('[data-sync-input]').forEach((input) => {
        input.addEventListener('input', () => {
          const target = document.getElementById(input.dataset.syncInput);
          if (target) target.value = input.value;
        });
      });
      toolInterface.querySelectorAll('[data-decor-action]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const action = btn.dataset.decorAction;
          if (action === 'flip-h')   decorTransform.scaleX *= -1;
          else if (action === 'flip-v')   decorTransform.scaleY *= -1;
          else if (action === 'rot-cw')   decorTransform.rotation = (decorTransform.rotation + 90) % 360;
          else if (action === 'rot-ccw')  decorTransform.rotation = (decorTransform.rotation - 90 + 360) % 360;
          else if (action === 'rot-180')  decorTransform.rotation = (decorTransform.rotation + 180) % 360;
          else if (action === 'zoom-in')  decorTransform.scale = Math.min(decorTransform.scale * 1.25, 4);
          else if (action === 'zoom-out') decorTransform.scale = Math.max(decorTransform.scale / 1.25, 0.25);
          applyDecorTransformPreview();
        });
      });
      toolInterface.querySelectorAll('[data-weather]').forEach((button) => {
        button.addEventListener('click', () => {
          weatherSelect.value = button.dataset.weather;
          document.querySelectorAll('[data-weather]').forEach((item) => item.classList.toggle('active', item === button));
        });
      });
      toolInterface.querySelectorAll('[data-material-preset]').forEach((button) => {
        button.addEventListener('click', () => {
          materialPresetSelect.value = button.dataset.materialPreset;
          document.querySelectorAll('[data-material-preset]').forEach((item) => item.classList.toggle('active', item === button));
        });
      });
      toolInterface.querySelector('[data-trigger-upload="texture"]')?.addEventListener('click', () => materialTextureImage.click());
      toolInterface.querySelector('[data-trigger-upload="style-reference"]')?.addEventListener('click', () => styleReferenceImage.click());
      toolInterface.querySelector('#tool-clear-selection')?.addEventListener('click', resetMaskCanvas);
      toolInterface.querySelector('#tool-continue-selection')?.addEventListener('click', () => {
        if (!hasMaskPaint) {
          setStatus('Select an object or draw a mask before continuing.', 'error');
          return;
        }
        materialSwapReady = true;
  updateToolOptions();
  preloadStudioProject();
        setStatus('Selection ready. Choose the next option, then generate.', 'success');
      });
      toolInterface.querySelector('#tool-keep-structural')?.addEventListener('change', (event) => {
        const target = document.getElementById('keep-structural-element');
        if (target) target.checked = event.target.checked;
      });
    }

    function renderToolInterface() {
      const config = getCurrentToolConfig();
      const fields = config.fields || [];
      let html = '';

      if (config.uiType === 'magic-redesign') html = renderMagicRedesignPanel(config);
      else if (config.uiType === 'redesign') html = renderRedesignPanel(config, fields);
      else if (config.uiType === 'mask') html = renderMaskPanel(config, fields);
      else if (config.uiType === 'material-swap') html = renderMaterialSwapPanel(config);
      else if (config.uiType === 'country') html = renderCountryPanel();
      else if (config.uiType === 'weather') html = renderWeatherPanel();
      else if (config.uiType === 'reference') html = renderReferencePanel();
      else if (config.uiType === 'texture') html = renderTexturePanel(config);
      else if (config.uiType === 'video') html = renderVideoPanel();
      else if (config.uiType === 'critique') html = renderCritiquePanel();
      else if (config.uiType === 'text') html = renderTextPanel(config);
      else if (config.uiType === 'advisor') html = renderAdvisorPanel(config);
      else if (config.uiType === 'object-position') html = renderObjectPositionPanel();
      else if (config.uiType === 'room-composer') html = renderRoomComposerPanel();
      else html = renderSingleActionPanel(config);

      toolInterface.innerHTML = html;
      wireToolInterface();
      if (window.lucide) lucide.createIcons();
    }

    function updateToolOptions() {
      const config = getCurrentToolConfig();
      const fields = config.fields || [];
      const activeModeConfig = currentToolKey() === 'redesign' ? getRedesignModeConfig() : null;
      const isMaterialSwap = !!config.materialSwap;
      const showMaterialStepOptions = !isMaterialSwap || materialSwapReady;

      spaceTypeGroup.hidden = !(fields.includes('design_type') || fields.includes('image_type'));
      designContextGrid.hidden = !(fields.includes('room_type') || fields.includes('design_style'));
      instructionsGroup.hidden = !(fields.includes('prompt') || fields.includes('custom_instruction') || fields.includes('custom_message'));
      spaceTypeGroup.querySelector('label').textContent = fields.includes('image_type')
        ? 'Select image type'
        : 'Select what kind of space you are generating';
      instructionsLabel.textContent = config.promptLabel || 'Additional Instructions';
      instructionsInput.placeholder = config.promptPlaceholder || 'Describe colors, mood, materials, furniture, or anything the AI should respect.';

      noDesignRow.hidden = !config.noDesignMax || (isMaterialSwap && !showMaterialStepOptions);
      interventionRow.hidden = !config.aiIntervention;
      strengthRow.hidden = !config.strength;
      weatherRow.hidden = !fields.includes('weather');
      countryRow.hidden = !fields.includes('country');
      paintColorRow.hidden = !fields.includes('rgb_color');
      materialRow.hidden = !fields.includes('materials');
      surfaceColorRow.hidden = !fields.includes('color');
      objectRow.hidden = !fields.includes('object');
      labelsRow.hidden = !fields.includes('labels');
      videoMotionRow.hidden = !config.videoMotion;
      materialPresetRow.hidden = !(config.materialPreset && showMaterialStepOptions);
      materialInstructionRow.hidden = !(config.materialInstruction && showMaterialStepOptions);
      textureGridRow.hidden = !(config.textureGrid && showMaterialStepOptions);
      textureUploadRow.hidden = !(config.textureUpload && showMaterialStepOptions);
      styleReferenceRow.hidden = !config.styleReference;
      const textureOptions = config.textureOptions || [];
      [...textureGridSelect.options].forEach((option) => {
        option.hidden = textureOptions.length > 0 && !textureOptions.includes(option.value);
      });
      if (textureOptions.length > 0 && !textureOptions.includes(textureGridSelect.value)) {
        textureGridSelect.value = textureOptions[textureOptions.length - 1];
      }
      updateMaterialTypeOptions();

      const maxDesign = activeModeConfig?.noDesignMax || config.noDesignMax || 1;
      const minDesign = config.noDesignMin || 1;
      [...noDesignSelect.options].forEach((option) => {
        const optionValue = parseInt(option.value, 10);
        option.hidden = optionValue > maxDesign || optionValue < minDesign;
      });
      if (parseInt(noDesignSelect.value, 10) > maxDesign) noDesignSelect.value = String(maxDesign);
      if (parseInt(noDesignSelect.value, 10) < minDesign) noDesignSelect.value = String(minDesign);

      const optionRows = [
        noDesignRow, interventionRow, strengthRow, weatherRow, countryRow,
        paintColorRow, materialRow, materialTypeRow, surfaceColorRow, objectRow, labelsRow, videoMotionRow,
        materialPresetRow, materialInstructionRow, textureGridRow, textureUploadRow, styleReferenceRow
      ];
      const hasVisibleOptions = optionRows.some((row) => !row.hidden);
      advancedOptions.hidden = true;
      if (!hasVisibleOptions) {
        advancedToggle.setAttribute('aria-expanded', 'false');
        toolOptionsPanel.classList.add('collapsed');
      }
      generateBtn.querySelector('span').textContent = config.submitLabel || (config.videoMotion ? 'Generate Video' : 'Generate Design');
      renderToolInterface();
      updateGenerateButtonState();
    }

    function setStatus(message, type) {
      studioStatus.textContent = message || '';
      studioStatus.className = 'studio-status' + (type ? ` ${type}` : '');
