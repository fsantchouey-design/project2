<%
  const studioProjectData = typeof studioProject !== 'undefined' && studioProject ? {
    id: String(studioProject._id),
    title: studioProject.title || '',
    description: studioProject.description || '',
    roomType: studioProject.roomType || '',
    style: studioProject.style || '',
    instructions: studioProject.requirements || studioProject.description || '',
    imageUrl: (studioProject.originalImages && studioProject.originalImages[0] && studioProject.originalImages[0].url)
      || (studioProject.designVariants && studioProject.designVariants[0] && (studioProject.designVariants[0].imageUrl || studioProject.designVariants[0].thumbnailUrl))
      || '',
    originalImageUrl: (studioProject.originalImages && studioProject.originalImages[0] && studioProject.originalImages[0].url) || '',
    latestDesigns: (function() {
      const variants = (studioProject.designVariants || []).slice().reverse().map(function(variant) {
        return {
          id: variant._id ? String(variant._id) : '',
          name: variant.name || variant.tool || 'Generated design',
          imageUrl: variant.imageUrl || variant.thumbnailUrl || '',
          thumbnailUrl: variant.thumbnailUrl || variant.imageUrl || '',
          tool: variant.tool || '',
          generatedAt: variant.generatedAt || variant.createdAt || null,
          isOriginal: false
        };
      }).filter(function(d) { return d.imageUrl; });
      const origUrl = (studioProject.originalImages && studioProject.originalImages[0] && studioProject.originalImages[0].url) || '';
      if (origUrl) {
        variants.push({
          id: 'original',
          name: 'Image originale',
          imageUrl: origUrl,
          thumbnailUrl: origUrl,
          tool: '',
          generatedAt: (studioProject.originalImages[0].uploadedAt) || null,
          isOriginal: true
        });
      }
      return variants;
    })()
  } : null;
