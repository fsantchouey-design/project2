<div class="ai-studio-page">
  <header class="studio-topbar">
    <div>
      <a href="/projects" class="studio-back">
        <i data-lucide="arrow-left"></i>
        Back to Projects
      </a>
      <h1>AI Design Studio</h1>
    </div>
    <button type="button" class="studio-secondary-btn" id="replace-image-btn">
      <i data-lucide="upload"></i>
      Upload New
    </button>
  </header>

  <div class="studio-shell">
    <aside class="tool-rail">
      <button type="button" class="tool-menu-toggle" id="tool-menu-toggle" aria-expanded="true">
        <span>
          <span class="tool-kicker">Standard Tools</span>
          <strong id="selected-tool-label">Perfect Redesign</strong>
        </span>
        <i data-lucide="chevron-down"></i>
      </button>

      <div class="tool-menu" id="tool-menu">
        <button type="button" class="tool-option active" data-tool-name="Perfect Redesign" data-endpoint="/api/v2/perfect_redesign">
          <i data-lucide="gem"></i>
          <span>Perfect Redesign</span>
        </button>
        <button type="button" class="tool-option" data-tool-name="Beautiful Redesign" data-endpoint="/api/v2/beautiful_redesign">
          <i data-lucide="sparkles"></i>
          <span>Beautiful Redesign</span>
        </button>
        <button type="button" class="tool-option" data-tool-name="Magic Redesign" data-endpoint="/api/v2/magic_redesign">
          <i data-lucide="zap"></i>
          <span>Magic Redesign</span>
        </button>
        <button type="button" class="tool-option" data-tool-name="Video Generation" data-endpoint="/api/v2/video_generation">
          <i data-lucide="video"></i>
          <span>Video Generation</span>
        </button>
        <button type="button" class="tool-option" data-tool-name="Creative Redesign" data-endpoint="/api/v2/creative_redesign">
          <i data-lucide="wand-2"></i>
          <span>Creative Redesign</span>
        </button>
        <button type="button" class="tool-option" data-tool-name="Sketch To Render" data-endpoint="/api/v2/sketch_to_render">
          <i data-lucide="pencil-ruler"></i>
          <span>Sketch To Render</span>
        </button>
        <button type="button" class="tool-option" data-tool-name="Virtual Staging" data-endpoint="/api/v2/virtual_staging">
          <i data-lucide="sofa"></i>
          <span>Virtual Staging</span>
        </button>
        <button type="button" class="tool-option" data-tool-name="Precision" data-endpoint="/api/v2/precision">
          <i data-lucide="target"></i>
          <span>Precision</span>
        </button>
        <button type="button" class="tool-option" data-tool-name="Fill Spaces" data-endpoint="/api/v2/fill_spaces">
          <i data-lucide="layout-grid"></i>
          <span>Fill Spaces</span>
        </button>
        <button type="button" class="tool-option" data-tool-name="Decor Staging" data-endpoint="/api/v2/decor_staging">
          <i data-lucide="lamp"></i>
          <span>Decor Staging</span>
        </button>
        <button type="button" class="tool-option" data-tool-name="Furniture Removal" data-endpoint="/api/v2/furniture_removal">
          <i data-lucide="eraser"></i>
          <span>Furniture Removal</span>
        </button>
        <button type="button" class="tool-option" data-tool-name="Change Color Textures" data-endpoint="/api/v2/change_color_textures">
          <i data-lucide="palette"></i>
          <span>Change Color Textures</span>
        </button>
        <button type="button" class="tool-option" data-tool-name="Furniture Finder" data-endpoint="/api/v2/furniture_finder">
          <i data-lucide="shopping-bag"></i>
          <span>Furniture Finder</span>
        </button>
        <button type="button" class="tool-option" data-tool-name="Full HD" data-endpoint="/api/v2/full_hd">
          <i data-lucide="monitor"></i>
          <span>Full HD</span>
        </button>
        <button type="button" class="tool-option" data-tool-name="Text To Design" data-endpoint="/api/v2/text_to_design">
          <i data-lucide="type"></i>
          <span>Text To Design</span>
        </button>
        <button type="button" class="tool-option" data-tool-name="Furniture Creator" data-endpoint="/api/v2/furniture_creator">
          <i data-lucide="armchair"></i>
          <span>Furniture Creator</span>
        </button>
        <button type="button" class="tool-option" data-tool-name="Design Advisor" data-endpoint="/api/v2/design_advisor">
          <i data-lucide="messages-square"></i>
          <span>Design Advisor</span>
        </button>
        <button type="button" class="tool-option" data-tool-name="Sky Colors" data-endpoint="/api/v2/sky_colors">
          <i data-lucide="cloud-sun"></i>
          <span>Sky Colors</span>
        </button>
        <button type="button" class="tool-option" data-tool-name="Design Transfer" data-endpoint="/api/v2/design_transfer">
          <i data-lucide="copy-plus"></i>
          <span>Design Transfer</span>
        </button>
        <button type="button" class="tool-option" data-tool-name="Floor Editor" data-endpoint="/api/v2/floor_editor">
          <i data-lucide="panel-bottom"></i>
          <span>Floor Editor</span>
        </button>
        <button type="button" class="tool-option" data-tool-name="Paint Visualizer" data-endpoint="/api/v2/paint_visualizer">
          <i data-lucide="paintbrush"></i>
          <span>Paint Visualizer</span>
        </button>
        <button type="button" class="tool-option" data-tool-name="Material Swap" data-endpoint="/api/v2/material_swap">
          <i data-lucide="swatch-book"></i>
          <span>Material Swap</span>
        </button>
        <button type="button" class="tool-option" data-tool-name="Room Composer" data-endpoint="/api/v2/room_composer">
          <i data-lucide="blocks"></i>
          <span>Room Composer</span>
        </button>
        <button type="button" class="tool-option" data-tool-name="Design Critique" data-endpoint="/api/v2/design_critique">
          <i data-lucide="search-check"></i>
          <span>Design Critique</span>
        </button>
        <button type="button" class="tool-option" data-tool-name="Create Mask Image" data-endpoint="/api/v2/create_maskimage">
          <i data-lucide="scan-line"></i>
          <span>Create Mask Image</span>
        </button>
        <button type="button" class="tool-option" data-tool-name="Smart Home" data-endpoint="/api/v2/smart_home">
          <i data-lucide="house-plug"></i>
          <span>Smart Home</span>
        </button>
      </div>
    </aside>

    <main class="preview-stage">
      <input type="file" id="design-image" accept="image/*" hidden>

      <label for="design-image" class="upload-canvas" id="upload-canvas">
        <img id="source-preview" class="source-preview" alt="Uploaded room preview" hidden>
        <div class="upload-placeholder" id="upload-placeholder">
          <span class="upload-icon"><i data-lucide="image-up"></i></span>
          <strong>Drop your room photo here</strong>
          <span>or click to upload a JPG, PNG, or WebP image</span>
        </div>
        <button type="button" class="image-action" id="change-image-btn" hidden>
          <i data-lucide="refresh-cw"></i>
          Change
        </button>
      </label>

      <section class="result-panel" id="result-panel" hidden>
        <div class="result-heading">
          <span>Generated Result</span>
          <strong id="result-tool-name">Perfect Redesign</strong>
        </div>
        <div class="result-media" id="result-media"></div>
      </section>
    </main>

    <aside class="config-panel">
      <div class="selected-tool-card">
        <span>Selected AI Tool</span>
        <strong id="config-tool-name">Perfect Redesign</strong>
        <small id="config-endpoint">/api/v2/perfect_redesign</small>
      </div>

      <div class="config-group">
        <label>Select what kind of space you are generating</label>
        <div class="segmented-control" data-input="designType">
          <button type="button" class="segment active" data-value="Interior">
            <i data-lucide="sofa"></i>
            Interior
          </button>
          <button type="button" class="segment" data-value="Exterior">
            <i data-lucide="home"></i>
            Exterior
          </button>
          <button type="button" class="segment" data-value="Garden">
            <i data-lucide="flower-2"></i>
            Garden
          </button>
        </div>
      </div>

      <div class="config-grid">
        <div class="config-group">
          <label for="room-type">Room Type</label>
          <select id="room-type" class="studio-select">
            <% if (typeof roomTypes !== 'undefined') { %>
              <% roomTypes.forEach(room => { %>
                <option value="<%= room.id %>" <%= room.id === 'living-room' ? 'selected' : '' %>><%= room.name %></option>
              <% }) %>
            <% } %>
          </select>
        </div>

        <div class="config-group">
          <label for="design-style">Design Style</label>
          <select id="design-style" class="studio-select">
            <% if (typeof styles !== 'undefined') { %>
              <% styles.forEach(style => { %>
                <option value="<%= style.id %>" <%= style.id === 'modern' ? 'selected' : '' %>><%= style.name %></option>
              <% }) %>
            <% } %>
            <option value="luxury">Luxury</option>
          </select>
        </div>
      </div>

      <div class="config-group">
        <label for="additional-instructions">Additional Instructions</label>
        <textarea id="additional-instructions" class="studio-textarea" rows="5" placeholder="Describe colors, mood, materials, furniture, or anything the AI should respect."></textarea>
      </div>

      <button type="button" class="generate-btn" id="generate-btn">
        <i data-lucide="sparkles"></i>
        <span>Generate Design</span>
      </button>

      <div class="studio-status" id="studio-status" aria-live="polite"></div>
    </aside>
  </div>
</div>

<style>
  .ai-studio-page {
    min-height: calc(100vh - 48px);
    padding: 20px;
    color: var(--text-primary);
  }

  .studio-topbar {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 18px;
  }

  .studio-back {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 8px;
    color: var(--text-muted);
    font-size: 14px;
    font-weight: 600;
  }

  .studio-back:hover {
    color: var(--accent-primary);
  }

  .studio-back i {
    width: 17px;
    height: 17px;
  }

  .studio-topbar h1 {
    margin: 0;
    font-size: 30px;
    letter-spacing: 0;
  }

  .studio-secondary-btn,
  .image-action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    min-height: 42px;
    padding: 0 14px;
    border: 1px solid var(--border-color);
    border-radius: 8px;
    background: var(--bg-card);
    color: var(--text-primary);
    font-weight: 700;
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s, color 0.2s;
  }

  .studio-secondary-btn:hover,
  .image-action:hover {
    border-color: rgba(16, 185, 129, 0.45);
    background: rgba(16, 185, 129, 0.08);
    color: var(--accent-primary);
  }

  .studio-secondary-btn i,
  .image-action i {
    width: 18px;
    height: 18px;
  }

  .studio-shell {
    display: grid;
    grid-template-columns: 240px minmax(360px, 1fr) minmax(320px, 420px);
    gap: 18px;
    align-items: start;
  }

  .tool-rail,
  .config-panel {
    position: sticky;
    top: 20px;
    border: 1px solid var(--border-color);
    border-radius: 8px;
    background: var(--bg-card);
    box-shadow: 0 18px 60px rgba(15, 23, 42, 0.08);
  }

  .tool-rail {
    overflow: hidden;
  }

  .tool-menu-toggle {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 15px;
    border: 0;
    border-bottom: 1px solid var(--border-color);
    background: linear-gradient(135deg, rgba(16, 185, 129, 0.12), rgba(14, 165, 233, 0.08));
    color: var(--text-primary);
    text-align: left;
    cursor: pointer;
  }

  .tool-kicker {
    display: block;
    margin-bottom: 5px;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .tool-menu-toggle strong {
    display: block;
    font-size: 15px;
  }

  .tool-menu-toggle i {
    width: 18px;
    height: 18px;
    transition: transform 0.2s;
  }

  .tool-menu-toggle.collapsed i {
    transform: rotate(-90deg);
  }

  .tool-menu {
    max-height: 66vh;
    overflow-y: auto;
    padding: 8px;
  }

  .tool-menu.collapsed {
    display: none;
  }

  .tool-option {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px;
    border: 1px solid transparent;
    border-radius: 8px;
    background: transparent;
    color: var(--text-secondary);
    font-weight: 700;
    text-align: left;
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s, color 0.2s;
  }

  .tool-option:hover {
    background: var(--bg-tertiary);
    color: var(--text-primary);
  }

  .tool-option.active {
    border-color: rgba(16, 185, 129, 0.45);
    background: rgba(16, 185, 129, 0.12);
    color: var(--accent-primary);
  }

  .tool-option i {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }

  .preview-stage {
    min-height: 76vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 18px;
    padding: 24px;
    border: 1px solid var(--border-color);
    border-radius: 8px;
    background:
      radial-gradient(circle at top left, rgba(16, 185, 129, 0.08), transparent 34%),
      var(--bg-secondary);
  }

  .upload-canvas {
    position: relative;
    width: min(100%, 520px);
    aspect-ratio: 9 / 16;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 28px;
    border: 2px dashed rgba(16, 185, 129, 0.4);
    border-radius: 8px;
    background: var(--bg-card);
    color: var(--text-muted);
    text-align: center;
    cursor: pointer;
    overflow: hidden;
    transition: border-color 0.2s, background 0.2s, transform 0.2s;
  }

  .upload-canvas [hidden] {
    display: none !important;
  }

  .upload-canvas:hover,
  .upload-canvas.dragover {
    border-color: var(--accent-primary);
    background: rgba(16, 185, 129, 0.08);
    transform: translateY(-1px);
  }

  .upload-canvas.has-image {
    padding: 0;
    border-style: solid;
    border-color: rgba(16, 185, 129, 0.55);
    background: #0f172a;
    box-shadow: 0 24px 90px rgba(15, 23, 42, 0.24);
  }

  .upload-canvas strong {
    color: var(--text-primary);
    font-size: 20px;
  }

  .upload-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
  }

  .upload-icon {
    width: 62px;
    height: 62px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    background: rgba(16, 185, 129, 0.12);
    color: var(--accent-primary);
  }

  .upload-icon i {
    width: 30px;
    height: 30px;
  }

  .source-preview {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: center;
  }

  .image-action {
    position: absolute;
    top: 14px;
    right: 14px;
    min-height: 38px;
    background: rgba(15, 23, 42, 0.74);
    border-color: rgba(255, 255, 255, 0.16);
    color: #fff;
    backdrop-filter: blur(10px);
  }

  .result-panel {
    width: min(100%, 540px);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    background: var(--bg-card);
    overflow: hidden;
  }

  .result-heading {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 14px 16px;
    border-bottom: 1px solid var(--border-color);
    color: var(--text-muted);
    font-size: 13px;
  }

  .result-heading strong {
    color: var(--accent-primary);
  }

  .result-media img,
  .result-media video {
    width: 100%;
    display: block;
  }

  .result-text {
    padding: 18px;
    color: var(--text-primary);
    line-height: 1.6;
    white-space: pre-wrap;
  }

  .config-panel {
    display: flex;
    flex-direction: column;
    gap: 18px;
    padding: 18px;
  }

  .selected-tool-card {
    display: flex;
    flex-direction: column;
    gap: 5px;
    padding: 15px;
    border: 1px solid rgba(16, 185, 129, 0.25);
    border-radius: 8px;
    background: linear-gradient(135deg, rgba(16, 185, 129, 0.12), rgba(14, 165, 233, 0.08));
  }

  .selected-tool-card span,
  .selected-tool-card small {
    color: var(--text-muted);
    font-size: 12px;
    font-weight: 700;
  }

  .selected-tool-card strong {
    font-size: 20px;
  }

  .config-group {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .config-group label {
    color: var(--text-primary);
    font-size: 14px;
    font-weight: 800;
  }

  .segmented-control {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 8px;
  }

  .segment {
    min-height: 54px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 7px;
    border: 1px solid var(--border-color);
    border-radius: 8px;
    background: var(--bg-secondary);
    color: var(--text-secondary);
    font-weight: 800;
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s, color 0.2s;
  }

  .segment.active {
    border-color: rgba(16, 185, 129, 0.55);
    background: linear-gradient(135deg, rgba(16, 185, 129, 0.95), rgba(14, 165, 233, 0.8));
    color: #052e2b;
  }

  .segment i {
    width: 17px;
    height: 17px;
  }

  .config-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .studio-select,
  .studio-textarea {
    width: 100%;
    border: 1px solid var(--border-color);
    border-radius: 8px;
    background: var(--bg-secondary);
    color: var(--text-primary);
    font: inherit;
    font-weight: 600;
  }

  .studio-select {
    min-height: 44px;
    padding: 0 12px;
  }

  .studio-textarea {
    resize: vertical;
    min-height: 120px;
    padding: 12px;
    line-height: 1.5;
  }

  .generate-btn {
    min-height: 54px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    border: 0;
    border-radius: 8px;
    background: linear-gradient(135deg, #10b981, #0ea5e9);
    color: #041316;
    font-weight: 900;
    cursor: pointer;
    box-shadow: 0 16px 34px rgba(16, 185, 129, 0.24);
    transition: transform 0.2s, opacity 0.2s;
  }

  .generate-btn:hover {
    transform: translateY(-1px);
  }

  .generate-btn:disabled {
    cursor: not-allowed;
    opacity: 0.65;
    transform: none;
  }

  .generate-btn i {
    width: 19px;
    height: 19px;
  }

  .studio-status {
    min-height: 22px;
    font-size: 13px;
    font-weight: 700;
    color: var(--text-muted);
  }

  .studio-status.error {
    color: #ef4444;
  }

  .studio-status.success {
    color: var(--accent-primary);
  }

  @media (max-width: 1180px) {
    .studio-shell {
      grid-template-columns: 220px minmax(320px, 1fr);
    }

    .config-panel {
      position: static;
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 820px) {
    .ai-studio-page {
      padding: 14px;
    }

    .studio-topbar {
      flex-direction: column;
    }

    .studio-shell {
      grid-template-columns: 1fr;
    }

    .tool-rail {
      position: static;
    }

    .preview-stage {
      min-height: auto;
      padding: 16px;
    }

    .upload-canvas {
      width: min(100%, 360px);
    }

    .config-grid,
    .segmented-control {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  (() => {
    const imageInput = document.getElementById('design-image');
    const replaceImageBtn = document.getElementById('replace-image-btn');
    const uploadCanvas = document.getElementById('upload-canvas');
    const uploadPlaceholder = document.getElementById('upload-placeholder');
    const sourcePreview = document.getElementById('source-preview');
    const changeImageBtn = document.getElementById('change-image-btn');
    const toolMenuToggle = document.getElementById('tool-menu-toggle');
    const toolMenu = document.getElementById('tool-menu');
    const selectedToolLabel = document.getElementById('selected-tool-label');
    const configToolName = document.getElementById('config-tool-name');
    const configEndpoint = document.getElementById('config-endpoint');
    const generateBtn = document.getElementById('generate-btn');
    const studioStatus = document.getElementById('studio-status');
    const resultPanel = document.getElementById('result-panel');
    const resultMedia = document.getElementById('result-media');
    const resultToolName = document.getElementById('result-tool-name');

    let selectedFile = null;
    let selectedEndpoint = '/api/v2/perfect_redesign';
    let selectedToolName = 'Perfect Redesign';
    let designType = 'Interior';

    function setStatus(message, type) {
      studioStatus.textContent = message || '';
      studioStatus.className = 'studio-status' + (type ? ` ${type}` : '');
    }

    function setImage(file) {
      if (!file) return;
      selectedFile = file;
      const reader = new FileReader();
      reader.onload = (event) => {
        sourcePreview.src = event.target.result;
        sourcePreview.hidden = false;
        uploadPlaceholder.hidden = true;
        changeImageBtn.hidden = false;
        uploadCanvas.classList.add('has-image');
        resultPanel.hidden = true;
        resultMedia.innerHTML = '';
        setStatus('');
      };
      reader.readAsDataURL(file);
    }

    imageInput.addEventListener('change', () => {
      setImage(imageInput.files && imageInput.files[0]);
    });

    replaceImageBtn.addEventListener('click', () => imageInput.click());
    changeImageBtn.addEventListener('click', (event) => {
      event.preventDefault();
      event.stopPropagation();
      imageInput.click();
    });

    ['dragenter', 'dragover', 'dragleave', 'drop'].forEach((eventName) => {
      uploadCanvas.addEventListener(eventName, (event) => {
        event.preventDefault();
        event.stopPropagation();
      });
    });

    ['dragenter', 'dragover'].forEach((eventName) => {
      uploadCanvas.addEventListener(eventName, () => uploadCanvas.classList.add('dragover'));
    });

    ['dragleave', 'drop'].forEach((eventName) => {
      uploadCanvas.addEventListener(eventName, () => uploadCanvas.classList.remove('dragover'));
    });

    uploadCanvas.addEventListener('drop', (event) => {
      const file = event.dataTransfer.files && event.dataTransfer.files[0];
      setImage(file);
    });

    toolMenuToggle.addEventListener('click', () => {
      const collapsed = toolMenu.classList.toggle('collapsed');
      toolMenuToggle.classList.toggle('collapsed', collapsed);
      toolMenuToggle.setAttribute('aria-expanded', String(!collapsed));
    });

    document.querySelectorAll('.tool-option').forEach((button) => {
      button.addEventListener('click', () => {
        document.querySelectorAll('.tool-option').forEach((item) => item.classList.remove('active'));
        button.classList.add('active');
        selectedEndpoint = button.dataset.endpoint;
        selectedToolName = button.dataset.toolName;
        selectedToolLabel.textContent = selectedToolName;
        configToolName.textContent = selectedToolName;
        configEndpoint.textContent = selectedEndpoint;
        resultToolName.textContent = selectedToolName;
        setStatus('');
      });
    });

    document.querySelectorAll('.segmented-control .segment').forEach((button) => {
      button.addEventListener('click', () => {
        document.querySelectorAll('.segmented-control .segment').forEach((item) => item.classList.remove('active'));
        button.classList.add('active');
        designType = button.dataset.value;
      });
    });

    function renderResult(data) {
      resultToolName.textContent = data.tool || selectedToolName;
      resultMedia.innerHTML = '';

      const firstDesign = data.designs && data.designs[0];
      const imageUrl = firstDesign && firstDesign.imageUrl ? firstDesign.imageUrl : data.imageUrl;

      if (data.videoUrl) {
        resultMedia.innerHTML = `<video src="${data.videoUrl}" controls playsinline></video>`;
      } else if (imageUrl) {
        resultMedia.innerHTML = `<img src="${imageUrl}" alt="${data.tool || selectedToolName} result">`;
      } else if (data.textResult) {
        const text = document.createElement('div');
        text.className = 'result-text';
        text.textContent = data.textResult;
        resultMedia.appendChild(text);
      } else if (data.resultArray) {
        const text = document.createElement('div');
        text.className = 'result-text';
        text.textContent = JSON.stringify(data.resultArray, null, 2);
        resultMedia.appendChild(text);
      } else {
        const text = document.createElement('div');
        text.className = 'result-text';
        text.textContent = 'Generation completed, but no preview was returned.';
        resultMedia.appendChild(text);
      }

      resultPanel.hidden = false;
    }

    async function handleGenerateDesign() {
      if (!selectedFile) {
        setStatus('Upload an image before generating a design.', 'error');
        return;
      }

      const formData = new FormData();
      formData.append('image', selectedFile);
      formData.append('designType', designType);
      formData.append('roomType', document.getElementById('room-type').value);
      formData.append('style', document.getElementById('design-style').value);
      formData.append('prompt', document.getElementById('additional-instructions').value);

      generateBtn.disabled = true;
      generateBtn.querySelector('span').textContent = 'Generating...';
      setStatus(`Calling ${selectedEndpoint}...`);

      try {
        const response = await fetch(selectedEndpoint, {
          method: 'POST',
          body: formData
        });
        const data = await response.json();

        if (!response.ok || !data.success) {
          throw new Error(data.error || 'Design generation failed.');
        }

        renderResult(data);
        setStatus('Design generated successfully.', 'success');
      } catch (error) {
        setStatus(error.message, 'error');
      } finally {
        generateBtn.disabled = false;
        generateBtn.querySelector('span').textContent = 'Generate Design';
      }
    }

    generateBtn.addEventListener('click', handleGenerateDesign);
    window.handleGenerateDesign = handleGenerateDesign;

    if (typeof lucide !== 'undefined') {
      lucide.createIcons();
    }
  })();
</script>
