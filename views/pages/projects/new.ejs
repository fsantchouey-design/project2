      uploadCanvas.style.setProperty('--decor-rotation', `${decorTransform.rotation}deg`);
      uploadCanvas.style.setProperty('--decor-scale-x', `${decorTransform.scaleX * decorTransform.scale}`);
      uploadCanvas.style.setProperty('--decor-scale-y', `${decorTransform.scaleY * decorTransform.scale}`);
    }

