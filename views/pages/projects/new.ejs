<div class="page-container">
  <div class="page-header">
    <a href="/projects" class="back-link">
      <i data-lucide="arrow-left"></i>
      Back to Projects
    </a>
    <h1>Create New Project</h1>
    <p class="text-muted">Describe your renovation project and let AI create stunning designs</p>
  </div>
  
  <form action="/projects" method="POST" enctype="multipart/form-data" class="project-form">
    <!-- Step 1: Basic Info -->
    <div class="form-section">
      <h2><span class="step-num">1</span> Project Details</h2>
      
      <div class="form-group">
        <label class="form-label">Project Title *</label>
        <input type="text" name="title" class="form-input" placeholder="e.g., Modern Kitchen Renovation" required>
      </div>
      
      <div class="form-group">
        <label class="form-label">Description *</label>
        <textarea name="description" class="form-textarea" rows="4" placeholder="Describe your vision for this space..." required maxlength="1000"></textarea>
        <p class="form-hint">Be as detailed as possible - mention colors, styles, materials, and any specific requirements</p>
      </div>
      
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Room Type *</label>
          <select name="roomType" class="form-select" required>
            <option value="">Select room type</option>
            <% if (typeof roomTypes !== 'undefined') { %>
              <% roomTypes.forEach(room => { %>
                <option value="<%= room.id %>"><%= room.name %></option>
              <% }) %>
            <% } %>
          </select>
        </div>
        
        <div class="form-group">
          <label class="form-label">Design Style</label>
          <select name="style" class="form-select">
            <option value="">Let AI decide</option>
            <% if (typeof styles !== 'undefined') { %>
              <% styles.forEach(style => { %>
                <option value="<%= style.id %>"><%= style.name %></option>
              <% }) %>
            <% } %>
          </select>
        </div>
      </div>
    </div>
    
    <!-- Step 2: Photos -->
    <div class="form-section">
      <h2><span class="step-num">2</span> Photos de votre espace</h2>
      <p class="section-desc">Uploadez les photos de votre espace actuel — l'IA les utilisera pour créer vos designs</p>

      <!-- Input fichier caché -->
      <input type="file" name="images" id="images" multiple accept="image/*" style="display:none">

      <!-- Zone de dépôt (visible tant qu'aucune image n'est sélectionnée) -->
      <div class="upload-dropzone" id="upload-dropzone">
        <label for="images" class="upload-dropzone-label">
          <i data-lucide="upload-cloud"></i>
          <span>Déposez vos photos ici ou <u>cliquez pour parcourir</u></span>
          <span class="upload-hint">Max 5 images · 10 Mo chacune · JPG, PNG, WebP</span>
        </label>
      </div>

      <!-- Prévisualisation portrait 9:16 (cachée au départ) -->
      <div class="portrait-preview-wrap" id="portrait-preview-wrap">
        <div class="portrait-preview-box" id="portrait-preview-box">
          <img id="portrait-main-img" src="" alt="Aperçu principal">
          <!-- Bouton X pour supprimer / changer l'image -->
          <button type="button" class="portrait-remove-btn" id="portrait-remove-btn" title="Supprimer">
            <i data-lucide="x"></i>
          </button>
          <!-- Clic sur l'image pour changer -->
          <label for="images" class="portrait-change-overlay" title="Changer l'image">
            <i data-lucide="camera"></i>
            <span>Changer</span>
          </label>
        </div>

        <!-- Miniatures des images supplémentaires + bouton d'ajout -->
        <div class="portrait-thumbs" id="portrait-thumbs">
          <label for="images" class="portrait-add-btn" title="Ajouter une image">
            <i data-lucide="plus"></i>
          </label>
        </div>
      </div>
    </div>
    
    <!-- Step 3: Budget -->
    <div class="form-section">
      <h2><span class="step-num">3</span> Budget (Optional)</h2>
      
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Minimum Budget (€)</label>
          <input type="number" name="budgetMin" class="form-input" placeholder="5000" min="0">
        </div>
        
        <div class="form-group">
          <label class="form-label">Maximum Budget (€)</label>
          <input type="number" name="budgetMax" class="form-input" placeholder="15000" min="0">
        </div>
      </div>
    </div>
    
    <!-- Step 4: Dimensions -->
    <div class="form-section">
      <h2><span class="step-num">4</span> Room Dimensions (Optional)</h2>
      
      <div class="form-row-3">
        <div class="form-group">
          <label class="form-label">Length (m)</label>
          <input type="number" name="length" class="form-input" placeholder="4.5" step="0.1" min="0">
        </div>
        
        <div class="form-group">
          <label class="form-label">Width (m)</label>
          <input type="number" name="width" class="form-input" placeholder="3.5" step="0.1" min="0">
        </div>
        
        <div class="form-group">
          <label class="form-label">Height (m)</label>
          <input type="number" name="height" class="form-input" placeholder="2.7" step="0.1" min="0">
        </div>
      </div>
    </div>
    
    <!-- Step 5: Preferences -->
    <div class="form-section">
      <h2><span class="step-num">5</span> Preferences (Optional)</h2>
      
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Preferred Colors</label>
          <input type="text" name="colors" class="form-input" placeholder="White, Gray, Wood tones">
          <p class="form-hint">Separate with commas</p>
        </div>
        
        <div class="form-group">
          <label class="form-label">Preferred Materials</label>
          <input type="text" name="materials" class="form-input" placeholder="Marble, Oak, Brass">
          <p class="form-hint">Separate with commas</p>
        </div>
      </div>
      
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Must Have</label>
          <input type="text" name="mustHave" class="form-input" placeholder="Island, Pendant lights">
          <p class="form-hint">Essential elements for your design</p>
        </div>
        
        <div class="form-group">
          <label class="form-label">Must Avoid</label>
          <input type="text" name="mustAvoid" class="form-input" placeholder="Carpet, Dark colors">
          <p class="form-hint">Elements you don't want</p>
        </div>
      </div>
    </div>
    
    <!-- Step 6: Priorities -->
    <div class="form-section">
      <h2><span class="step-num">6</span> Priorities</h2>
      
      <div class="priority-sliders">
        <div class="priority-item">
          <label>Quality</label>
          <input type="range" name="priorityQuality" min="1" max="5" value="3" class="priority-slider">
          <span class="priority-labels"><span>Budget</span><span>Premium</span></span>
        </div>
        
        <div class="priority-item">
          <label>Price Focus</label>
          <input type="range" name="priorityPrice" min="1" max="5" value="3" class="priority-slider">
          <span class="priority-labels"><span>Flexible</span><span>Strict</span></span>
        </div>
        
        <div class="priority-item">
          <label>Timeline</label>
          <input type="range" name="prioritySpeed" min="1" max="5" value="3" class="priority-slider">
          <span class="priority-labels"><span>Relaxed</span><span>Urgent</span></span>
        </div>
      </div>
    </div>
    
    <!-- DIY Option -->
    <div class="form-section">
      <div class="diy-option">
        <input type="checkbox" name="isDIY" id="isDIY">
        <label for="isDIY">
          <div class="diy-icon"><i data-lucide="hammer"></i></div>
          <div>
            <strong>DIY Project</strong>
            <p>I plan to do this myself without hiring a contractor</p>
          </div>
        </label>
      </div>
    </div>
    
    <!-- Submit -->
    <div class="form-actions">
      <a href="/projects" class="btn btn-ghost">Cancel</a>
      <button type="submit" class="btn btn-primary btn-lg">
        <i data-lucide="sparkles"></i>
        Create Project
      </button>
    </div>
  </form>
</div>

<style>
  .page-container {
    max-width: 800px;
    margin: 0 auto;
    padding: var(--spacing-xl);
  }
  
  .page-header {
    margin-bottom: var(--spacing-2xl);
  }
  
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-xs);
    color: var(--text-muted);
    font-size: 0.9rem;
    margin-bottom: var(--spacing-md);
    transition: color var(--transition-fast);
  }
  
  .back-link:hover {
    color: var(--text-primary);
  }
  
  .back-link i {
    width: 16px;
    height: 16px;
  }
  
  .page-header h1 {
    font-size: 2rem;
    margin-bottom: var(--spacing-sm);
  }
  
  .text-muted {
    color: var(--text-muted);
  }
  
  .project-form {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xl);
  }
  
  .form-section {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: var(--spacing-xl);
  }
  
  .form-section h2 {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    font-size: 1.25rem;
    margin-bottom: var(--spacing-lg);
  }
  
  .step-num {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--accent-gradient);
    border-radius: 50%;
    font-size: 0.9rem;
    font-weight: 700;
    color: #000;
  }
  
  .section-desc {
    color: var(--text-muted);
    margin-bottom: var(--spacing-lg);
    margin-top: calc(-1 * var(--spacing-sm));
  }
  
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-lg);
  }
  
  .form-row-3 {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: var(--spacing-lg);
  }
  
  /* Upload Dropzone */
  .upload-dropzone {
    border: 2px dashed var(--border-color);
    border-radius: var(--radius-lg);
    transition: border-color var(--transition-base), background var(--transition-base);
    cursor: pointer;
  }

  .upload-dropzone:hover,
  .upload-dropzone.dragover {
    border-color: var(--accent-primary);
    background: rgba(0, 255, 136, 0.04);
  }

  .upload-dropzone-label {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-md);
    padding: var(--spacing-3xl);
    text-align: center;
    cursor: pointer;
  }

  .upload-dropzone-label i {
    width: 48px;
    height: 48px;
    color: var(--text-muted);
  }

  .upload-hint {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  /* Portrait 9:16 preview */
  .portrait-preview-wrap {
    display: none;
    gap: var(--spacing-lg);
    align-items: flex-start;
  }

  .portrait-preview-wrap.visible {
    display: flex;
  }

  .portrait-preview-box {
    position: relative;
    width: 220px;
    flex-shrink: 0;
    aspect-ratio: 9 / 16;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 2px solid var(--border-color);
    background: var(--bg-secondary);
  }

  .portrait-preview-box img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .portrait-remove-btn {
    position: absolute;
    top: 8px;
    right: 8px;
    width: 28px;
    height: 28px;
    background: rgba(0,0,0,0.65);
    border: none;
    border-radius: 50%;
    color: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    transition: background var(--transition-fast);
  }

  .portrait-remove-btn:hover {
    background: rgba(220,38,38,0.85);
  }

  .portrait-remove-btn i {
    width: 14px;
    height: 14px;
  }

  .portrait-change-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(transparent, rgba(0,0,0,0.6));
    color: #fff;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    gap: 4px;
    padding: 14px 8px 10px;
    cursor: pointer;
    opacity: 0;
    transition: opacity var(--transition-fast);
    font-size: 0.8rem;
    font-weight: 500;
  }

  .portrait-preview-box:hover .portrait-change-overlay {
    opacity: 1;
  }

  .portrait-change-overlay i {
    width: 18px;
    height: 18px;
  }

  /* Thumbnail strip */
  .portrait-thumbs {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
    padding-top: 4px;
  }

  .portrait-thumb {
    position: relative;
    width: 72px;
    aspect-ratio: 9 / 16;
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 2px solid var(--border-color);
    cursor: pointer;
    transition: border-color var(--transition-fast);
  }

  .portrait-thumb.active {
    border-color: var(--accent-primary);
  }

  .portrait-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .portrait-thumb-remove {
    position: absolute;
    top: 3px;
    right: 3px;
    width: 18px;
    height: 18px;
    background: rgba(0,0,0,0.65);
    border: none;
    border-radius: 50%;
    color: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity var(--transition-fast);
  }

  .portrait-thumb:hover .portrait-thumb-remove {
    opacity: 1;
  }

  .portrait-thumb-remove i {
    width: 10px;
    height: 10px;
  }

  .portrait-add-btn {
    width: 72px;
    aspect-ratio: 9 / 16;
    border-radius: var(--radius-md);
    border: 2px dashed var(--border-color);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--text-muted);
    transition: border-color var(--transition-fast), color var(--transition-fast);
  }

  .portrait-add-btn:hover {
    border-color: var(--accent-primary);
    color: var(--accent-primary);
  }

  .portrait-add-btn i {
    width: 20px;
    height: 20px;
  }
  
  /* Priority Sliders */
  .priority-sliders {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xl);
  }
  
  .priority-item label {
    display: block;
    font-weight: 500;
    margin-bottom: var(--spacing-sm);
  }
  
  .priority-slider {
    width: 100%;
    height: 8px;
    background: var(--bg-secondary);
    border-radius: var(--radius-full);
    outline: none;
    -webkit-appearance: none;
  }
  
  .priority-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 20px;
    height: 20px;
    background: var(--accent-gradient);
    border-radius: 50%;
    cursor: pointer;
  }
  
  .priority-labels {
    display: flex;
    justify-content: space-between;
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-top: var(--spacing-xs);
  }
  
  /* DIY Option */
  .diy-option {
    display: flex;
    align-items: center;
    gap: var(--spacing-lg);
  }
  
  .diy-option input[type="checkbox"] {
    display: none;
  }
  
  .diy-option label {
    display: flex;
    align-items: center;
    gap: var(--spacing-lg);
    padding: var(--spacing-lg);
    background: var(--bg-secondary);
    border: 2px solid var(--border-color);
    border-radius: var(--radius-lg);
    cursor: pointer;
    transition: all var(--transition-base);
    flex: 1;
  }
  
  .diy-option input:checked + label {
    border-color: var(--accent-primary);
    background: rgba(0, 255, 136, 0.05);
  }
  
  .diy-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-tertiary);
    border-radius: var(--radius-md);
    color: var(--text-muted);
    transition: all var(--transition-base);
  }
  
  .diy-option input:checked + label .diy-icon {
    background: var(--accent-gradient);
    color: #000;
  }
  
  .diy-option strong {
    display: block;
    margin-bottom: var(--spacing-xs);
  }
  
  .diy-option p {
    font-size: 0.85rem;
    color: var(--text-muted);
  }
  
  /* Form Actions */
  .form-actions {
    display: flex;
    justify-content: flex-end;
    gap: var(--spacing-md);
    padding-top: var(--spacing-lg);
  }
  
  @media (max-width: 768px) {
    .form-row,
    .form-row-3 {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  (() => {
    const fileInput     = document.getElementById('images');
    const dropzone      = document.getElementById('upload-dropzone');
    const previewWrap   = document.getElementById('portrait-preview-wrap');
    const mainImg       = document.getElementById('portrait-main-img');
    const removeBtn     = document.getElementById('portrait-remove-btn');
    const thumbsWrap    = document.getElementById('portrait-thumbs');

    // Internal file list (FileList is read-only, so we manage our own array)
    let selectedFiles = [];
    let activeIndex   = 0;

    /* ── helpers ── */
    function syncInputFiles() {
      const dt = new DataTransfer();
      selectedFiles.forEach(f => dt.items.add(f));
      fileInput.files = dt.files;
    }

    function readAsDataURL(file) {
      return new Promise(resolve => {
        const r = new FileReader();
        r.onload = e => resolve(e.target.result);
        r.readAsDataURL(file);
      });
    }

    function showDropzone() {
      dropzone.style.display = '';
      previewWrap.classList.remove('visible');
      mainImg.src = '';
    }

    async function renderPreview() {
      if (selectedFiles.length === 0) { showDropzone(); return; }

      dropzone.style.display = 'none';
      previewWrap.classList.add('visible');

      // Main image
      mainImg.src = await readAsDataURL(selectedFiles[activeIndex]);

      // Rebuild thumbnail strip (keep add button last)
      thumbsWrap.innerHTML = '';

      for (let i = 0; i < selectedFiles.length; i++) {
        const url   = await readAsDataURL(selectedFiles[i]);
        const thumb = document.createElement('div');
        thumb.className = 'portrait-thumb' + (i === activeIndex ? ' active' : '');
        thumb.innerHTML = `
          <img src="${url}" alt="Photo ${i + 1}">
          <button type="button" class="portrait-thumb-remove" data-idx="${i}" title="Supprimer">
            <i data-lucide="x"></i>
          </button>
        `;
        thumb.addEventListener('click', (e) => {
          if (e.target.closest('.portrait-thumb-remove')) return;
          activeIndex = i;
          renderPreview();
        });
        thumbsWrap.appendChild(thumb);
      }

      // Add-more button
      const addBtn = document.createElement('label');
      addBtn.setAttribute('for', 'images');
      addBtn.className = 'portrait-add-btn';
      addBtn.title = 'Ajouter une image';
      addBtn.innerHTML = '<i data-lucide="plus"></i>';
      thumbsWrap.appendChild(addBtn);

      // Bind remove buttons on thumbnails
      thumbsWrap.querySelectorAll('.portrait-thumb-remove').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          const idx = parseInt(btn.dataset.idx, 10);
          removeFile(idx);
        });
      });

      lucide.createIcons();
    }

    function addFiles(newFiles) {
      Array.from(newFiles).forEach(file => {
        if (file.size > 10 * 1024 * 1024) {
          alert(`${file.name} dépasse 10 Mo et ne sera pas ajouté.`);
          return;
        }
        if (selectedFiles.length >= 5) {
          alert('Maximum 5 images autorisées.');
          return;
        }
        selectedFiles.push(file);
      });
      if (selectedFiles.length > 0) activeIndex = 0;
      syncInputFiles();
      renderPreview();
    }

    function removeFile(idx) {
      selectedFiles.splice(idx, 1);
      if (activeIndex >= selectedFiles.length) activeIndex = Math.max(0, selectedFiles.length - 1);
      syncInputFiles();
      renderPreview();
    }

    /* ── file input change ── */
    fileInput.addEventListener('change', function () {
      if (this.files.length === 0) return;
      // Replace all when user picks via "Changer" overlay; append otherwise
      if (selectedFiles.length === 0) {
        addFiles(this.files);
      } else {
        // Merge: add new ones up to limit
        addFiles(this.files);
      }
      // Reset input so same file can be re-selected
      this.value = '';
    });

    /* ── remove main image button ── */
    removeBtn.addEventListener('click', () => {
      removeFile(activeIndex);
    });

    /* ── drag & drop on dropzone ── */
    ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(evt =>
      dropzone.addEventListener(evt, e => { e.preventDefault(); e.stopPropagation(); }, false)
    );
    dropzone.addEventListener('dragenter', () => dropzone.classList.add('dragover'));
    dropzone.addEventListener('dragover',  () => dropzone.classList.add('dragover'));
    dropzone.addEventListener('dragleave', () => dropzone.classList.remove('dragover'));
    dropzone.addEventListener('drop', (e) => {
      dropzone.classList.remove('dragover');
      addFiles(e.dataTransfer.files);
    });
  })();
</script>

