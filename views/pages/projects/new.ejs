      return TOOL_CONFIG[currentToolKey()] || {};
    }

    function getRedesignModeConfig(mode = selectedRedesignMode) {
      return (TOOL_CONFIG.redesign?.modeTools || []).find((item) => item.value === mode);
    }

    function setRedesignMode(mode, render = true) {
      const modeConfig = getRedesignModeConfig(mode) || getRedesignModeConfig('perfect_redesign');
      if (!modeConfig) return;
      selectedRedesignMode = modeConfig.value;
      selectedEndpoint = modeConfig.endpoint;
      configEndpoint.textContent = selectedEndpoint;
      if (render) updateToolOptions();
    }

    function isMaterialSwapTool() {
      return currentToolKey() === 'material_swap';
    }

