    function applyLightboxTransform() {
      lightboxImage.style.setProperty('--zoom', lightboxZoom);
      lightboxImage.style.setProperty('--pan-x', `${panX}px`);
      lightboxImage.style.setProperty('--pan-y', `${panY}px`);
      lightboxContent.classList.toggle('zoomed', lightboxZoom > 1);
    }

    function resetLightboxZoom() {
      lightboxZoom = 1;
      panX = 0;
      panY = 0;
      applyLightboxTransform();
    }

    function openLightboxWithSrc(src) {
      if (!src) return;
      lightboxImage.src = src;
      resetLightboxZoom();
      imageLightbox.hidden = false;
      document.body.style.overflow = 'hidden';
      requestAnimationFrame(() => imageLightbox.classList.add('open'));
    }

    function openLightbox() {
      if (!sourcePreview.src || sourcePreview.hidden) return;
      openLightboxWithSrc(sourcePreview.src);
    }

    function closeLightbox() {
      imageLightbox.classList.remove('open');
      document.body.style.overflow = '';
      setTimeout(() => {
        imageLightbox.hidden = true;
        lightboxImage.removeAttribute('src');
        resetLightboxZoom();
      }, 180);
    }

    function getCanvasPoint(event) {
      const rect = maskCanvas.getBoundingClientRect();
      return {
        x: (event.clientX - rect.left) * (maskCanvas.width / rect.width),
        y: (event.clientY - rect.top) * (maskCanvas.height / rect.height)
      };
    }

    function makeObjectSelection(point) {
      // TODO: Replace this local pixel-connected selection with API-backed object segmentation when available.
      const pixelSelection = makePixelConnectedSelection(point);
      if (pixelSelection) return pixelSelection;
      return makePreviewSelection(point);
    }

    function makePreviewSelection(point) {
      const radiusX = Math.max(maskCanvas.width * 0.11, 70);
      const radiusY = Math.max(maskCanvas.height * 0.09, 70);
      return {
        type: 'ellipse',
        x: point.x / maskCanvas.width,
        y: point.y / maskCanvas.height,
        rx: radiusX / maskCanvas.width,
        ry: radiusY / maskCanvas.height
      };
    }

    function makePixelConnectedSelection(point) {
      if (!sourcePreview.complete || !sourcePreview.naturalWidth || !maskCanvas.width || !maskCanvas.height) return null;

      try {
        const width = maskCanvas.width;
        const height = maskCanvas.height;
        const sampleCanvas = document.createElement('canvas');
        sampleCanvas.width = width;
        sampleCanvas.height = height;
        const sampleCtx = sampleCanvas.getContext('2d', { willReadFrequently: true });
        drawImageCover(sampleCtx, sourcePreview, width, height);
        const pixels = sampleCtx.getImageData(0, 0, width, height).data;
        const startX = Math.max(0, Math.min(width - 1, Math.round(point.x)));
        const startY = Math.max(0, Math.min(height - 1, Math.round(point.y)));
        const startIndex = (startY * width + startX) * 4;
        const seed = [pixels[startIndex], pixels[startIndex + 1], pixels[startIndex + 2]];
        const tolerance = 42;
        const visited = new Uint8Array(width * height);
        const selected = new Uint8Array(width * height);
        const stack = [startY * width + startX];
        let selectedCount = 0;
        const maxPixels = Math.floor(width * height * 0.32);

        while (stack.length) {
          const index = stack.pop();
          if (visited[index]) continue;
          visited[index] = 1;

          const offset = index * 4;
          const distance =
            Math.abs(pixels[offset] - seed[0]) +
            Math.abs(pixels[offset + 1] - seed[1]) +
            Math.abs(pixels[offset + 2] - seed[2]);

          if (distance > tolerance) continue;

          selected[index] = 1;
          selectedCount += 1;
          if (selectedCount > maxPixels) return null;

          const x = index % width;
          const y = Math.floor(index / width);
          if (x > 0) stack.push(index - 1);
          if (x < width - 1) stack.push(index + 1);
          if (y > 0) stack.push(index - width);
          if (y < height - 1) stack.push(index + width);
        }

        if (selectedCount < 140) return null;

        const selectionCanvas = document.createElement('canvas');
        selectionCanvas.width = width;
        selectionCanvas.height = height;
        const selectionCtx = selectionCanvas.getContext('2d');
        const output = selectionCtx.createImageData(width, height);
        for (let i = 0; i < selected.length; i += 1) {
          if (!selected[i]) continue;
          const offset = i * 4;
          output.data[offset] = 16;
          output.data[offset + 1] = 185;
          output.data[offset + 2] = 129;
          output.data[offset + 3] = 150;
        }
        selectionCtx.putImageData(output, 0, 0);

        return {
          type: 'bitmap',
          canvas: selectionCanvas,
          ctx: selectionCtx,
          width,
          height
        };
      } catch (error) {
        return null;
      }
    }

    function drawImageCover(ctx, image, width, height) {
      const imageRatio = image.naturalWidth / image.naturalHeight;
      const canvasRatio = width / height;
      let sourceWidth = image.naturalWidth;
      let sourceHeight = image.naturalHeight;
      let sourceX = 0;
      let sourceY = 0;

      if (imageRatio > canvasRatio) {
        sourceWidth = image.naturalHeight * canvasRatio;
        sourceX = (image.naturalWidth - sourceWidth) / 2;
      } else {
        sourceHeight = image.naturalWidth / canvasRatio;
        sourceY = (image.naturalHeight - sourceHeight) / 2;
      }

      ctx.drawImage(image, sourceX, sourceY, sourceWidth, sourceHeight, 0, 0, width, height);
    }

    function selectionToCanvas(selection) {
      return {
        x: selection.x * maskCanvas.width,
        y: selection.y * maskCanvas.height,
        rx: selection.rx * maskCanvas.width,
        ry: selection.ry * maskCanvas.height
      };
    }

    function findSelectionAtPoint(point) {
      return clickSelections.findIndex((selection) => {
        if (selection.type === 'bitmap' && selection.ctx) {
          const x = Math.max(0, Math.min(selection.width - 1, Math.round(point.x)));
          const y = Math.max(0, Math.min(selection.height - 1, Math.round(point.y)));
          return selection.ctx.getImageData(x, y, 1, 1).data[3] > 0;
        }
        const area = selectionToCanvas(selection);
        const dx = (point.x - area.x) / area.rx;
        const dy = (point.y - area.y) / area.ry;
        return dx * dx + dy * dy <= 1;
      });
    }

    function drawSelectionShape(ctx, selection, options = {}) {
      if (selection.type === 'bitmap' && selection.canvas) {
        ctx.drawImage(selection.canvas, 0, 0, maskCanvas.width, maskCanvas.height);
        return;
      }

      const area = selectionToCanvas(selection);
      ctx.save();
      ctx.beginPath();
      ctx.ellipse(area.x, area.y, area.rx, area.ry, 0, 0, Math.PI * 2);
      ctx.fillStyle = options.preview ? 'rgba(16, 185, 129, 0.22)' : 'rgba(16, 185, 129, 0.55)';
      ctx.strokeStyle = options.preview ? 'rgba(59, 130, 246, 0.8)' : 'rgba(16, 185, 129, 0.95)';
      ctx.lineWidth = options.preview ? 2 : 3;
      ctx.fill();
      ctx.stroke();
      ctx.restore();
    }

    function renderMaskOverlay() {
      if (!maskCanvas.width || !maskCanvas.height) return;
      maskCtx.clearRect(0, 0, maskCanvas.width, maskCanvas.height);
      clickSelections.forEach((selection) => drawSelectionShape(maskCtx, selection));
      if (brushCanvas.width && brushCanvas.height) {
        maskCtx.drawImage(brushCanvas, 0, 0);
      }
      if (hoverSelection && selectionMode === 'click') {
        drawSelectionShape(maskCtx, hoverSelection, { preview: true });
      }
      hasMaskPaint = clickSelections.length > 0 || hasManualBrushPaint;
      if (isMaterialSwapTool()) updateMaterialSelectionLabel();
    }

    function resetMaskCanvas() {
      if (!maskCanvas.width || !maskCanvas.height) return;
      maskCtx.clearRect(0, 0, maskCanvas.width, maskCanvas.height);
      if (brushCanvas.width && brushCanvas.height) {
        brushCtx.clearRect(0, 0, brushCanvas.width, brushCanvas.height);
      }
      clickSelections = [];
      hoverSelection = null;
      hasMaskPaint = false;
      hasManualBrushPaint = false;
      materialSwapReady = false;
      if (isMaterialSwapTool()) updateMaterialSelectionLabel();
    }

    function sizeMaskCanvas() {
      const rect = uploadCanvas.getBoundingClientRect();
      const nextWidth = Math.max(1, Math.round(rect.width));
      const nextHeight = Math.max(1, Math.round(rect.height));
      if (maskCanvas.width === nextWidth && maskCanvas.height === nextHeight) return;
      maskCanvas.width = nextWidth;
      maskCanvas.height = nextHeight;
      brushCanvas.width = nextWidth;
      brushCanvas.height = nextHeight;
      resetMaskCanvas();
    }

    function updateMaskControls() {
      const config = getCurrentToolConfig();
      const needsMask = !!config.mask;
      selectedRequiresMask = needsMask;
      maskToolsPanel.hidden = !needsMask;
      materialSwapTabs.hidden = !config.materialSwap;
      imageZoomControls.hidden = !config.materialSwap || sourcePreview.hidden;
      maskCanvas.hidden = !needsMask || sourcePreview.hidden;
      uploadCanvas.classList.toggle('mask-mode', needsMask && !sourcePreview.hidden);
      maskToolTitle.textContent = `${selectedToolName} selection`;
      maskToolHelp.textContent = config.maskHelp || 'Brush over the area this tool should affect.';
      if (needsMask && !sourcePreview.hidden) sizeMaskCanvas();
      maskCanvas.classList.toggle('click-mode', selectionMode === 'click');
      if (config.materialSwap && !sourcePreview.hidden) updateMaterialSelectionLabel();

      const brushOnlyTools = ['furniture_removal', 'change_color_textures'];
      const brushOnly = brushOnlyTools.includes(currentToolKey());
      const selModeGroup = document.querySelector('.selection-mode-group');
      if (selModeGroup) selModeGroup.hidden = brushOnly;
      if (brushOnly && needsMask) setSelectionMode('brush');
    }

    function setMaskMode(mode) {
      maskMode = mode;
      maskBrushBtn.classList.toggle('active', mode === 'brush');
      maskEraserBtn.classList.toggle('active', mode === 'eraser');
    }

    function setSelectionMode(mode) {
      selectionMode = mode;
      clickSelectionBtn.classList.toggle('active', mode === 'click');
      brushSelectionBtn.classList.toggle('active', mode === 'brush');
      maskCanvas.classList.toggle('click-mode', mode === 'click');
      hoverSelection = null;
      renderMaskOverlay();
    }

    function toggleClickSelection(event) {
      const point = getCanvasPoint(event);
      const existingIndex = findSelectionAtPoint(point);
      if (existingIndex >= 0) {
        clickSelections.splice(existingIndex, 1);
      } else {
        clickSelections.push(makeObjectSelection(point));
      }
      hoverSelection = null;
      if (isMaterialSwapTool()) materialSwapReady = false;
      renderMaskOverlay();
      if (isMaterialSwapTool()) updateToolOptions();
    }

    function eraseClickSelections(point, radius) {
      clickSelections = clickSelections.filter((selection) => {
        if (selection.type !== 'bitmap' || !selection.ctx) {
          const area = selectionToCanvas(selection);
          const dx = (point.x - area.x) / (area.rx + radius);
          const dy = (point.y - area.y) / (area.ry + radius);
          return dx * dx + dy * dy > 1;
        }
        selection.ctx.save();
        selection.ctx.globalCompositeOperation = 'destination-out';
        selection.ctx.beginPath();
        selection.ctx.arc(point.x, point.y, radius, 0, Math.PI * 2);
        selection.ctx.fill();
        selection.ctx.restore();
        return true;
      });
    }

    function drawMaskStroke(event) {
      const point = getCanvasPoint(event);
      const radius = parseInt(maskBrushSize.value, 10) / 2;
      brushCtx.save();
      brushCtx.globalCompositeOperation = maskMode === 'eraser' ? 'destination-out' : 'source-over';
      brushCtx.fillStyle = 'rgba(16, 185, 129, 0.58)';
      brushCtx.beginPath();
      brushCtx.arc(point.x, point.y, radius, 0, Math.PI * 2);
      brushCtx.fill();
      brushCtx.restore();
      if (maskMode === 'eraser') eraseClickSelections(point, radius);
      if (maskMode === 'brush') hasManualBrushPaint = true;
      if (isMaterialSwapTool()) materialSwapReady = false;
      renderMaskOverlay();
      if (isMaterialSwapTool()) updateToolOptions();
    }

    function getMaskBase64() {
      if (!selectedRequiresMask || !hasMaskPaint) return '';

      // Scale mask to match the natural image dimensions, minimum 512×512,
      // so the API never receives a mask smaller than the required threshold.
      const natW = (sourcePreview && sourcePreview.naturalWidth) || maskCanvas.width;
      const natH = (sourcePreview && sourcePreview.naturalHeight) || maskCanvas.height;
      // Mirror ensureMinImageSize: Cloudinary pads both dims to 512×512 if either is < 512.
      // Proportional scaling would produce different dims than the server image — causing API rejection.
      const outW = (natW >= 512 && natH >= 512) ? natW : 512;
      const outH = (natW >= 512 && natH >= 512) ? natH : 512;

      const scaledCanvas = document.createElement('canvas');
      scaledCanvas.width = outW;
      scaledCanvas.height = outH;
      const scaledCtx = scaledCanvas.getContext('2d');
      scaledCtx.drawImage(maskCanvas, 0, 0, outW, outH);

      const exportCanvas = document.createElement('canvas');
      exportCanvas.width = outW;
      exportCanvas.height = outH;
      const exportCtx = exportCanvas.getContext('2d');
      const sourceData = scaledCtx.getImageData(0, 0, outW, outH);
      const outputData = exportCtx.createImageData(outW, outH);
      let hasSelectedPixels = false;

      for (let i = 0; i < sourceData.data.length; i += 4) {
        const alpha = sourceData.data[i + 3];
        if (alpha > 0) hasSelectedPixels = true;
        outputData.data[i] = alpha > 0 ? 255 : 0;
        outputData.data[i + 1] = alpha > 0 ? 255 : 0;
        outputData.data[i + 2] = alpha > 0 ? 255 : 0;
        outputData.data[i + 3] = 255;
      }

      if (!hasSelectedPixels) return '';
      exportCtx.putImageData(outputData, 0, 0);
      return exportCanvas.toDataURL('image/png');
    }

  function hasSourceImage() {
    return Boolean(selectedFile || projectSourceImageUrl || (!sourcePreview.hidden && sourcePreview.src));
  }

  function isSupportedImageFile(file) {
    if (!file) return false;
    if (ACCEPTED_IMAGE_TYPES.includes(file.type)) return true;
    const extension = (file.name || '').split('.').pop()?.toLowerCase();
    return ACCEPTED_IMAGE_EXTENSIONS.includes(extension);
  }

  function applyPreviewOrientation(imageElement) {
    const isLandscape = imageElement.naturalWidth >= imageElement.naturalHeight;
    uploadCanvas.classList.toggle('is-landscape', isLandscape);
    uploadCanvas.classList.toggle('is-portrait', !isLandscape);
  }

  function updateGenerateButtonState() {
    const currentConfig = getCurrentToolConfig();
    const requiresImage = !currentConfig.imageOptional;
    generateBtn.disabled = isGenerating || (requiresImage && !hasSourceImage());
  }

  function setPreviewFromUrl(url, options = {}) {
    if (!url) return;
    selectedFile = null;
    projectSourceImageUrl = url;
    sourcePreview.onload = () => {
      applyPreviewOrientation(sourcePreview);
      sizeMaskCanvas();
      updateMaskControls();
      updateGenerateButtonState();
    };
    sourcePreview.onerror = () => {
      setStatus('Unable to load the project image preview.', 'error');
      updateGenerateButtonState();
    };
    sourcePreview.src = url;
    sourcePreview.hidden = false;
    uploadPlaceholder.hidden = true;
    changeImageBtn.hidden = false;
    uploadCanvas.classList.add('has-image');
    resetMaskCanvas();
    resetPreviewTransform();
    updateMaskControls();
    if (!options.keepResult) {
      resultPanel.hidden = true;
      resultMedia.innerHTML = '';
    }
    updateGenerateButtonState();
  }

  function renderLatestDesigns() {
    if (!latestDesignsGrid || !latestDesignsEmpty || !latestDesignsCount) return;
    const visibleDesigns = latestDesigns.filter((design) => design.imageUrl || design.thumbnailUrl);
    const aiCount = visibleDesigns.filter((d) => !d.isOriginal).length;
    latestDesignsCount.textContent = `${aiCount} ${aiCount === 1 ? 'design' : 'designs'}`;
    latestDesignsGrid.innerHTML = visibleDesigns.map((design, index) => `
      <button type="button" class="latest-design-card${design.isOriginal ? ' is-original' : ''}" data-design-index="${index}">
        <img src="${design.thumbnailUrl || design.imageUrl}" alt="${design.name || 'Generated design'}">
        ${design.isOriginal ? '<div class="latest-design-badge">Original</div>' : ''}
        <span>${design.name || design.tool || 'Generated design'}</span>
      </button>
    `).join('');
    latestDesignsEmpty.classList.toggle('is-visible', visibleDesigns.length === 0);
  }

  function addLatestDesignsFromResponse(data) {
    const incoming = data.savedDesigns || data.designs || [];
    if (!incoming.length) return;
    const normalized = incoming
      .map((design) => ({
        id: design.id || `${Date.now()}-${Math.random()}`,
        name: design.name || selectedToolName,
        imageUrl: design.imageUrl || design.url || '',
        thumbnailUrl: design.thumbnailUrl || design.imageUrl || design.url || '',
        tool: design.tool || selectedToolName,
        generatedAt: design.generatedAt || new Date().toISOString(),
        isOriginal: false
      }))
      .filter((design) => design.imageUrl || design.thumbnailUrl);
    // Keep the original image entry at the end; prepend new AI designs before it
    const originalEntry = latestDesigns.find((d) => d.isOriginal);
    const existing = latestDesigns.filter((d) => !d.isOriginal);
    latestDesigns = [...normalized, ...existing];
    if (originalEntry) latestDesigns.push(originalEntry);
    renderLatestDesigns();
  }

  function preloadStudioProject() {
    if (!STUDIO_PROJECT) {
      renderLatestDesigns();
      return;
    }
    if (STUDIO_PROJECT.imageUrl) {
      setPreviewFromUrl(STUDIO_PROJECT.imageUrl, { keepResult: true });
    }
    const roomTypeSelect = document.getElementById('room-type');
    const styleSelect = document.getElementById('design-style');
    const instructionsInput = document.getElementById('additional-instructions');
    if (roomTypeSelect && STUDIO_PROJECT.roomType) roomTypeSelect.value = STUDIO_PROJECT.roomType;
    if (styleSelect && STUDIO_PROJECT.style) styleSelect.value = STUDIO_PROJECT.style;
    if (instructionsInput && STUDIO_PROJECT.instructions) instructionsInput.value = STUDIO_PROJECT.instructions;
    renderLatestDesigns();
  }

  latestDesignsGrid?.addEventListener('click', (event) => {
    const card = event.target.closest('.latest-design-card');
    if (!card) return;
    const design = latestDesigns[Number(card.dataset.designIndex)];
    const previewUrl = design?.imageUrl || design?.thumbnailUrl;
    if (previewUrl) {
      setPreviewFromUrl(previewUrl);
      setStatus(design?.isOriginal ? 'Image originale chargée.' : 'Design chargé dans l\'aperçu.', 'success');
    }
  });

  function setImage(file) {
    if (!file) return;
    if (!isSupportedImageFile(file)) {
      setStatus('Please upload a JPG, PNG, or WebP image.', 'error');
      imageInput.value = '';
      updateGenerateButtonState();
      return;
    }
    selectedFile = file;
    projectSourceImageUrl = '';
    const reader = new FileReader();
      reader.onload = (event) => {
        sourcePreview.onload = () => {
          applyPreviewOrientation(sourcePreview);
          sizeMaskCanvas();
          updateMaskControls();
          updateGenerateButtonState();
        };
        sourcePreview.onerror = () => {
          setStatus('Unable to preview this image. Please try another JPG, PNG, or WebP file.', 'error');
          updateGenerateButtonState();
        };
        sourcePreview.src = event.target.result;
        sourcePreview.hidden = false;
        uploadPlaceholder.hidden = true;
        changeImageBtn.hidden = false;
        uploadCanvas.classList.add('has-image');
        resetMaskCanvas();
        resetPreviewTransform();
        resetDecorTransform();
        updateMaskControls();
        resultPanel.hidden = true;
        resultMedia.innerHTML = '';
        setStatus('Image ready.', 'success');
        updateGenerateButtonState();
      };
      reader.onerror = () => {
        setStatus('Unable to read this image. Please try another file.', 'error');
        updateGenerateButtonState();
      };
      reader.readAsDataURL(file);
    }

    imageInput.addEventListener('change', () => {
      setImage(imageInput.files && imageInput.files[0]);
      imageInput.value = '';
    });

    materialTextureImage.addEventListener('change', () => {
      selectedTextureFile = materialTextureImage.files && materialTextureImage.files[0];
      if (!selectedTextureFile) return;
      textureUploadLabel.textContent = selectedTextureFile.name;
      const reader = new FileReader();
      reader.onload = (event) => {
        texturePreview.src = event.target.result;
        texturePreview.hidden = false;
      };
      reader.readAsDataURL(selectedTextureFile);
    });

    styleReferenceImage.addEventListener('change', () => {
      selectedStyleReferenceFile = styleReferenceImage.files && styleReferenceImage.files[0];
      if (!selectedStyleReferenceFile) return;
      styleReferenceUploadLabel.textContent = selectedStyleReferenceFile.name;
      const reader = new FileReader();
      reader.onload = (event) => {
        styleReferencePreview.src = event.target.result;
        styleReferencePreview.hidden = false;
      };
      reader.readAsDataURL(selectedStyleReferenceFile);
    });

    replaceImageBtn.addEventListener('click', () => imageInput.click());
    textureUploadBtn.addEventListener('click', () => materialTextureImage.click());
    styleReferenceUploadBtn.addEventListener('click', () => styleReferenceImage.click());
    sourcePreview.addEventListener('click', (event) => {
      event.preventDefault();
      event.stopPropagation();
      if (selectedRequiresMask) return;
      openLightbox();
    });

    changeImageBtn.addEventListener('click', (event) => {
      event.preventDefault();
      event.stopPropagation();
      imageInput.click();
    });

    uploadPlaceholder.addEventListener('click', () => {
      imageInput.click();
    });

    maskBrushBtn.addEventListener('click', () => setMaskMode('brush'));
    maskEraserBtn.addEventListener('click', () => setMaskMode('eraser'));
    clickSelectionBtn.addEventListener('click', () => setSelectionMode('click'));
    brushSelectionBtn.addEventListener('click', () => setSelectionMode('brush'));
    materialAutoTab.addEventListener('click', () => setMaterialSwapTab('automatic'));
    materialManualTab.addEventListener('click', () => setMaterialSwapTab('manual'));
    materialContinueBtn.addEventListener('click', () => {
      if (!hasMaskPaint) {
        setStatus('Select an object or draw a mask before continuing.', 'error');
        return;
      }
      materialSwapReady = true;
      updateToolOptions();
      setStatus('Selection ready. Choose a material, then generate.', 'success');
    });
    imageZoomRange.addEventListener('input', () => {
      previewZoom = parseFloat(imageZoomRange.value);
      if (previewZoom <= 1) {
        previewPanX = 0;
        previewPanY = 0;
      }
      applyPreviewTransform();
    });
    imagePanToggle.addEventListener('click', () => {
      previewPanMode = previewZoom > 1 && !previewPanMode;
      imagePanToggle.classList.toggle('active', previewPanMode);
      setStatus(previewPanMode ? 'Drag the image to reposition it.' : '');
    });
    maskBrushSize.addEventListener('input', () => {
      maskBrushSizeValue.textContent = maskBrushSize.value;
    });
    strengthRange.addEventListener('input', () => {
      strengthValue.textContent = strengthRange.value;
    });
    materialSelect.addEventListener('change', updateMaterialTypeOptions);
    maskClearBtn.addEventListener('click', resetMaskCanvas);
    advancedToggle.addEventListener('click', () => {
      const expanded = advancedToggle.getAttribute('aria-expanded') === 'true';
      advancedToggle.setAttribute('aria-expanded', String(!expanded));
      toolOptionsPanel.classList.toggle('collapsed', expanded);
    });

    maskCanvas.addEventListener('pointerdown', (event) => {
      if (!selectedRequiresMask) return;
      event.preventDefault();
      event.stopPropagation();
      sizeMaskCanvas();
      if (previewPanMode && previewZoom > 1) {
        previewPanStart = {
          pointerId: event.pointerId,
          startX: event.clientX,
          startY: event.clientY,
          panX: previewPanX,
          panY: previewPanY
        };
        maskCanvas.setPointerCapture(event.pointerId);
        return;
      }
      if (selectionMode === 'click') {
        toggleClickSelection(event);
        return;
      }
      isMaskDrawing = true;
      maskCanvas.setPointerCapture(event.pointerId);
      drawMaskStroke(event);
    });

    maskCanvas.addEventListener('pointermove', (event) => {
      if (previewPanStart) {
        event.preventDefault();
        event.stopPropagation();
        previewPanX = previewPanStart.panX + event.clientX - previewPanStart.startX;
        previewPanY = previewPanStart.panY + event.clientY - previewPanStart.startY;
        applyPreviewTransform();
        return;
      }
      if (selectedRequiresMask && selectionMode === 'click') {
        event.preventDefault();
        event.stopPropagation();
        hoverSelection = makePreviewSelection(getCanvasPoint(event));
        renderMaskOverlay();
        return;
      }
      if (!isMaskDrawing) return;
      event.preventDefault();
      event.stopPropagation();
      drawMaskStroke(event);
    });

    maskCanvas.addEventListener('pointerleave', () => {
      if (selectionMode !== 'click') return;
      hoverSelection = null;
      renderMaskOverlay();
    });

    maskCanvas.addEventListener('pointerup', (event) => {
      previewPanStart = null;
      isMaskDrawing = false;
      try {
        maskCanvas.releasePointerCapture(event.pointerId);
      } catch (error) {}
    });

    maskCanvas.addEventListener('pointercancel', () => {
      previewPanStart = null;
      isMaskDrawing = false;
    });

    lightboxClose.addEventListener('click', closeLightbox);

    imageLightbox.addEventListener('click', (event) => {
      if (event.target === imageLightbox || event.target === lightboxContent) {
        closeLightbox();
      }
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && !imageLightbox.hidden) {
        closeLightbox();
      }
    });

    lightboxContent.addEventListener('dblclick', () => {
      if (lightboxZoom > 1) {
        resetLightboxZoom();
      } else {
        lightboxZoom = 2.25;
        applyLightboxTransform();
      }
    });

    lightboxContent.addEventListener('wheel', (event) => {
      if (imageLightbox.hidden) return;
      event.preventDefault();
      const nextZoom = lightboxZoom + (event.deltaY < 0 ? 0.18 : -0.18);
      lightboxZoom = Math.min(3.5, Math.max(1, nextZoom));
      if (lightboxZoom === 1) {
        panX = 0;
        panY = 0;
      }
      applyLightboxTransform();
    }, { passive: false });

    lightboxContent.addEventListener('pointerdown', (event) => {
      if (lightboxZoom <= 1) return;
      dragStart = {
        pointerId: event.pointerId,
        startX: event.clientX,
        startY: event.clientY,
        panX,
        panY
      };
      lightboxContent.setPointerCapture(event.pointerId);
      lightboxContent.classList.add('dragging');
    });

    lightboxContent.addEventListener('pointermove', (event) => {
      if (!dragStart) return;
      panX = dragStart.panX + event.clientX - dragStart.startX;
      panY = dragStart.panY + event.clientY - dragStart.startY;
      applyLightboxTransform();
    });

    lightboxContent.addEventListener('pointerup', () => {
      dragStart = null;
      lightboxContent.classList.remove('dragging');
    });

    lightboxContent.addEventListener('pointercancel', () => {
      dragStart = null;
      lightboxContent.classList.remove('dragging');
    });

    ['dragenter', 'dragover', 'dragleave', 'drop'].forEach((eventName) => {
      uploadCanvas.addEventListener(eventName, (event) => {
        event.preventDefault();
        event.stopPropagation();
      });
    });

    ['dragenter', 'dragover'].forEach((eventName) => {
      uploadCanvas.addEventListener(eventName, () => uploadCanvas.classList.add('dragover'));
    });

    ['dragleave', 'drop'].forEach((eventName) => {
      uploadCanvas.addEventListener(eventName, () => uploadCanvas.classList.remove('dragover'));
    });

    uploadCanvas.addEventListener('drop', (event) => {
      const file = event.dataTransfer.files && event.dataTransfer.files[0];
      setImage(file);
    });

    toolMenuToggle.addEventListener('click', () => {
      const collapsed = toolMenu.classList.toggle('collapsed');
      toolMenuToggle.classList.toggle('collapsed', collapsed);
      toolMenuToggle.setAttribute('aria-expanded', String(!collapsed));
    });

    document.querySelectorAll('.tool-option').forEach((button) => {
      button.addEventListener('click', () => {
        selectToolButton(button);
        setStatus('');
      });
    });

    function normalizeToolSlug(value) {
      return (value || '').trim().toLowerCase().replace(/^\/api\/v2\//, '').replace(/-/g, '_');
    }

    function selectToolButton(button) {
      document.querySelectorAll('.tool-option').forEach((item) => item.classList.remove('active'));
      button.classList.add('active');
      selectedEndpoint = button.dataset.endpoint;
      selectedToolName = button.dataset.toolName;
      selectedToolKey = button.dataset.toolKey || endpointToolKey(selectedEndpoint);
      if (selectedToolKey === 'redesign') {
        setRedesignMode(selectedRedesignMode || 'perfect_redesign', false);
      }
      selectedRequiresMask = button.dataset.requiresMask === 'true';
      selectedToolLabel.textContent = selectedToolName;
      configToolName.textContent = selectedToolName;
      configEndpoint.textContent = selectedEndpoint;
      resultToolName.textContent = selectedToolName;
      materialSwapReady = false;
      resetMaskCanvas();
      resetPreviewTransform();
      resetDecorTransform();
      setSelectionMode('click');
      if (currentToolKey() === 'material_swap') setMaterialSwapTab('automatic');
      updateMaskControls();
      updateToolOptions();
    }

    function selectToolFromUrl() {
      const requestedTool = normalizeToolSlug(new URLSearchParams(window.location.search).get('tool'));
      if (!requestedTool) return;
      const redesignModes = ['perfect_redesign', 'beautiful_redesign', 'creative_redesign'];

      if (requestedTool === 'redesign' || redesignModes.includes(requestedTool)) {
        const redesignButton = [...document.querySelectorAll('.tool-option')].find((button) => button.dataset.toolKey === 'redesign');
        if (redesignButton) {
          if (redesignModes.includes(requestedTool)) selectedRedesignMode = requestedTool;
          selectToolButton(redesignButton);
          return;
        }
      }

      const requestedButton = [...document.querySelectorAll('.tool-option')].find((button) => {
        return normalizeToolSlug(button.dataset.endpoint) === requestedTool || normalizeToolSlug(button.dataset.toolKey) === requestedTool;
      });

      if (requestedButton) {
        selectToolButton(requestedButton);
      } else {
        setStatus('The requested AI tool was not found. Redesign is selected by default.', 'error');
      }
    }

    window.addEventListener('resize', () => {
      if (!sourcePreview.hidden) sizeMaskCanvas();
    });

    document.querySelectorAll('.segmented-control .segment').forEach((button) => {
      button.addEventListener('click', () => {
        document.querySelectorAll('.segmented-control .segment').forEach((item) => item.classList.remove('active'));
        button.classList.add('active');
        designType = button.dataset.value;
      });
    });

    function renderResult(data) {
      if (data.projectId) {
        currentProjectId = data.projectId;
      }
      if (data.sourceImageUrl && !projectSourceImageUrl) {
        projectSourceImageUrl = data.sourceImageUrl;
      }
      resultToolName.textContent = data.tool || selectedToolName;
      resultMedia.innerHTML = '';

      const firstDesign = data.designs && data.designs[0];
      const imageUrl = firstDesign && firstDesign.imageUrl ? firstDesign.imageUrl : data.imageUrl;

      if (data.videoUrl) {
        resultMedia.innerHTML = `<video src="${data.videoUrl}" controls playsinline></video>`;
      } else if (data.resultArray) {
        const products = document.createElement('div');
        products.className = 'product-results';
        products.innerHTML = Object.entries(data.resultArray).map(([category, items]) => {
          const safeItems = Array.isArray(items) ? items.slice(0, 4) : [];
          return `
            <section class="product-category">
              <h4>${category}</h4>
              <div class="product-grid">
                ${safeItems.map((item) => `
                  <a class="product-card" href="${item.link || '#'}" target="_blank" rel="noopener">
                    ${item.thumbnail ? `<img src="${item.thumbnail}" alt="${item.title || category}">` : ''}
                    <strong>${item.title || 'Product match'}</strong>
                    <span>${item.source || ''}${item.price?.value ? ` · ${item.price.value}` : ''}</span>
                  </a>
                `).join('')}
              </div>
            </section>
          `;
        }).join('');
        resultMedia.appendChild(products);
      } else if (imageUrl) {
        if (isMaterialSwapTool() && sourcePreview.src) {
          const compare = document.createElement('div');
          compare.className = 'before-after-result';
          compare.innerHTML = `
            <div class="before-after-frame">
              <img src="${sourcePreview.src}" alt="Before Material Swap">
              <span>Before</span>
            </div>
            <div class="before-after-frame">
              <img src="${imageUrl}" alt="${data.tool || selectedToolName} result" class="generated-preview-image">
              <span>After</span>
            </div>
          `;
          compare.querySelector('.generated-preview-image').addEventListener('click', () => openLightboxWithSrc(imageUrl));
          resultMedia.appendChild(compare);
        } else {
          const resultImage = document.createElement('img');
          resultImage.src = imageUrl;
          resultImage.alt = `${data.tool || selectedToolName} result`;
          resultImage.className = 'generated-preview-image';
          resultImage.addEventListener('click', () => openLightboxWithSrc(imageUrl));
          resultMedia.appendChild(resultImage);
        }
      } else if (data.textResult) {
        const text = document.createElement('div');
        text.className = 'result-text';
        text.textContent = data.textResult;
        resultMedia.appendChild(text);
      } else {
        const text = document.createElement('div');
        text.className = 'result-text';
        text.textContent = 'Generation completed, but no preview was returned.';
        resultMedia.appendChild(text);
      }

    resultPanel.hidden = false;
    addLatestDesignsFromResponse(data);
    showProjectActionsBar();
    }

    async function handleGenerateDesign() {
      const currentConfig = getCurrentToolConfig();
    if (!hasSourceImage() && !currentConfig.imageOptional) {
      setStatus('Image is required', 'error');
      updateGenerateButtonState();
      return;
    }
      if (!selectedEndpoint) {
        setStatus('Select an AI tool before generating a design.', 'error');
        return;
      }
      const isVideoTool = currentToolKey() === 'video_generation';
      const isFloorEditor = currentToolKey() === 'floor_editor';
      if (isVideoTool && !videoMotionSelect.value) {
        setStatus('Veuillez choisir un mouvement caméra.', 'error');
        return;
      }
      const isMaterialSwap = isMaterialSwapTool();
      const isDesignTransfer = currentToolKey() === 'design_transfer';
      if (selectedRequiresMask && !hasMaskPaint) {
        setStatus('Please paint the area you want to modify before generating.', 'error');
        return;
      }
      if (isMaterialSwap && !materialSwapReady) {
        setStatus('Click Continue after selecting the object, then choose the material.', 'error');
        return;
      }
      if (isDesignTransfer && !selectedStyleReferenceFile) {
        setStatus('Upload a reference style image before transferring a design.', 'error');
        return;
      }
      if (isFloorEditor && !selectedTextureFile) {
        setStatus('Upload a texture image before editing the floor.', 'error');
        return;
      }
      if (currentToolKey() === 'change_color_textures' && !surfaceColorRow.hidden && !surfaceColorInput.value) {
        const hasPrompt = document.getElementById('additional-instructions')?.value?.trim();
        const hasMaterials = !materialRow.hidden && materialSelect.value;
        if (!hasPrompt && !hasMaterials) {
          setStatus('Please select a valid color.', 'error');
          return;
        }
      }

      const formData = new FormData();
      let decorImageFile = selectedFile;
      if (currentToolKey() === 'decor_staging' && selectedFile && hasDecorTransform()) {
        decorImageFile = await applyDecorTransformToFile(selectedFile);
      }
    if (decorImageFile) formData.append('image', decorImageFile);
    if (currentProjectId) formData.append('projectId', currentProjectId);
    if (!selectedFile && projectSourceImageUrl) formData.append('sourceImageUrl', projectSourceImageUrl);
      formData.append('selectedToolEndpoint', selectedEndpoint);
      formData.append('selectedToolName', selectedToolName);
      const fields = currentConfig.fields || [];
      if (fields.includes('design_type') || fields.includes('image_type')) formData.append('spaceType', designType);
      if (fields.includes('room_type')) formData.append('roomType', document.getElementById('room-type').value);
      if (fields.includes('design_style')) formData.append('designStyle', document.getElementById('design-style').value);
      if (fields.includes('prompt') || fields.includes('custom_instruction') || fields.includes('custom_message')) {
        formData.append('additionalInstructions', document.getElementById('additional-instructions').value);
      }
      if (fields.includes('keep_structural_element')) {
        formData.append('keepStructural', document.getElementById('tool-keep-structural')?.checked ? 'true' : 'false');
      }

      if (!noDesignRow.hidden) formData.append('noDesign', noDesignSelect.value);
      if (!interventionRow.hidden) formData.append('aiIntervention', interventionSelect.value);
      if (!strengthRow.hidden) formData.append('strength', strengthRange.value);
      if (!weatherRow.hidden) formData.append('weather', weatherSelect.value);
      if (!countryRow.hidden) formData.append('countryCode', countrySelect.value);
      if (!paintColorRow.hidden) formData.append('rgbColor', hexToRgbString(paintColorInput.value));
      if (!materialRow.hidden && materialSelect.value) formData.append('materials', materialSelect.value);
      if (!materialTypeRow.hidden && materialTypeSelect.value) formData.append('materialsType', materialTypeSelect.value);
      if (!surfaceColorRow.hidden && surfaceColorInput.value) formData.append('color', surfaceColorInput.value);
      if (!objectRow.hidden && objectInput.value.trim()) formData.append('object', objectInput.value.trim());
      if (!labelsRow.hidden) {
        const selectedLabels = [...labelsSelect.selectedOptions].map(o => o.value);
        formData.append('labels', selectedLabels.length > 0 ? selectedLabels.join('|') : 'wall|floor|ceiling|sofa|chair|table|lamp');
      }
      if (isVideoTool) formData.append('tool_name', videoMotionSelect.value);
      if (isDesignTransfer && selectedStyleReferenceFile) formData.append('styleImage', selectedStyleReferenceFile);
      if (!textureGridRow.hidden) formData.append('noOfTexture', textureGridSelect.value);
      if (!textureUploadRow.hidden && selectedTextureFile) formData.append('textureImage', selectedTextureFile);
      if (isMaterialSwap) {
        formData.append('materials', materialPresetSelect.value);
        formData.append('materialInstruction', materialInstructionInput.value.trim() || materialPresetSelect.value);
      }

      if (selectedRequiresMask) {
        const maskBase64 = getMaskBase64();
        if (maskBase64) formData.append('maskBase64', maskBase64);
      }

      isGenerating = true;
      updateGenerateButtonState();
      generateBtn.querySelector('span').textContent = isVideoTool ? 'Generating video...' : currentToolKey() === 'furniture_finder' ? 'Finding products...' : 'Generating...';
      setStatus(isVideoTool ? 'Processing video...' : currentToolKey() === 'furniture_finder' ? 'Finding matching products...' : `Generating with ${selectedToolName}...`);

      try {
        const response = await fetch('/api/generate-design', {
          method: 'POST',
          body: formData
        });
        const data = await response.json();

        if (!response.ok || !data.success) {
          throw new Error(data.error || 'Design generation failed.');
        }

        renderResult(data);
        setStatus(isVideoTool ? 'Video generated successfully.' : 'Design generated successfully.', 'success');
      } catch (error) {
        setStatus(error.message, 'error');
      } finally {
        isGenerating = false;
        generateBtn.querySelector('span').textContent = getCurrentToolConfig().submitLabel || (isVideoTool ? 'Generate Video' : 'Generate Design');
        updateGenerateButtonState();
      }
    }

    generateBtn.addEventListener('click', handleGenerateDesign);
    window.handleGenerateDesign = handleGenerateDesign;
    updateToolOptions();
    selectToolFromUrl();

    if (typeof lucide !== 'undefined') {
      lucide.createIcons();
    }

    // ── Project action buttons ────────────────────────────────────────────

    function showProjectActionsBar() {
      // kept for future use — bar is now always visible
    }

    function showToast(message, type) {
      type = type || 'success';
      let toast = document.getElementById('studio-toast');
      if (!toast) {
        toast = document.createElement('div');
        toast.id = 'studio-toast';
        document.body.appendChild(toast);
      }
      const icon = type === 'success' ? 'check-circle' : 'alert-circle';
      toast.innerHTML = `<i data-lucide="${icon}"></i><span></span>`;
      toast.className = `studio-toast is-${type}`;
      toast.querySelector('span').textContent = message;
      clearTimeout(toast._hideTimer);
      requestAnimationFrame(() => {
        requestAnimationFrame(() => toast.classList.add('is-visible'));
      });
      toast._hideTimer = setTimeout(() => toast.classList.remove('is-visible'), 4000);
      if (typeof lucide !== 'undefined') lucide.createIcons({ nodes: [toast] });
    }

    async function handleSaveProject() {
      console.log('[CraftyCrib] handleSaveProject() called', { currentProjectId, designs: latestDesigns.length });
      if (!currentProjectId) {
        showToast('Générez un design d\'abord avant de sauvegarder.', 'error');
        return;
      }
      const btn = document.getElementById('btn-save-project');
      btn.disabled = true;
      btn.querySelector('span').textContent = 'Sauvegarde en cours…';
      try {
        const featuredImage = latestDesigns[0]?.imageUrl || latestDesigns[0]?.thumbnailUrl || '';
        const body = { status: 'completed' };
        if (featuredImage) body.featuredImage = featuredImage;
        const res = await fetch(`/api/projects/${currentProjectId}/status`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body)
        });
        const data = await res.json();
        if (!res.ok || !data.success) throw new Error(data.error || 'Erreur lors de la sauvegarde.');
        btn.querySelector('span').textContent = 'Projet sauvegardé ✓';
        showToast('Projet sauvegardé dans Mes projets.', 'success');
      } catch (err) {
        btn.disabled = false;
        btn.querySelector('span').textContent = 'Sauvegarder dans Mes projets';
        showToast(err.message, 'error');
      }
    }

    async function handleShareWithProfessionals() {
      console.log('[CraftyCrib] handleShareWithProfessionals() called', { currentProjectId });
      if (!currentProjectId) {
        showToast('Générez un design d\'abord avant de partager.', 'error');
        return;
      }
      const btn = document.getElementById('btn-share-project');
      btn.disabled = true;
      btn.querySelector('span').textContent = 'Partage en cours…';
      try {
        const res = await fetch(`/api/projects/${currentProjectId}/status`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ visibility: 'contractors' })
        });
        const data = await res.json();
        if (!res.ok || !data.success) throw new Error(data.error || 'Erreur lors du partage.');
        btn.querySelector('span').textContent = 'Partagé avec des professionnels ✓';
        showToast('Projet prêt à être partagé avec des professionnels.', 'success');
      } catch (err) {
        btn.disabled = false;
        btn.querySelector('span').textContent = 'Partager avec des professionnels';
        showToast(err.message, 'error');
      }
    }

    document.getElementById('btn-save-project')?.addEventListener('click', handleSaveProject);
    document.getElementById('btn-share-project')?.addEventListener('click', handleShareWithProfessionals);
    window.handleSaveProject = handleSaveProject;
    window.handleShareWithProfessionals = handleShareWithProfessionals;

    preloadStudioProject();

  })();
</script>
