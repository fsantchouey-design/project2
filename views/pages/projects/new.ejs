<div class="ai-studio-page">
  <header class="studio-topbar">
    <div>
      <a href="/projects" class="studio-back">
        <i data-lucide="arrow-left"></i>
        Back to Projects
      </a>
      <h1>AI Design Studio</h1>
    </div>
    <button type="button" class="studio-secondary-btn" id="replace-image-btn">
      <i data-lucide="upload"></i>
      Upload New
    </button>
  </header>

  <div class="studio-shell">
    <aside class="tool-rail">
      <button type="button" class="tool-menu-toggle" id="tool-menu-toggle" aria-expanded="true">
        <span>
          <span class="tool-kicker">Standard Tools</span>
          <strong id="selected-tool-label">Perfect Redesign</strong>
        </span>
        <i data-lucide="chevron-down"></i>
      </button>

      <div class="tool-menu" id="tool-menu">
        <button type="button" class="tool-option active" data-tool-name="Perfect Redesign" data-endpoint="/api/v2/perfect_redesign" data-requires-mask="false">
          <i data-lucide="gem"></i>
          <span>Perfect Redesign</span>
        </button>
        <button type="button" class="tool-option" data-tool-name="Beautiful Redesign" data-endpoint="/api/v2/beautiful_redesign" data-requires-mask="false">
          <i data-lucide="sparkles"></i>
          <span>Beautiful Redesign</span>
        </button>
        <button type="button" class="tool-option" data-tool-name="Magic Redesign" data-endpoint="/api/v2/magic_redesign" data-requires-mask="false">
          <i data-lucide="zap"></i>
          <span>Magic Redesign</span>
        </button>
        <button type="button" class="tool-option" data-tool-name="Video Generation" data-endpoint="/api/v2/video_generation" data-requires-mask="false">
          <i data-lucide="video"></i>
          <span>Video Generation</span>
        </button>
        <button type="button" class="tool-option" data-tool-name="Creative Redesign" data-endpoint="/api/v2/creative_redesign" data-requires-mask="false">
          <i data-lucide="wand-2"></i>
          <span>Creative Redesign</span>
        </button>
        <button type="button" class="tool-option" data-tool-name="Sketch To Render" data-endpoint="/api/v2/sketch_to_render" data-requires-mask="false">
          <i data-lucide="pencil-ruler"></i>
          <span>Sketch To Render</span>
        </button>
        <button type="button" class="tool-option" data-tool-name="Virtual Staging" data-endpoint="/api/v2/virtual_staging" data-requires-mask="false">
          <i data-lucide="sofa"></i>
          <span>Virtual Staging</span>
        </button>
        <button type="button" class="tool-option" data-tool-name="Precision" data-endpoint="/api/v2/precision" data-requires-mask="true">
          <i data-lucide="target"></i>
          <span>Precision</span>
        </button>
        <button type="button" class="tool-option" data-tool-name="Fill Spaces" data-endpoint="/api/v2/fill_spaces" data-requires-mask="true">
          <i data-lucide="layout-grid"></i>
          <span>Fill Spaces</span>
        </button>
        <button type="button" class="tool-option" data-tool-name="Decor Staging" data-endpoint="/api/v2/decor_staging" data-requires-mask="false">
          <i data-lucide="lamp"></i>
          <span>Decor Staging</span>
        </button>
        <button type="button" class="tool-option" data-tool-name="Furniture Removal" data-endpoint="/api/v2/furniture_removal" data-requires-mask="true">
          <i data-lucide="eraser"></i>
          <span>Furniture Removal</span>
        </button>
        <button type="button" class="tool-option" data-tool-name="Change Color Textures" data-endpoint="/api/v2/change_color_textures" data-requires-mask="true">
          <i data-lucide="palette"></i>
          <span>Change Color Textures</span>
        </button>
        <button type="button" class="tool-option" data-tool-name="Furniture Finder" data-endpoint="/api/v2/furniture_finder" data-requires-mask="false">
          <i data-lucide="shopping-bag"></i>
          <span>Furniture Finder</span>
        </button>
        <button type="button" class="tool-option" data-tool-name="Full HD" data-endpoint="/api/v2/full_hd" data-requires-mask="false">
          <i data-lucide="monitor"></i>
          <span>Full HD</span>
        </button>
        <button type="button" class="tool-option" data-tool-name="Text To Design" data-endpoint="/api/v2/text_to_design" data-requires-mask="false">
          <i data-lucide="type"></i>
          <span>Text To Design</span>
        </button>
        <button type="button" class="tool-option" data-tool-name="Furniture Creator" data-endpoint="/api/v2/furniture_creator" data-requires-mask="false">
          <i data-lucide="armchair"></i>
          <span>Furniture Creator</span>
        </button>
        <button type="button" class="tool-option" data-tool-name="Design Advisor" data-endpoint="/api/v2/design_advisor" data-requires-mask="false">
          <i data-lucide="messages-square"></i>
          <span>Design Advisor</span>
        </button>
        <button type="button" class="tool-option" data-tool-name="Sky Colors" data-endpoint="/api/v2/sky_colors" data-requires-mask="false">
          <i data-lucide="cloud-sun"></i>
          <span>Sky Colors</span>
        </button>
        <button type="button" class="tool-option" data-tool-name="Design Transfer" data-endpoint="/api/v2/design_transfer" data-requires-mask="false">
          <i data-lucide="copy-plus"></i>
          <span>Design Transfer</span>
        </button>
        <button type="button" class="tool-option" data-tool-name="Floor Editor" data-endpoint="/api/v2/floor_editor" data-requires-mask="true">
          <i data-lucide="panel-bottom"></i>
          <span>Floor Editor</span>
        </button>
        <button type="button" class="tool-option" data-tool-name="Paint Visualizer" data-endpoint="/api/v2/paint_visualizer" data-requires-mask="true">
          <i data-lucide="paintbrush"></i>
          <span>Paint Visualizer</span>
        </button>
        <button type="button" class="tool-option" data-tool-name="Material Swap" data-endpoint="/api/v2/material_swap" data-requires-mask="true">
          <i data-lucide="swatch-book"></i>
          <span>Material Swap</span>
        </button>
        <button type="button" class="tool-option" data-tool-name="Room Composer" data-endpoint="/api/v2/room_composer" data-requires-mask="false">
          <i data-lucide="blocks"></i>
          <span>Room Composer</span>
        </button>
        <button type="button" class="tool-option" data-tool-name="Design Critique" data-endpoint="/api/v2/design_critique" data-requires-mask="false">
          <i data-lucide="search-check"></i>
          <span>Design Critique</span>
        </button>
        <button type="button" class="tool-option" data-tool-name="Create Mask Image" data-endpoint="/api/v2/create_maskimage" data-requires-mask="false">
          <i data-lucide="scan-line"></i>
          <span>Create Mask Image</span>
        </button>
        <button type="button" class="tool-option" data-tool-name="Smart Home" data-endpoint="/api/v2/smart_home" data-requires-mask="false">
          <i data-lucide="house-plug"></i>
          <span>Smart Home</span>
        </button>
      </div>
    </aside>

    <main class="preview-stage">
      <input type="file" id="design-image" accept="image/*" hidden>

      <label for="design-image" class="upload-canvas" id="upload-canvas">
        <img id="source-preview" class="source-preview" alt="Uploaded room preview" hidden>
        <canvas id="mask-canvas" class="mask-canvas" hidden></canvas>
        <div class="upload-placeholder" id="upload-placeholder">
          <span class="upload-icon"><i data-lucide="image-up"></i></span>
          <strong>Drop your room photo here</strong>
          <span>or click to upload a JPG, PNG, or WebP image</span>
        </div>
        <button type="button" class="image-action" id="change-image-btn" hidden>
          <i data-lucide="refresh-cw"></i>
          Change
        </button>
      </label>

      <section class="result-panel" id="result-panel" hidden>
        <div class="result-heading">
          <span>Generated Result</span>
          <strong id="result-tool-name">Perfect Redesign</strong>
        </div>
        <div class="result-media" id="result-media"></div>
      </section>
    </main>

    <aside class="config-panel">
      <div class="selected-tool-card">
        <span>Selected AI Tool</span>
        <strong id="config-tool-name">Perfect Redesign</strong>
        <small id="config-endpoint">/api/v2/perfect_redesign</small>
      </div>

      <div class="config-group">
        <label>Select what kind of space you are generating</label>
        <div class="segmented-control" data-input="designType">
          <button type="button" class="segment active" data-value="Interior">
            <i data-lucide="sofa"></i>
            Interior
          </button>
          <button type="button" class="segment" data-value="Exterior">
            <i data-lucide="home"></i>
            Exterior
          </button>
          <button type="button" class="segment" data-value="Garden">
            <i data-lucide="flower-2"></i>
            Garden
          </button>
        </div>
      </div>

      <div class="config-grid">
        <div class="config-group">
          <label for="room-type">Room Type</label>
          <select id="room-type" class="studio-select">
            <% if (typeof roomTypes !== 'undefined') { %>
              <% roomTypes.forEach(room => { %>
                <option value="<%= room.id %>" <%= room.id === 'living-room' ? 'selected' : '' %>><%= room.name %></option>
              <% }) %>
            <% } %>
          </select>
        </div>

        <div class="config-group">
          <label for="design-style">Design Style</label>
          <select id="design-style" class="studio-select">
            <% if (typeof styles !== 'undefined') { %>
              <% styles.forEach(style => { %>
                <option value="<%= style.id %>" <%= style.id === 'modern' ? 'selected' : '' %>><%= style.name %></option>
              <% }) %>
            <% } %>
          </select>
        </div>
      </div>

      <div class="config-group">
        <label for="additional-instructions">Additional Instructions</label>
        <textarea id="additional-instructions" class="studio-textarea" rows="5" placeholder="Describe colors, mood, materials, furniture, or anything the AI should respect."></textarea>
      </div>

      <div class="advanced-options" id="advanced-options">
        <button type="button" class="advanced-toggle" id="advanced-toggle" aria-expanded="false">
          <span>
            <i data-lucide="sliders-horizontal"></i>
            Advanced options
          </span>
          <i data-lucide="chevron-down"></i>
        </button>

        <div class="tool-options-panel collapsed" id="tool-options-panel">
          <div class="tool-option-row" id="option-no-design">
            <label for="option-no-design-select">Variations</label>
            <select id="option-no-design-select" class="studio-select">
              <option value="1">1 design</option>
              <option value="2">2 designs</option>
              <option value="3">3 designs</option>
              <option value="4">4 designs</option>
            </select>
          </div>

          <div class="tool-option-row" id="option-ai-intervention">
            <label for="option-ai-intervention-select">AI Intervention</label>
            <select id="option-ai-intervention-select" class="studio-select">
              <option value="Very Low">Very Low</option>
              <option value="Low">Low</option>
              <option value="Mid" selected>Medium</option>
              <option value="Extreme">Extreme</option>
            </select>
          </div>

          <div class="tool-option-row" id="option-strength" hidden>
            <label for="option-strength-range">
              Edit Strength
              <span id="option-strength-value">5</span>
            </label>
            <input type="range" id="option-strength-range" min="1" max="10" value="5">
          </div>

          <div class="tool-option-row" id="option-weather" hidden>
            <label for="option-weather-select">Sky Mood</label>
            <select id="option-weather-select" class="studio-select">
              <option value="Clear Sky">Clear Sky</option>
              <option value="Sunshine">Sunshine</option>
              <option value="Cloudy">Cloudy</option>
              <option value="Rainy">Rainy</option>
              <option value="Dawn">Dawn</option>
              <option value="Dusk">Dusk</option>
              <option value="Night">Night</option>
            </select>
          </div>

          <div class="tool-option-row" id="option-country" hidden>
            <label for="option-country-select">Shopping Country</label>
            <select id="option-country-select" class="studio-select">
              <option value="US">United States</option>
              <option value="CA">Canada</option>
              <option value="FR">France</option>
              <option value="GB">United Kingdom</option>
            </select>
          </div>

          <div class="tool-option-row" id="option-paint-color" hidden>
            <label for="option-paint-color-input">Paint Color</label>
            <input type="color" id="option-paint-color-input" class="studio-color" value="#f8fafc">
          </div>

          <div class="tool-option-row" id="option-material" hidden>
            <label for="option-material-select">Material</label>
            <select id="option-material-select" class="studio-select">
              <option value="">No material preference</option>
              <option value="Wood">Wood</option>
              <option value="Stone">Stone</option>
              <option value="Metal">Metal</option>
              <option value="Glass">Glass</option>
              <option value="Fabrics">Fabrics</option>
              <option value="Ceramics and Porcelain">Ceramics and Porcelain</option>
              <option value="Natural Fibers">Natural Fibers</option>
              <option value="Composite Materials">Composite Materials</option>
            </select>
          </div>

          <div class="tool-option-row" id="option-material-type" hidden>
            <label for="option-material-type-select">Material Type</label>
            <select id="option-material-type-select" class="studio-select"></select>
          </div>

          <div class="tool-option-row" id="option-surface-color" hidden>
            <label for="option-surface-color-input">Surface Color</label>
            <input type="color" id="option-surface-color-input" class="studio-color" value="#d1d5db">
          </div>

          <div class="tool-option-row" id="option-object" hidden>
            <label for="option-object-input">Object / Surface</label>
            <input type="text" id="option-object-input" class="studio-input" placeholder="wall, sofa, cabinet, countertop">
          </div>
        </div>
      </div>

      <div class="mask-tools-panel" id="mask-tools-panel" hidden>
        <div>
          <span class="mask-tools-kicker">Object Selection</span>
          <strong id="mask-tool-title">Select the area to edit</strong>
          <p id="mask-tool-help">Click the object or area to target, or switch to brush selection for manual control.</p>
        </div>
        <div class="selection-mode-group" aria-label="Selection Mode">
          <span>Selection Mode</span>
          <div class="selection-mode-buttons">
            <button type="button" class="selection-mode-btn active" id="click-selection-btn">
              <i data-lucide="mouse-pointer-click"></i>
              Click selection
            </button>
            <button type="button" class="selection-mode-btn" id="brush-selection-btn">
              <i data-lucide="paintbrush"></i>
              Brush selection
            </button>
          </div>
        </div>
        <div class="mask-tool-buttons">
          <button type="button" class="mask-tool-btn active" id="mask-brush-btn">
            <i data-lucide="paintbrush"></i>
            Brush
          </button>
          <button type="button" class="mask-tool-btn" id="mask-eraser-btn">
            <i data-lucide="eraser"></i>
            Eraser
          </button>
        </div>
        <label class="mask-size-label" for="mask-brush-size">
          Brush Size
          <span id="mask-brush-size-value">34</span>
        </label>
        <input type="range" id="mask-brush-size" min="8" max="90" value="34">
        <button type="button" class="mask-clear-btn" id="mask-clear-btn">
          <i data-lucide="trash-2"></i>
          Clear Selection
        </button>
      </div>

      <button type="button" class="generate-btn" id="generate-btn">
        <i data-lucide="sparkles"></i>
        <span>Generate Design</span>
      </button>

      <div class="studio-status" id="studio-status" aria-live="polite"></div>
    </aside>
  </div>
</div>

<div class="image-lightbox" id="image-lightbox" hidden>
  <button type="button" class="lightbox-close" id="lightbox-close" aria-label="Close image preview">
    <i data-lucide="x"></i>
  </button>
  <div class="lightbox-content" id="lightbox-content">
    <img id="lightbox-image" alt="Full screen room preview">
  </div>
  <div class="lightbox-hint">Double-click or scroll to zoom · Drag when zoomed</div>
</div>

<style>
  .ai-studio-page {
    min-height: calc(100vh - 48px);
    padding: 20px;
    color: var(--text-primary);
  }

  .studio-topbar {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 18px;
  }

  .studio-back {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 8px;
    color: var(--text-muted);
    font-size: 14px;
    font-weight: 600;
  }

  .studio-back:hover {
    color: var(--accent-primary);
  }

  .studio-back i {
    width: 17px;
    height: 17px;
  }

  .studio-topbar h1 {
    margin: 0;
    font-size: 30px;
    letter-spacing: 0;
  }

  .studio-secondary-btn,
  .image-action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    min-height: 42px;
    padding: 0 14px;
    border: 1px solid var(--border-color);
    border-radius: 8px;
    background: var(--bg-card);
    color: var(--text-primary);
    font-weight: 700;
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s, color 0.2s;
  }

  .studio-secondary-btn:hover,
  .image-action:hover {
    border-color: rgba(16, 185, 129, 0.45);
    background: rgba(16, 185, 129, 0.08);
    color: var(--accent-primary);
  }

  .studio-secondary-btn i,
  .image-action i {
    width: 18px;
    height: 18px;
  }

  .studio-shell {
    display: grid;
    grid-template-columns: 240px minmax(360px, 1fr) minmax(320px, 420px);
    gap: 18px;
    align-items: start;
  }

  .tool-rail,
  .config-panel {
    position: sticky;
    top: 20px;
    border: 1px solid var(--border-color);
    border-radius: 8px;
    background: var(--bg-card);
    box-shadow: 0 18px 60px rgba(15, 23, 42, 0.08);
  }

  .tool-rail {
    overflow: hidden;
  }

  .tool-menu-toggle {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 15px;
    border: 0;
    border-bottom: 1px solid var(--border-color);
    background: linear-gradient(135deg, rgba(16, 185, 129, 0.12), rgba(14, 165, 233, 0.08));
    color: var(--text-primary);
    text-align: left;
    cursor: pointer;
  }

  .tool-kicker {
    display: block;
    margin-bottom: 5px;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .tool-menu-toggle strong {
    display: block;
    font-size: 15px;
  }

  .tool-menu-toggle i {
    width: 18px;
    height: 18px;
    transition: transform 0.2s;
  }

  .tool-menu-toggle.collapsed i {
    transform: rotate(-90deg);
  }

  .tool-menu {
    max-height: 66vh;
    overflow-y: auto;
    padding: 8px;
  }

  .tool-menu.collapsed {
    display: none;
  }

  .tool-option {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px;
    border: 1px solid transparent;
    border-radius: 8px;
    background: transparent;
    color: var(--text-secondary);
    font-weight: 700;
    text-align: left;
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s, color 0.2s;
  }

  .tool-option:hover {
    background: var(--bg-tertiary);
    color: var(--text-primary);
  }

  .tool-option.active {
    border-color: rgba(16, 185, 129, 0.45);
    background: rgba(16, 185, 129, 0.12);
    color: var(--accent-primary);
  }

  .tool-option i {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }

  .preview-stage {
    min-height: 76vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 18px;
    padding: 24px;
    border: 1px solid var(--border-color);
    border-radius: 8px;
    background:
      radial-gradient(circle at top left, rgba(16, 185, 129, 0.08), transparent 34%),
      var(--bg-secondary);
  }

  .upload-canvas {
    position: relative;
    width: min(100%, 520px);
    aspect-ratio: 9 / 16;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 28px;
    border: 2px dashed rgba(16, 185, 129, 0.4);
    border-radius: 8px;
    background: var(--bg-card);
    color: var(--text-muted);
    text-align: center;
    cursor: pointer;
    overflow: hidden;
    transition: border-color 0.2s, background 0.2s, transform 0.2s;
  }

  .upload-canvas [hidden] {
    display: none !important;
  }

  .upload-canvas:hover,
  .upload-canvas.dragover {
    border-color: var(--accent-primary);
    background: rgba(16, 185, 129, 0.08);
    transform: translateY(-1px);
  }

  .upload-canvas.has-image {
    padding: 0;
    border-style: solid;
    border-color: rgba(16, 185, 129, 0.55);
    background: #0f172a;
    box-shadow: 0 24px 90px rgba(15, 23, 42, 0.24);
  }

  .upload-canvas.mask-mode {
    cursor: crosshair;
  }

  .upload-canvas strong {
    color: var(--text-primary);
    font-size: 20px;
  }

  .upload-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
  }

  .upload-icon {
    width: 62px;
    height: 62px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    background: rgba(16, 185, 129, 0.12);
    color: var(--accent-primary);
  }

  .upload-icon i {
    width: 30px;
    height: 30px;
  }

  .source-preview {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: center;
    cursor: zoom-in;
  }

  .upload-canvas.mask-mode .source-preview {
    cursor: crosshair;
  }

  .mask-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 2;
    cursor: crosshair;
    touch-action: none;
  }

  .mask-canvas.click-mode {
    cursor: pointer;
  }

  .image-action {
    position: absolute;
    top: 14px;
    right: 14px;
    min-height: 38px;
    background: rgba(15, 23, 42, 0.74);
    border-color: rgba(255, 255, 255, 0.16);
    color: #fff;
    backdrop-filter: blur(10px);
    z-index: 3;
  }

  .result-panel {
    width: min(100%, 540px);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    background: var(--bg-card);
    overflow: hidden;
  }

  .result-heading {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 14px 16px;
    border-bottom: 1px solid var(--border-color);
    color: var(--text-muted);
    font-size: 13px;
  }

  .result-heading strong {
