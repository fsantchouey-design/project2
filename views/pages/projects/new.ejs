      uploadCanvas.style.setProperty('--preview-zoom', previewZoom);
      uploadCanvas.style.setProperty('--preview-pan-x', `${previewPanX}px`);
      uploadCanvas.style.setProperty('--preview-pan-y', `${previewPanY}px`);
      uploadCanvas.classList.toggle('is-pannable', previewZoom > 1);
      if (previewZoom <= 1 && previewPanMode) {
        previewPanMode = false;
        imagePanToggle.classList.remove('active');
      }
    }

    function resetPreviewTransform() {
      previewZoom = 1;
      previewPanX = 0;
      previewPanY = 0;
      previewPanMode = false;
      imageZoomRange.value = '1';
      imagePanToggle.classList.remove('active');
      applyPreviewTransform();
    }

