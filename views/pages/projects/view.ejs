<div class="page-container">
  <div class="page-header">
    <a href="/projects" class="back-link">
      <i data-lucide="arrow-left"></i>
      Back to Projects
    </a>
    <div class="page-header-flex">
      <div>
        <h1><%= project.title %></h1>
        <span class="project-status-badge status-<%= project.status %>"><%= project.status %></span>
      </div>
      <div class="page-actions">
        <a href="/projects/<%= project._id %>/edit" class="btn btn-secondary">
          <i data-lucide="edit"></i>
          Edit
        </a>
        <% if (project.originalImages && project.originalImages.length > 0) { %>
          <button class="btn btn-secondary" onclick="openColorChanger()" id="color-btn">
            <i data-lucide="palette"></i>
            Change Colors
          </button>
        <% } %>
        <button class="btn btn-primary" onclick="generateDesign()" id="generate-btn">
          <i data-lucide="sparkles"></i>
          Generate Design
        </button>
      </div>
    </div>
  </div>
  
  <div class="project-layout">
    <!-- Main Content -->
    <div class="project-main">
      <!-- Design Gallery -->
      <div class="section-card">
        <h2>Design Variants</h2>
        
        <% if (project.designVariants && project.designVariants.length > 0) { %>
          <div class="design-gallery">
            <% project.designVariants.forEach((variant, index) => { %>
              <div class="design-variant <%= variant.isSelected ? 'selected' : '' %>">
                <div class="variant-image">
                  <img src="<%= variant.imageUrl || '/images/placeholder.png' %>" alt="<%= variant.name %>">
                  <div class="variant-overlay">
                    <button class="btn btn-sm btn-primary" onclick="viewFullscreen('<%= variant.imageUrl %>')">
                      <i data-lucide="maximize-2"></i>
                    </button>
                  </div>
                </div>
                <div class="variant-info">
                  <h4><%= variant.name || 'Design ' + (index + 1) %></h4>
                  <% if (variant.style) { %>
                    <span class="tag"><%= variant.style %></span>
                  <% } %>
                  <% if (variant.budgetLevel) { %>
                    <span class="tag"><%= variant.budgetLevel %></span>
                  <% } %>
                </div>
              </div>
            <% }) %>
          </div>
        <% } else { %>
          <div class="empty-designs">
            <i data-lucide="image"></i>
            <p>No designs generated yet</p>
            <button class="btn btn-primary" onclick="generateDesign()">
              <i data-lucide="sparkles"></i>
              Generate First Design
            </button>
          </div>
        <% } %>
      </div>
      
      <!-- Original Images / Upload Section -->
      <div class="section-card">
        <div class="section-header">
          <h2>Original Photos</h2>
          <button class="btn btn-sm btn-secondary" onclick="toggleUpload()">
            <i data-lucide="plus"></i>
            Add Photos
          </button>
        </div>
        
        <!-- Upload Area (Hidden by default) -->
        <div class="upload-section" id="upload-section" style="display: none;">
          <form id="upload-form" enctype="multipart/form-data">
            <div class="upload-area" id="upload-area">
              <input type="file" name="images" id="images" multiple accept="image/*" class="file-input">
              <label for="images" class="upload-label">
                <i data-lucide="upload-cloud"></i>
                <span>Drop images here or click to browse</span>
                <span class="upload-hint">Max 5 images, 10MB each (JPG, PNG, WebP)</span>
              </label>
            </div>
            <div id="upload-preview" class="upload-preview"></div>
            <div class="upload-actions">
              <button type="button" class="btn btn-ghost" onclick="toggleUpload()">Cancel</button>
              <button type="submit" class="btn btn-primary" id="upload-btn">
                <i data-lucide="upload"></i>
                Upload Images
              </button>
            </div>
          </form>
        </div>
        
        <% if (project.originalImages && project.originalImages.length > 0) { %>
          <div class="original-gallery">
            <% project.originalImages.forEach(img => { %>
              <div class="original-image">
                <img src="<%= img.url %>" alt="Original">
                <button class="delete-img-btn" onclick="deleteImage('<%= img._id %>')" title="Delete">
                  <i data-lucide="trash-2"></i>
                </button>
              </div>
            <% }) %>
          </div>
        <% } else { %>
          <div class="empty-images" onclick="toggleUpload()">
            <i data-lucide="image-plus"></i>
            <p>No photos yet</p>
            <span>Upload photos of your current space to generate AI designs</span>
          </div>
        <% } %>
      </div>
      
      <!-- Description -->
      <div class="section-card">
        <h2>Project Description</h2>
        <p class="description-text"><%= project.description %></p>
      </div>
    </div>
    
    <!-- Sidebar -->
    <div class="project-sidebar">
      <!-- Details -->
      <div class="sidebar-card">
        <h3>Details</h3>
        <div class="detail-list">
          <div class="detail-item">
            <span class="detail-label">Room Type</span>
            <span class="detail-value"><%= project.roomType %></span>
          </div>
          <% if (project.style) { %>
            <div class="detail-item">
              <span class="detail-label">Style</span>
              <span class="detail-value"><%= project.style %></span>
            </div>
          <% } %>
          <% if (project.budget && (project.budget.min || project.budget.max)) { %>
            <div class="detail-item">
              <span class="detail-label">Budget</span>
              <span class="detail-value">
                <%= project.budget.min ? '€' + project.budget.min.toLocaleString() : '' %>
                <%= project.budget.min && project.budget.max ? ' - ' : '' %>
                <%= project.budget.max ? '€' + project.budget.max.toLocaleString() : '' %>
              </span>
            </div>
          <% } %>
          <% if (project.dimensions && (project.dimensions.length || project.dimensions.width)) { %>
            <div class="detail-item">
              <span class="detail-label">Dimensions</span>
              <span class="detail-value">
                <%= project.dimensions.length || '?' %>m × <%= project.dimensions.width || '?' %>m
                <% if (project.dimensions.height) { %> × <%= project.dimensions.height %>m<% } %>
              </span>
            </div>
          <% } %>
          <div class="detail-item">
            <span class="detail-label">Created</span>
            <span class="detail-value"><%= new Date(project.createdAt).toLocaleDateString() %></span>
          </div>
        </div>
      </div>
      
      <!-- Share -->
      <div class="sidebar-card">
        <h3>Share Project</h3>
        <div class="share-link">
          <input type="text" value="<%= process.env.APP_URL || 'https://craftycrib.com' %>/projects/share/<%= project.shareToken %>" readonly class="form-input" id="share-url">
          <button class="btn btn-secondary" onclick="copyShareLink()">
            <i data-lucide="copy"></i>
          </button>
        </div>
      </div>
      
      <!-- Visibility -->
      <div class="sidebar-card">
        <h3>Visibility</h3>
        <select class="form-select" onchange="updateVisibility(this.value)">
          <option value="private" <%= project.visibility === 'private' ? 'selected' : '' %>>Private</option>
          <option value="contractors" <%= project.visibility === 'contractors' ? 'selected' : '' %>>Visible to Contractors</option>
          <option value="public" <%= project.visibility === 'public' ? 'selected' : '' %>>Public</option>
        </select>
      </div>
      
      <% if (!project.isDIY) { %>
        <!-- Contractor Requests -->
        <div class="sidebar-card">
          <h3>Contractor Requests</h3>
          <% if (project.contractorRequests && project.contractorRequests.length > 0) { %>
            <div class="contractor-list">
              <% project.contractorRequests.forEach(req => { %>
                <div class="contractor-request">
                  <div class="contractor-info">
                    <strong><%= req.contractor.companyName %></strong>
                    <% if (req.quotation) { %>
                      <span class="quote">€<%= req.quotation.toLocaleString() %></span>
                    <% } %>
                  </div>
                  <span class="request-status status-<%= req.status %>"><%= req.status %></span>
                </div>
              <% }) %>
            </div>
          <% } else { %>
            <p class="empty-text">No requests yet. Make your project visible to contractors to receive quotes.</p>
          <% } %>
        </div>
      <% } %>
    </div>
  </div>
</div>

<!-- Color & Texture Editor (Full-Screen) -->
<% if (project.originalImages && project.originalImages.length > 0) { %>
<div class="color-editor" id="color-modal">
  <div class="color-editor-header">
    <div class="editor-title">
      <i data-lucide="palette"></i>
      <span>Color & Texture Editor</span>
    </div>
    <div class="editor-toolbar">
      <div class="tool-group">
        <button class="tool-btn active" id="tool-brush" onclick="setTool('brush')" title="Brush (B)">
          <i data-lucide="paintbrush"></i>
        </button>
        <button class="tool-btn" id="tool-eraser" onclick="setTool('eraser')" title="Eraser (E)">
          <i data-lucide="eraser"></i>
        </button>
      </div>
      <div class="tool-separator"></div>
      <div class="tool-group brush-size-group">
        <i data-lucide="circle" class="size-icon"></i>
        <input type="range" id="brush-size" min="5" max="100" value="30" class="brush-slider">
        <span class="brush-size-val" id="brush-size-display">30</span>
      </div>
      <div class="tool-separator"></div>
      <div class="tool-group">
        <button class="tool-btn" onclick="undoStroke()" title="Undo (Ctrl+Z)">
          <i data-lucide="undo-2"></i>
        </button>
        <button class="tool-btn" onclick="clearMask()" title="Clear All">
          <i data-lucide="trash-2"></i>
        </button>
      </div>
    </div>
    <button class="close-editor-btn" onclick="closeColorChanger()" title="Close (Esc)">
      <i data-lucide="x"></i>
    </button>
  </div>

  <div class="color-editor-body">
    <div class="canvas-area">
      <div class="canvas-wrapper" id="canvas-wrapper">
        <canvas id="mask-canvas"></canvas>
        <div class="canvas-cursor" id="canvas-cursor"></div>
      </div>
      <div class="canvas-hint">
        <i data-lucide="info"></i>
        Paint over the areas you want to change, then configure options on the right
      </div>
    </div>

    <div class="editor-panel">
      <div class="panel-scroll">
        <div class="panel-section">
          <label class="panel-label">Target Object</label>
          <select id="cc-object" class="form-select">
            <option value="wall">Wall</option>
            <option value="floor">Floor</option>
            <option value="ceiling">Ceiling</option>
            <option value="furniture">Furniture</option>
            <option value="door">Door</option>
            <option value="window">Window</option>
          </select>
        </div>

        <div class="panel-section">
          <label class="panel-label">Color</label>
          <select id="cc-color" class="form-select">
            <option value="">None (use prompt or material only)</option>
            <option value="White">White</option>
            <option value="Off White">Off White</option>
            <option value="Cream">Cream</option>
            <option value="Ivory">Ivory</option>
            <option value="Beige">Beige</option>
            <option value="Light Gray">Light Gray</option>
            <option value="Medium Gray">Medium Gray</option>
            <option value="Charcoal Black">Charcoal Black</option>
            <option value="Taupe">Taupe</option>
            <option value="Light Brown">Light Brown</option>
            <option value="Dark Brown">Dark Brown</option>
            <option value="Navy Blue">Navy Blue</option>
            <option value="Sky Blue">Sky Blue</option>
            <option value="Teal">Teal</option>
            <option value="Forest Green">Forest Green</option>
            <option value="Sage Green">Sage Green</option>
            <option value="Olive Green">Olive Green</option>
            <option value="Burgundy">Burgundy</option>
            <option value="Terracotta">Terracotta</option>
            <option value="Coral">Coral</option>
            <option value="Blush Pink">Blush Pink</option>
            <option value="Lavender">Lavender</option>
            <option value="Mustard Yellow">Mustard Yellow</option>
            <option value="Rust">Rust</option>
          </select>
        </div>

        <div class="panel-section">
          <label class="panel-label">Material <span class="optional-tag">optional</span></label>
          <select id="cc-materials" class="form-select">
            <option value="">None</option>
            <option value="Wood">Wood</option>
            <option value="Stone">Stone</option>
            <option value="Metal">Metal</option>
            <option value="Glass">Glass</option>
            <option value="Fabrics">Fabrics</option>
            <option value="Ceramics and Porcelain">Ceramics & Porcelain</option>
            <option value="Plastics and Polymers">Plastics & Polymers</option>
            <option value="Paper and Cardboard">Paper & Cardboard</option>
            <option value="Natural Fibers">Natural Fibers</option>
            <option value="Composite Materials">Composite Materials</option>
          </select>
        </div>

        <div class="panel-section" id="cc-materials-type-group" style="display:none;">
          <label class="panel-label">Material Type</label>
          <select id="cc-materials-type" class="form-select"></select>
        </div>

        <div class="panel-section">
          <label class="panel-label">Custom Instructions <span class="optional-tag">optional</span></label>
          <input type="text" id="cc-prompt" class="form-input" placeholder="e.g., Dark matte finish, rustic look">
          <span class="input-hint">Use when desired option isn't in the dropdowns</span>
        </div>
      </div>

      <div class="panel-actions">
        <button class="btn btn-primary btn-full" onclick="submitColorChange()" id="cc-submit-btn">
          <i data-lucide="sparkles"></i>
          Apply Changes
        </button>
      </div>
    </div>
  </div>
</div>
<% } %>

<!-- Fullscreen Modal -->
<div class="fullscreen-modal" id="fullscreen-modal" onclick="closeFullscreen()">
  <img src="" alt="Design" id="fullscreen-image">
  <button class="close-fullscreen"><i data-lucide="x"></i></button>
</div>

<style>
  .page-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: var(--spacing-xl);
  }
  
  .page-header {
    margin-bottom: var(--spacing-2xl);
  }
  
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-xs);
    color: var(--text-muted);
    font-size: 0.9rem;
    margin-bottom: var(--spacing-md);
  }
  
  .back-link:hover {
    color: var(--text-primary);
  }
  
  .page-header-flex {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--spacing-lg);
    flex-wrap: wrap;
  }
  
  .page-header-flex h1 {
    font-size: 2rem;
    margin-bottom: var(--spacing-sm);
  }
  
  .project-status-badge {
    display: inline-block;
    padding: 0.25rem 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-full);
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: capitalize;
  }
  
  .status-completed { color: var(--success); border-color: rgba(0, 255, 136, 0.3); }
  .status-generating { color: var(--warning); border-color: rgba(255, 165, 2, 0.3); }
  .status-draft { color: var(--text-muted); }
  
  .page-actions {
    display: flex;
    gap: var(--spacing-md);
  }
  
  .project-layout {
    display: grid;
    grid-template-columns: 1fr 350px;
    gap: var(--spacing-xl);
  }
  
  .section-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: var(--spacing-xl);
    margin-bottom: var(--spacing-xl);
  }
  
  .section-card h2 {
    font-size: 1.25rem;
    margin-bottom: var(--spacing-lg);
  }
  
  .design-gallery {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: var(--spacing-lg);
  }
  
  .design-variant {
    background: var(--bg-secondary);
    border: 2px solid var(--border-color);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: all var(--transition-base);
  }
  
  .design-variant:hover {
    border-color: var(--accent-primary);
  }
  
  .design-variant.selected {
    border-color: var(--accent-primary);
    box-shadow: 0 0 20px rgba(0, 255, 136, 0.2);
  }
  
  .variant-image {
    position: relative;
    height: 180px;
  }
  
  .variant-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .variant-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity var(--transition-fast);
  }
  
  .variant-image:hover .variant-overlay {
    opacity: 1;
  }
  
  .variant-info {
    padding: var(--spacing-md);
  }
  
  .variant-info h4 {
    font-size: 0.95rem;
    margin-bottom: var(--spacing-sm);
  }
  
  .empty-designs {
    text-align: center;
    padding: var(--spacing-3xl);
    color: var(--text-muted);
  }
  
  .empty-designs i {
    width: 48px;
    height: 48px;
    margin-bottom: var(--spacing-md);
  }
  
  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--spacing-lg);
  }
  
  .section-header h2 {
    margin: 0;
  }
  
  .original-gallery {
    display: flex;
    gap: var(--spacing-md);
    flex-wrap: wrap;
  }
  
  .original-image {
    position: relative;
    width: 150px;
    height: 150px;
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 2px solid var(--border-color);
  }
  
  .original-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .original-image .delete-img-btn {
    position: absolute;
    top: 8px;
    right: 8px;
    width: 32px;
    height: 32px;
    background: rgba(255, 50, 50, 0.9);
    border: none;
    border-radius: 50%;
    color: white;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity var(--transition-fast);
  }
  
  .original-image:hover .delete-img-btn {
    opacity: 1;
  }
  
  .original-image .delete-img-btn i {
    width: 16px;
    height: 16px;
  }
  
  .empty-images {
    text-align: center;
    padding: var(--spacing-3xl);
    background: var(--bg-secondary);
    border: 2px dashed var(--border-color);
    border-radius: var(--radius-lg);
    cursor: pointer;
    transition: all var(--transition-base);
  }
  
  .empty-images:hover {
    border-color: var(--accent-primary);
    background: rgba(0, 255, 136, 0.05);
  }
  
  .empty-images i {
    width: 48px;
    height: 48px;
    color: var(--text-muted);
    margin-bottom: var(--spacing-md);
  }
  
  .empty-images p {
    font-weight: 600;
    margin-bottom: var(--spacing-xs);
  }
  
  .empty-images span {
    font-size: 0.9rem;
    color: var(--text-muted);
  }
  
  .upload-section {
    margin-bottom: var(--spacing-xl);
    padding: var(--spacing-lg);
    background: var(--bg-secondary);
    border-radius: var(--radius-lg);
  }
  
  .upload-area {
    position: relative;
    border: 2px dashed var(--border-color);
    border-radius: var(--radius-md);
    transition: all var(--transition-base);
  }
  
  .upload-area:hover,
  .upload-area.dragover {
    border-color: var(--accent-primary);
    background: rgba(0, 255, 136, 0.05);
  }
  
  .file-input {
    position: absolute;
    width: 100%;
    height: 100%;
    opacity: 0;
    cursor: pointer;
  }
  
  .upload-label {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-sm);
    padding: var(--spacing-xl);
    text-align: center;
    cursor: pointer;
  }
  
  .upload-label i {
    width: 36px;
    height: 36px;
    color: var(--text-muted);
  }
  
  .upload-hint {
    font-size: 0.8rem;
    color: var(--text-muted);
  }
  
  .upload-preview {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
    margin-top: var(--spacing-md);
  }
  
  .upload-preview .preview-item {
    position: relative;
    width: 80px;
    height: 80px;
    border-radius: var(--radius-sm);
    overflow: hidden;
  }
  
  .upload-preview .preview-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .upload-actions {
    display: flex;
    justify-content: flex-end;
    gap: var(--spacing-md);
    margin-top: var(--spacing-lg);
  }
  
  .description-text {
    color: var(--text-secondary);
    line-height: 1.7;
    white-space: pre-wrap;
  }
  
  /* Sidebar */
  .sidebar-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: var(--spacing-lg);
    margin-bottom: var(--spacing-lg);
  }
  
  .sidebar-card h3 {
    font-size: 1rem;
    margin-bottom: var(--spacing-md);
  }
  
  .detail-list {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }
  
  .detail-item {
    display: flex;
    justify-content: space-between;
    font-size: 0.9rem;
  }
  
  .detail-label {
    color: var(--text-muted);
  }
  
  .detail-value {
    font-weight: 500;
    text-transform: capitalize;
  }
  
  .share-link {
    display: flex;
    gap: var(--spacing-sm);
  }
  
  .share-link input {
    flex: 1;
    font-size: 0.8rem;
  }
  
  .empty-text {
    font-size: 0.9rem;
    color: var(--text-muted);
  }
  
  .contractor-list {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }
  
  .contractor-request {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--spacing-sm);
    background: var(--bg-secondary);
    border-radius: var(--radius-sm);
  }
  
  .contractor-info strong {
    display: block;
    font-size: 0.9rem;
  }
  
  .contractor-info .quote {
    font-size: 0.8rem;
    color: var(--accent-primary);
  }
  
  .request-status {
    font-size: 0.75rem;
    text-transform: capitalize;
  }
  
  /* Color & Texture Editor (Full-Screen) */
  .color-editor {
    position: fixed;
    inset: 0;
    background: var(--bg-primary);
    display: none;
    flex-direction: column;
    z-index: 9998;
  }

  .color-editor.active {
    display: flex;
  }

  .color-editor-header {
    display: flex;
    align-items: center;
    gap: var(--spacing-lg);
    padding: 10px 16px;
    background: var(--bg-card);
    border-bottom: 1px solid var(--border-color);
    flex-shrink: 0;
    min-height: 52px;
  }

  .editor-title {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    color: var(--text-primary);
    font-weight: 600;
    font-size: 0.95rem;
    white-space: nowrap;
  }

  .editor-title i {
    width: 18px;
    height: 18px;
    color: var(--accent-primary);
  }

  .editor-toolbar {
    display: flex;
    align-items: center;
    gap: 8px;
    flex: 1;
    justify-content: center;
  }

  .tool-group {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .tool-separator {
    width: 1px;
