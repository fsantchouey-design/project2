  }

  .close-editor-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: transparent;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-sm);
    color: var(--text-muted);
    cursor: pointer;
    transition: all 0.15s;
    flex-shrink: 0;
  }

  .close-editor-btn:hover {
    background: var(--error);
    border-color: var(--error);
    color: #fff;
  }

  .close-editor-btn i {
    width: 18px;
    height: 18px;
  }

  .color-editor-body {
    flex: 1;
    display: flex;
    overflow: hidden;
  }

  .canvas-area {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 16px;
    min-width: 0;
    background: var(--bg-primary);
  }

  .canvas-wrapper {
    position: relative;
    display: inline-block;
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: 0 0 0 1px var(--border-color), var(--shadow-xl);
  }

  .canvas-wrapper canvas {
    display: block;
    cursor: none;
  }

  .canvas-cursor {
    position: absolute;
    border: 2px solid rgba(16, 185, 129, 0.8);
    border-radius: 50%;
    pointer-events: none;
    display: none;
    transform: translate(-50%, -50%);
    z-index: 10;
    box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.3);
  }

  .canvas-cursor.eraser-cursor {
    border-color: rgba(239, 68, 68, 0.8);
  }

  .canvas-hint {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    margin-top: 12px;
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .canvas-hint i {
    width: 14px;
    height: 14px;
  }

  .editor-panel {
    width: 300px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    background: var(--bg-card);
    border-left: 1px solid var(--border-color);
  }

  .panel-scroll {
    flex: 1;
    overflow-y: auto;
    padding: 20px 16px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .panel-section {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .panel-label {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .optional-tag {
    font-size: 0.65rem;
    font-weight: 400;
    color: var(--text-muted);
    text-transform: none;
    letter-spacing: 0;
    opacity: 0.7;
  }

  .input-hint {
    font-size: 0.72rem;
    color: var(--text-muted);
    margin-top: 2px;
    opacity: 0.7;
  }

  .editor-panel .form-select,
  .editor-panel .form-input {
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    color: var(--text-primary);
    font-size: 0.85rem;
    padding: 8px 10px;
    border-radius: var(--radius-sm);
  }

  .editor-panel .form-select:focus,
  .editor-panel .form-input:focus {
    border-color: var(--accent-primary);
    outline: none;
    box-shadow: 0 0 0 2px rgba(16, 185, 129, 0.15);
  }

  .panel-actions {
    padding: 16px;
    border-top: 1px solid var(--border-color);
    flex-shrink: 0;
  }

  .btn-full {
    width: 100%;
    justify-content: center;
  }

  @media (max-width: 768px) {
    .color-editor-body {
      flex-direction: column;
    }
    .editor-panel {
      width: 100%;
      max-height: 40vh;
      border-left: none;
      border-top: 1px solid var(--border-color);
    }
    .canvas-area {
      min-height: 300px;
    }
    .editor-toolbar {
      display: none;
    }
  }

  /* Fullscreen Modal */
  .fullscreen-modal {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.95);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 9999;
    padding: var(--spacing-xl);
  }
  
  .fullscreen-modal.active {
    display: flex;
  }
  
  .fullscreen-modal img {
    max-width: 100%;
    max-height: 100%;
    border-radius: var(--radius-lg);
  }
  
  .close-fullscreen {
    position: absolute;
    top: var(--spacing-xl);
    right: var(--spacing-xl);
    background: var(--bg-card);
    border: none;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    color: var(--text-primary);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  @media (max-width: 1024px) {
    .project-layout {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const projectId = '<%= project._id %>';
  const uploadSection = document.getElementById('upload-section');
  const uploadForm = document.getElementById('upload-form');
  const uploadArea = document.getElementById('upload-area');
  const fileInput = document.getElementById('images');
  const previewContainer = document.getElementById('upload-preview');
  
  function toggleUpload() {
    uploadSection.style.display = uploadSection.style.display === 'none' ? 'block' : 'none';
    if (uploadSection.style.display === 'block') {
      lucide.createIcons();
    }
  }
  
  // Drag and drop
  if (uploadArea) {
    ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
      uploadArea.addEventListener(eventName, e => {
        e.preventDefault();
        e.stopPropagation();
      }, false);
    });
    
    ['dragenter', 'dragover'].forEach(eventName => {
      uploadArea.addEventListener(eventName, () => uploadArea.classList.add('dragover'), false);
    });
    
    ['dragleave', 'drop'].forEach(eventName => {
      uploadArea.addEventListener(eventName, () => uploadArea.classList.remove('dragover'), false);
    });
    
    uploadArea.addEventListener('drop', (e) => {
      const dt = e.dataTransfer;
      fileInput.files = dt.files;
      fileInput.dispatchEvent(new Event('change'));
    });
  }
  
  // Image preview
  if (fileInput) {
    fileInput.addEventListener('change', function() {
      previewContainer.innerHTML = '';
      
      Array.from(this.files).forEach((file, index) => {
        const reader = new FileReader();
        reader.onload = function(e) {
          const previewItem = document.createElement('div');
          previewItem.className = 'preview-item';
          previewItem.innerHTML = `<img src="${e.target.result}" alt="Preview">`;
          previewContainer.appendChild(previewItem);
        };
        reader.readAsDataURL(file);
      });
    });
  }
  
  // Upload form submit
  if (uploadForm) {
    uploadForm.addEventListener('submit', async function(e) {
      e.preventDefault();
      
      const formData = new FormData();
      Array.from(fileInput.files).forEach(file => {
        formData.append('images', file);
      });
      
      const uploadBtn = document.getElementById('upload-btn');
      uploadBtn.disabled = true;
      uploadBtn.innerHTML = '<span class="spinner"></span> Uploading...';
      
      try {
        const response = await fetch(`/projects/${projectId}/upload`, {
          method: 'POST',
          body: formData
        });
        
        const data = await response.json();
        
        if (data.success) {
          if (typeof CraftyCrib !== 'undefined') {
            CraftyCrib.showToast(data.message);
          }
          setTimeout(() => window.location.reload(), 500);
        } else {
          if (typeof CraftyCrib !== 'undefined') {
            CraftyCrib.showToast(data.error || 'Upload failed', 'error');
          }
          uploadBtn.disabled = false;
          uploadBtn.innerHTML = '<i data-lucide="upload"></i> Upload Images';
          lucide.createIcons();
        }
      } catch (err) {
        if (typeof CraftyCrib !== 'undefined') {
          CraftyCrib.showToast('An error occurred', 'error');
        }
        uploadBtn.disabled = false;
        uploadBtn.innerHTML = '<i data-lucide="upload"></i> Upload Images';
        lucide.createIcons();
      }
    });
  }
  
  async function deleteImage(imageId) {
    if (!confirm('Are you sure you want to delete this image?')) return;
    
    try {
      const response = await fetch(`/projects/${projectId}/images/${imageId}`, {
        method: 'DELETE'
      });
      
      const data = await response.json();
      
      if (data.success) {
        if (typeof CraftyCrib !== 'undefined') {
          CraftyCrib.showToast('Image deleted');
        }
        window.location.reload();
      } else {
        if (typeof CraftyCrib !== 'undefined') {
          CraftyCrib.showToast(data.error || 'Delete failed', 'error');
        }
      }
    } catch (err) {
      if (typeof CraftyCrib !== 'undefined') {
        CraftyCrib.showToast('An error occurred', 'error');
      }
    }
  }
  
  function showNotification(message, type = 'success') {
    if (typeof CraftyCrib !== 'undefined' && CraftyCrib.showToast) {
      CraftyCrib.showToast(message, type);
    } else {
      const toast = document.createElement('div');
      toast.style.cssText = 'position:fixed;top:20px;right:20px;z-index:99999;padding:14px 24px;border-radius:8px;color:#fff;font-size:0.95rem;max-width:400px;box-shadow:0 4px 20px rgba(0,0,0,0.3);transition:opacity 0.3s;';
      toast.style.background = type === 'error' ? '#e74c3c' : '#00ff88';
      if (type !== 'error') toast.style.color = '#000';
      toast.textContent = message;
      document.body.appendChild(toast);
      setTimeout(() => { toast.style.opacity = '0'; setTimeout(() => toast.remove(), 300); }, 5000);
    }
  }

  async function generateDesign() {
    const btn = document.getElementById('generate-btn');
    if (btn) {
      btn.disabled = true;
      btn.innerHTML = '<span class="spinner"></span> Generating...';
    }

    function resetBtn() {
      if (btn) {
        btn.disabled = false;
        btn.innerHTML = '<i data-lucide="sparkles"></i> Generate Design';
        lucide.createIcons();
      }
    }

    try {
      const response = await fetch(`/projects/${projectId}/generate`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' }
      });

      // Session expired - server redirected to login page
      if (response.redirected) {
        window.location.href = '/auth/login';
        return;
      }

      // Check if response is JSON before parsing
      const contentType = response.headers.get('content-type');
      if (!contentType || !contentType.includes('application/json')) {
        if (response.status === 401) {
          showNotification('Session expired. Please log in again.', 'error');
          setTimeout(() => window.location.href = '/auth/login', 1500);
          return;
        }
        throw new Error('Server returned an unexpected response. Please try again.');
      }

      const data = await response.json();

      if (data.success) {
        showNotification('Design generated successfully!');
        setTimeout(() => window.location.reload(), 1000);
      } else {
        const errorMsg = data.error || 'Failed to generate design';
        showNotification(errorMsg, 'error');
        console.error('Generation failed:', errorMsg);
        resetBtn();
      }
    } catch (err) {
      console.error('Generation error:', err);
      showNotification(err.message || 'An error occurred while generating', 'error');
      resetBtn();
    }
  }
  
  function copyShareLink() {
    const input = document.getElementById('share-url');
    input.select();
    document.execCommand('copy');
    if (typeof CraftyCrib !== 'undefined') {
      CraftyCrib.showToast('Link copied to clipboard!');
    }
  }
  
  async function updateVisibility(visibility) {
    try {
      const response = await fetch(`/api/projects/${projectId}/status`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ visibility })
      });
      if (typeof CraftyCrib !== 'undefined') {
        CraftyCrib.showToast('Visibility updated');
      }
    } catch (err) {
      if (typeof CraftyCrib !== 'undefined') {
        CraftyCrib.showToast('Failed to update visibility', 'error');
      }
    }
  }
  
  function viewFullscreen(imageUrl) {
    const modal = document.getElementById('fullscreen-modal');
    const img = document.getElementById('fullscreen-image');
    img.src = imageUrl;
    modal.classList.add('active');
  }
  
  function closeFullscreen() {
    document.getElementById('fullscreen-modal').classList.remove('active');
  }
  
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      closeFullscreen();
      closeColorChanger();
    }
  });

  // === Color & Texture Editor ===
  <% if (project.originalImages && project.originalImages.length > 0) { %>
  let maskCanvas, displayCtx;
  let overlayCanvas, overlayCtx;
  let painting = false;
  let bgImage = null;
  let currentTool = 'brush';
  let lastPoint = null;
  let strokeHistory = [];
  const MAX_UNDO = 25;
  let editorInitialized = false;

  const MATERIAL_SUBTYPES = {
    'Wood': ['Oak', 'Maple', 'Cherry', 'Walnut', 'Pine', 'Teak', 'Mahogany', 'Bamboo', 'Birch', 'Rosewood', 'Ash', 'Cedar', 'Hickory', 'Alder', 'Ebony'],
    'Stone': ['Marble', 'Granite', 'Limestone', 'Slate', 'Travertine', 'Sandstone', 'Quartzite', 'Onyx', 'Soapstone', 'Basalt', 'Flagstone', 'Bluestone', 'Fieldstone', 'Cobblestone', 'Terrazzo'],
    'Metal': ['Gold', 'Silver', 'Bronze', 'Copper', 'Brass', 'Iron', 'Steel', 'Aluminum', 'Nickel', 'Titanium', 'Platinum', 'Chrome', 'Zinc', 'Pewter', 'Tin'],
    'Glass': ['Clear', 'Frosted', 'Tinted', 'Stained', 'Tempered', 'Laminated', 'Mirrored', 'Etched', 'Colored', 'Opaque', 'Crackle', 'Murano', 'Sea', 'Blown', 'Fused'],
    'Fabrics': ['Cotton', 'Linen', 'Silk', 'Velvet', 'Wool', 'Leather', 'Suede', 'Tweed', 'Chenille', 'Jacquard', 'Satin', 'Polyester', 'Nylon', 'Rayon', 'Cashmere'],
    'Ceramics and Porcelain': ['Glazed', 'Matte', 'Porcelain', 'Terracotta', 'Mosaic', 'Subway', 'Hexagonal', 'Penny', 'Quarry', 'Encaustic', 'Majolica', 'Delft', 'Raku', 'Bisque', 'Celadon'],
    'Plastics and Polymers': ['Acrylic', 'Polycarbonate', 'PVC', 'Polyethylene', 'Polypropylene', 'ABS', 'Nylon', 'Teflon', 'Silicone', 'Epoxy', 'Fiberglass', 'Melamine', 'Bakelite', 'Lucite', 'Resin'],
    'Paper and Cardboard': ['Wallpaper', 'Cardboard', 'Kraft', 'Parchment', 'Foil embossed', 'Textured', 'Handmade paper', 'Recycled paper', 'Flocked paper', 'Metallic paper', 'Vellum', 'Linen paper', 'Watercolor paper', 'Matte', 'Glossy'],
    'Natural Fibers': ['Jute', 'Sisal', 'Hemp', 'Bamboo', 'Rattan', 'Wicker', 'Seagrass', 'Coir', 'Cotton', 'Linen', 'Wool', 'Silk', 'Raffia', 'Palm', 'Cork'],
    'Composite Materials': ['MDF', 'Plywood', 'Particleboard', 'Laminate', 'Fiberglass', 'Carbon Fiber', 'Kevlar', 'Corian', 'Quartz', 'Engineered Stone', 'WPC', 'Cement Board', 'Hardboard', 'OSB', 'LVL']
  };

  function openColorChanger() {
    const modal = document.getElementById('color-modal');
    modal.classList.add('active');
    lucide.createIcons();

    if (!editorInitialized) {
      initMaskCanvas();
      bindEditorEvents();
      editorInitialized = true;
    } else if (bgImage) {
      resizeCanvas();
    }
  }

  function closeColorChanger() {
    const modal = document.getElementById('color-modal');
    if (modal) modal.classList.remove('active');
  }

  function bindEditorEvents() {
    document.getElementById('cc-materials').addEventListener('change', function() {
      const typeGroup = document.getElementById('cc-materials-type-group');
      const typeSelect = document.getElementById('cc-materials-type');
      if (this.value && MATERIAL_SUBTYPES[this.value]) {
        typeSelect.innerHTML = '';
        MATERIAL_SUBTYPES[this.value].forEach(t => {
          const opt = document.createElement('option');
          opt.value = t;
          opt.textContent = t;
          typeSelect.appendChild(opt);
        });
        typeGroup.style.display = 'block';
      } else {
        typeGroup.style.display = 'none';
      }
    });

    document.getElementById('brush-size').addEventListener('input', function() {
      document.getElementById('brush-size-display').textContent = this.value;
    });

    document.addEventListener('keydown', function(e) {
      const modal = document.getElementById('color-modal');
      if (!modal || !modal.classList.contains('active')) return;
      if (e.ctrlKey && e.key === 'z') { e.preventDefault(); undoStroke(); }
      if (e.key === 'b' && !e.ctrlKey && document.activeElement.tagName !== 'INPUT') setTool('brush');
      if (e.key === 'e' && !e.ctrlKey && document.activeElement.tagName !== 'INPUT') setTool('eraser');
    });
  }

  function setTool(tool) {
    currentTool = tool;
    document.getElementById('tool-brush').classList.toggle('active', tool === 'brush');
    document.getElementById('tool-eraser').classList.toggle('active', tool === 'eraser');
    const cursor = document.getElementById('canvas-cursor');
    cursor.classList.toggle('eraser-cursor', tool === 'eraser');
  }

  function initMaskCanvas() {
    maskCanvas = document.getElementById('mask-canvas');
    displayCtx = maskCanvas.getContext('2d');

    const img = new Image();
    img.crossOrigin = 'anonymous';
    img.onload = function() {
      bgImage = img;
      resizeCanvas();
    };
    img.src = '<%= project.originalImages[0].url %>';

    maskCanvas.addEventListener('mousedown', startPaint);
    maskCanvas.addEventListener('mousemove', onCanvasMouseMove);
    maskCanvas.addEventListener('mouseup', stopPaint);
    maskCanvas.addEventListener('mouseleave', function() { stopPaint(); hideCursor(); });
    maskCanvas.addEventListener('mouseenter', showCursor);

    maskCanvas.addEventListener('touchstart', (e) => { e.preventDefault(); startPaint(getTouchPos(e)); }, { passive: false });
    maskCanvas.addEventListener('touchmove', (e) => { e.preventDefault(); onCanvasMouseMove(getTouchPos(e)); }, { passive: false });
    maskCanvas.addEventListener('touchend', stopPaint);
  }

  function resizeCanvas() {
    if (!bgImage) return;
    const area = document.querySelector('.canvas-area');
    const maxW = area.clientWidth - 32;
    const maxH = area.clientHeight - 60;
    const scale = Math.min(maxW / bgImage.width, maxH / bgImage.height, 1);
    const w = Math.round(bgImage.width * scale);
    const h = Math.round(bgImage.height * scale);

    const prevOverlay = overlayCanvas;
    maskCanvas.width = w;
    maskCanvas.height = h;

    overlayCanvas = document.createElement('canvas');
    overlayCanvas.width = w;
    overlayCanvas.height = h;
    overlayCtx = overlayCanvas.getContext('2d');

    if (prevOverlay) {
      overlayCtx.drawImage(prevOverlay, 0, 0, prevOverlay.width, prevOverlay.height, 0, 0, w, h);
    }

    strokeHistory = [];
    compositeDisplay();
  }

  function getTouchPos(e) {
    const rect = maskCanvas.getBoundingClientRect();
    const touch = e.touches[0];
    return { offsetX: touch.clientX - rect.left, offsetY: touch.clientY - rect.top };
  }

  function compositeDisplay() {
    displayCtx.clearRect(0, 0, maskCanvas.width, maskCanvas.height);
    displayCtx.drawImage(bgImage, 0, 0, maskCanvas.width, maskCanvas.height);
    displayCtx.globalAlpha = 0.4;
    displayCtx.drawImage(overlayCanvas, 0, 0);
    displayCtx.globalAlpha = 1.0;
  }

  function startPaint(e) {
    painting = true;
    strokeHistory.push(overlayCtx.getImageData(0, 0, overlayCanvas.width, overlayCanvas.height));
    if (strokeHistory.length > MAX_UNDO) strokeHistory.shift();
    lastPoint = { x: e.offsetX, y: e.offsetY };
    paintAt(e.offsetX, e.offsetY);
  }

  function onCanvasMouseMove(e) {
    updateCursor(e);
    if (painting) paintAt(e.offsetX, e.offsetY);
  }

  function paintAt(x, y) {
    const brushSize = parseInt(document.getElementById('brush-size').value);

    if (currentTool === 'brush') {
      overlayCtx.globalCompositeOperation = 'source-over';
      overlayCtx.strokeStyle = '#00ff88';
      overlayCtx.fillStyle = '#00ff88';
    } else {
      overlayCtx.globalCompositeOperation = 'destination-out';
      overlayCtx.strokeStyle = 'rgba(0,0,0,1)';
      overlayCtx.fillStyle = 'rgba(0,0,0,1)';
    }

    if (lastPoint) {
      overlayCtx.beginPath();
      overlayCtx.lineWidth = brushSize;
      overlayCtx.lineCap = 'round';
      overlayCtx.lineJoin = 'round';
      overlayCtx.moveTo(lastPoint.x, lastPoint.y);
      overlayCtx.lineTo(x, y);
      overlayCtx.stroke();
    } else {
      overlayCtx.beginPath();
      overlayCtx.arc(x, y, brushSize / 2, 0, Math.PI * 2);
      overlayCtx.fill();
    }

    overlayCtx.globalCompositeOperation = 'source-over';
    lastPoint = { x, y };
    compositeDisplay();
  }

  function stopPaint() {
    painting = false;
    lastPoint = null;
  }

  function undoStroke() {
    if (strokeHistory.length > 0) {
      overlayCtx.putImageData(strokeHistory.pop(), 0, 0);
      compositeDisplay();
    }
  }

  function clearMask() {
    strokeHistory = [];
    if (overlayCtx) overlayCtx.clearRect(0, 0, overlayCanvas.width, overlayCanvas.height);
    if (bgImage) compositeDisplay();
  }

  function updateCursor(e) {
    const cursor = document.getElementById('canvas-cursor');
    const brushSize = parseInt(document.getElementById('brush-size').value);
    cursor.style.width = brushSize + 'px';
    cursor.style.height = brushSize + 'px';
    cursor.style.left = e.offsetX + 'px';
    cursor.style.top = e.offsetY + 'px';
    cursor.style.display = 'block';
  }

  function showCursor() {
    document.getElementById('canvas-cursor').style.display = 'block';
  }

  function hideCursor() {
    document.getElementById('canvas-cursor').style.display = 'none';
  }

  function hasMaskContent() {
    if (!overlayCtx) return false;
    const data = overlayCtx.getImageData(0, 0, overlayCanvas.width, overlayCanvas.height).data;
    for (let i = 3; i < data.length; i += 4) {
      if (data[i] > 0) return true;
    }
    return false;
  }

  function generateMaskBase64() {
    const tempCanvas = document.createElement('canvas');
    tempCanvas.width = maskCanvas.width;
    tempCanvas.height = maskCanvas.height;
    const ctx = tempCanvas.getContext('2d');

    ctx.fillStyle = '#000000';
    ctx.fillRect(0, 0, tempCanvas.width, tempCanvas.height);

    const overlayData = overlayCtx.getImageData(0, 0, overlayCanvas.width, overlayCanvas.height);
    const maskData = ctx.getImageData(0, 0, tempCanvas.width, tempCanvas.height);
    for (let i = 0; i < overlayData.data.length; i += 4) {
      if (overlayData.data[i + 3] > 0) {
        maskData.data[i] = 255;
        maskData.data[i + 1] = 255;
        maskData.data[i + 2] = 255;
        maskData.data[i + 3] = 255;
      }
    }
    ctx.putImageData(maskData, 0, 0);
    return tempCanvas.toDataURL('image/png');
  }

  async function submitColorChange() {
    if (!hasMaskContent()) {
      showNotification('Please paint over the areas you want to change first', 'error');
      return;
    }

    const color = document.getElementById('cc-color').value;
    const materials = document.getElementById('cc-materials').value;
    const materialsType = document.getElementById('cc-materials-type').value;
    const prompt = document.getElementById('cc-prompt').value;
    const object = document.getElementById('cc-object').value;

    if (!color && !materials && !prompt) {
      showNotification('Please select a color, material, or provide custom instructions', 'error');
      return;
    }

    const btn = document.getElementById('cc-submit-btn');
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner"></span> Processing...';

    function resetBtn() {
      btn.disabled = false;
      btn.innerHTML = '<i data-lucide="sparkles"></i> Apply Changes';
      lucide.createIcons();
    }

    try {
      const body = { maskBase64: generateMaskBase64(), object };
      if (prompt) body.prompt = prompt;
      if (color) body.color = color;
      if (materials) {
        body.materials = materials;
        if (materialsType) body.materialsType = materialsType;
      }

      const response = await fetch(`/projects/${projectId}/change-colors`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body)
      });

      const contentType = response.headers.get('content-type');
      if (!contentType || !contentType.includes('application/json')) {
        if (response.status === 401) {
          showNotification('Session expired. Please log in again.', 'error');
          setTimeout(() => window.location.href = '/auth/login', 1500);
          return;
        }
        throw new Error('Server returned an unexpected response');
      }

      const data = await response.json();

      if (data.success) {
        showNotification('Colors changed successfully!');
        closeColorChanger();
        setTimeout(() => window.location.reload(), 1000);
      } else {
        showNotification(data.error || 'Failed to change colors', 'error');
        resetBtn();
      }
    } catch (err) {
      console.error('Color change error:', err);
      showNotification(err.message || 'An error occurred', 'error');
      resetBtn();
    }
  }
  <% } %>
</script>

