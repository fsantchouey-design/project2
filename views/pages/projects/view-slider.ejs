<%
  const originalImage = (project.originalImages && project.originalImages[0] && project.originalImages[0].url) || '';
  const latestVariant = (project.designVariants && project.designVariants.length)
    ? project.designVariants[project.designVariants.length - 1]
    : null;
  const generatedImage = latestVariant ? (latestVariant.imageUrl || latestVariant.thumbnailUrl || '') : '';
%>

<div class="project-compare-page">
  <header class="project-compare-header">
    <a href="/projects/<%= project._id %>/studio" class="back-link">Back to Studio</a>
    <div>
      <p class="eyebrow">Project Preview</p>
      <h1><%= project.title || 'Project' %></h1>
      <p>Compare the original image with the latest generated design.</p>
    </div>
    <a href="/projects/<%= project._id %>/studio" class="studio-link">Open AI Studio</a>
  </header>

  <% if (originalImage && generatedImage) { %>
    <section class="before-after" id="before-after">
      <img class="before-after__image before-after__image--after" src="<%= generatedImage %>" alt="Latest generated design">
      <div class="before-after__before" id="before-layer">
        <img class="before-after__image" src="<%= originalImage %>" alt="Original project image">
      </div>
      <div class="before-after__handle" id="compare-handle" aria-hidden="true">
        <span></span>
      </div>
      <input class="before-after__range" id="compare-range" type="range" min="0" max="100" value="50" aria-label="Before after comparison">
      <div class="before-after__labels">
        <span>Original</span>
        <span>Latest Design</span>
      </div>
    </section>
  <% } else { %>
    <section class="project-compare-empty">
      <h2>No comparison available yet</h2>
      <p>Open the AI Studio, generate a design, then come back to compare the result.</p>
      <a href="/projects/<%= project._id %>/studio" class="studio-link">Open AI Studio</a>
    </section>
  <% } %>
</div>

<style>
  .project-compare-page {
    min-height: calc(100vh - 80px);
    padding: 32px;
    color: #f8fafc;
    background:
      radial-gradient(circle at top left, rgba(20, 184, 166, 0.18), transparent 34%),
      #07111f;
  }

  .project-compare-header {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 24px;
    align-items: center;
    margin-bottom: 28px;
  }

  .project-compare-header h1 {
    margin: 4px 0 8px;
    font-size: clamp(2rem, 3vw, 3.2rem);
  }

  .project-compare-header p {
    margin: 0;
    color: #94a3b8;
  }

  .eyebrow {
    color: #5eead4;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .back-link,
  .studio-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0 18px;
    border: 1px solid rgba(94, 234, 212, 0.28);
    border-radius: 12px;
    color: #f8fafc;
    text-decoration: none;
    background: rgba(15, 23, 42, 0.72);
  }

  .studio-link {
    background: linear-gradient(135deg, #14b8a6, #2563eb);
    border-color: transparent;
    font-weight: 800;
  }

  .before-after {
    position: relative;
    overflow: hidden;
    max-width: 1180px;
    aspect-ratio: 16 / 10;
    margin: 0 auto;
    border: 1px solid rgba(94, 234, 212, 0.22);
    border-radius: 24px;
    background: #020617;
    box-shadow: 0 32px 90px rgba(0, 0, 0, 0.34);
  }

  .before-after__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    user-select: none;
    pointer-events: none;
  }

  .before-after__before {
    position: absolute;
    inset: 0;
    width: 50%;
    overflow: hidden;
  }

  .before-after__handle {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    width: 3px;
    background: #5eead4;
    transform: translateX(-50%);
    pointer-events: none;
  }

  .before-after__handle span {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 54px;
    height: 54px;
    border: 2px solid rgba(255, 255, 255, 0.88);
    border-radius: 999px;
    background: rgba(15, 23, 42, 0.84);
    transform: translate(-50%, -50%);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.4);
  }

  .before-after__range {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    cursor: ew-resize;
  }

  .before-after__labels {
    position: absolute;
    left: 18px;
    right: 18px;
    bottom: 18px;
    display: flex;
    justify-content: space-between;
    gap: 16px;
    pointer-events: none;
  }

  .before-after__labels span {
    padding: 8px 12px;
    border-radius: 999px;
    background: rgba(2, 6, 23, 0.74);
    color: #f8fafc;
    font-weight: 800;
  }

  .project-compare-empty {
    max-width: 720px;
    margin: 80px auto 0;
    padding: 36px;
    border: 1px dashed rgba(94, 234, 212, 0.32);
    border-radius: 24px;
    text-align: center;
    background: rgba(15, 23, 42, 0.78);
  }

  @media (max-width: 760px) {
    .project-compare-page {
      padding: 20px;
    }

    .project-compare-header {
      grid-template-columns: 1fr;
    }

    .before-after {
      aspect-ratio: 4 / 5;
    }
  }
</style>

<script>
  const range = document.getElementById('compare-range');
  const beforeLayer = document.getElementById('before-layer');
  const handle = document.getElementById('compare-handle');

  function updateComparison(value) {
    if (!beforeLayer || !handle) return;
    beforeLayer.style.width = `${value}%`;
    handle.style.left = `${value}%`;
  }

  range?.addEventListener('input', (event) => {
    updateComparison(event.target.value);
  });

  updateComparison(range?.value || 50);
</script>
