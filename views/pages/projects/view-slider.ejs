<%
  const originalImage = (project.originalImages && project.originalImages[0] && project.originalImages[0].url) || '';
  const allVariants = (project.designVariants || []).slice().reverse();
  const latestVariant = allVariants.length ? allVariants[0] : null;
  const generatedImage = latestVariant ? (latestVariant.imageUrl || latestVariant.thumbnailUrl || '') : '';
  const mainInitialImage = generatedImage || originalImage;

  const allDesigns = [];
  allVariants.forEach(function(variant) {
    const img = variant.imageUrl || variant.thumbnailUrl || '';
    if (!img) return;
    allDesigns.push({
      id: variant._id ? String(variant._id) : '',
      name: variant.name || variant.tool || 'Generated design',
      imageUrl: img,
      thumbnailUrl: variant.thumbnailUrl || img,
      tool: variant.tool || '',
      style: variant.aiParameters && variant.aiParameters.style ? variant.aiParameters.style : (project.style || ''),
      generatedAt: variant.generatedAt || variant.createdAt || null,
      isOriginal: false
    });
  });
  if (originalImage) {
    allDesigns.push({
      id: 'original',
      name: 'Image originale',
      imageUrl: originalImage,
      thumbnailUrl: originalImage,
      tool: '',
      style: '',
      generatedAt: (project.originalImages[0] && project.originalImages[0].uploadedAt) || null,
      isOriginal: true
    });
  }
%>

<div class="project-compare-page">
  <header class="project-compare-header">
    <a href="/projects/<%= project._id %>/studio" class="back-link">Back to Studio</a>
    <div>
      <p class="eyebrow">Project Preview</p>
      <h1><%= project.title || 'Project' %></h1>
      <p>Visualisez vos générations et sélectionnez la version souhaitée.</p>
      <div class="project-compare-meta">
        <% if (project.style) { %><span>Style: <%= project.style %></span><% } %>
        <% if (project.status) { %><span>Status: <%= project.status %></span><% } %>
        <% if (latestVariant && latestVariant.tool) { %><span>Tool: <%= latestVariant.tool %></span><% } %>
      </div>
    </div>
    <a href="/projects/<%= project._id %>/studio" class="studio-link">Open AI Studio</a>
  </header>

  <% if (mainInitialImage) { %>
    <section class="main-image-section">
      <div class="main-image-wrapper">
        <img id="main-display-image" src="<%= mainInitialImage %>" alt="Design principal">
        <div class="main-image-badge" id="main-image-badge">
          <% if (generatedImage) { %><%= latestVariant && latestVariant.tool ? latestVariant.tool : 'Dernière génération' %><% } else { %>Image originale<% } %>
        </div>
      </div>
    </section>

    <% if (allDesigns.length) { %>
      <section class="compare-latest">
        <div class="compare-latest__header">
          <div>
            <p class="eyebrow">Toutes les versions</p>
            <h2>Cliquez sur une image pour l'afficher</h2>
          </div>
          <span><%= allDesigns.length %> version<%= allDesigns.length > 1 ? 's' : '' %></span>
        </div>
        <div class="compare-latest__grid" id="compare-latest-grid">
          <% allDesigns.forEach(function(design, index) { %>
            <button
              type="button"
              class="compare-design-card <%= index === 0 ? 'is-active' : '' %>"
              data-index="<%= index %>"
              data-original="<%= design.isOriginal ? 'true' : 'false' %>"
            >
              <img src="<%= design.thumbnailUrl || design.imageUrl %>" alt="<%= design.name %>" loading="lazy">
              <% if (design.isOriginal) { %>
                <div class="card-badge card-badge--original">Original</div>
              <% } %>
              <span class="card-label"><%= design.name %></span>
            </button>
          <% }); %>
        </div>
      </section>
    <% } %>
  <% } else { %>
    <section class="project-compare-empty">
      <h2>Aucun design disponible</h2>
      <p>Ouvrez le Studio IA, générez un design, puis revenez sur cette page.</p>
      <a href="/projects/<%= project._id %>/studio" class="studio-link">Open AI Studio</a>
    </section>
  <% } %>
</div>

<style>
  .project-compare-page {
    min-height: calc(100vh - 80px);
    padding: 32px;
    color: #f8fafc;
    background:
      radial-gradient(circle at top left, rgba(20, 184, 166, 0.18), transparent 34%),
      #07111f;
  }

  .project-compare-header {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 24px;
    align-items: center;
    margin-bottom: 28px;
  }

  .project-compare-header h1 {
    margin: 4px 0 8px;
    font-size: clamp(2rem, 3vw, 3.2rem);
  }

  .project-compare-header p {
    margin: 0;
    color: #94a3b8;
  }

  .project-compare-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 14px;
  }

  .project-compare-meta span {
    padding: 7px 11px;
    border: 1px solid rgba(94, 234, 212, 0.2);
    border-radius: 999px;
    color: #cbd5e1;
    background: rgba(15, 23, 42, 0.72);
    font-size: 0.85rem;
    font-weight: 700;
  }

  .eyebrow {
    color: #5eead4;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .back-link,
  .studio-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0 18px;
    border: 1px solid rgba(94, 234, 212, 0.28);
    border-radius: 12px;
    color: #f8fafc;
    text-decoration: none;
    background: rgba(15, 23, 42, 0.72);
  }

  .studio-link {
    background: linear-gradient(135deg, #14b8a6, #2563eb);
    border-color: transparent;
    font-weight: 800;
  }

  /* Main image display */
  .main-image-section {
    max-width: 1180px;
    margin: 0 auto 28px;
  }

  .main-image-wrapper {
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(94, 234, 212, 0.22);
    border-radius: 24px;
    background: #020617;
    box-shadow: 0 32px 90px rgba(0, 0, 0, 0.34);
    aspect-ratio: 16 / 9;
  }

  #main-display-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: opacity 0.22s ease;
  }

  .main-image-badge {
    position: absolute;
    top: 18px;
    left: 18px;
    padding: 8px 14px;
    border-radius: 999px;
    background: rgba(2, 6, 23, 0.78);
    color: #5eead4;
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    backdrop-filter: blur(8px);
    border: 1px solid rgba(94, 234, 212, 0.28);
  }

  /* Latest designs grid */
  .project-compare-empty {
    max-width: 720px;
    margin: 80px auto 0;
    padding: 36px;
    border: 1px dashed rgba(94, 234, 212, 0.32);
    border-radius: 24px;
    text-align: center;
    background: rgba(15, 23, 42, 0.78);
  }

  .compare-latest {
    max-width: 1180px;
    margin: 0 auto;
    padding: 22px;
    border: 1px solid rgba(94, 234, 212, 0.18);
    border-radius: 22px;
    background: rgba(15, 23, 42, 0.78);
  }

  .compare-latest__header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 16px;
  }

  .compare-latest__header h2 {
    margin: 4px 0 0;
    font-size: 1.25rem;
  }

  .compare-latest__header span {
    color: #94a3b8;
    font-weight: 800;
  }

  .compare-latest__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 12px;
  }

  .compare-design-card {
    position: relative;
    overflow: hidden;
    min-height: 110px;
    border: 2px solid rgba(148, 163, 184, 0.16);
    border-radius: 14px;
    background: #020617;
    cursor: pointer;
    padding: 0;
    transition: transform 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease;
  }

  .compare-design-card:hover,
  .compare-design-card.is-active {
    transform: translateY(-2px);
    border-color: rgba(94, 234, 212, 0.72);
    box-shadow: 0 18px 36px rgba(20, 184, 166, 0.16);
  }

  .compare-design-card[data-original="true"] {
    border-color: rgba(251, 191, 36, 0.38);
  }

  .compare-design-card[data-original="true"]:hover,
  .compare-design-card[data-original="true"].is-active {
    border-color: rgba(251, 191, 36, 0.88);
    box-shadow: 0 18px 36px rgba(251, 191, 36, 0.14);
  }

  .compare-design-card img {
    width: 100%;
    height: 100%;
    min-height: 110px;
    object-fit: cover;
    display: block;
  }

  .card-badge {
    position: absolute;
    top: 8px;
    left: 8px;
    padding: 4px 10px;
    border-radius: 999px;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .card-badge--original {
    background: rgba(251, 191, 36, 0.92);
    color: #1c1400;
  }

  .card-label {
    position: absolute;
    left: 8px;
    right: 8px;
    bottom: 8px;
    color: #fff;
    font-size: 0.76rem;
    font-weight: 800;
    text-align: left;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.78);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  @media (max-width: 760px) {
    .project-compare-page {
      padding: 20px;
    }

    .project-compare-header {
      grid-template-columns: 1fr;
    }

    .main-image-wrapper {
      aspect-ratio: 4 / 3;
    }

    .compare-latest__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>

<script>
  const mainImage = document.getElementById('main-display-image');
  const mainBadge = document.getElementById('main-image-badge');
  const latestGrid = document.getElementById('compare-latest-grid');
  const allDesigns = <%- JSON.stringify(allDesigns) %>;

  latestGrid?.addEventListener('click', (event) => {
    const card = event.target.closest('.compare-design-card');
    if (!card || !mainImage) return;
    const design = allDesigns[Number(card.dataset.index)];
    if (!design) return;

    mainImage.style.opacity = '0';
    setTimeout(() => {
      mainImage.src = design.imageUrl || design.thumbnailUrl;
      mainImage.style.opacity = '1';
    }, 120);

    if (mainBadge) {
      mainBadge.textContent = design.isOriginal ? 'Image originale' : (design.tool || design.name || 'Génération IA');
    }

    latestGrid.querySelectorAll('.compare-design-card').forEach((item) => {
      item.classList.toggle('is-active', item === card);
    });
  });
</script>
