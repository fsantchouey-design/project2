  text-decoration: none;
  padding: 4px 10px;
  border: 1px solid var(--border-color);
  border-radius: 999px;
  transition: all 0.15s;
}
.ep-clear-btn:hover { color: #ef4444; border-color: #ef4444; }

.ep-results-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28px;
}
.ep-results-count { font-size: 0.95rem; color: var(--text-secondary); }
.ep-results-count strong { color: var(--text-primary); font-size: 1.1rem; }

/* Contractor cards */
.ep-contractors-grid {
