<!-- ===== HERO BANNER ===== -->
<section class="ep-hero">
  <div class="ep-hero-inner">
    <p class="ep-hero-eyebrow">
      <i data-lucide="hard-hat" style="width:16px;height:16px;vertical-align:-3px;margin-right:6px;"></i>
      Entrepreneurs vérifiés · CraftyCrib
    </p>
    <h1 class="ep-hero-title">Trouvez l'entrepreneur<br>idéal pour votre projet</h1>
    <p class="ep-hero-sub">Connectez-vous avec des professionnels qualifiés qui donneront vie à vos designs IA.</p>

    <form class="ep-search-form" action="/contractors" method="GET" id="searchForm">
      <div class="ep-search-box">
        <i data-lucide="search" class="ep-search-icon"></i>
        <input
          type="text"
          name="q"
          class="ep-search-input"
          placeholder="Rechercher un service ou une ville…"
          value="<%= filters.q %>"
          autocomplete="off"
        >
        <% if (filters.specialty) { %>
          <input type="hidden" name="specialty" value="<%= filters.specialty %>">
        <% } %>
        <button type="submit" class="ep-search-btn">
          <i data-lucide="search" style="width:18px;height:18px;"></i>
          Rechercher
        </button>
      </div>
    </form>

    <div class="ep-hero-stats">
      <span><i data-lucide="shield-check" style="width:15px;height:15px;color:var(--accent-primary);vertical-align:-3px;margin-right:4px;"></i>Professionnels vérifiés</span>
      <span><i data-lucide="star" style="width:15px;height:15px;color:#f59e0b;vertical-align:-3px;margin-right:4px;"></i>Avis clients authentiques</span>
      <span><i data-lucide="message-circle" style="width:15px;height:15px;color:var(--accent-primary);vertical-align:-3px;margin-right:4px;"></i>Contact direct</span>
    </div>
  </div>
  <div class="ep-hero-bg">
    <div class="ep-orb ep-orb-1"></div>
    <div class="ep-orb ep-orb-2"></div>
  </div>
</section>

<!-- ===== CATEGORIES GRID ===== -->
<section class="ep-section ep-categories-section">
  <div class="ep-container">
    <div class="ep-section-header">
      <h2 class="ep-section-title">Parcourir par catégorie</h2>
      <p class="ep-section-sub">Cliquez sur une catégorie pour voir les sous-services disponibles</p>
    </div>

    <div class="ep-cat-grid">
      <% categories.forEach((cat, idx) => { %>
        <% const isActive = filters.specialty === cat.specialty && (!filters.service || cat.subcategories.includes(filters.service)); %>
        <div class="ep-cat-card <%= isActive ? 'ep-cat-active' : '' %>" data-idx="<%= idx %>">
          <button class="ep-cat-toggle" type="button" onclick="toggleCat(<%= idx %>)">
            <span class="ep-cat-icon-wrap">
              <i data-lucide="<%= cat.icon %>"></i>
            </span>
            <span class="ep-cat-label"><%= cat.label %></span>
            <span class="ep-cat-plus" id="plus-<%= idx %>"><%= isActive ? '−' : '+' %></span>
          </button>
          <div class="ep-subcat-panel" id="panel-<%= idx %>" style="<%= isActive ? '' : 'display:none' %>">
            <div class="ep-subcat-list">
              <% cat.subcategories.forEach(sub => { %>
                <% const subActive = filters.service === sub && filters.specialty === cat.specialty; %>
                <a
                  href="/contractors?specialty=<%= cat.specialty %>&service=<%= encodeURIComponent(sub) %>"
                  class="ep-subcat-chip <%= subActive ? 'ep-subcat-chip-active' : '' %>"
                >
                  <%= sub %>
                  <i data-lucide="arrow-right" style="width:12px;height:12px;margin-left:4px;opacity:0.6;"></i>
                </a>
              <% }) %>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- ===== RESULTS SECTION ===== -->
<section class="ep-section ep-results-section" id="results">
  <div class="ep-container">

    <!-- Active filter breadcrumb -->
    <% if (filters.specialty || filters.q) { %>
      <div class="ep-breadcrumb">
        <a href="/contractors" class="ep-breadcrumb-home">
          <i data-lucide="layout-grid" style="width:14px;height:14px;"></i>
          Toutes les catégories
        </a>
        <% if (filters.specialty) { %>
          <i data-lucide="chevron-right" style="width:14px;height:14px;color:var(--text-muted);"></i>
          <span class="ep-breadcrumb-cat">
            <% const bc = categories.find(c => c.specialty === filters.specialty); %>
            <%= bc ? bc.label : filters.specialty %>
          </span>
        <% } %>
        <% if (filters.service) { %>
          <i data-lucide="chevron-right" style="width:14px;height:14px;color:var(--text-muted);"></i>
          <span class="ep-breadcrumb-service"><%= filters.service %></span>
        <% } %>
        <% if (filters.q) { %>
          <i data-lucide="chevron-right" style="width:14px;height:14px;color:var(--text-muted);"></i>
          <span class="ep-breadcrumb-service">«&nbsp;<%= filters.q %>&nbsp;»</span>
        <% } %>
        <a href="/contractors" class="ep-clear-btn">
          <i data-lucide="x" style="width:13px;height:13px;"></i> Effacer
        </a>
      </div>
    <% } %>

    <!-- Count + sort -->
    <div class="ep-results-bar">
      <p class="ep-results-count">
        <strong><%= contractors.length %></strong>
        entrepreneur<%= contractors.length !== 1 ? 's' : '' %>
        <%= filters.service ? `pour « ${filters.service} »` : (filters.specialty ? 'dans cette catégorie' : 'disponibles') %>
      </p>
    </div>

    <!-- Contractors grid -->
    <% if (contractors.length > 0) { %>
      <div class="ep-contractors-grid">
        <% contractors.forEach(c => { %>
          <article class="ep-card">
            <div class="ep-card-top">
              <div class="ep-avatar">
                <% if (c.logo) { %>
                  <img src="<%= c.logo %>" alt="<%= c.companyName %>">
                <% } else { %>
                  <span><%= c.companyName.charAt(0).toUpperCase() %></span>
                <% } %>
                <% if (c.isVerified) { %>
                  <span class="ep-verified" title="Vérifié">
                    <i data-lucide="badge-check" style="width:12px;height:12px;"></i>
                  </span>
                <% } %>
              </div>
              <div class="ep-card-info">
                <h3 class="ep-card-name"><%= c.companyName %></h3>
                <p class="ep-card-tagline"><%= c.tagline || 'Entrepreneur professionnel' %></p>
                <div class="ep-card-meta">
                  <span class="ep-meta-item">
                    <i data-lucide="star" style="width:13px;height:13px;color:#f59e0b;"></i>
                    <%= c.rating?.average ? c.rating.average.toFixed(1) : '—' %>
                    <span class="ep-meta-muted">(<%= c.rating?.count || 0 %>)</span>
                  </span>
                  <span class="ep-meta-item">
                    <i data-lucide="map-pin" style="width:13px;height:13px;"></i>
                    <%= c.address?.city || 'France' %>
                  </span>
                  <% if (c.availability?.status === 'available') { %>
                    <span class="ep-badge-avail">Disponible</span>
                  <% } %>
                </div>
              </div>
              <% if (c.isPremium) { %>
                <span class="ep-badge-premium">Pro</span>
              <% } %>
            </div>

            <div class="ep-card-body">
              <p class="ep-card-desc"><%= c.description ? c.description.substring(0, 110) + (c.description.length > 110 ? '…' : '') : 'Aucune description.' %></p>
              <div class="ep-tags">
                <% (c.specialties || []).slice(0, 4).forEach(spec => { %>
                  <span class="ep-tag"><%= spec %></span>
                <% }) %>
                <% if ((c.specialties || []).length > 4) { %>
                  <span class="ep-tag ep-tag-more">+<%= c.specialties.length - 4 %></span>
                <% } %>
              </div>
            </div>

            <div class="ep-card-footer">
              <a href="/contractors/<%= c.slug %>" class="btn btn-secondary ep-btn-profile">
                <i data-lucide="user" style="width:15px;height:15px;"></i>
                Voir le profil
              </a>
              <button class="btn btn-primary ep-btn-contact" onclick="contactContractor('<%= c._id %>')">
                <i data-lucide="message-circle" style="width:15px;height:15px;"></i>
                Contacter
              </button>
            </div>
          </article>
        <% }) %>
      </div>

    <% } else { %>
      <div class="ep-empty">
        <div class="ep-empty-icon">
          <i data-lucide="hard-hat"></i>
        </div>
        <h3>Aucun entrepreneur trouvé</h3>
        <p>Aucun professionnel ne correspond à ce critère pour l'instant. Essayez une autre catégorie ou revenez bientôt.</p>
        <a href="/contractors" class="btn btn-secondary" style="margin-top: 16px;">Voir tous les entrepreneurs</a>
      </div>
    <% } %>
  </div>
</section>

<!-- ===== JOIN CTA ===== -->
<section class="ep-join-section">
  <div class="ep-join-bg">
    <div class="ep-orb ep-orb-1"></div>
    <div class="ep-orb ep-orb-2"></div>
  </div>
  <div class="ep-join-content">
    <span class="ep-join-badge">
      <i data-lucide="briefcase" style="width:14px;height:14px;margin-right:6px;vertical-align:-2px;"></i>
      Vous êtes entrepreneur ?
    </span>
    <h2>Rejoignez CraftyCrib Pro</h2>
    <p>Connectez-vous avec des propriétaires ayant des designs IA prêts à construire. Développez votre clientèle.</p>
    <div class="ep-join-actions">
      <a href="/auth/register?role=contractor" class="btn btn-primary btn-lg">
        <i data-lucide="building-2"></i>
        Créer mon profil entrepreneur
      </a>
    </div>
    <p class="ep-join-note">Gratuit · Prospects qualifiés · Gérez votre portfolio</p>
  </div>
</section>


<!-- ===== STYLES ===== -->
<style>
/* ---- Global ---- */
.ep-container { max-width: 1160px; margin: 0 auto; padding: 0 1.5rem; }
.ep-section { padding: 64px 0; }

/* ---- Hero ---- */
.ep-hero {
  position: relative;
  padding: 140px 1.5rem 90px;
  text-align: center;
  overflow: hidden;
}
.ep-hero-bg { position: absolute; inset: 0; pointer-events: none; z-index: 0; }
.ep-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(80px);
  opacity: 0.25;
}
.ep-orb-1 { width: 500px; height: 500px; top: -160px; left: -100px; background: var(--accent-primary, #00ff88); }
.ep-orb-2 { width: 400px; height: 400px; bottom: -100px; right: -80px; background: #6366f1; }

.ep-hero-inner { position: relative; z-index: 1; max-width: 760px; margin: 0 auto; }
.ep-hero-eyebrow {
  display: inline-block;
  font-size: 0.78rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--accent-primary, #00ff88);
  border: 1px solid rgba(0,255,136,0.3);
  border-radius: 999px;
  padding: 6px 16px;
  margin-bottom: 24px;
}
.ep-hero-title {
  font-size: clamp(2rem, 5vw, 3.6rem);
  font-weight: 800;
  line-height: 1.15;
  letter-spacing: -0.02em;
  margin-bottom: 18px;
  color: var(--text-primary);
}
.ep-hero-sub {
  font-size: 1.05rem;
  color: var(--text-secondary);
  margin-bottom: 40px;
}

/* Search */
.ep-search-form { max-width: 680px; margin: 0 auto 28px; }
.ep-search-box {
  display: flex;
  align-items: center;
  background: var(--bg-card, #1a1a1a);
  border: 1.5px solid var(--border-color, #333);
  border-radius: 999px;
  padding: 6px 6px 6px 20px;
  gap: 10px;
  transition: border-color 0.2s;
}
.ep-search-box:focus-within { border-color: var(--accent-primary, #00ff88); }
.ep-search-icon { width: 18px; height: 18px; color: var(--text-muted); flex-shrink: 0; }
.ep-search-input {
  flex: 1;
  background: transparent;
  border: none;
  outline: none;
  font-size: 0.95rem;
  color: var(--text-primary);
  min-width: 0;
}
.ep-search-btn {
  display: flex;
  align-items: center;
  gap: 8px;
  background: var(--accent-primary, #00ff88);
  color: #000;
  border: none;
  border-radius: 999px;
  padding: 10px 22px;
  font-size: 0.9rem;
  font-weight: 600;
  cursor: pointer;
  white-space: nowrap;
  transition: opacity 0.2s;
  flex-shrink: 0;
}
.ep-search-btn:hover { opacity: 0.85; }

/* Stats row */
.ep-hero-stats {
  display: flex;
  justify-content: center;
  gap: 24px;
  flex-wrap: wrap;
  font-size: 0.85rem;
  color: var(--text-secondary);
}

/* ---- Categories ---- */
.ep-categories-section { background: var(--bg-secondary, #111); }
.ep-section-header { text-align: center; margin-bottom: 40px; }
.ep-section-title { font-size: 1.8rem; font-weight: 700; margin-bottom: 8px; color: var(--text-primary); }
.ep-section-sub { font-size: 0.95rem; color: var(--text-muted); }

.ep-cat-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 14px;
}

.ep-cat-card {
  background: var(--bg-card, #1a1a1a);
  border: 1.5px solid var(--border-color, #2a2a2a);
  border-radius: 14px;
  overflow: hidden;
  transition: border-color 0.2s;
}
.ep-cat-card:hover,
