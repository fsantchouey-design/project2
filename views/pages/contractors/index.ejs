.ep-subcat-panel {
  border-top: 1px solid var(--border-color, #2a2a2a);
  padding: 12px 16px 16px;
  background: var(--bg-secondary, #111);
}
.ep-subcat-list { display: flex; flex-wrap: wrap; gap: 8px; }
.ep-subcat-chip {
  display: inline-flex;
  align-items: center;
  padding: 6px 12px;
  background: var(--bg-card, #1a1a1a);
  border: 1px solid var(--border-color, #2a2a2a);
  border-radius: 999px;
  font-size: 0.8rem;
  color: var(--text-secondary);
  text-decoration: none;
  transition: all 0.15s;
}
.ep-subcat-chip:hover {
  border-color: var(--accent-primary, #00ff88);
  color: var(--accent-primary, #00ff88);
  background: rgba(0,255,136,0.06);
}
.ep-subcat-chip-active {
  background: rgba(0,255,136,0.12);
  border-color: var(--accent-primary, #00ff88);
  color: var(--accent-primary, #00ff88);
  font-weight: 600;
}

/* ---- Results section ---- */
.ep-results-section { background: var(--bg-primary, #0a0a0a); }

/* Breadcrumb */
.ep-breadcrumb {
  display: flex;
  align-items: center;
  gap: 8px;
