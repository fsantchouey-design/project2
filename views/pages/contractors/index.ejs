  border-color: var(--accent-primary, #00ff88);
}

.ep-cat-toggle {
  width: 100%;
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 16px 18px;
  background: transparent;
  border: none;
  cursor: pointer;
  text-align: left;
}
.ep-cat-icon-wrap {
  width: 44px;
  height: 44px;
  border-radius: 12px;
  background: rgba(0,255,136,0.08);
  border: 1px solid rgba(0,255,136,0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  color: var(--accent-primary, #00ff88);
}
.ep-cat-icon-wrap i { width: 20px; height: 20px; }
.ep-cat-label {
  flex: 1;
  font-size: 0.95rem;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.3;
}
.ep-cat-plus {
  width: 28px;
  height: 28px;
