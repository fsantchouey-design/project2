<script>
// Toggle category expand/collapse
function toggleCat(idx) {
  const panel = document.getElementById('panel-' + idx);
  const plus  = document.getElementById('plus-' + idx);
  const card  = panel.closest('.ep-cat-card');
  const open  = panel.style.display !== 'none';

  if (open) {
    panel.style.display = 'none';
    plus.textContent = '+';
    card.classList.remove('ep-cat-active');
  } else {
    panel.style.display = '';
    plus.textContent = '−';
    card.classList.add('ep-cat-active');
  }
}

// On load: scroll to results if a filter is active
(function() {
  const hasFilter = '<%= filters.specialty || filters.q %>' !== '';
  if (hasFilter) {
    const el = document.getElementById('results');
    if (el) setTimeout(() => el.scrollIntoView({ behavior: 'smooth', block: 'start' }), 300);
  }
})();

function contactContractor(contractorId) {
  <% if (typeof user !== 'undefined' && user) { %>
    window.location.href = `/dashboard/messages?contractor=${contractorId}`;
  <% } else { %>
    window.location.href = `/auth/login?redirect=/contractors`;
  <% } %>
}

// =============================================
// QUOTE MODAL
// =============================================
let qmState = { specialty: '', service: '', catLabel: '', timing: '', currentStep: 1 };

function openQuoteModal(specialty, service, catLabel) {
  qmState = { specialty, service, catLabel, timing: '', currentStep: 1 };

  document.getElementById('qm-cat-label').textContent = catLabel;
  document.getElementById('qm-service-label').textContent = service;

  // Reset form fields
  ['qm-postal','qm-desc','qm-fn','qm-ln','qm-addr','qm-apt','qm-city','qm-cpostale','qm-phone','qm-altphone','qm-email'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.value = '';
  });
  const prov = document.getElementById('qm-prov');
  if (prov) prov.value = 'Québec';

  document.querySelectorAll('.qm-timing-opt').forEach(b => b.classList.remove('qm-timing-selected'));
  document.getElementById('qm-photo-previews').innerHTML = '';
  const fi = document.getElementById('qm-photos');
  if (fi) fi.value = '';

  // Pre-fill with user data if logged in
  <% if (typeof user !== 'undefined' && user) { %>
    const fn = document.getElementById('qm-fn');
    const em = document.getElementById('qm-email');
    if (fn) fn.value = '<%= user.firstName || "" %>';
    const ln = document.getElementById('qm-ln');
    if (ln) ln.value = '<%= user.lastName || "" %>';
    if (em) em.value = '<%= user.email || "" %>';
  <% } %>

  goToStep(1);
  document.getElementById('quoteModal').classList.add('qm-open');
  document.body.style.overflow = 'hidden';

  // Re-init lucide icons in modal
  if (window.lucide) lucide.createIcons();
}

function closeQuoteModal() {
  document.getElementById('quoteModal').classList.remove('qm-open');
  document.body.style.overflow = '';
}

function handleOverlayClick(e) {
  if (e.target === document.getElementById('quoteModal')) closeQuoteModal();
}

function goToStep(n) {
  for (let i = 1; i <= 4; i++) {
    document.getElementById('qm-pane-' + i).style.display = (i === n) ? '' : 'none';
    const prog = document.getElementById('qm-prog-' + i);
    prog.classList.remove('qm-step-active', 'qm-step-done');
    if (i < n)  prog.classList.add('qm-step-done');
    if (i === n) prog.classList.add('qm-step-active');

    // Update circle content
    const circle = prog.querySelector('.qm-step-circle');
    if (i < n) circle.innerHTML = '✓';
    else circle.textContent = i;
  }
  qmState.currentStep = n;
  if (window.lucide) lucide.createIcons();
}

function qmNext(fromStep) {
  if (fromStep === 1) {
    const postal = document.getElementById('qm-postal').value.trim();
    if (!postal) { shakeField('qm-postal'); return; }
    goToStep(2);
  } else if (fromStep === 2) {
    if (!qmState.timing) {
      alert('Veuillez sélectionner quand vous souhaitez que les travaux commencent.');
      return;
    }
    goToStep(3);
  }
}

function qmPrev(fromStep) {
  goToStep(fromStep - 1);
}

function selectTiming(btn) {
  document.querySelectorAll('.qm-timing-opt').forEach(b => b.classList.remove('qm-timing-selected'));
  btn.classList.add('qm-timing-selected');
  qmState.timing = btn.dataset.val;
}

function shakeField(id) {
  const el = document.getElementById(id);
  el.style.borderColor = '#ef4444';
  el.focus();
  setTimeout(() => { el.style.borderColor = ''; }, 2000);
}

function previewPhotos(input) {
  const container = document.getElementById('qm-photo-previews');
  container.innerHTML = '';
  const files = Array.from(input.files).slice(0, 5);
  files.forEach(file => {
    const reader = new FileReader();
    reader.onload = e => {
      const img = document.createElement('img');
      img.src = e.target.result;
      img.className = 'qm-photo-thumb';
      container.appendChild(img);
    };
    reader.readAsDataURL(file);
  });
}

async function submitQuote() {
  // Validate step 3
  const required = [
    { id: 'qm-fn', label: 'Prénom' },
    { id: 'qm-ln', label: 'Nom' },
    { id: 'qm-addr', label: 'Adresse' },
    { id: 'qm-city', label: 'Ville' },
    { id: 'qm-prov', label: 'Province' },
    { id: 'qm-cpostale', label: 'Code postal' },
    { id: 'qm-phone', label: 'Téléphone' },
    { id: 'qm-email', label: 'Courriel' }
  ];
  for (const f of required) {
    if (!document.getElementById(f.id).value.trim()) {
      shakeField(f.id);
      return;
    }
  }

  const submitBtn = document.getElementById('qm-submit-btn');
  submitBtn.disabled = true;
  submitBtn.textContent = 'Envoi en cours…';

  goToStep(4);
  document.getElementById('qm-step4-loading').style.display = 'flex';
  document.getElementById('qm-step4-content').style.display = 'none';

  try {
    const fd = new FormData();
    fd.append('service',    qmState.service);
    fd.append('specialty',  qmState.specialty);
    fd.append('postalCode', document.getElementById('qm-postal').value.trim());
    fd.append('timing',     qmState.timing);
    fd.append('description',document.getElementById('qm-desc').value.trim());
    fd.append('firstName',  document.getElementById('qm-fn').value.trim());
    fd.append('lastName',   document.getElementById('qm-ln').value.trim());
    fd.append('address',    document.getElementById('qm-addr').value.trim());
    fd.append('apartment',  document.getElementById('qm-apt').value.trim());
    fd.append('city',       document.getElementById('qm-city').value.trim());
    fd.append('province',   document.getElementById('qm-prov').value.trim());
    fd.append('contactPostalCode', document.getElementById('qm-cpostale').value.trim());
    fd.append('phone',      document.getElementById('qm-phone').value.trim());
    fd.append('altPhone',   document.getElementById('qm-altphone').value.trim());
    fd.append('email',      document.getElementById('qm-email').value.trim());

    // Attach photos if any
    const photoInput = document.getElementById('qm-photos');
    if (photoInput && photoInput.files.length > 0) {
      Array.from(photoInput.files).slice(0, 5).forEach(f => fd.append('photos', f));
    }

    const resp = await fetch('/contractors/quote', { method: 'POST', body: fd });
    const data = await resp.json();

    document.getElementById('qm-step4-loading').style.display = 'none';
    document.getElementById('qm-step4-content').style.display = '';

    if (data.success) {
      renderResults(data.contractors);
    } else {
      document.getElementById('qm-no-results').style.display = '';
    }
  } catch (err) {
    document.getElementById('qm-step4-loading').style.display = 'none';
    document.getElementById('qm-step4-content').style.display = '';
    document.getElementById('qm-no-results').style.display = '';
  }

  if (window.lucide) lucide.createIcons();
}

function renderResults(contractors) {
  const list = document.getElementById('qm-results-list');
  const noRes = document.getElementById('qm-no-results');
  list.innerHTML = '';

  if (!contractors || contractors.length === 0) {
    noRes.style.display = '';
    return;
  }
  noRes.style.display = 'none';

  contractors.forEach(c => {
    const stars = c.rating && c.rating.average ? '★ ' + c.rating.average.toFixed(1) + ' (' + c.rating.count + ' avis)' : 'Nouveau';
    const avatarHtml = c.logo
      ? `<img src="${c.logo}" alt="${c.companyName}">`
      : c.initials;

    list.innerHTML += `
      <a href="/contractors/${c.slug}" class="qm-result-card" target="_blank">
        <div class="qm-result-avatar">${avatarHtml}</div>
        <div class="qm-result-info">
          <div class="qm-result-name">${c.companyName}${c.isPremium ? ' <span style="font-size:0.65rem;background:linear-gradient(135deg,#f59e0b,#ef4444);color:#fff;padding:1px 6px;border-radius:999px;vertical-align:middle;">Pro</span>' : ''}</div>
          <div class="qm-result-desc">${c.tagline || c.city}</div>
          <div class="qm-result-rating">${stars}</div>
        </div>
        <span class="qm-result-cta">Voir profil</span>
      </a>`;
  });

  if (window.lucide) lucide.createIcons();
}
</script>

