  min-width: 0;
}
.ep-search-btn {
  display: flex;
  align-items: center;
  gap: 8px;
  background: var(--accent-primary, #00ff88);
  color: #000;
  border: none;
  border-radius: 999px;
  padding: 10px 22px;
  font-size: 0.9rem;
  font-weight: 600;
