  white-space: nowrap;
  transition: opacity 0.2s;
  flex-shrink: 0;
}
.ep-search-btn:hover { opacity: 0.85; }

/* Stats row */
.ep-hero-stats {
  display: flex;
  justify-content: center;
  gap: 24px;
  flex-wrap: wrap;
  font-size: 0.85rem;
  color: var(--text-secondary);
}

/* ---- Categories ---- */
.ep-categories-section { background: var(--bg-secondary, #111); }
