}

/* ============================================================
   QUOTE MODAL — 4-step wizard
   ============================================================ */
.qm-overlay {
  display: none;
  position: fixed;
  inset: 0;
  z-index: 9000;
  background: rgba(0,0,0,0.72);
  backdrop-filter: blur(4px);
  align-items: center;
  justify-content: center;
  padding: 16px;
}
.qm-overlay.qm-open { display: flex; }

.qm-dialog {
  background: var(--bg-card, #1a1a1a);
  border: 1.5px solid var(--border-color, #2a2a2a);
  border-radius: 20px;
  width: 100%;
  max-width: 660px;
  max-height: 90vh;
  overflow-y: auto;
  position: relative;
  animation: qm-in 0.22s ease;
}
@keyframes qm-in {
  from { opacity: 0; transform: translateY(20px) scale(0.97); }
  to   { opacity: 1; transform: translateY(0) scale(1); }
}

/* Header */
.qm-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 24px 28px 0;
  gap: 12px;
}
.qm-service-info { flex: 1; }
.qm-service-cat {
  font-size: 0.75rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--accent-primary, #00ff88);
  margin-bottom: 4px;
}
.qm-service-name {
  font-size: 1.15rem;
  font-weight: 700;
  color: var(--text-primary);
}
.qm-close {
  width: 34px;
  height: 34px;
  border-radius: 50%;
  background: var(--bg-secondary, #111);
  border: 1px solid var(--border-color, #2a2a2a);
  color: var(--text-muted);
  font-size: 1.1rem;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.15s;
  line-height: 1;
}
.qm-close:hover { background: #ef4444; color: #fff; border-color: #ef4444; }

/* Progress bar */
.qm-progress {
  display: flex;
  align-items: center;
  padding: 24px 28px 0;
  gap: 0;
}
.qm-step-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  position: relative;
  gap: 6px;
}
.qm-step-item:not(:last-child)::after {
  content: '';
  position: absolute;
  top: 16px;
  left: 50%;
  width: 100%;
  height: 2px;
  background: var(--border-color, #2a2a2a);
  z-index: 0;
  transition: background 0.3s;
}
.qm-step-item.qm-step-done:not(:last-child)::after { background: var(--accent-primary, #00ff88); }

.qm-step-circle {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  border: 2px solid var(--border-color, #2a2a2a);
  background: var(--bg-secondary, #111);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.8rem;
  font-weight: 700;
  color: var(--text-muted);
  position: relative;
  z-index: 1;
  transition: all 0.25s;
}
.qm-step-item.qm-step-active .qm-step-circle {
  border-color: var(--accent-primary, #00ff88);
  background: rgba(0,255,136,0.12);
  color: var(--accent-primary, #00ff88);
}
.qm-step-item.qm-step-done .qm-step-circle {
  border-color: var(--accent-primary, #00ff88);
  background: var(--accent-primary, #00ff88);
  color: #000;
}
.qm-step-label {
  font-size: 0.68rem;
  color: var(--text-muted);
  font-weight: 500;
  text-align: center;
  white-space: nowrap;
}
.qm-step-item.qm-step-active .qm-step-label,
.qm-step-item.qm-step-done .qm-step-label { color: var(--text-primary); }

/* Panes */
.qm-pane { padding: 28px 28px 32px; }
.qm-pane-title {
  font-size: 1.25rem;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 6px;
}
.qm-pane-sub {
  font-size: 0.875rem;
  color: var(--text-secondary);
  margin-bottom: 28px;
}

/* Form elements */
.qm-field { margin-bottom: 18px; }
.qm-label {
  display: block;
  font-size: 0.83rem;
  font-weight: 600;
  color: var(--text-secondary);
  margin-bottom: 7px;
}
.qm-input, .qm-textarea, .qm-select {
  width: 100%;
  background: var(--bg-secondary, #111);
  border: 1.5px solid var(--border-color, #2a2a2a);
  border-radius: 10px;
  padding: 11px 14px;
  font-size: 0.9rem;
  color: var(--text-primary);
  outline: none;
  transition: border-color 0.15s;
  font-family: inherit;
  box-sizing: border-box;
}
.qm-input:focus, .qm-textarea:focus, .qm-select:focus { border-color: var(--accent-primary, #00ff88); }
.qm-textarea { resize: vertical; min-height: 90px; }

.qm-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
@media (max-width: 480px) { .qm-row { grid-template-columns: 1fr; } }

/* Timing options */
.qm-timing-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  margin-bottom: 22px;
}
.qm-timing-opt {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  padding: 16px 12px;
  background: var(--bg-secondary, #111);
  border: 1.5px solid var(--border-color, #2a2a2a);
  border-radius: 12px;
  cursor: pointer;
  transition: all 0.15s;
  text-align: center;
  color: var(--text-secondary);
}
.qm-timing-opt:hover { border-color: rgba(0,255,136,0.4); color: var(--text-primary); }
.qm-timing-opt.qm-timing-selected {
  border-color: var(--accent-primary, #00ff88);
  background: rgba(0,255,136,0.07);
  color: var(--accent-primary, #00ff88);
}
.qm-timing-opt svg, .qm-timing-opt i { width: 22px; height: 22px; }
.qm-timing-opt span { font-size: 0.82rem; font-weight: 600; line-height: 1.3; }

/* Photo upload */
.qm-photo-zone {
  border: 2px dashed var(--border-color, #2a2a2a);
  border-radius: 12px;
  padding: 24px;
  text-align: center;
  cursor: pointer;
  transition: border-color 0.15s;
  color: var(--text-muted);
  font-size: 0.875rem;
}
.qm-photo-zone:hover { border-color: var(--accent-primary, #00ff88); color: var(--accent-primary, #00ff88); }
.qm-photo-zone i { width: 28px; height: 28px; margin-bottom: 8px; display: block; margin: 0 auto 8px; }
.qm-photo-zone input { display: none; }
.qm-photo-previews {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  margin-top: 12px;
}
.qm-photo-thumb {
  width: 72px;
  height: 72px;
  border-radius: 8px;
  object-fit: cover;
  border: 1.5px solid var(--border-color, #2a2a2a);
  position: relative;
}

/* Footer nav */
.qm-footer {
  display: flex;
  justify-content: space-between;
  gap: 12px;
  margin-top: 28px;
}
.qm-btn-prev {
  background: var(--bg-secondary, #111);
  border: 1.5px solid var(--border-color, #2a2a2a);
  border-radius: 10px;
  padding: 11px 24px;
  font-size: 0.9rem;
  font-weight: 600;
  color: var(--text-secondary);
  cursor: pointer;
  transition: all 0.15s;
}
.qm-btn-prev:hover { border-color: var(--accent-primary, #00ff88); color: var(--text-primary); }
.qm-btn-next {
  flex: 1;
  background: var(--accent-primary, #00ff88);
  border: none;
  border-radius: 10px;
  padding: 11px 24px;
  font-size: 0.9rem;
  font-weight: 700;
  color: #000;
  cursor: pointer;
  transition: opacity 0.15s;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
}
.qm-btn-next:hover { opacity: 0.85; }
.qm-btn-next:disabled { opacity: 0.45; cursor: not-allowed; }

/* Step 4 — results */
.qm-result-grid {
  display: flex;
  flex-direction: column;
  gap: 12px;
  margin-top: 20px;
}
.qm-result-card {
  display: flex;
  align-items: center;
  gap: 14px;
  background: var(--bg-secondary, #111);
  border: 1.5px solid var(--border-color, #2a2a2a);
  border-radius: 14px;
  padding: 14px 16px;
  text-decoration: none;
  transition: border-color 0.15s;
}
.qm-result-card:hover { border-color: var(--accent-primary, #00ff88); }
.qm-result-avatar {
  width: 52px;
  height: 52px;
  border-radius: 12px;
  background: var(--accent-gradient, linear-gradient(135deg,#00ff88,#00ccff));
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.3rem;
  font-weight: 700;
  color: #000;
  flex-shrink: 0;
  overflow: hidden;
}
.qm-result-avatar img { width: 100%; height: 100%; object-fit: cover; }
.qm-result-info { flex: 1; min-width: 0; }
.qm-result-name { font-size: 0.95rem; font-weight: 700; color: var(--text-primary); margin-bottom: 3px; }
.qm-result-desc { font-size: 0.78rem; color: var(--text-secondary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.qm-result-rating { font-size: 0.78rem; color: var(--text-muted); margin-top: 3px; }
.qm-result-cta {
  background: var(--accent-primary, #00ff88);
  color: #000;
  border: none;
  border-radius: 8px;
  padding: 8px 14px;
  font-size: 0.8rem;
  font-weight: 700;
  cursor: pointer;
  white-space: nowrap;
  text-decoration: none;
  display: inline-block;
  flex-shrink: 0;
}
.qm-no-results {
  text-align: center;
  padding: 40px 24px;
  color: var(--text-muted);
  font-size: 0.9rem;
}
.qm-success-banner {
  background: rgba(0,255,136,0.08);
  border: 1px solid rgba(0,255,136,0.25);
  border-radius: 10px;
  padding: 14px 18px;
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 0.85rem;
  color: var(--text-secondary);
  margin-bottom: 20px;
}
.qm-success-banner i { color: var(--accent-primary, #00ff88); flex-shrink: 0; }
.qm-spinner {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 48px 0;
}
.qm-spinner-ring {
  width: 40px;
  height: 40px;
  border: 3px solid var(--border-color, #2a2a2a);
  border-top-color: var(--accent-primary, #00ff88);
  border-radius: 50%;
  animation: qm-spin 0.8s linear infinite;
}
@keyframes qm-spin { to { transform: rotate(360deg); } }
</style>

<!-- ===== QUOTE MODAL ===== -->
