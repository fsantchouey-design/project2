  color: var(--accent-primary, #00ff88);
  border: 1px solid rgba(0,255,136,0.3);
  border-radius: 999px;
  padding: 5px 16px;
  margin-bottom: 20px;
}
.ep-join-content h2 {
  font-size: clamp(1.8rem, 4vw, 2.8rem);
  font-weight: 800;
  margin-bottom: 14px;
  color: var(--text-primary);
}
.ep-join-content p {
  font-size: 1rem;
  color: var(--text-secondary);
  margin-bottom: 32px;
  line-height: 1.7;
}
.ep-join-actions { display: flex; justify-content: center; gap: 16px; flex-wrap: wrap; }
.ep-join-note { margin-top: 16px; font-size: 0.82rem; color: var(--text-muted); }

/* ---- Responsive ---- */
@media (max-width: 640px) {
  .ep-hero { padding: 110px 1rem 70px; }
  .ep-search-box { flex-direction: column; align-items: stretch; border-radius: 14px; padding: 12px; gap: 8px; }
  .ep-search-btn { border-radius: 8px; justify-content: center; }
  .ep-hero-stats { flex-direction: column; gap: 8px; }
  .ep-cat-grid { grid-template-columns: 1fr; }
  .ep-contractors-grid { grid-template-columns: 1fr; }
