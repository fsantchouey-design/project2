            <td><strong>Prix</strong></td>
            <td><strong><%= plans.regular.price %>$ <%= plans.regular.period %></strong></td>
            <td class="highlight"><strong><%= plans.advanced.price %>$ <%= plans.advanced.period %></strong></td>
            <td><strong><%= plans.premium.price %>$ <%= plans.premium.period %></strong></td>
          </tr>
        </tbody>
      </table>
    </div>
