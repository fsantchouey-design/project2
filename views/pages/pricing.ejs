<script>
(function () {
  function initBillingToggle(switchId, gridId, annualInfoClass, monthlyLabelId, annualLabelId) {
    var switchEl = document.getElementById(switchId);
    var grid = document.getElementById(gridId);
    if (!switchEl || !grid) return;

    var priceEls = grid.querySelectorAll('.price-amount[data-monthly]');
    var annualInfoEls = grid.querySelectorAll('.' + annualInfoClass);
    var monthlyLabel = document.getElementById(monthlyLabelId);
    var annualLabel = document.getElementById(annualLabelId);

    function update() {
      var isAnnual = switchEl.checked;
      priceEls.forEach(function (el) {
        el.textContent = (isAnnual ? el.dataset.annual : el.dataset.monthly) + '$';
      });
      annualInfoEls.forEach(function (el) {
        el.style.display = isAnnual ? 'flex' : 'none';
      });
      if (monthlyLabel) monthlyLabel.classList.toggle('active', !isAnnual);
      if (annualLabel) annualLabel.classList.toggle('active', isAnnual);
    }

    switchEl.addEventListener('change', update);
    update();
  }

  initBillingToggle('ai-billing-switch', 'ai-plans-grid', 'ai-annual-info', 'ai-monthly-label', 'ai-annual-label');
  initBillingToggle('contractor-billing-switch', 'contractor-plans-grid', 'contractor-annual-info', 'contractor-monthly-label', 'contractor-annual-label');
})();
</script>

