<!-- Pricing Hero -->
<section class="pricing-hero">
  <div class="container">
    <span class="hero-badge">
      <i data-lucide="sparkles"></i>
      Tarifs transparents
    </span>
    <h1>Choisissez votre <span class="gradient-text">forfait idéal</span></h1>
    <p class="hero-subtitle">Commencez gratuitement ou débloquez tout le potentiel du design d'intérieur par IA.</p>
  </div>

  <div class="hero-bg">
    <div class="gradient-orb hero-orb-1"></div>
    <div class="gradient-orb hero-orb-2"></div>
  </div>
</section>

<!-- Main Pricing Section — Plans IA -->
<section class="pricing-section">
  <div class="container">
    <h2 class="plans-section-title">Abonnements IA</h2>
    <p class="plans-section-subtitle">Visualisez vos espaces avec la puissance de l'intelligence artificielle.</p>

    <!-- AI Billing Toggle -->
    <div class="billing-toggle-wrapper">
      <div class="billing-toggle">
        <span class="toggle-option" id="ai-monthly-label">Mensuel</span>
        <label class="toggle-switch" for="ai-billing-switch">
          <input type="checkbox" id="ai-billing-switch" checked>
          <span class="toggle-slider"></span>
        </label>
        <span class="toggle-option active" id="ai-annual-label">
          Annuel
          <span class="toggle-badge-pill">2 mois offerts</span>
        </span>
      </div>
    </div>

    <!-- Pricing Cards Grid -->
    <div class="pricing-grid three-cards" id="ai-plans-grid">

      <!-- Régulier Plan -->
      <div class="pricing-card">
        <div class="card-header">
          <span class="plan-name"><%= plans.regular.name %></span>
          <span class="plan-subtitle"><%= plans.regular.subtitle %></span>
        </div>
        <div class="card-price">
          <span class="price-amount"
                data-monthly="<%= plans.regular.price %>"
                data-annual="<%= plans.regular.priceMonthlyEquivalent %>"><%= plans.regular.priceMonthlyEquivalent %>$</span>
          <span class="price-period">CAD /mois</span>
        </div>
        <div class="annual-price-info ai-annual-info">
          <span class="annual-total-text"><%= plans.regular.priceAnnual %>$ CAD / an</span>
          <span class="annual-savings-badge">Économisez <%= plans.regular.savings %>$</span>
        </div>
        <div class="generations-badge">
          <i data-lucide="zap"></i>
          <span><%= plans.regular.generations %> crédits IA / mois</span>
        </div>
        <p class="plan-description"><%= plans.regular.description %></p>
        <ul class="features-list">
          <% plans.regular.features.forEach(feature => { %>
            <li class="<%= feature.addon ? 'addon' : '' %>">
              <i data-lucide="<%= feature.addon ? 'plus-circle' : 'check' %>"></i>
              <%= feature.text %>
            </li>
          <% }) %>
        </ul>
        <% if (plans.regular.bonus) { %>
          <div class="bonus-box">
            <%= plans.regular.bonus %>
          </div>
        <% } %>
        <a href="<%= plans.regular.ctaLink %>" class="btn btn-secondary btn-full" data-stripe-plan="regular"><%= plans.regular.cta %></a>
      </div>

      <!-- Avancé Plan (Popular) -->
      <div class="pricing-card popular-card">
        <% if (plans.advanced.badge) { %>
          <span class="card-badge popular"><%= plans.advanced.badge %></span>
        <% } %>
        <div class="popular-ribbon">Plus populaire</div>
        <div class="card-header">
          <span class="plan-name"><%= plans.advanced.name %></span>
          <span class="plan-subtitle"><%= plans.advanced.subtitle %></span>
        </div>
        <div class="card-price">
          <span class="price-amount"
                data-monthly="<%= plans.advanced.price %>"
                data-annual="<%= plans.advanced.priceMonthlyEquivalent %>"><%= plans.advanced.priceMonthlyEquivalent %>$</span>
          <span class="price-period">CAD /mois</span>
        </div>
        <div class="annual-price-info ai-annual-info">
          <span class="annual-total-text"><%= plans.advanced.priceAnnual %>$ CAD / an</span>
          <span class="annual-savings-badge">Économisez <%= plans.advanced.savings %>$</span>
        </div>
        <div class="generations-badge">
          <i data-lucide="zap"></i>
          <span><%= plans.advanced.generations %> générations IA / mois</span>
        </div>
        <p class="plan-description"><%= plans.advanced.description %></p>
        <ul class="features-list">
          <% plans.advanced.features.forEach(feature => { %>
            <li class="<%= feature.addon ? 'addon' : '' %>">
              <i data-lucide="<%= feature.addon ? 'plus-circle' : 'check' %>"></i>
              <%= feature.text %>
            </li>
          <% }) %>
        </ul>
        <a href="<%= plans.advanced.ctaLink %>" class="btn btn-primary btn-full" data-stripe-plan="advanced">
          <i data-lucide="sparkles"></i>
          <%= plans.advanced.cta %>
        </a>
      </div>

      <!-- Premium Plan -->
      <div class="pricing-card premium-card">
        <% if (plans.premium.badge) { %>
          <span class="card-badge premium"><%= plans.premium.badge %></span>
        <% } %>
        <div class="card-header">
          <span class="plan-name"><%= plans.premium.name %></span>
          <span class="plan-subtitle"><%= plans.premium.subtitle %></span>
        </div>
        <div class="card-price">
          <span class="price-amount"
                data-monthly="<%= plans.premium.price %>"
                data-annual="<%= plans.premium.priceMonthlyEquivalent %>"><%= plans.premium.priceMonthlyEquivalent %>$</span>
          <span class="price-period">CAD /mois</span>
        </div>
        <div class="annual-price-info ai-annual-info">
          <span class="annual-total-text"><%= plans.premium.priceAnnual %>$ CAD / an</span>
          <span class="annual-savings-badge">Économisez <%= plans.premium.savings %>$</span>
        </div>
        <div class="generations-badge<%= plans.premium.generations === 0 ? ' unlimited' : '' %>">
          <i data-lucide="<%= plans.premium.generations === 0 ? 'infinity' : 'zap' %>"></i>
          <span><%= plans.premium.generations === 0 ? 'Générations illimitées' : plans.premium.generations + ' générations / mois' %></span>
        </div>
        <p class="plan-description"><%= plans.premium.description %></p>
        <ul class="features-list">
          <% plans.premium.features.forEach(feature => { %>
            <li>
              <i data-lucide="check"></i>
              <%= feature.text %>
            </li>
          <% }) %>
        </ul>
        <a href="<%= plans.premium.ctaLink %>" class="btn btn-outline btn-full" data-stripe-plan="premium">
          <i data-lucide="crown"></i>
          <%= plans.premium.cta %>
        </a>
      </div>

    </div>
  </div>
</section>

<!-- Contractor Plans Section -->
<section class="pricing-section contractor-plans-section">
  <div class="container">
    <h2 class="plans-section-title">Abonnements entrepreneurs</h2>
    <p class="plans-section-subtitle">Recevez des projets qualifiés, sans commission.</p>

    <!-- Contractor Billing Toggle -->
    <div class="billing-toggle-wrapper">
      <div class="billing-toggle">
        <span class="toggle-option" id="contractor-monthly-label">Mensuel</span>
        <label class="toggle-switch" for="contractor-billing-switch">
          <input type="checkbox" id="contractor-billing-switch" checked>
          <span class="toggle-slider"></span>
        </label>
        <span class="toggle-option active" id="contractor-annual-label">
          Annuel
          <span class="toggle-badge-pill">2 mois offerts</span>
        </span>
      </div>
    </div>

    <!-- Contractor Cards Grid -->
    <div class="pricing-grid" id="contractor-plans-grid">

      <% contractorPlans.forEach(function(plan) { %>
        <div class="pricing-card<%= plan.popular ? ' popular-card' : '' %><%= plan.id === 'elite' ? ' premium-card' : '' %>">
          <% if (plan.badge) { %>
            <span class="card-badge popular"><%= plan.badge %></span>
          <% } %>
          <% if (plan.popular) { %>
            <div class="popular-ribbon">Plus populaire</div>
          <% } %>

          <div class="card-header">
            <span class="plan-name"><%= plan.name %></span>
            <span class="plan-subtitle"><%= plan.subtitle %></span>
          </div>

          <% if (plan.price === 0) { %>
            <div class="card-price">
              <span class="price-amount">0$</span>
              <span class="price-period">/ mois</span>
            </div>
          <% } else { %>
            <div class="card-price">
              <span class="price-amount"
                    data-monthly="<%= plan.price %>"
                    data-annual="<%= plan.priceMonthlyEquivalent %>"><%= plan.priceMonthlyEquivalent %>$</span>
              <span class="price-period">CAD /mois</span>
            </div>
            <div class="annual-price-info contractor-annual-info">
              <span class="annual-total-text"><%= plan.priceAnnual %>$ CAD / an</span>
              <span class="annual-savings-badge">Économisez <%= plan.savings %>$</span>
            </div>
          <% } %>

          <ul class="features-list">
            <% plan.features.forEach(function(feature) { %>
              <li class="<%= feature.addon ? 'addon' : '' %>">
                <i data-lucide="<%= feature.addon ? 'minus-circle' : 'check' %>"></i>
                <%= feature.text %>
              </li>
            <% }) %>
          </ul>

          <% if (plan.popular) { %>
            <a href="<%= plan.ctaLink %>" class="btn btn-primary btn-full" data-stripe-plan="contractor-<%= plan.id %>">
              <i data-lucide="sparkles"></i>
              <%= plan.cta %>
            </a>
          <% } else if (plan.id === 'elite') { %>
            <a href="<%= plan.ctaLink %>" class="btn btn-outline btn-full" data-stripe-plan="contractor-<%= plan.id %>">
              <i data-lucide="crown"></i>
              <%= plan.cta %>
            </a>
          <% } else if (plan.price === 0) { %>
            <a href="<%= plan.ctaLink %>" class="btn btn-secondary btn-full" data-stripe-plan="contractor-<%= plan.id %>">
              <%= plan.cta %>
            </a>
          <% } else { %>
            <a href="<%= plan.ctaLink %>" class="btn btn-secondary btn-full" data-stripe-plan="contractor-<%= plan.id %>">
              <%= plan.cta %>
            </a>
          <% } %>
        </div>
      <% }) %>

    </div>

    <p class="contractor-bonus-text">💡 1 seul projet peut rentabiliser votre abonnement.</p>
  </div>
</section>

<!-- Bonus Section - Contractor Partnership -->
