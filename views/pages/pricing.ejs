  }

  .ph-toggle__label.is-active { color: #f1f5f9; }

  .ph-toggle__switch {
    position: relative;
    display: inline-block;
    width: 48px;
    height: 26px;
    cursor: pointer;
  }

  .ph-toggle__switch input { opacity: 0; width: 0; height: 0; }

  .ph-toggle__track {
    position: absolute;
    inset: 0;
    border-radius: 26px;
    background: #1e293b;
    border: 1px solid rgba(94, 234, 212, 0.18);
    transition: 0.25s;
  }

  .ph-toggle__track::before {
    content: '';
    position: absolute;
    width: 18px;
    height: 18px;
    top: 3px;
    left: 3px;
    border-radius: 50%;
    background: #475569;
    transition: 0.25s;
  }

  .ph-toggle__switch input:checked + .ph-toggle__track {
    background: rgba(20, 184, 166, 0.18);
    border-color: #14b8a6;
  }

  .ph-toggle__switch input:checked + .ph-toggle__track::before {
    transform: translateX(22px);
    background: #14b8a6;
  }

  .ph-toggle__badge {
    display: inline-block;
    margin-left: 6px;
    padding: 2px 8px;
