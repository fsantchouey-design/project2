<script>
(function () {
  var switchEl = document.getElementById('ph-billing-switch');
  var monthlyLabel = document.getElementById('ph-monthly-label');
  var annualLabel  = document.getElementById('ph-annual-label');
  var annualInfoEls = document.querySelectorAll('.ph-plan-annual-info');
  var priceEls = document.querySelectorAll('.ph-plan-amount[data-monthly]');

  function update() {
    var annual = switchEl.checked;
    priceEls.forEach(function (el) {
      el.textContent = (annual ? el.dataset.annual : el.dataset.monthly) + '$';
    });
    annualInfoEls.forEach(function (el) {
      el.classList.toggle('is-visible', annual);
    });
    monthlyLabel.classList.toggle('is-active', !annual);
    annualLabel.classList.toggle('is-active', annual);
  }

  switchEl.addEventListener('change', update);
  update();
})();
</script>
