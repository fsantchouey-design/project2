  /* ── Divider ──────────────────────────────────────── */
  .ph-divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(94, 234, 212, 0.14), transparent);
    max-width: 900px;
    margin: 0 auto;
  }

  /* ── Responsive ───────────────────────────────────── */
  @media (max-width: 1024px) {
    .ph-plans-grid {
      grid-template-columns: 1fr;
      max-width: 480px;
    }

    .ph-plan-card--popular {
      transform: none;
      order: -1;
    }

    .ph-plan-card--popular:hover { transform: translateY(-5px); }

    .ph-packs-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .ph-hero { padding: 96px 20px 60px; }

    .ph-section { padding: 56px 20px; }

    .ph-packs-section { padding: 56px 20px 64px; }

    .ph-packs-grid {
      grid-template-columns: 1fr;
      max-width: 380px;
      margin-inline: auto;
    }
  }
</style>

