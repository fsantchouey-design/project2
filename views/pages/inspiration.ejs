<!-- JSON-LD : CollectionPage + BreadcrumbList -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CollectionPage",
      "name": "Inspiration <%= label %> — CraftyCrib",
      "description": "Découvrez des inspirations de design pour votre <%= label.toLowerCase() %>. Styles, tendances et idées de décoration intérieure.",
      "url": "https://craftycrib.com/inspiration/<%= category %>",
      "isPartOf": { "@type": "WebSite", "name": "CraftyCrib", "url": "https://craftycrib.com" }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://craftycrib.com" },
        { "@type": "ListItem", "position": 2, "name": "Inspiration", "item": "https://craftycrib.com/inspiration/cuisine" },
        { "@type": "ListItem", "position": 3, "name": "<%= label %>", "item": "https://craftycrib.com/inspiration/<%= category %>" }
      ]
    }
  ]
}
</script>

<div class="page-container">
  <div class="page-header">
    <h1>Inspiration <%= label %></h1>
    <p class="text-muted">Découvrez des idées de design pour votre <%= label.toLowerCase() %>.</p>
  </div>

  <!-- Category tabs -->
  <div style="display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 28px;">
    <% categories.forEach(cat => { %>
      <a href="/inspiration/<%= cat.slug %>"
        class="btn btn-sm <%= cat.slug === category ? 'btn-primary' : 'btn-secondary' %>">
        <%= cat.label %>
      </a>
    <% }) %>
  </div>

  <% if (images.length === 0) { %>
    <div style="text-align: center; padding: 64px 24px; background: var(--bg-secondary); border-radius: 12px;">
      <i data-lucide="image-off" style="width: 48px; height: 48px; color: var(--text-muted); margin-bottom: 16px;"></i>
      <h3 style="margin-bottom: 8px; color: var(--text-primary);">Aucune image pour le moment</h3>
      <p class="text-muted">Des inspirations <%= label.toLowerCase() %> seront bientôt disponibles.</p>
    </div>
  <% } else { %>
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 20px;">
      <% images.forEach(img => { %>
        <div style="border-radius: 12px; overflow: hidden; background: var(--bg-secondary); box-shadow: 0 1px 4px rgba(0,0,0,0.07);">
          <div style="height: 200px; overflow: hidden; background: #f1f5f9;">
            <img src="<%= img.imageUrl %>" alt="<%= img.title %>"
              style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s ease;"
              onmouseover="this.style.transform='scale(1.04)'"
              onmouseout="this.style.transform='scale(1)'"
              onerror="this.parentElement.style.background='#e2e8f0'">
          </div>
          <div style="padding: 14px 16px;">
            <p style="font-weight: 600; font-size: 15px; margin: 0 0 6px 0; color: var(--text-primary);"><%= img.title %></p>
            <% if (img.style) { %>
              <span style="font-size: 12px; padding: 2px 10px; border-radius: 999px; background: var(--bg-tertiary, #f1f5f9); color: var(--text-secondary); font-weight: 500;">
                <%= img.style %>
              </span>
            <% } %>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>
