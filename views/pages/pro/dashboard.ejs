          </div>
          <div style="width:42px;height:24px;border-radius:999px;background:<%= n[2] ? 'var(--pro-green)' : 'rgba(255,255,255,0.1)' %>;cursor:pointer;position:relative;transition:all 0.2s;flex-shrink:0;">
            <div style="width:18px;height:18px;background:#fff;border-radius:50%;position:absolute;top:3px;left:<%= n[2] ? '21px' : '3px' %>;transition:left 0.2s;box-shadow:0 1px 4px rgba(0,0,0,0.3);"></div>
          </div>
        </div>
        <% }); %>
      </div>
    </div>
  </div>

  <!-- Integrations Tab -->
  <div class="pro-settings-panel" id="stab-integrations">
    <div class="pro-settings-section">
      <div class="pro-settings-section-title">Intégrations disponibles</div>
      <div style="display:flex;flex-direction:column;gap:12px;">
        <% [
          ['Google Calendar', 'Synchronisez vos rendez-vous', 'calendar', false],
          ['Stripe', 'Paiements en ligne intégrés', 'credit-card', true],
          ['Slack', 'Notifications équipe en temps réel', 'hash', false],
          ['Zapier', 'Automatisez vos workflows', 'zap', false]
        ].forEach(function(i) { %>
        <div style="display:flex;align-items:center;gap:14px;padding:14px;background:rgba(255,255,255,0.02);border:1px solid var(--pro-border);border-radius:var(--pro-radius);">
          <div style="width:40px;height:40px;border-radius:9px;background:rgba(255,255,255,0.06);display:flex;align-items:center;justify-content:center;"><i data-lucide="<%= i[2] %>" style="width:18px;height:18px;color:var(--pro-text2);"></i></div>
          <div style="flex:1;">
            <div style="font-size:13px;font-weight:600;color:var(--pro-text);"><%= i[0] %></div>
            <div style="font-size:11.5px;color:var(--pro-text3);"><%= i[1] %></div>
          </div>
          <button class="pro-btn pro-btn-sm <%= i[3] ? 'pro-btn-danger' : 'pro-btn-secondary' %>">
            <%= i[3] ? 'Déconnecter' : 'Connecter' %>
          </button>
        </div>
        <% }); %>
      </div>
    </div>
  </div>
</div>
