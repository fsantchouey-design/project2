    </div>
  </div>

  <div class="pro-analytics-kpi">
    <div class="pro-analytics-kpi-card">
      <div class="pro-analytics-kpi-value">1,284</div>
      <div class="pro-analytics-kpi-label">Vues profil</div>
      <div class="pro-analytics-kpi-change up"><i data-lucide="trending-up"></i> +18% vs mois dernier</div>
