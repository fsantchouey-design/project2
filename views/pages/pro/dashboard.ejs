    <div style="display:flex;flex-direction:column;gap:16px;">
      <!-- AI Insights -->
      <div class="pro-card">
        <div class="pro-card-header">
          <span class="pro-card-title pro-flex-center"><i data-lucide="cpu" style="width:15px;height:15px;color:var(--pro-green)"></i> Insights Criby IA</span>
          <button class="pro-btn pro-btn-ghost pro-btn-sm"><i data-lucide="refresh-cw"></i></button>
        </div>
        <div class="pro-card-body" style="padding-top:12px;">
          <div class="pro-insight-card">
            <div class="pro-insight-label"><i data-lucide="trending-up"></i> Opportunité</div>
            <div class="pro-insight-text">Les cuisines modernes performent 34% mieux ce mois. Mettez en avant vos réalisations cuisine dans votre portfolio.</div>
          </div>
          <div class="pro-insight-card" style="background:linear-gradient(135deg,rgba(6,182,212,0.08),rgba(59,130,246,0.05));border-color:rgba(6,182,212,0.2)">
            <div class="pro-insight-label" style="color:var(--pro-cyan)"><i data-lucide="eye"></i> Visibilité</div>
            <div class="pro-insight-text">Votre profil a gagné +18% de visibilité cette semaine. Répondez aux 3 leads en attente pour maximiser la conversion.</div>
          </div>
          <div class="pro-insight-card" style="background:linear-gradient(135deg,rgba(139,92,246,0.08),rgba(59,130,246,0.05));border-color:rgba(139,92,246,0.2)">
            <div class="pro-insight-label" style="color:var(--pro-purple)"><i data-lucide="map-pin"></i> Régional</div>
            <div class="pro-insight-text">Les clients parisiens convertissent 2.3x mieux que la moyenne nationale. Zone prioritaire recommandée : 75001–75016.</div>
          </div>
        </div>
      </div>

      <!-- Recent Activity -->
      <div class="pro-card">
        <div class="pro-card-header">
          <span class="pro-card-title">Activité récente</span>
          <button class="pro-btn pro-btn-ghost pro-btn-sm">Tout voir</button>
        </div>
        <div class="pro-card-body">
          <div class="pro-activity-item">
            <div class="pro-activity-dot green"><i data-lucide="user-plus"></i></div>
            <div>
              <div style="font-size:13px;color:var(--pro-text);">Nouveau lead — <strong>Thomas R.</strong></div>
              <div class="pro-activity-meta">Appartement complet · Paris 75008 · €35,000</div>
              <div class="pro-activity-time">Il y a 23 min</div>
            </div>
          </div>
          <div class="pro-activity-item">
            <div class="pro-activity-dot cyan"><i data-lucide="message-square"></i></div>
            <div>
              <div style="font-size:13px;color:var(--pro-text);">Message de <strong>Sarah M.</strong></div>
              <div class="pro-activity-meta">"Pouvez-vous m'envoyer le devis final ?"</div>
              <div class="pro-activity-time">Il y a 1h</div>
            </div>
          </div>
          <div class="pro-activity-item">
            <div class="pro-activity-dot amber"><i data-lucide="star"></i></div>
            <div>
              <div style="font-size:13px;color:var(--pro-text);">Nouvel avis <strong>5★</strong> de Julie P.</div>
              <div class="pro-activity-meta">"Travail exceptionnel, très professionnel."</div>
              <div class="pro-activity-time">Il y a 3h</div>
            </div>
          </div>
          <div class="pro-activity-item">
            <div class="pro-activity-dot purple"><i data-lucide="folder-check"></i></div>
            <div>
              <div style="font-size:13px;color:var(--pro-text);">Projet complété — <strong>Dupont Living</strong></div>
              <div class="pro-activity-meta">Salon moderne · 85% satisfaction client</div>
              <div class="pro-activity-time">Hier, 16h30</div>
            </div>
          </div>
          <div class="pro-activity-item">
            <div class="pro-activity-dot green"><i data-lucide="credit-card"></i></div>
            <div>
              <div style="font-size:13px;color:var(--pro-text);">Paiement reçu — <strong>€4,200</strong></div>
              <div class="pro-activity-meta">Projet Renovation Bernard · Acompte 30%</div>
              <div class="pro-activity-time">Hier, 09h15</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Right: Tasks + Messages -->
    <div style="display:flex;flex-direction:column;gap:16px;">
      <!-- Today's tasks -->
      <div class="pro-card">
        <div class="pro-card-header">
          <span class="pro-card-title">Tâches du jour</span>
          <button class="pro-btn pro-btn-ghost pro-btn-sm"><i data-lucide="plus"></i></button>
        </div>
        <div class="pro-card-body">
          <div class="pro-task-item">
            <div class="pro-task-check done"></div>
            <span class="pro-task-label" style="text-decoration:line-through;color:var(--pro-text3)">Envoyer devis Marc D.</span>
            <span class="pro-task-due">09:00</span>
          </div>
          <div class="pro-task-item">
            <div class="pro-task-check"></div>
            <span class="pro-task-label">Répondre à Thomas R.</span>
            <span class="pro-task-due">11:00</span>
          </div>
          <div class="pro-task-item">
            <div class="pro-task-check"></div>
            <span class="pro-task-label">Appel client Julie P.</span>
            <span class="pro-task-due" style="color:var(--pro-amber)">14:00</span>
          </div>
          <div class="pro-task-item">
            <div class="pro-task-check"></div>
            <span class="pro-task-label">Upload photos projet Dupont</span>
            <span class="pro-task-due">16:00</span>
          </div>
          <div class="pro-task-item">
            <div class="pro-task-check"></div>
            <span class="pro-task-label">Réviser portfolio cuisine</span>
            <span class="pro-task-due">18:00</span>
          </div>
        </div>
      </div>

      <!-- Quick messages -->
      <div class="pro-card">
        <div class="pro-card-header">
          <span class="pro-card-title">Messages récents</span>
          <button class="pro-btn pro-btn-ghost pro-btn-sm">Voir tout</button>
        </div>
        <div class="pro-card-body" style="padding-top:8px;">
          <% var msgs = [
            { name: 'Sarah M.', msg: 'Pouvez-vous m\'envoyer le devis ?', time: '23min', unread: true, color: '#10b981' },
            { name: 'Thomas R.', msg: 'Parfait ! J\'attends votre retour.', time: '1h', unread: true, color: '#06b6d4' },
            { name: 'Marc D.', msg: 'Merci pour les rendus IA !', time: '3h', unread: false, color: '#8b5cf6' }
          ]; %>
          <% msgs.forEach(function(m) { %>
          <div class="pro-activity-item" style="cursor:pointer;">
            <div class="pro-activity-dot" style="background:rgba(255,255,255,0.05);color:<%= m.color %>;font-size:12px;font-weight:700;">
              <%= m.name.charAt(0) %>
            </div>
            <div style="flex:1;min-width:0;">
              <div style="font-size:12.5px;font-weight:<%= m.unread ? '700' : '500' %>;color:var(--pro-text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><%= m.name %></div>
              <div class="pro-activity-meta" style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><%= m.msg %></div>
            </div>
            <div style="display:flex;flex-direction:column;align-items:flex-end;gap:4px;flex-shrink:0;">
              <span class="pro-activity-time"><%= m.time %></span>
              <% if (m.unread) { %><span style="width:7px;height:7px;border-radius:50%;background:var(--pro-green);display:block;"></span><% } %>
            </div>
          </div>
          <% }); %>
        </div>
      </div>

      <!-- Upcoming -->
      <div class="pro-card">
        <div class="pro-card-header">
          <span class="pro-card-title">Prochains rendez-vous</span>
          <button class="pro-btn pro-btn-ghost pro-btn-sm"><i data-lucide="calendar"></i></button>
        </div>
        <div class="pro-card-body" style="padding-top:8px;">
          <div style="display:flex;flex-direction:column;gap:8px;">
            <div style="display:flex;align-items:center;gap:10px;padding:10px;background:rgba(16,185,129,0.06);border:1px solid rgba(16,185,129,0.15);border-radius:9px;">
              <div style="text-align:center;min-width:36px;">
                <div style="font-size:17px;font-weight:800;color:var(--pro-green);line-height:1;">10</div>
                <div style="font-size:9px;text-transform:uppercase;color:var(--pro-text3);">Mai</div>
              </div>
              <div>
                <div style="font-size:12.5px;font-weight:600;color:var(--pro-text);">Appel client — Julie P.</div>
                <div style="font-size:11px;color:var(--pro-text3);">14:00 – Salle de bain · €5,500</div>
              </div>
            </div>
            <div style="display:flex;align-items:center;gap:10px;padding:10px;background:rgba(6,182,212,0.06);border:1px solid rgba(6,182,212,0.15);border-radius:9px;">
              <div style="text-align:center;min-width:36px;">
                <div style="font-size:17px;font-weight:800;color:var(--pro-cyan);line-height:1;">12</div>
                <div style="font-size:9px;text-transform:uppercase;color:var(--pro-text3);">Mai</div>
              </div>
              <div>
                <div style="font-size:12.5px;font-weight:600;color:var(--pro-text);">Visite — Projet Bernard</div>
                <div style="font-size:11px;color:var(--pro-text3);">10:00 – Lyon 69001 · Renovation</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

