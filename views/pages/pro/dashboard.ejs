      <div class="pro-analytics-kpi-change up"><i data-lucide="trending-up"></i> +5 points</div>
    </div>
    <div class="pro-analytics-kpi-card">
      <div class="pro-analytics-kpi-value">€42,800</div>
      <div class="pro-analytics-kpi-label">Revenus estimés</div>
      <div class="pro-analytics-kpi-change up"><i data-lucide="trending-up"></i> +8% croissance</div>
    </div>
    <div class="pro-analytics-kpi-card">
      <div class="pro-analytics-kpi-value">4.9 ★</div>
      <div class="pro-analytics-kpi-label">Note moyenne</div>
      <div class="pro-analytics-kpi-change up"><i data-lucide="trending-up"></i> 47 avis clients</div>
    </div>
  </div>

  <div class="pro-analytics-grid">
    <div class="pro-chart-area">
      <div class="pro-chart-title">Revenus mensuels</div>
      <div class="pro-chart-sub">6 derniers mois · en euros</div>
      <svg class="pro-line-chart" viewBox="0 0 600 180" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
        <defs>
          <linearGradient id="chartGrad" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#10b981" stop-opacity="0.3"/>
