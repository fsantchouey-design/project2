  <div class="pn-body">

    <!-- Left: note list -->
    <div class="pn-list-panel">
      <div class="pn-list-top">
        <div class="pn-search-wrap">
          <svg class="pn-search-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          <input type="text" class="pn-search-input" id="pn-search" placeholder="Rechercher…">
        </div>
        <div class="pn-tag-filters">
          <button class="pn-tag-filter active" data-tag="">Toutes</button>
          <button class="pn-tag-filter" data-tag="Lead">Lead</button>
          <button class="pn-tag-filter" data-tag="Projet">Projet</button>
          <button class="pn-tag-filter" data-tag="Client">Client</button>
          <button class="pn-tag-filter" data-tag="Devis">Devis</button>
          <button class="pn-tag-filter" data-tag="Rendez-vous">RDV</button>
          <button class="pn-tag-filter" data-tag="Inspiration">Inspi</button>
          <button class="pn-tag-filter" data-tag="IA">IA</button>
        </div>
      </div>
      <div class="pn-list-scroll" id="pn-list-scroll">
        <% if (typeof proNotes === 'undefined' || proNotes.length === 0) { %>
          <div class="pn-empty-list">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
            <span>Aucune note pour l'instant</span>
          </div>
        <% } %>
        <% if (typeof proNotes !== 'undefined') { %>
          <% proNotes.forEach(function(note) { %>
            <div class="pn-note-card <%= note.pinned ? 'is-pinned' : '' %>"
                 data-id="<%= note._id %>"
                 data-title="<%= (note.title || '').replace(/\"/g, '&quot;') %>"
                 data-content="<%= (note.content || '').replace(/\"/g, '&quot;') %>"
                 data-tags="<%= (note.tags || []).join(',') %>"
                 data-pinned="<%= note.pinned ? 'true' : 'false' %>">
              <div class="pn-card-title"><%= note.title || 'Note sans titre' %></div>
              <div class="pn-card-preview"><%= note.content || '' %></div>
              <div class="pn-card-meta">
                <span class="pn-card-date"><%= new Date(note.updatedAt).toLocaleDateString('fr-FR', { day: 'numeric', month: 'short' }) %></span>
                <div class="pn-card-tags">
                  <% (note.tags || []).slice(0, 2).forEach(function(tag) { %>
                    <span class="pn-tag-pill ptag-<%= tag.replace(/[^a-zA-Z]/g, '-') %>"><%= tag %></span>
                  <% }); %>
                </div>
              </div>
            </div>
          <% }); %>
        <% } %>
      </div>
    </div>

    <!-- Right: editor -->
    <div class="pn-editor-panel" id="pn-editor-panel">
      <button class="pn-mob-back" id="pn-mob-back">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        Retour aux notes
      </button>

      <div class="pn-editor-empty" id="pn-editor-empty">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
        <h3>Sélectionnez une note</h3>
        <p>Choisissez une note dans la liste<br>ou créez-en une nouvelle.</p>
      </div>

      <div class="pn-editor-wrap" id="pn-editor-wrap" style="display:none">
        <div class="pn-editor-toolbar">
          <span class="pn-save-status" id="pn-save-status"></span>
          <div class="pn-editor-actions">
            <button class="pn-action-btn" id="pn-pin-btn">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="17" x2="12" y2="22"/><path d="M5 17h14v-1.76a2 2 0 0 0-1.11-1.79l-1.78-.9A2 2 0 0 1 15 10.76V6h1a2 2 0 0 0 0-4H8a2 2 0 0 0 0 4h1v4.76a2 2 0 0 1-1.11 1.79l-1.78.9A2 2 0 0 0 5 15.24Z"/></svg>
              Épingler
            </button>
            <button class="pn-action-btn del" id="pn-del-btn">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
              Supprimer
            </button>
          </div>
        </div>

        <div class="pn-tags-row">
          <span class="pn-tags-label">Tags :</span>
          <button class="pn-tag-toggle ptag-Lead"        data-tag="Lead">Lead</button>
          <button class="pn-tag-toggle ptag-Projet"      data-tag="Projet">Projet</button>
          <button class="pn-tag-toggle ptag-Client"      data-tag="Client">Client</button>
          <button class="pn-tag-toggle ptag-Devis"       data-tag="Devis">Devis</button>
          <button class="pn-tag-toggle ptag-Rendez-vous" data-tag="Rendez-vous">Rendez-vous</button>
          <button class="pn-tag-toggle ptag-Inspiration" data-tag="Inspiration">Inspiration</button>
          <button class="pn-tag-toggle ptag-IA"          data-tag="IA">IA</button>
        </div>

        <input type="text" class="pn-title-input" id="pn-title" placeholder="Titre de la note…">
        <textarea class="pn-content-textarea" id="pn-content" placeholder="Réflexions, informations client, détails du devis, idées design…"></textarea>
      </div>
    </div>

  </div>

  <script>
  (function() {
    var pnCurrentId = null;
    var pnSaveTimer = null;

    var editorPanel = document.getElementById('pn-editor-panel');
    var editorEmpty = document.getElementById('pn-editor-empty');
    var editorWrap  = document.getElementById('pn-editor-wrap');
    var titleInput  = document.getElementById('pn-title');
    var contentTA   = document.getElementById('pn-content');
    var pinBtn      = document.getElementById('pn-pin-btn');
    var delBtn      = document.getElementById('pn-del-btn');
    var listScroll  = document.getElementById('pn-list-scroll');
    var searchInput = document.getElementById('pn-search');
    var mobBack     = document.getElementById('pn-mob-back');
    var saveStatus  = document.getElementById('pn-save-status');
    var newBtn      = document.getElementById('pn-new-btn');

    function setStatus(type, text) {
      saveStatus.textContent = text;
      saveStatus.className = 'pn-save-status';
      if (type) saveStatus.classList.add(type);
    }

    function openEditor() {
      editorEmpty.style.display = 'none';
      editorWrap.style.display  = 'flex';
      if (window.innerWidth <= 900) {
        editorPanel.classList.add('mob-open');
      }
    }

    if (mobBack) {
      mobBack.addEventListener('click', function() {
        editorPanel.classList.remove('mob-open');
      });
    }

    function getActiveTags() {
      var active = [];
      document.querySelectorAll('.pn-tag-toggle.active').forEach(function(btn) {
        active.push(btn.getAttribute('data-tag'));
      });
      return active;
    }

    function isPinned() {
      return pinBtn && pinBtn.classList.contains('pinned');
    }

    function setPinState(pinned) {
      if (pinned) {
        pinBtn.classList.add('pinned');
        pinBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" style="width:13px;height:13px;flex-shrink:0;"><line x1="12" y1="17" x2="12" y2="22"/><path d="M5 17h14v-1.76a2 2 0 0 0-1.11-1.79l-1.78-.9A2 2 0 0 1 15 10.76V6h1a2 2 0 0 0 0-4H8a2 2 0 0 0 0 4h1v4.76a2 2 0 0 1-1.11 1.79l-1.78.9A2 2 0 0 0 5 15.24Z"/></svg> Epinglee';
      } else {
        pinBtn.classList.remove('pinned');
        pinBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:13px;height:13px;flex-shrink:0;"><line x1="12" y1="17" x2="12" y2="22"/><path d="M5 17h14v-1.76a2 2 0 0 0-1.11-1.79l-1.78-.9A2 2 0 0 1 15 10.76V6h1a2 2 0 0 0 0-4H8a2 2 0 0 0 0 4h1v4.76a2 2 0 0 1-1.11 1.79l-1.78.9A2 2 0 0 0 5 15.24Z"/></svg> Epingler';
      }
    }

    function loadNote(card) {
      pnCurrentId = card.getAttribute('data-id');
      titleInput.value = card.getAttribute('data-title').replace(/&quot;/g, '"');
      contentTA.value  = card.getAttribute('data-content').replace(/&quot;/g, '"');
      var tags = (card.getAttribute('data-tags') || '').split(',').filter(function(t) { return t; });
      document.querySelectorAll('.pn-tag-toggle').forEach(function(btn) {
        if (tags.indexOf(btn.getAttribute('data-tag')) !== -1) {
          btn.classList.add('active');
        } else {
          btn.classList.remove('active');
        }
      });
      setPinState(card.getAttribute('data-pinned') === 'true');
      document.querySelectorAll('.pn-note-card').forEach(function(c) { c.classList.remove('selected'); });
      card.classList.add('selected');
      setStatus('', '');
      openEditor();
    }

    document.querySelectorAll('.pn-note-card').forEach(function(card) {
      card.addEventListener('click', function() { loadNote(this); });
    });

    function scheduleAutoSave() {
      clearTimeout(pnSaveTimer);
      setStatus('saving', 'Enregistrement...');
      pnSaveTimer = setTimeout(saveCurrentNote, 1500);
    }

    function saveCurrentNote() {
      if (!pnCurrentId) return;
      var body = {
        title:   titleInput.value,
        content: contentTA.value,
        tags:    getActiveTags(),
        pinned:  isPinned()
      };
      var xhr = new XMLHttpRequest();
      xhr.open('PUT', '/pro/notes/' + pnCurrentId);
      xhr.setRequestHeader('Content-Type', 'application/json');
      xhr.onload = function() {
        if (xhr.status === 200) {
          setStatus('saved', 'Sauvegarde');
          updateCardInList(pnCurrentId, body);
        } else {
          setStatus('error', 'Erreur');
        }
      };
      xhr.onerror = function() { setStatus('error', 'Erreur reseau'); };
      xhr.send(JSON.stringify(body));
    }

    function updateCardInList(id, data) {
      var card = document.querySelector('.pn-note-card[data-id="' + id + '"]');
      if (!card) return;
      card.setAttribute('data-title',   data.title   || '');
      card.setAttribute('data-content', data.content || '');
      card.setAttribute('data-tags',    (data.tags   || []).join(','));
      card.setAttribute('data-pinned',  data.pinned  ? 'true' : 'false');
      var tEl = card.querySelector('.pn-card-title');
      if (tEl) tEl.textContent = data.title || 'Note sans titre';
      var pEl = card.querySelector('.pn-card-preview');
      if (pEl) pEl.textContent = data.content || '';
      var tagsEl = card.querySelector('.pn-card-tags');
      if (tagsEl) {
        tagsEl.innerHTML = '';
        (data.tags || []).slice(0, 2).forEach(function(tag) {
          var s = document.createElement('span');
          s.className = 'pn-tag-pill ptag-' + tag.replace(/[^a-zA-Z]/g, '-');
          s.textContent = tag;
          tagsEl.appendChild(s);
        });
      }
      if (data.pinned) { card.classList.add('is-pinned'); } else { card.classList.remove('is-pinned'); }
    }

    if (titleInput)  titleInput.addEventListener('input',  scheduleAutoSave);
    if (contentTA)   contentTA.addEventListener('input',   scheduleAutoSave);

    document.querySelectorAll('.pn-tag-toggle').forEach(function(btn) {
      btn.addEventListener('click', function() {
        this.classList.toggle('active');
        scheduleAutoSave();
      });
    });

    if (pinBtn) {
      pinBtn.addEventListener('click', function() {
        if (!pnCurrentId) return;
        setPinState(!isPinned());
        scheduleAutoSave();
      });
    }

    if (delBtn) {
      delBtn.addEventListener('click', function() {
        if (!pnCurrentId) return;
        if (!confirm('Supprimer cette note ?')) return;
        var idToDelete = pnCurrentId;
        var xhr = new XMLHttpRequest();
        xhr.open('DELETE', '/pro/notes/' + idToDelete);
        xhr.setRequestHeader('Content-Type', 'application/json');
        xhr.onload = function() {
          if (xhr.status === 200) {
            var card = document.querySelector('.pn-note-card[data-id="' + idToDelete + '"]');
            if (card) card.remove();
            pnCurrentId = null;
            editorEmpty.style.display = 'flex';
            editorWrap.style.display  = 'none';
            editorPanel.classList.remove('mob-open');
            if (!document.querySelector('.pn-note-card')) {
              listScroll.innerHTML = '<div class="pn-empty-list"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="width:28px;height:28px;"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg><span>Aucune note</span></div>';
            }
          }
        };
        xhr.send();
      });
    }

    if (newBtn) {
      newBtn.addEventListener('click', function() {
        var xhr = new XMLHttpRequest();
        xhr.open('POST', '/pro/notes');
        xhr.setRequestHeader('Content-Type', 'application/json');
        xhr.onload = function() {
          if (xhr.status === 200) {
            var res = JSON.parse(xhr.responseText);
            var note = res.note;
            var card = document.createElement('div');
            card.className = 'pn-note-card selected';
            card.setAttribute('data-id',      note._id);
            card.setAttribute('data-title',   '');
            card.setAttribute('data-content', '');
            card.setAttribute('data-tags',    '');
            card.setAttribute('data-pinned',  'false');
            card.innerHTML =
              '<div class="pn-card-title">Note sans titre</div>' +
              '<div class="pn-card-preview"></div>' +
              '<div class="pn-card-meta">' +
                '<span class="pn-card-date">Maintenant</span>' +
                '<div class="pn-card-tags"></div>' +
              '</div>';
            card.addEventListener('click', function() { loadNote(this); });
            var emptyEl = listScroll.querySelector('.pn-empty-list');
            if (emptyEl) emptyEl.remove();
            listScroll.insertBefore(card, listScroll.firstChild);
            document.querySelectorAll('.pn-note-card').forEach(function(c) { c.classList.remove('selected'); });
            pnCurrentId = note._id;
            titleInput.value = '';
            contentTA.value  = '';
            document.querySelectorAll('.pn-tag-toggle').forEach(function(b) { b.classList.remove('active'); });
            setPinState(false);
            setStatus('', '');
            openEditor();
            titleInput.focus();
          }
        };
        xhr.send(JSON.stringify({ title: '', content: '' }));
      });
    }

    if (searchInput) {
      searchInput.addEventListener('input', filterNotes);
    }

    document.querySelectorAll('.pn-tag-filter').forEach(function(btn) {
      btn.addEventListener('click', function() {
        document.querySelectorAll('.pn-tag-filter').forEach(function(b) { b.classList.remove('active'); });
        this.classList.add('active');
        filterNotes();
      });
    });

    function filterNotes() {
      var query = searchInput ? searchInput.value.toLowerCase().trim() : '';
      var activeTagBtn = document.querySelector('.pn-tag-filter.active');
      var activeTag = activeTagBtn ? (activeTagBtn.getAttribute('data-tag') || '') : '';
      document.querySelectorAll('.pn-note-card').forEach(function(card) {
        var title   = (card.getAttribute('data-title')   || '').toLowerCase();
        var content = (card.getAttribute('data-content') || '').toLowerCase();
        var tags    = (card.getAttribute('data-tags')    || '').toLowerCase();
        var matchSearch = !query || title.indexOf(query) !== -1 || content.indexOf(query) !== -1;
        var matchTag    = !activeTag || tags.indexOf(activeTag.toLowerCase()) !== -1;
        card.style.display = (matchSearch && matchTag) ? '' : 'none';
      });
    }
  })();
  </script>
</div>

