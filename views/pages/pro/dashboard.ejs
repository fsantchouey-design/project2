<!-- ============================================================
     CraftyCrib Pro Dashboard — All Sections
     ============================================================ -->

<!-- ===================== DASHBOARD ===================== -->
<div class="pro-section active" id="sec-dashboard">
  <div class="pro-page-header">
    <div>
      <div class="pro-page-title">Demandes clients reçues</div>
      <div class="pro-page-sub">Formulaires soumis depuis la section Entrepreneurs</div>
    </div>
  </div>

  <style>
  .prq-tabs {
    display: flex;
    gap: 8px;
    margin-bottom: 20px;
    flex-wrap: wrap;
  }
  .prq-tab {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 7px 16px;
    border-radius: 8px;
    border: 1px solid var(--pro-border);
    background: transparent;
    color: rgba(255,255,255,0.45);
    font-size: 0.82rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.15s;
    font-family: inherit;
  }
  .prq-tab:hover { background: rgba(255,255,255,0.04); color: #e2e8f0; }
  .prq-tab.active {
    background: var(--pro-card2);
    border-color: var(--pro-green);
    color: var(--pro-green);
  }
  .prq-tab-count {
    font-size: 0.7rem;
    padding: 1px 6px;
    border-radius: 10px;
    background: rgba(255,255,255,0.1);
    color: rgba(255,255,255,0.5);
  }
  .prq-tab.active .prq-tab-count {
    background: rgba(16,185,129,0.2);
    color: var(--pro-green);
  }
  .prq-empty {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
    padding: 64px 24px;
    text-align: center;
    color: rgba(255,255,255,0.2);
    border: 1px dashed var(--pro-border);
    border-radius: 14px;
  }
  .prq-empty svg { width:40px; height:40px; }
  .prq-empty p { font-size:0.85rem; margin:0; }
  .prq-list {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .prq-card {
    background: var(--pro-card);
    border: 1px solid var(--pro-border);
    border-radius: 14px;
    overflow: hidden;
    transition: border-color 0.2s;
  }
  .prq-card:hover { border-color: rgba(255,255,255,0.12); }
  .prq-card-top {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 18px;
    border-bottom: 1px solid var(--pro-border);
    flex-wrap: wrap;
  }
  .prq-service-chip {
    font-size: 0.7rem;
    font-weight: 700;
    padding: 3px 10px;
    border-radius: 20px;
    background: rgba(16,185,129,0.15);
    color: var(--pro-green);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    white-space: nowrap;
  }
  .prq-subservice {
    font-size: 0.88rem;
    font-weight: 600;
    color: #e2e8f0;
    flex: 1;
  }
  .prq-date {
    font-size: 0.72rem;
    color: rgba(255,255,255,0.3);
    white-space: nowrap;
  }
  .prq-status-badge {
    font-size: 0.7rem;
    font-weight: 700;
    padding: 3px 10px;
    border-radius: 20px;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    white-space: nowrap;
  }
  .prq-s-new       { background: rgba(6,182,212,0.15);  color: #22d3ee; }
  .prq-s-accepted  { background: rgba(16,185,129,0.15); color: var(--pro-green); }
  .prq-s-refused   { background: rgba(239,68,68,0.12);  color: #f87171; }
  .prq-s-contacted { background: rgba(245,158,11,0.15); color: var(--pro-amber); }
  .prq-s-closed    { background: rgba(255,255,255,0.07); color: rgba(255,255,255,0.35); }
  .prq-card-actions {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }
  .prq-btn {
    display: flex;
    align-items: center;
    gap: 5px;
    padding: 5px 12px;
    border-radius: 7px;
    border: 1px solid var(--pro-border);
    background: transparent;
    color: rgba(255,255,255,0.45);
    font-size: 0.74rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.15s;
    font-family: inherit;
    white-space: nowrap;
  }
  .prq-btn svg { width: 12px; height: 12px; flex-shrink: 0; }
  .prq-btn:hover { background: rgba(255,255,255,0.05); color: #e2e8f0; }
  .prq-btn.accept {
    border-color: rgba(16,185,129,0.35);
    color: var(--pro-green);
  }
  .prq-btn.accept:hover { background: rgba(16,185,129,0.1); }
  .prq-btn.refuse {
    border-color: rgba(239,68,68,0.3);
    color: #f87171;
  }
  .prq-btn.refuse:hover { background: rgba(239,68,68,0.08); }
  .prq-details-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    padding: 0;
  }
  .prq-col {
    padding: 16px 18px;
  }
  .prq-col:first-child {
    border-right: 1px solid var(--pro-border);
  }
  .prq-col-title {
    font-size: 0.68rem;
    font-weight: 700;
    color: rgba(255,255,255,0.3);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 12px;
  }
  .prq-row {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    margin-bottom: 9px;
  }
  .prq-row:last-child { margin-bottom: 0; }
  .prq-row-label {
    font-size: 0.71rem;
    color: rgba(255,255,255,0.3);
    white-space: nowrap;
    min-width: 90px;
    padding-top: 1px;
  }
  .prq-row-val {
    font-size: 0.8rem;
    color: #cbd5e1;
    line-height: 1.45;
    word-break: break-word;
  }
  .prq-row-val a {
    color: var(--pro-cyan);
    text-decoration: none;
  }
  .prq-row-val a:hover { text-decoration: underline; }
  .prq-desc {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.5);
    line-height: 1.6;
    font-style: italic;
    padding: 10px 18px;
    border-top: 1px solid var(--pro-border);
    border-bottom: 1px solid var(--pro-border);
  }
  .prq-photos {
    display: flex;
    gap: 8px;
    padding: 12px 18px;
    flex-wrap: wrap;
    border-top: 1px solid var(--pro-border);
  }
  .prq-photo-thumb {
    width: 72px;
    height: 72px;
    object-fit: cover;
    border-radius: 7px;
    border: 1px solid var(--pro-border);
    cursor: pointer;
    transition: opacity 0.15s;
  }
  .prq-photo-thumb:hover { opacity: 0.8; }
  @media (max-width: 700px) {
    .prq-details-grid { grid-template-columns: 1fr; }
    .prq-col:first-child { border-right: none; border-bottom: 1px solid var(--pro-border); }
    .prq-card-top { gap: 8px; }
    .prq-row-label { min-width: 72px; }
  }
  </style>

  <!-- Filter tabs -->
  <div class="prq-tabs" id="prq-tabs">
    <button class="prq-tab active" data-filter="">
      Toutes <span class="prq-tab-count" id="prq-count-all">0</span>
    </button>
    <button class="prq-tab" data-filter="new">
      Nouvelles <span class="prq-tab-count" id="prq-count-new">0</span>
    </button>
    <button class="prq-tab" data-filter="accepted">
      Acceptées <span class="prq-tab-count" id="prq-count-accepted">0</span>
    </button>
    <button class="prq-tab" data-filter="refused">
      Refusées <span class="prq-tab-count" id="prq-count-refused">0</span>
    </button>
  </div>

  <!-- Empty state -->
  <div class="prq-empty" id="prq-empty">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
    <p>Aucune demande dans cette catégorie.</p>
  </div>

  <!-- Requests list -->
  <div class="prq-list" id="prq-list">

    <% var timingLabel = function(t) {
      if (t === 'asap')     return 'Dès que possible';
      if (t === 'week')     return "D'ici une semaine";
      if (t === 'later')    return "Dans plus d'une semaine";
      if (t === 'flexible') return 'Flexible';
      return t || '-';
    }; %>

    <% var statusLabel = function(s) {
      if (s === 'new')       return 'Nouvelle';
      if (s === 'accepted')  return 'Acceptée';
      if (s === 'refused')   return 'Refusée';
      if (s === 'contacted') return 'Contactée';
      if (s === 'closed')    return 'Fermée';
      return s || 'Nouvelle';
    }; %>

    <% if (typeof quoteRequests !== 'undefined' && quoteRequests.length > 0) { %>
      <% quoteRequests.forEach(function(q) { %>

        <div class="prq-card" data-id="<%= q._id %>" data-status="<%= q.status || 'new' %>">

          <!-- Top bar -->
          <div class="prq-card-top">
            <span class="prq-service-chip"><%= q.specialty || 'Service' %></span>
            <span class="prq-subservice"><%= q.service || '' %></span>
            <span class="prq-date">
              <%= new Date(q.createdAt).toLocaleDateString('fr-FR', { day: 'numeric', month: 'short', year: 'numeric' }) %>
              &nbsp;·&nbsp;
              <%= new Date(q.createdAt).toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' }) %>
            </span>
            <span class="prq-status-badge prq-s-<%= q.status || 'new' %>">
              <%= statusLabel(q.status) %>
            </span>
            <div class="prq-card-actions">
              <% if (q.status !== 'accepted') { %>
                <button class="prq-btn accept" onclick="prqSetStatus('<%= q._id %>', 'accepted')">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                  <%= q.status === 'refused' ? 'Accepter quand même' : 'Accepter' %>
                </button>
              <% } %>
              <% if (q.status !== 'refused') { %>
                <button class="prq-btn refuse" onclick="prqSetStatus('<%= q._id %>', 'refused')">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                  Refuser
                </button>
              <% } %>
            </div>
          </div>

          <!-- Details grid -->
          <div class="prq-details-grid">
            <!-- Col 1 : Projet -->
            <div class="prq-col">
              <div class="prq-col-title">Projet</div>
              <div class="prq-row">
                <span class="prq-row-label">Code postal</span>
                <span class="prq-row-val"><%= q.postalCode || '-' %></span>
              </div>
              <div class="prq-row">
                <span class="prq-row-label">Délai</span>
                <span class="prq-row-val"><%= timingLabel(q.timing) %></span>
              </div>
              <% if (q.photos && q.photos.length > 0) { %>
                <div class="prq-row">
                  <span class="prq-row-label">Photos</span>
                  <span class="prq-row-val"><%= q.photos.length %> photo<%= q.photos.length > 1 ? 's' : '' %></span>
                </div>
              <% } %>
            </div>
            <!-- Col 2 : Coordonnées -->
            <div class="prq-col">
              <div class="prq-col-title">Coordonnées</div>
              <div class="prq-row">
                <span class="prq-row-label">Nom</span>
                <span class="prq-row-val"><%= q.firstName %> <%= q.lastName %></span>
              </div>
              <div class="prq-row">
                <span class="prq-row-label">Adresse</span>
                <span class="prq-row-val">
                  <%= q.address || '' %><% if (q.apartment) { %>, Apt <%= q.apartment %><% } %><br>
                  <%= q.city || '' %><% if (q.province) { %>, <%= q.province %><% } %><% if (q.contactPostalCode) { %> &nbsp;<%= q.contactPostalCode %><% } %>
                </span>
              </div>
              <div class="prq-row">
                <span class="prq-row-label">Téléphone</span>
                <span class="prq-row-val">
                  <a href="tel:<%= q.phone %>"><%= q.phone %></a>
                  <% if (q.altPhone) { %><br><a href="tel:<%= q.altPhone %>"><%= q.altPhone %></a><% } %>
                </span>
              </div>
              <div class="prq-row">
                <span class="prq-row-label">Courriel</span>
                <span class="prq-row-val"><a href="mailto:<%= q.email %>"><%= q.email %></a></span>
              </div>
            </div>
          </div>

          <!-- Description -->
          <% if (q.description && q.description.trim()) { %>
            <div class="prq-desc">"<%= q.description %>"</div>
          <% } %>

          <!-- Photos -->
          <% if (q.photos && q.photos.length > 0) { %>
            <div class="prq-photos">
              <% q.photos.forEach(function(photo) { %>
                <img class="prq-photo-thumb" src="<%= photo %>" alt="Photo projet" onclick="window.open('<%= photo %>','_blank')">
              <% }); %>
            </div>
          <% } %>

        </div><!-- /.prq-card -->

      <% }); %>
    <% } %>

  </div><!-- /#prq-list -->

  <script>
  (function() {

    var STATUS_LABELS = {
      'new':       'Nouvelle',
      'accepted':  'Acceptée',
      'refused':   'Refusée',
      'contacted': 'Contactée',
      'closed':    'Fermée'
    };

    var currentFilter = '';

    function countByStatus(status) {
      var cards = document.querySelectorAll('.prq-card');
      var n = 0;
      cards.forEach(function(c) {
        if (!status || c.getAttribute('data-status') === status) n++;
      });
      return n;
    }

    function updateCounts() {
      var el;
      el = document.getElementById('prq-count-all');
      if (el) el.textContent = countByStatus('');
      el = document.getElementById('prq-count-new');
      if (el) el.textContent = countByStatus('new');
      el = document.getElementById('prq-count-accepted');
      if (el) el.textContent = countByStatus('accepted');
      el = document.getElementById('prq-count-refused');
      if (el) el.textContent = countByStatus('refused');
    }

    function applyFilter() {
      var cards = document.querySelectorAll('.prq-card');
      var visible = 0;
      cards.forEach(function(card) {
        var s = card.getAttribute('data-status');
        var show = !currentFilter || s === currentFilter;
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      var empty = document.getElementById('prq-empty');
      if (empty) empty.style.display = visible === 0 ? 'flex' : 'none';
    }

    document.querySelectorAll('.prq-tab').forEach(function(tab) {
      tab.addEventListener('click', function() {
        document.querySelectorAll('.prq-tab').forEach(function(t) { t.classList.remove('active'); });
        this.classList.add('active');
        currentFilter = this.getAttribute('data-filter') || '';
        applyFilter();
      });
    });

    updateCounts();
    applyFilter();

  })();

  function prqSetStatus(id, newStatus) {
    var STATUS_LABELS = {
      'new': 'Nouvelle', 'accepted': 'Acceptée',
      'refused': 'Refusée', 'contacted': 'Contactée', 'closed': 'Fermée'
    };
    var xhr = new XMLHttpRequest();
    xhr.open('PUT', '/pro/quotes/' + id + '/status');
    xhr.setRequestHeader('Content-Type', 'application/json');
    xhr.onload = function() {
      if (xhr.status === 200) {
        var card = document.querySelector('.prq-card[data-id="' + id + '"]');
        if (!card) return;
        var res = JSON.parse(xhr.responseText);
        var s = res.status;
        card.setAttribute('data-status', s);

        // Update status badge
        var badge = card.querySelector('.prq-status-badge');
        if (badge) {
          badge.className = 'prq-status-badge prq-s-' + s;
          badge.textContent = STATUS_LABELS[s] || s;
        }

        // Rebuild action buttons
        var actionsDiv = card.querySelector('.prq-card-actions');
        if (actionsDiv) {
          actionsDiv.innerHTML = '';
          if (s !== 'accepted') {
            var btnA = document.createElement('button');
            btnA.className = 'prq-btn accept';
            btnA.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> ' + (s === 'refused' ? 'Accepter quand même' : 'Accepter');
            btnA.onclick = function() { prqSetStatus(id, 'accepted'); };
            actionsDiv.appendChild(btnA);
          }
          if (s !== 'refused') {
            var btnR = document.createElement('button');
            btnR.className = 'prq-btn refuse';
            btnR.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg> Refuser';
            btnR.onclick = function() { prqSetStatus(id, 'refused'); };
            actionsDiv.appendChild(btnR);
          }
        }

        // Re-apply current filter + recount
        (function() {
          var tabs = document.querySelectorAll('.prq-tab');
          var currentFilter = '';
          tabs.forEach(function(t) { if (t.classList.contains('active')) currentFilter = t.getAttribute('data-filter') || ''; });
          var cards = document.querySelectorAll('.prq-card');
          var visible = 0;
          cards.forEach(function(c) {
            var show = !currentFilter || c.getAttribute('data-status') === currentFilter;
            c.style.display = show ? '' : 'none';
            if (show) visible++;
          });
          var empty = document.getElementById('prq-empty');
          if (empty) empty.style.display = visible === 0 ? 'flex' : 'none';
          var el;
          el = document.getElementById('prq-count-all');
          if (el) el.textContent = (function() { var n=0; cards.forEach(function(c){ n++; }); return n; })();
          el = document.getElementById('prq-count-new');
          if (el) el.textContent = (function() { var n=0; cards.forEach(function(c){ if(c.getAttribute('data-status')==='new') n++; }); return n; })();
          el = document.getElementById('prq-count-accepted');
          if (el) el.textContent = (function() { var n=0; cards.forEach(function(c){ if(c.getAttribute('data-status')==='accepted') n++; }); return n; })();
          el = document.getElementById('prq-count-refused');
          if (el) el.textContent = (function() { var n=0; cards.forEach(function(c){ if(c.getAttribute('data-status')==='refused') n++; }); return n; })();
        })();
      }
    };
    xhr.onerror = function() { alert('Erreur réseau, veuillez réessayer.'); };
    xhr.send(JSON.stringify({ status: newStatus }));
  }
  </script>

</div>

<!-- ===================== LEADS ===================== -->
<div class="pro-section" id="sec-leads">
  <div class="pro-page-header">
    <div>
      <div class="pro-page-title">Leads</div>
      <div class="pro-page-sub">Vos leads acceptés · Suivez le statut de vos clients potentiels</div>
    </div>
  </div>

  <style>
  .pro-lead-contact {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 6px 0 2px;
    border-top: 1px solid var(--pro-border);
    margin-top: 4px;
  }
  .pro-lead-contact-link {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.72rem;
    color: var(--pro-cyan);
    text-decoration: none;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .pro-lead-contact-link:hover { text-decoration: underline; }
  .pro-lead-contact-link svg { width: 11px; height: 11px; flex-shrink: 0; }
  .pro-lead-cat-chip {
    font-size: 0.63rem;
    font-weight: 700;
    padding: 2px 8px;
    border-radius: 20px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .plc-peinture     { background: rgba(139,92,246,0.12);  color: #a78bfa; }
  .plc-cuisine      { background: rgba(245,158,11,0.12);  color: var(--pro-amber); }
  .plc-salle-de-bain{ background: rgba(6,182,212,0.12);   color: var(--pro-cyan); }
  .plc-renovation   { background: rgba(16,185,129,0.12);  color: var(--pro-green); }
  .plc-mobilier     { background: rgba(236,72,153,0.12);  color: #f472b6; }
  .plc-decoration   { background: rgba(99,102,241,0.12);  color: #818cf8; }
  .plc-exterieur    { background: rgba(16,185,129,0.08);  color: #34d399; }
  .plc-autre        { background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.3); }
  .pro-leads-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    padding: 56px 24px;
    text-align: center;
    color: rgba(255,255,255,0.2);
    border: 1px dashed var(--pro-border);
    border-radius: 14px;
  }
  .pro-leads-empty svg { width: 38px; height: 38px; }
  .pro-leads-empty p { font-size: 0.82rem; margin: 0; max-width: 320px; }
  </style>

  <%
    var acceptedLeads = (typeof quoteRequests !== 'undefined' ? quoteRequests : []).filter(function(q) {
      return q.status === 'accepted';
    });

    var getLeadCat = function(q) {
      var s = ((q.service || '') + ' ' + (q.specialty || '')).toLowerCase();
      if (s.indexOf('peint') !== -1) return 'peinture';
      if (s.indexOf('cuisin') !== -1) return 'cuisine';
      if (s.indexOf('salle') !== -1 || s.indexOf('bain') !== -1 || s.indexOf('douche') !== -1) return 'salle-de-bain';
      if (s.indexOf('renov') !== -1 || s.indexOf('complet') !== -1) return 'renovation';
      if (s.indexOf('mobil') !== -1 || s.indexOf('meuble') !== -1) return 'mobilier';
      if (s.indexOf('decor') !== -1 || s.indexOf('design') !== -1) return 'decoration';
      if (s.indexOf('exter') !== -1 || s.indexOf('jardin') !== -1 || s.indexOf('terrasse') !== -1) return 'exterieur';
      return 'autre';
    };
  %>

