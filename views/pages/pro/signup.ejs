<style>
.pro-signup-form { width: 100%; }
.pro-signup-form h1 { font-size: 24px; font-weight: 800; color: #fff; margin: 0 0 6px; }
.pro-signup-form .subtitle { color: #a0a0a0; font-size: 14px; margin: 0 0 28px; }
.pro-section-title {
  font-size: 11px;
  font-weight: 700;
  color: #00ff88;
  text-transform: uppercase;
  letter-spacing: 1.2px;
  margin: 28px 0 14px;
  padding-bottom: 8px;
  border-bottom: 1px solid rgba(255,255,255,0.08);
}
.pro-field-group { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
.pro-field-group.full { grid-template-columns: 1fr; }
.form-group { margin-bottom: 14px; }
.form-group label { display: block; font-size: 13px; font-weight: 600; color: #d0d0d0; margin-bottom: 6px; }
.form-group label span.req { color: #00ff88; }
.form-group input,
.form-group textarea,
.form-group select {
  width: 100%;
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.12);
  border-radius: 10px;
  padding: 11px 14px;
  color: #fff;
  font-size: 14px;
  font-family: inherit;
  box-sizing: border-box;
  transition: border-color 0.2s;
  outline: none;
}
.form-group input:focus,
.form-group textarea:focus,
.form-group select:focus {
  border-color: rgba(0,255,136,0.5);
}
.form-group textarea { resize: vertical; min-height: 100px; }
.categories-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
  margin-top: 4px;
}
.cat-label {
  display: flex;
  align-items: center;
  gap: 8px;
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 8px;
  padding: 9px 12px;
  cursor: pointer;
  font-size: 13px;
  color: #c0c0c0;
  transition: all 0.15s;
}
.cat-label input[type="checkbox"] { accent-color: #00ff88; width: 15px; height: 15px; flex-shrink: 0; }
.cat-label:hover { border-color: rgba(0,255,136,0.35); color: #fff; }
.pro-submit-btn {
  width: 100%;
  background: linear-gradient(135deg, #00ff88, #00d4ff);
  color: #000;
  border: none;
  border-radius: 12px;
  padding: 15px;
  font-size: 15px;
  font-weight: 700;
  cursor: pointer;
  margin-top: 28px;
  font-family: inherit;
  transition: opacity 0.2s;
}
.pro-submit-btn:hover { opacity: 0.9; }
.file-hint { font-size: 12px; color: #666; margin-top: 5px; }
.alert-error-inline {
  background: rgba(255,68,68,0.1);
  border: 1px solid rgba(255,68,68,0.3);
  border-radius: 10px;
  padding: 12px 16px;
  color: #ff8888;
  font-size: 14px;
  margin-bottom: 20px;
  display: flex;
  align-items: flex-start;
  gap: 10px;
}
</style>

<div class="pro-signup-form">
  <h1>Créer un compte pro</h1>
  <p class="subtitle">Remplissez ce formulaire pour rejoindre le réseau CraftyCrib Pro.</p>

  <% if (typeof error_msg !== "undefined" && error_msg && error_msg.length > 0) { %>
    <div class="alert-error-inline">
      <i data-lucide="alert-circle" style="width:16px;height:16px;flex-shrink:0;margin-top:1px;"></i>
      <span><%= error_msg %></span>
    </div>
  <% } %>

  <form action="/pro/signup" method="POST" enctype="multipart/form-data" class="pro-signup-form" id="proSignupForm">

    <!-- IDENTITE -->
    <div class="pro-section-title">Identité</div>
    <div class="pro-field-group">
      <div class="form-group">
        <label>Prénom <span class="req">*</span></label>
        <input type="text" name="firstName" value="<%= typeof formData !== 'undefined' && formData.firstName ? formData.firstName : '' %>" required>
      </div>
      <div class="form-group">
        <label>Nom <span class="req">*</span></label>
        <input type="text" name="lastName" value="<%= typeof formData !== 'undefined' && formData.lastName ? formData.lastName : '' %>" required>
      </div>
    </div>
    <div class="form-group">
      <label>Nom de l'entreprise <span class="req">*</span></label>
      <input type="text" name="companyName" value="<%= typeof formData !== 'undefined' && formData.companyName ? formData.companyName : '' %>" required>
    </div>
    <div class="pro-field-group">
      <div class="form-group">
        <label>Email professionnel <span class="req">*</span></label>
        <input type="email" name="email" value="<%= typeof formData !== 'undefined' && formData.email ? formData.email : '' %>" required>
      </div>
      <div class="form-group">
        <label>Téléphone <span class="req">*</span></label>
        <input type="tel" name="phone" value="<%= typeof formData !== 'undefined' && formData.phone ? formData.phone : '' %>" required>
      </div>
    </div>

    <!-- ADRESSE -->
    <div class="pro-section-title">Adresse</div>
    <div class="form-group">
      <label>Adresse <span class="req">*</span></label>
      <input type="text" name="address" value="<%= typeof formData !== 'undefined' && formData.address ? formData.address : '' %>" required>
    </div>
    <div class="pro-field-group">
      <div class="form-group">
        <label>Ville <span class="req">*</span></label>
        <input type="text" name="city" value="<%= typeof formData !== 'undefined' && formData.city ? formData.city : '' %>" required>
      </div>
      <div class="form-group">
        <label>Code postal <span class="req">*</span></label>
        <input type="text" name="postalCode" value="<%= typeof formData !== 'undefined' && formData.postalCode ? formData.postalCode : '' %>" required>
      </div>
    </div>
    <div class="form-group">
      <label>Pays <span class="req">*</span></label>
      <input type="text" name="country" value="<%= typeof formData !== 'undefined' && formData.country ? formData.country : 'Canada' %>" required>
    </div>

    <!-- METIER -->
    <div class="pro-section-title">Métier</div>
    <div class="form-group">
      <label>Catégories de services <span class="req">*</span></label>
      <div class="categories-grid">
        <% var cats = ['Peinture et décoration','Rénovation cuisine','Rénovation salle de bain','Planchers et revêtements','Éclairage','Mobilier et aménagement','Jardinage et extérieur','Plomberie','Électricité','Nettoyage','Chauffage et climatisation','Portes et fenêtres']; %>
        <% var selectedCats = (typeof formData !== 'undefined' && formData.categories) ? (Array.isArray(formData.categories) ? formData.categories : [formData.categories]) : []; %>
        <% cats.forEach(function(cat) { %>
          <label class="cat-label">
            <input type="checkbox" name="categories" value="<%= cat %>" <%= selectedCats.indexOf(cat) !== -1 ? 'checked' : '' %>>
            <%= cat %>
          </label>
        <% }); %>
      </div>
    </div>
    <div class="pro-field-group">
      <div class="form-group">
        <label>Années d'expérience <span class="req">*</span></label>
        <input type="text" name="yearsExperience" placeholder="ex: 5 ans" value="<%= typeof formData !== 'undefined' && formData.yearsExperience ? formData.yearsExperience : '' %>" required>
      </div>
      <div class="form-group">
        <label>Numéro d'entreprise</label>
        <input type="text" name="businessNumber" placeholder="optionnel" value="<%= typeof formData !== 'undefined' && formData.businessNumber ? formData.businessNumber : '' %>">
      </div>
    </div>
    <div class="form-group">
      <label>Zones de service <span class="req">*</span></label>
      <input type="text" name="serviceAreas" placeholder="ex: Montréal, Laval, Longueuil" value="<%= typeof formData !== 'undefined' && formData.serviceAreas ? formData.serviceAreas : '' %>" required>
    </div>

    <!-- PRESENTATION -->
    <div class="pro-section-title">Présentation</div>
    <div class="form-group">
      <label>Description de votre activité <span class="req">*</span></label>
      <textarea name="description" placeholder="Décrivez votre expertise, vos réalisations..."><%= typeof formData !== 'undefined' && formData.description ? formData.description : '' %></textarea>
    </div>
    <div class="form-group">
      <label>Site web</label>
      <input type="url" name="website" placeholder="https://monsite.com" value="<%= typeof formData !== 'undefined' && formData.website ? formData.website : '' %>">
    </div>
    <div class="pro-field-group">
      <div class="form-group">
        <label>Instagram</label>
        <input type="text" name="socialInstagram" placeholder="@moncompte" value="<%= typeof formData !== 'undefined' && formData.socialInstagram ? formData.socialInstagram : '' %>">
      </div>
      <div class="form-group">
        <label>Facebook</label>
        <input type="text" name="socialFacebook" placeholder="facebook.com/..." value="<%= typeof formData !== 'undefined' && formData.socialFacebook ? formData.socialFacebook : '' %>">
      </div>
    </div>

    <!-- MEDIAS -->
    <div class="pro-section-title">Médias</div>
    <div class="form-group">
      <label>Logo de l'entreprise</label>
      <input type="file" name="logo" accept="image/*">
      <p class="file-hint">Formats acceptés : JPG, PNG, WEBP. Max 5MB.</p>
    </div>
    <div class="form-group">
      <label>Photos de réalisations</label>
      <input type="file" name="photos" accept="image/*" multiple>
      <p class="file-hint">Jusqu'à 10 photos. Formats acceptés : JPG, PNG, WEBP.</p>
    </div>

    <!-- SECURITE -->
    <div class="pro-section-title">Sécurité</div>
    <div class="pro-field-group">
      <div class="form-group">
        <label>Mot de passe <span class="req">*</span></label>
        <input type="password" name="password" placeholder="Minimum 6 caractères" required>
      </div>
      <div class="form-group">
        <label>Confirmer le mot de passe <span class="req">*</span></label>
        <input type="password" name="confirmPassword" placeholder="Répétez le mot de passe" required>
      </div>
    </div>

    <button type="submit" class="pro-submit-btn">
      <i data-lucide="send" style="width:16px;height:16px;vertical-align:-3px;margin-right:8px;"></i>
      Envoyer ma demande
    </button>
  </form>

  <div style="text-align:center;margin-top:20px;">
    <a href="/pro/register" style="font-size:13px;color:#666;text-decoration:none;">
      <i data-lucide="arrow-left" style="width:13px;height:13px;vertical-align:-2px;margin-right:4px;"></i>
      Retour
    </a>
  </div>
</div>

<script>
document.getElementById("proSignupForm").addEventListener("submit", function(e) {
  var checks = this.querySelectorAll("input[name='categories']:checked");
  if (checks.length === 0) {
    e.preventDefault();
    alert("Veuillez sélectionner au moins une catégorie de services.");
  }
});
</script>
