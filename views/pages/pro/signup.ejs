      if (!this.value.trim()) spFerr('sperr_cnesstFileNumber', 'sp_cnesstFileNumber', 'Le numéro de dossier CNESST est obligatoire.');
      else if (!spIsCnesstNum(this.value)) spFerr('sperr_cnesstFileNumber', 'sp_cnesstFileNumber', 'Le numéro de dossier CNESST doit contenir au moins 5 chiffres (chiffres uniquement).');
      else spFok('sperr_cnesstFileNumber', 'sp_cnesstFileNumber');
    });
  }

  addFileListener('sp_cnesstAttestation', 'sperr_cnesstAttestation');

  /* Step 5 */
  onBlurRequired('sp_serviceAreas', 'sperr_serviceAreas', 'Les zones de service');
  onBlurRequired('sp_yearsExperience', 'sperr_yearsExperience', "Les années d'expérience");

  var pwEl = document.getElementById('sp_password');
  var cpwEl = document.getElementById('sp_confirmPassword');

  if (pwEl) {
    pwEl.addEventListener('input', function() {
      spPwStrength(this.value);
      if (this.value.length >= 6) spFok('sperr_password', 'sp_password');
      else spFclear('sperr_password', 'sp_password');
      if (cpwEl && cpwEl.value) {
        if (this.value === cpwEl.value) spFok('sperr_confirmPassword', 'sp_confirmPassword');
        else spFclear('sperr_confirmPassword', 'sp_confirmPassword');
      }
    });
    pwEl.addEventListener('blur', function() {
      if (!this.value) spFerr('sperr_password', 'sp_password', 'Le mot de passe est obligatoire.');
      else if (this.value.length < 6) spFerr('sperr_password', 'sp_password', 'Le mot de passe doit contenir au moins 6 caractères.');
      else spFok('sperr_password', 'sp_password');
    });
  }

  if (cpwEl) {
    cpwEl.addEventListener('input', function() {
      if (pwEl && this.value === pwEl.value && this.value.length >= 6) spFok('sperr_confirmPassword', 'sp_confirmPassword');
      else spFclear('sperr_confirmPassword', 'sp_confirmPassword');
    });
    cpwEl.addEventListener('blur', function() {
      if (!this.value) spFerr('sperr_confirmPassword', 'sp_confirmPassword', 'Veuillez confirmer votre mot de passe.');
      else if (pwEl && this.value !== pwEl.value) spFerr('sperr_confirmPassword', 'sp_confirmPassword', 'Les mots de passe ne correspondent pas.');
      else spFok('sperr_confirmPassword', 'sp_confirmPassword');
    });
  }

});
</script>
