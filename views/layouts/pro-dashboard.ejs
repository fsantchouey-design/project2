<!DOCTYPE html>
<html lang="fr" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0">
  <title><%= typeof title !== 'undefined' ? title : 'Pro Dashboard — CraftyCrib' %></title>
  <meta name="robots" content="noindex, nofollow">
  <link rel="icon" type="image/png" href="/assets/logoicon.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,400;0,14..32,500;0,14..32,600;0,14..32,700;0,14..32,800;0,14..32,900&display=swap" rel="stylesheet">
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
  <link rel="stylesheet" href="/css/pro-dashboard.css">
</head>
<body>
<div class="pro-layout">

  <!-- OVERLAY (mobile) -->
  <div class="pro-overlay" id="pro-overlay"></div>

  <!-- SIDEBAR -->
  <aside class="pro-sidebar" id="pro-sidebar">
    <a href="/pro/dashboard" class="pro-sidebar-logo">
      <img src="/assets/logoicon.png" alt="CraftyCrib">
      <div class="pro-sidebar-logo-text">
        <span>CraftyCrib</span>
        <span>Pro Studio</span>
      </div>
    </a>

    <nav class="pro-sidebar-nav">
      <div class="pro-nav-section">
        <span class="pro-nav-label">Vue d'ensemble</span>
        <button class="pro-nav-item active" data-section="dashboard">
          <i data-lucide="layout-dashboard"></i>
          Dashboard
        </button>
        <button class="pro-nav-item" data-section="leads">
          <i data-lucide="users"></i>
          Leads
          <span class="pro-nav-badge">12</span>
        </button>
        <button class="pro-nav-item" data-section="projects">
          <i data-lucide="folder-open"></i>
          Projects
          <span class="pro-nav-badge amber">8</span>
        </button>
        <button class="pro-nav-item" data-section="portfolio">
          <i data-lucide="image"></i>
          Portfolio
        </button>
      </div>

      <div class="pro-nav-section">
        <span class="pro-nav-label">Communication</span>
        <button class="pro-nav-item" data-section="notes">
          <i data-lucide="notebook-pen"></i>
          Notes
        </button>
        <button class="pro-nav-item" data-section="calendar">
          <i data-lucide="calendar"></i>
          Calendar
        </button>
      </div>

      <div class="pro-nav-section">
        <span class="pro-nav-label">Business</span>
        <button class="pro-nav-item" data-section="analytics">
          <i data-lucide="bar-chart-2"></i>
          Analytics
        </button>
        <button class="pro-nav-item" data-section="reviews">
          <i data-lucide="star"></i>
          Reviews
        </button>
        <button class="pro-nav-item" data-section="team">
          <i data-lucide="users-2"></i>
          Team
        </button>
      </div>

      <div class="pro-nav-section">
        <span class="pro-nav-label">Compte</span>
        <button class="pro-nav-item" data-section="billing">
          <i data-lucide="credit-card"></i>
          Billing
        </button>
        <button class="pro-nav-item" data-section="settings">
          <i data-lucide="settings"></i>
          Settings
        </button>
      </div>
    </nav>

    <div class="pro-sidebar-footer">
      <div class="pro-profile-card">
        <div class="pro-profile-avatar">
          <% if (typeof user !== 'undefined' && user && user.avatar) { %>
            <img src="<%= user.avatar %>" alt="Avatar">
          <% } else if (typeof user !== 'undefined' && user) { %>
            <%= (user.firstName || 'P').charAt(0).toUpperCase() %>
          <% } else { %>
            P
          <% } %>
        </div>
        <div class="pro-profile-info">
          <div class="pro-profile-name">
            <% if (typeof user !== 'undefined' && user) { %>
              <%= user.firstName || 'Professionnel' %> <%= (user.lastName || '').charAt(0) %>.
            <% } else { %>
              Professionnel
            <% } %>
          </div>
          <div class="pro-profile-plan">
            <i data-lucide="shield-check"></i>
            Pro Verified
          </div>
        </div>
      </div>
      <a href="/auth/logout" class="pro-logout-btn">
        <i data-lucide="log-out"></i>
        Déconnexion
      </a>
    </div>
  </aside>

  <!-- MAIN -->
  <div class="pro-main">
    <!-- TOPBAR -->
    <header class="pro-topbar">
      <button class="pro-topbar-menu" id="pro-menu-btn" aria-label="Menu">
        <i data-lucide="menu"></i>
      </button>

      <div class="pro-topbar-search">
        <i data-lucide="search"></i>
        <input type="text" placeholder="Chercher un lead, projet, client…">
      </div>

      <div class="pro-topbar-right">
        <button class="pro-topbar-btn" title="Aide">
          <i data-lucide="help-circle"></i>
        </button>
        <button class="pro-topbar-btn" title="Notifications">
          <i data-lucide="bell"></i>
          <span class="pro-topbar-notif-dot"></span>
        </button>
        <div class="pro-topbar-avatar">
          <% if (typeof user !== 'undefined' && user && user.avatar) { %>
            <img src="<%= user.avatar %>" alt="Avatar">
          <% } else if (typeof user !== 'undefined' && user) { %>
            <%= (user.firstName || 'P').charAt(0).toUpperCase() %>
          <% } else { %>
            P
          <% } %>
        </div>
      </div>
    </header>

    <!-- CONTENT -->
    <main class="pro-content">
      <%- body %>
    </main>
  </div>

  <!-- CRIBY AI ASSISTANT -->
  <button class="pro-criby-btn" id="pro-criby-btn" title="Criby AI">
    <i data-lucide="sparkles"></i>
  </button>

  <div class="pro-criby-panel" id="pro-criby-panel">
    <div class="pro-criby-header">
      <div class="pro-criby-avatar">✦</div>
      <div>
        <div class="pro-criby-title">Criby AI</div>
        <div class="pro-criby-sub">Assistant professionnel</div>
      </div>
      <button class="pro-criby-close" id="pro-criby-close">
        <i data-lucide="x"></i>
      </button>
    </div>
    <div class="pro-criby-messages" id="pro-criby-messages">
      <div class="pro-criby-msg">
        <div class="pro-criby-ava bot">✦</div>
        <div class="pro-criby-bubble">
          Bonjour ! Je suis Criby, votre assistant IA. Comment puis-je vous aider aujourd'hui ?
        </div>
      </div>
      <div class="pro-criby-msg">
        <div class="pro-criby-ava bot">✦</div>
        <div class="pro-criby-bubble">
          Vous avez <strong>3 nouveaux leads</strong> aujourd'hui et un rendez-vous client demain à 14h.
        </div>
      </div>
    </div>
    <div class="pro-criby-suggestions">
      <button class="pro-criby-suggestion" data-prompt="Find my best leads">Find my best leads</button>
      <button class="pro-criby-suggestion" data-prompt="Create a quote">Create a quote</button>
      <button class="pro-criby-suggestion" data-prompt="Analyze my projects">Analyze projects</button>
      <button class="pro-criby-suggestion" data-prompt="Generate a moodboard">Moodboard IA</button>
    </div>
    <div class="pro-criby-input-area">
      <input type="text" class="pro-criby-input" id="pro-criby-input" placeholder="Demandez quelque chose…">
      <button class="pro-criby-send" id="pro-criby-send">
        <i data-lucide="send"></i>
      </button>
    </div>
  </div>

</div>

<script>
(function() {
  // Init Lucide
  if (typeof lucide !== 'undefined') lucide.createIcons();

  // Sidebar toggle (mobile)
  var menuBtn = document.getElementById('pro-menu-btn');
  var sidebar = document.getElementById('pro-sidebar');
  var overlay = document.getElementById('pro-overlay');

  function openSidebar() {
    sidebar.classList.add('open');
    overlay.classList.add('visible');
  }
  function closeSidebar() {
    sidebar.classList.remove('open');
    overlay.classList.remove('visible');
  }
  if (menuBtn) menuBtn.addEventListener('click', openSidebar);
  if (overlay) overlay.addEventListener('click', closeSidebar);

  // Section navigation
  var navItems = document.querySelectorAll('.pro-nav-item[data-section]');
  var sections = document.querySelectorAll('.pro-section');

  function activateSection(sectionId) {
    sections.forEach(function(s) { s.classList.remove('active'); });
    navItems.forEach(function(n) { n.classList.remove('active'); });
    var target = document.getElementById('sec-' + sectionId);
    if (target) target.classList.add('active');
    var navItem = document.querySelector('.pro-nav-item[data-section="' + sectionId + '"]');
    if (navItem) navItem.classList.add('active');
    closeSidebar();
    if (typeof lucide !== 'undefined') lucide.createIcons();
  }

  navItems.forEach(function(item) {
    item.addEventListener('click', function() {
      activateSection(this.getAttribute('data-section'));
    });
  });

  // Activate dashboard by default
  activateSection('dashboard');

  // Settings tabs
  var settingsTabs = document.querySelectorAll('.pro-settings-tab');
  settingsTabs.forEach(function(tab) {
    tab.addEventListener('click', function() {
      settingsTabs.forEach(function(t) { t.classList.remove('active'); });
      document.querySelectorAll('.pro-settings-panel').forEach(function(p) { p.classList.remove('active'); });
      this.classList.add('active');
      var panel = document.getElementById('stab-' + this.getAttribute('data-tab'));
      if (panel) panel.classList.add('active');
    });
  });

  // Criby AI widget
  var cribyBtn = document.getElementById('pro-criby-btn');
  var cribyPanel = document.getElementById('pro-criby-panel');
  var cribyClose = document.getElementById('pro-criby-close');
  var cribyInput = document.getElementById('pro-criby-input');
  var cribySend = document.getElementById('pro-criby-send');
  var cribyMessages = document.getElementById('pro-criby-messages');

  if (cribyBtn) {
    cribyBtn.addEventListener('click', function() {
      if (cribyPanel.classList.contains('open')) {
        cribyPanel.classList.remove('open');
        cribyPanel.style.display = '';
      } else {
        cribyPanel.style.display = 'flex';
        setTimeout(function() { cribyPanel.classList.add('open'); }, 10);
      }
    });
  }
  if (cribyClose) {
    cribyClose.addEventListener('click', function() {
      cribyPanel.classList.remove('open');
      setTimeout(function() { cribyPanel.style.display = ''; }, 250);
    });
  }

  function addCribyMsg(text, isUser) {
    var msg = document.createElement('div');
    msg.className = 'pro-criby-msg' + (isUser ? ' user' : '');
    var ava = document.createElement('div');
    ava.className = 'pro-criby-ava' + (isUser ? '' : ' bot');
    ava.textContent = isUser ? 'V' : '❖';
    var bubble = document.createElement('div');
    bubble.className = 'pro-criby-bubble';
    bubble.textContent = text;
    msg.appendChild(ava);
    msg.appendChild(bubble);
    cribyMessages.appendChild(msg);
    cribyMessages.scrollTop = cribyMessages.scrollHeight;
  }

  var cribyResponses = {
    'Find my best leads': 'Vos 3 meilleurs leads ce mois : Thomas R. (95% compat, €35K), Sarah M. (92%, €8K) et Julie P. (85%, €5.5K). Je recommande de contacter Thomas en priorité.',
    'Create a quote': 'Je peux vous aider à créer un devis. Quel est le client, le type de projet et le budget estimé ?',
    'Analyze my projects': 'Analyse en cours... 8 projets actifs, taux de complétion moyen : 67%. Projet prioritaire : Rénovation Dupont — deadline dans 5 jours.',
    'Generate a moodboard': 'Moodboard IA : précisez le style (Moderne, Scandinave, Industriel…) et le type de pièce pour que je génère votre moodboard personnalisé.'
  };

  function sendCribyMessage(text) {
    if (!text.trim()) return;
    addCribyMsg(text, true);
    var response = cribyResponses[text] || 'Je traite votre demande... Fonctionnalité complète disponible en plan Pro+.';
    setTimeout(function() { addCribyMsg(response, false); }, 800);
  }

  if (cribySend) {
    cribySend.addEventListener('click', function() {
      sendCribyMessage(cribyInput.value);
      cribyInput.value = '';
    });
  }
  if (cribyInput) {
    cribyInput.addEventListener('keydown', function(e) {
      if (e.key === 'Enter') { sendCribyMessage(this.value); this.value = ''; }
    });
  }

  document.querySelectorAll('.pro-criby-suggestion').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var prompt = this.getAttribute('data-prompt');
      sendCribyMessage(prompt);
    });
  });

  // Task checkboxes
  document.querySelectorAll('.pro-task-check').forEach(function(check) {
    check.addEventListener('click', function() {
      this.classList.toggle('done');
    });
  });

})();
</script>
</body>
</html>
