<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0">

  <!-- Primary SEO Meta Tags -->
  <title><%= typeof title !== 'undefined' ? title : 'CraftyCrib - Design Intérieur IA' %></title>
  <meta name="description" content="<%= typeof metaDescription !== 'undefined' ? metaDescription : 'Transformez votre espace de vie avec le design intérieur propulsé par l\'IA. Obtenez des maquettes 3D instantanées et connectez-vous avec des entrepreneurs professionnels.' %>">
  <% if (typeof keywords !== 'undefined' && keywords) { %><meta name="keywords" content="<%= keywords %>"><% } %>
  <meta name="author" content="CraftyCrib">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href="<%= typeof canonicalUrl !== 'undefined' ? canonicalUrl : 'https://craftycrib.com' %>">

  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website">
  <meta property="og:url" content="<%= typeof canonicalUrl !== 'undefined' ? canonicalUrl : 'https://craftycrib.com' %>">
  <meta property="og:title" content="<%= typeof title !== 'undefined' ? title : 'CraftyCrib - Design Intérieur IA' %>">
  <meta property="og:description" content="<%= typeof metaDescription !== 'undefined' ? metaDescription : 'Transformez votre espace de vie avec le design intérieur propulsé par l\'IA.' %>">
  <meta property="og:image" content="<%= (typeof ogImage !== 'undefined' && ogImage) ? ogImage : 'https://craftycrib.com/images/og-image.png' %>">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:site_name" content="CraftyCrib">
  <meta property="og:locale" content="fr_FR">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:url" content="<%= typeof canonicalUrl !== 'undefined' ? canonicalUrl : 'https://craftycrib.com' %>">
  <meta name="twitter:title" content="<%= typeof title !== 'undefined' ? title : 'CraftyCrib - Design Intérieur IA' %>">
  <meta name="twitter:description" content="<%= typeof metaDescription !== 'undefined' ? metaDescription : 'Transformez votre espace de vie avec le design intérieur propulsé par l\'IA.' %>">
  <meta name="twitter:image" content="<%= (typeof ogImage !== 'undefined' && ogImage) ? ogImage : 'https://craftycrib.com/images/og-image.png' %>">

  <!-- Favicon -->
  <link rel="icon" type="image/png" sizes="32x32" href="/assets/logoicon.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/assets/logoicon.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/assets/logoicon.png">
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#10b981">

  <!-- JSON-LD: WebSite + SearchAction -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "CraftyCrib",
    "url": "https://craftycrib.com",
    "description": "Plateforme de design intérieur propulsée par l'IA — visualisations 3D et marketplace d'entrepreneurs.",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://craftycrib.com/gallery?q={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  }
  </script>

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
  
  <!-- Lucide Icons -->
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
  
  <!-- Main Styles -->
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <!-- Navigation -->
  <nav class="navbar">
    <div class="nav-container">
      <a href="/" class="nav-logo" aria-label="CraftyCrib — Accueil">
        <img src="/assets/logoicon.png" alt="CraftyCrib Logo" class="logo-icon" width="32" height="32">
        <span class="logo-text">CraftyCrib</span>
      </a>
      
      <div class="nav-links">
        <a href="/dashboard" class="nav-link">
          <i data-lucide="layout-dashboard"></i>
          Dashboard
        </a>
        <a href="/projects" class="nav-link">
          <i data-lucide="folder"></i>
          Projects
        </a>
        <a href="/contractors" class="nav-link">
          <i data-lucide="users"></i>
          Contractors
        </a>
        <a href="/dashboard/messages" class="nav-link">
          <i data-lucide="message-circle"></i>
          Messages
        </a>
      </div>
      
      <div class="nav-actions">
        <%- include('../partials/language-selector') %>
        <% if (user) { %>

          <!-- Premium avatar dropdown -->
          <div class="ua-wrap" id="ua-wrap">
            <button class="ua-trigger" id="ua-trigger" aria-haspopup="true" aria-expanded="false" aria-label="Menu utilisateur">
              <% if (user.avatar && user.avatar !== '/images/default-avatar.png') { %>
                <img src="<%= user.avatar %>" alt="<%= user.firstName %>" class="ua-photo">
              <% } else { %>
                <span class="ua-initials"><%= user.firstName.charAt(0).toUpperCase() %><%= user.lastName.charAt(0).toUpperCase() %></span>
              <% } %>
              <span class="ua-dot"></span>
            </button>

            <div class="ua-dropdown" id="ua-dropdown" role="menu" aria-hidden="true">

              <!-- User identity block -->
              <div class="ua-identity">
                <div class="ua-id-avatar">
                  <% if (user.avatar && user.avatar !== '/images/default-avatar.png') { %>
                    <img src="<%= user.avatar %>" alt="<%= user.firstName %>">
                  <% } else { %>
                    <span><%= user.firstName.charAt(0).toUpperCase() %><%= user.lastName.charAt(0).toUpperCase() %></span>
                  <% } %>
                </div>
                <div class="ua-id-info">
                  <strong class="ua-id-name"><%= user.firstName %> <%= user.lastName %></strong>
                  <span class="ua-id-email"><%= user.email %></span>
                  <div class="ua-id-meta">
                    <span class="ua-plan-badge ua-plan-<%= user.subscription ? user.subscription.plan : 'free' %>">
                      <% const plan = user.subscription ? user.subscription.plan : 'free'; %>
                      <% if (plan === 'advanced') { %>Avancé
                      <% } else if (plan === 'partner') { %>Partner
                      <% } else if (plan === 'credits') { %>Crédits
                      <% } else { %>Gratuit<% } %>
                    </span>
                    <span class="ua-credits-count">
                      <i data-lucide="zap"></i>
                      <%= user.subscription ? user.subscription.credits : 0 %> crédits
                    </span>
                  </div>
                </div>
              </div>

              <div class="ua-sep"></div>

              <!-- Primary actions -->
              <div class="ua-group">
                <a href="/profile" class="ua-item" role="menuitem">
                  <i data-lucide="user-circle"></i>
                  <span>Voir le profil</span>
                </a>
                <a href="/settings" class="ua-item" role="menuitem">
                  <i data-lucide="settings"></i>
                  <span>Paramètres du compte</span>
                </a>
                <a href="/billing" class="ua-item" role="menuitem">
                  <i data-lucide="credit-card"></i>
                  <span>Abonnement & Facturation</span>
                </a>
                <a href="/pricing" class="ua-item ua-item--glow" role="menuitem">
                  <i data-lucide="zap"></i>
                  <span>Acheter des crédits</span>
                </a>
              </div>

              <div class="ua-sep"></div>

              <!-- Secondary actions -->
              <div class="ua-group">
                <a href="/dashboard/notifications" class="ua-item" role="menuitem">
                  <i data-lucide="bell"></i>
                  <span>Notifications</span>
                </a>
                <button type="button" class="ua-item ua-item--btn" id="ua-theme-btn" role="menuitem">
                  <i data-lucide="moon" id="ua-theme-icon"></i>
                  <span id="ua-theme-label">Thème sombre</span>
                </button>
              </div>

              <div class="ua-sep"></div>

              <!-- Logout -->
              <div class="ua-group">
                <a href="/auth/logout" class="ua-item ua-item--danger" role="menuitem">
                  <i data-lucide="log-out"></i>
                  <span>Se déconnecter</span>
                </a>
              </div>

            </div>
          </div>

        <% } else { %>
          <a href="/auth/login" class="btn btn-ghost">Login</a>
          <a href="/auth/register" class="btn btn-primary">Get Started</a>
        <% } %>
      </div>
      
      <button class="mobile-menu-btn">
        <i data-lucide="menu"></i>
      </button>
    </div>
  </nav>

  <!-- Flash Messages -->
  <% if (success_msg && success_msg.length > 0) { %>
    <div class="alert alert-success">
      <i data-lucide="check-circle"></i>
      <%= success_msg %>
      <button class="alert-close"><i data-lucide="x"></i></button>
    </div>
  <% } %>
  
  <% if (error_msg && error_msg.length > 0) { %>
    <div class="alert alert-error">
      <i data-lucide="alert-circle"></i>
      <%= error_msg %>
      <button class="alert-close"><i data-lucide="x"></i></button>
    </div>
  <% } %>
  
  <% if (error && error.length > 0) { %>
    <div class="alert alert-error">
      <i data-lucide="alert-circle"></i>
      <%= error %>
      <button class="alert-close"><i data-lucide="x"></i></button>
    </div>
  <% } %>

  <!-- Main Content -->
  <main class="main-content">
    <%- body %>
  </main>

  <!-- Footer -->
  <footer class="footer">
    <div class="footer-container">
      <div class="footer-brand">
        <img src="/assets/logoicon.png" alt="CraftyCrib" class="footer-logo" width="40" height="40">
        <p>Transform your living space with AI-powered interior design.</p>
        <div class="social-links">
          <a href="<%= typeof socialLinks !== 'undefined' && socialLinks.facebook ? socialLinks.facebook : '#' %>" target="_blank" rel="noopener noreferrer" aria-label="Facebook"><i data-lucide="facebook"></i></a>
          <a href="<%= typeof socialLinks !== 'undefined' && socialLinks.instagram ? socialLinks.instagram : '#' %>" target="_blank" rel="noopener noreferrer" aria-label="Instagram"><i data-lucide="instagram"></i></a>
          <a href="<%= typeof socialLinks !== 'undefined' && socialLinks.tiktok ? socialLinks.tiktok : '#' %>" target="_blank" rel="noopener noreferrer" aria-label="TikTok"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/></svg></a>
        </div>
      </div>
      
      <div class="footer-links">
        <div class="footer-col">
          <h4>Product</h4>
          <a href="/how-it-works">How It Works</a>
          <a href="/pricing">Pricing</a>
          <a href="/contractors">Find Contractors</a>
        </div>
        <div class="footer-col">
          <h4>Company</h4>
          <a href="/about">About Us</a>
          <a href="/contact">Contact</a>
          <a href="#">Careers</a>
        </div>
        <div class="footer-col">
          <h4>Légal</h4>
          <a href="/politique-confidentialite">Politique de confidentialité</a>
          <a href="/politique-cookies">Politique de cookies</a>
          <a href="/conditions-utilisation">Conditions d'utilisation</a>
        </div>
      </div>
    </div>
    
    <div class="footer-bottom">
      <p>&copy; <%= currentYear %> CraftyCrib. All rights reserved.</p>
    </div>
  </footer>

  <!-- Scripts -->
  <script src="/js/main.js"></script>
  <script>
    lucide.createIcons();

    // ── Avatar dropdown ───────────────────────────────
    (function () {
      var trigger  = document.getElementById('ua-trigger');
      var dropdown = document.getElementById('ua-dropdown');
      var wrap     = document.getElementById('ua-wrap');
      if (!trigger || !dropdown) return;

      function open() {
        dropdown.classList.add('is-open');
        trigger.setAttribute('aria-expanded', 'true');
        dropdown.setAttribute('aria-hidden', 'false');
      }

      function close() {
        dropdown.classList.remove('is-open');
        trigger.setAttribute('aria-expanded', 'false');
        dropdown.setAttribute('aria-hidden', 'true');
      }

      trigger.addEventListener('click', function (e) {
        e.stopPropagation();
        dropdown.classList.contains('is-open') ? close() : open();
      });

      document.addEventListener('click', function (e) {
        if (wrap && !wrap.contains(e.target)) close();
      });

      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') close();
      });

      // Theme toggle inside dropdown
      var themeBtn   = document.getElementById('ua-theme-btn');
      var themeIcon  = document.getElementById('ua-theme-icon');
      var themeLabel = document.getElementById('ua-theme-label');

      function syncThemeLabel() {
        if (!themeIcon || !themeLabel) return;
        var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
        themeIcon.setAttribute('data-lucide', isDark ? 'sun' : 'moon');
        themeLabel.textContent = isDark ? 'Thème clair' : 'Thème sombre';
        lucide.createIcons();
      }

      syncThemeLabel();

      if (themeBtn) {
        themeBtn.addEventListener('click', function () {
          var cur = document.documentElement.getAttribute('data-theme');
          var next = cur === 'dark' ? 'light' : 'dark';
          document.documentElement.setAttribute('data-theme', next);
          localStorage.setItem('theme', next);
          syncThemeLabel();
        });
      }
    })();
  </script>
</body>
</html>

