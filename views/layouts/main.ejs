<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0">

  <!-- Primary SEO Meta Tags -->
  <title><%= typeof title !== 'undefined' ? title : 'CraftyCrib - Design Intérieur IA' %></title>
  <meta name="description" content="<%= typeof metaDescription !== 'undefined' ? metaDescription : 'Transformez votre espace de vie avec le design intérieur propulsé par l\'IA. Obtenez des maquettes 3D instantanées et connectez-vous avec des entrepreneurs professionnels.' %>">
  <% if (typeof keywords !== 'undefined' && keywords) { %><meta name="keywords" content="<%= keywords %>"><% } %>
  <meta name="author" content="CraftyCrib">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href="<%= typeof canonicalUrl !== 'undefined' ? canonicalUrl : 'https://craftycrib.com' %>">

  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website">
  <meta property="og:url" content="<%= typeof canonicalUrl !== 'undefined' ? canonicalUrl : 'https://craftycrib.com' %>">
  <meta property="og:title" content="<%= typeof title !== 'undefined' ? title : 'CraftyCrib - Design Intérieur IA' %>">
  <meta property="og:description" content="<%= typeof metaDescription !== 'undefined' ? metaDescription : 'Transformez votre espace de vie avec le design intérieur propulsé par l\'IA.' %>">
  <meta property="og:image" content="<%= (typeof ogImage !== 'undefined' && ogImage) ? ogImage : 'https://craftycrib.com/images/og-image.png' %>">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:site_name" content="CraftyCrib">
  <meta property="og:locale" content="fr_FR">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:url" content="<%= typeof canonicalUrl !== 'undefined' ? canonicalUrl : 'https://craftycrib.com' %>">
  <meta name="twitter:title" content="<%= typeof title !== 'undefined' ? title : 'CraftyCrib - Design Intérieur IA' %>">
  <meta name="twitter:description" content="<%= typeof metaDescription !== 'undefined' ? metaDescription : 'Transformez votre espace de vie avec le design intérieur propulsé par l\'IA.' %>">
  <meta name="twitter:image" content="<%= (typeof ogImage !== 'undefined' && ogImage) ? ogImage : 'https://craftycrib.com/images/og-image.png' %>">

  <!-- Favicon -->
  <link rel="icon" type="image/png" sizes="32x32" href="/assets/logoicon.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/assets/logoicon.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/assets/logoicon.png">
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#10b981">

  <!-- JSON-LD: WebSite + SearchAction -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "CraftyCrib",
    "url": "https://craftycrib.com",
    "description": "Plateforme de design intérieur propulsée par l'IA — visualisations 3D et marketplace d'entrepreneurs.",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://craftycrib.com/gallery?q={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  }
  </script>

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
  
  <!-- Lucide Icons -->
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
  
  <!-- Main Styles -->
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <!-- Navigation -->
  <nav class="navbar">
    <div class="nav-container">
      <a href="/" class="nav-logo" aria-label="CraftyCrib — Accueil">
        <img src="/assets/logoicon.png" alt="CraftyCrib Logo" class="logo-icon" width="32" height="32">
        <span class="logo-text">CraftyCrib</span>
      </a>
      
      <div class="nav-links">
        <a href="/dashboard" class="nav-link">
          <i data-lucide="layout-dashboard"></i>
          Dashboard
        </a>
        <a href="/projects" class="nav-link">
          <i data-lucide="folder"></i>
          Projects
        </a>
        <a href="/contractors" class="nav-link">
          <i data-lucide="users"></i>
          Contractors
        </a>
        <a href="/dashboard/messages" class="nav-link">
          <i data-lucide="message-circle"></i>
          Messages
        </a>
      </div>
      
      <div class="nav-actions">
        <%- include('../partials/language-selector') %>
        <% if (user) { %>
          <div class="user-menu">
            <button class="user-btn">
              <div class="user-avatar">
                <%= user.firstName.charAt(0) %><%= user.lastName.charAt(0) %>
              </div>
              <span><%= user.firstName %></span>
              <i data-lucide="chevron-down"></i>
            </button>
            <div class="user-dropdown">
              <a href="/dashboard/settings"><i data-lucide="settings"></i> Settings</a>
              <a href="/auth/logout"><i data-lucide="log-out"></i> Logout</a>
            </div>
          </div>
        <% } else { %>
          <a href="/auth/login" class="btn btn-ghost">Login</a>
          <a href="/auth/register" class="btn btn-primary">Get Started</a>
        <% } %>
      </div>
      
      <button class="mobile-menu-btn">
        <i data-lucide="menu"></i>
      </button>
    </div>
  </nav>

  <!-- Flash Messages -->
  <% if (success_msg && success_msg.length > 0) { %>
    <div class="alert alert-success">
      <i data-lucide="check-circle"></i>
      <%= success_msg %>
      <button class="alert-close"><i data-lucide="x"></i></button>
    </div>
  <% } %>
  
  <% if (error_msg && error_msg.length > 0) { %>
    <div class="alert alert-error">
      <i data-lucide="alert-circle"></i>
      <%= error_msg %>
      <button class="alert-close"><i data-lucide="x"></i></button>
    </div>
  <% } %>
  
  <% if (error && error.length > 0) { %>
    <div class="alert alert-error">
      <i data-lucide="alert-circle"></i>
      <%= error %>
      <button class="alert-close"><i data-lucide="x"></i></button>
    </div>
  <% } %>

  <!-- Main Content -->
  <main class="main-content">
    <%- body %>
  </main>

  <!-- Footer -->
  <footer class="footer">
    <div class="footer-container">
      <div class="footer-brand">
        <img src="/assets/logoicon.png" alt="CraftyCrib" class="footer-logo" width="40" height="40">
        <p>Transform your living space with AI-powered interior design.</p>
        <div class="social-links">
          <a href="<%= typeof socialLinks !== 'undefined' && socialLinks.facebook ? socialLinks.facebook : '#' %>" target="_blank" rel="noopener noreferrer" aria-label="Facebook"><i data-lucide="facebook"></i></a>
          <a href="<%= typeof socialLinks !== 'undefined' && socialLinks.instagram ? socialLinks.instagram : '#' %>" target="_blank" rel="noopener noreferrer" aria-label="Instagram"><i data-lucide="instagram"></i></a>
          <a href="<%= typeof socialLinks !== 'undefined' && socialLinks.tiktok ? socialLinks.tiktok : '#' %>" target="_blank" rel="noopener noreferrer" aria-label="TikTok"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/></svg></a>
        </div>
      </div>
      
      <div class="footer-links">
        <div class="footer-col">
          <h4>Product</h4>
          <a href="/how-it-works">How It Works</a>
          <a href="/pricing">Pricing</a>
          <a href="/contractors">Find Contractors</a>
        </div>
        <div class="footer-col">
          <h4>Company</h4>
          <a href="/about">About Us</a>
          <a href="/contact">Contact</a>
          <a href="#">Careers</a>
        </div>
        <div class="footer-col">
          <h4>Legal</h4>
          <a href="/privacy">Privacy Policy</a>
          <a href="/terms">Terms of Service</a>
        </div>
      </div>
    </div>
    
    <div class="footer-bottom">
      <p>&copy; <%= currentYear %> CraftyCrib. All rights reserved.</p>
    </div>
  </footer>

  <!-- Scripts -->
  <script src="/js/main.js"></script>
  <script>
    lucide.createIcons();
  </script>
</body>
</html>

